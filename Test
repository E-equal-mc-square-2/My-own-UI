-- ✅ SIMPLE EXAMPLE USING ALL ELEMENTS
-- Load the fixed library
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

-- Create Window
local Window = Library:CreateWindow({
	Title = "Kilometres UI X",
	Subtitle = "All Elements Demo",
	Theme = "LiquidGlass",
	Width = 750,
	Height = 360,
	SaveSettings = true,
	ToggleKey = Enum.KeyCode.RightShift,
})

-- ========================================
-- TAB 1: MAIN
-- ========================================
local MainTab = Window:CreateTab("Main")

local BasicSection = MainTab:CreateSection("Basic Elements")

-- Info
BasicSection:Info("📌 This shows all available elements")

-- Button
BasicSection:Button("Click Me", function()
	Window:Notify("Button Clicked", "You pressed the button!", 2)
end)

-- Toggle
BasicSection:Toggle("Enable Feature", false, function(state)
	print("Toggle is now:", state)
end)

-- Slider
BasicSection:Slider("Power Level", 0, 100, 50, function(value)
	print("Slider Value:", value)
end, 1)

-- Textbox
BasicSection:Textbox("Enter Name", "Type here...", function(text)
	print("Textbox Input:", text)
	Window:Notify("Textbox", "You typed: " .. text, 2)
end)

-- Dropdown (NEW LIST STYLE)
BasicSection:Dropdown("Select Mode", {
	"Legit",
	"Rage",
	"Silent",
	"Instant Hit",
	"Never Miss",
	"Prediction",
	"Ultra Lock"
}, "Legit", function(selected)
	print("Selected Mode:", selected)
	Window:Notify("Mode Changed", selected, 1.5)
end)

local CombatSection = MainTab:CreateSection("Combat")

CombatSection:Toggle("Aimbot", false, function(v)
	print("Aimbot:", v)
end)

CombatSection:Toggle("Silent Aim", false, function(v)
	print("Silent Aim:", v)
end)

CombatSection:Slider("FOV", 10, 500, 100, function(v)
	print("FOV:", v)
end, 5)

CombatSection:Dropdown("Target Part", {
	"Head",
	"Torso",
	"HumanoidRootPart",
	"Random"
}, "Head", function(v)
	print("Target Part:", v)
end)

