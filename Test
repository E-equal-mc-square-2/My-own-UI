local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

--// WINDOW

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "FULL ELEMENT SHOWCASE"
})

--// =====================================================================
--// TABS
--// =====================================================================

local Main = Library:CreateTab("Main")
local Combat = Library:CreateTab("Combat")
local Visuals = Library:CreateTab("Visuals")
local Player = Library:CreateTab("Player")
local Settings = Library:CreateTab("Settings")

--// =====================================================================
--// MAIN TAB
--// =====================================================================

local Farming = Main:CreateSection("Farming")

Farming:Button("Collect Coins", function()
    print("Coins Collected")
end)

Farming:Button("Open Crate", function()
    print("Crate Opened")
end)

Farming:Toggle("Auto Farm", false, function(v)
    print("Auto Farm:", v)
end)

Farming:Toggle("Auto Rebirth", false, function(v)
    print("Auto Rebirth:", v)
end)

Farming:Toggle("Auto Spin", false, function(v)
    print("Auto Spin:", v)
end)

--// =====================================================================
--// COMBAT TAB
--// =====================================================================

local Aura = Combat:CreateSection("Combat")

Aura:Button("Kill Aura", function()
    print("Kill Aura Activated")
end)

Aura:Button("Hit All", function()
    print("Hit All")
end)

Aura:Toggle("Silent Aim", false, function(v)
    print("Silent Aim:", v)
end)

Aura:Toggle("Auto Attack", false, function(v)
    print("Auto Attack:", v)
end)

Aura:Toggle("Critical Hits", false, function(v)
    print("Critical Hits:", v)
end)

--// =====================================================================
--// VISUALS TAB
--// =====================================================================

local ESP = Visuals:CreateSection("ESP")

ESP:Toggle("Player ESP", false, function(v)
    print("Player ESP:", v)
end)

ESP:Toggle("Box ESP", false, function(v)
    print("Box ESP:", v)
end)

ESP:Toggle("Tracer ESP", false, function(v)
    print("Tracer ESP:", v)
end)

ESP:Toggle("Health ESP", false, function(v)
    print("Health ESP:", v)
end)

ESP:Button("Refresh ESP", function()
    print("ESP Refreshed")
end)

local World = Visuals:CreateSection("World")

World:Button("Full Bright", function()

    local Lighting = game:GetService("Lighting")

    Lighting.Brightness = 5
    Lighting.ClockTime = 14
    Lighting.FogEnd = 100000
end)

World:Button("Remove Fog", function()

    game:GetService("Lighting").FogEnd = 100000
end)

World:Toggle("Rainbow World", false, function(v)
    print("Rainbow World:", v)
end)

--// =====================================================================
--// PLAYER TAB
--// =====================================================================

local Character = Player:CreateSection("Character")

Character:Button("Reset Character", function()

    game.Players.LocalPlayer.Character:BreakJoints()
end)

Character:Button("Sit", function()

    local Humanoid = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")

    if Humanoid then
        Humanoid.Sit = true
    end
end)

Character:Toggle("Infinite Jump", false, function(v)
    print("Infinite Jump:", v)
end)

Character:Toggle("Fly", false, function(v)
    print("Fly:", v)
end)

Character:Toggle("Noclip", false, function(v)
    print("Noclip:", v)
end)

local Movement = Player:CreateSection("Movement")

Movement:Button("WalkSpeed 32", function()

    local Humanoid = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")

    if Humanoid then
        Humanoid.WalkSpeed = 32
    end
end)

Movement:Button("JumpPower 100", function()

    local Humanoid = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")

    if Humanoid then
        Humanoid.JumpPower = 100
    end
end)

Movement:Toggle("Sprint", false, function(v)
    print("Sprint:", v)
end)

--// =====================================================================
--// SETTINGS TAB
--// =====================================================================

local UI = Settings:CreateSection("UI Settings")

UI:Button("Hide UI", function()

    local gui = game.CoreGui:FindFirstChild("KilometresUIX")

    if gui then
        gui.Enabled = false
    end
end)

UI:Button("Show UI", function()

    local gui = game.CoreGui:FindFirstChild("KilometresUIX")

    if gui then
        gui.Enabled = true
    end
end)

UI:Button("Destroy UI", function()

    local gui = game.CoreGui:FindFirstChild("KilometresUIX")

    if gui then
        gui:Destroy()
    end
end)

UI:Toggle("Blur Background", false, function(v)
    print("Blur:", v)
end)

UI:Toggle("Notifications", true, function(v)
    print("Notifications:", v)
end)

UI:Toggle("Save Config", true, function(v)
    print("Save Config:", v)
end)

--// =====================================================================
--// EXTRA MASS ELEMENT TEST
--// =====================================================================

local Stress = Settings:CreateSection("Stress Test")

for i = 1, 20 do

    Stress:Button("Extra Button "..i, function()
        print("Clicked:", i)
    end)

end

print("Kilometres UI X Example Loaded")
