--// KILOMETRES UI V5 EXAMPLE
--// Uses all available systems/elements

local UI = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

----------------------------------------------------------------
-- EXTRA TABS
----------------------------------------------------------------

local MainTab = UI:CreateTab("Main")
local CombatTab = UI:CreateTab("Combat")
local VisualTab = UI:CreateTab("Visual")
local UtilityTab = UI:CreateTab("Utility")

----------------------------------------------------------------
-- MAIN TOGGLES
----------------------------------------------------------------

UI:CreateToggle(MainTab, "Auto Farm", false, function(v)
	print("Auto Farm:", v)
end)

UI:CreateToggle(MainTab, "Auto Collect", true, function(v)
	print("Auto Collect:", v)
end)

UI:CreateToggle(MainTab, "Auto Rebirth", false, function(v)
	print("Auto Rebirth:", v)
end)

UI:CreateToggle(MainTab, "Anti AFK", true, function(v)
	print("Anti AFK:", v)
end)

----------------------------------------------------------------
-- COMBAT TOGGLES
----------------------------------------------------------------

UI:CreateToggle(CombatTab, "Kill Aura", false, function(v)
	print("Kill Aura:", v)
end)

UI:CreateToggle(CombatTab, "Silent Aim", false, function(v)
	print("Silent Aim:", v)
end)

UI:CreateToggle(CombatTab, "ESP Players", true, function(v)
	print("ESP Players:", v)
end)

UI:CreateToggle(CombatTab, "Hitbox Expand", false, function(v)
	print("Hitbox Expand:", v)
end)

----------------------------------------------------------------
-- VISUAL TOGGLES
----------------------------------------------------------------

UI:CreateToggle(VisualTab, "FullBright", false, function(v)
	print("FullBright:", v)

	if v then
		game:GetService("Lighting").Brightness = 5
	else
		game:GetService("Lighting").Brightness = 2
	end
end)

UI:CreateToggle(VisualTab, "Shadows", true, function(v)
	print("Shadows:", v)

	game:GetService("Lighting").GlobalShadows = v
end)

UI:CreateToggle(VisualTab, "Bloom Effect", true, function(v)
	print("Bloom:", v)
end)

UI:CreateToggle(VisualTab, "Particles", true, function(v)
	print("Particles:", v)
end)

----------------------------------------------------------------
-- UTILITY TOGGLES
----------------------------------------------------------------

UI:CreateToggle(UtilityTab, "Infinite Jump", false, function(v)
	print("Infinite Jump:", v)
end)

UI:CreateToggle(UtilityTab, "Fly", false, function(v)
	print("Fly:", v)
end)

UI:CreateToggle(UtilityTab, "NoClip", false, function(v)
	print("NoClip:", v)
end)

UI:CreateToggle(UtilityTab, "Speed Boost", false, function(v)
	print("Speed Boost:", v)

	local humanoid = game.Players.LocalPlayer.Character and
		game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")

	if humanoid then
		humanoid.WalkSpeed = v and 50 or 16
	end
end)

----------------------------------------------------------------
-- CUSTOM UI OBJECTS INSIDE TABS
----------------------------------------------------------------

-- LABEL EXAMPLE
local Label = Instance.new("TextLabel")
Label.Size = UDim2.new(1, -10, 0, 40)
Label.BackgroundTransparency = 1
Label.Text = "KilometresUI V5 Example"
Label.Font = Enum.Font.GothamBold
Label.TextSize = 22
Label.TextColor3 = UI.Themes[UI.Theme].Accent
Label.Parent = MainTab

-- BUTTON EXAMPLE
local Button = Instance.new("TextButton")
Button.Size = UDim2.new(1, -10, 0, 45)
Button.BackgroundColor3 = UI.Themes[UI.Theme].Accent
Button.Text = "Show Notification"
Button.Font = Enum.Font.GothamBold
Button.TextSize = 16
Button.TextColor3 = Color3.new(1,1,1)
Button.Parent = MainTab

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 12)
ButtonCorner.Parent = Button

Button.MouseButton1Click:Connect(function()
	print("Notification Button Clicked")
end)

----------------------------------------------------------------
-- DROPDOWN STYLE EXAMPLE
----------------------------------------------------------------

local Dropdown = Instance.new("TextButton")
Dropdown.Size = UDim2.new(1, -10, 0, 45)
Dropdown.BackgroundColor3 = UI.Themes[UI.Theme].Secondary
Dropdown.Text = "Select Weapon"
Dropdown.Font = Enum.Font.GothamBold
Dropdown.TextSize = 15
Dropdown.TextColor3 = UI.Themes[UI.Theme].Text
Dropdown.Parent = CombatTab

local DropCorner = Instance.new("UICorner")
DropCorner.CornerRadius = UDim.new(0,12)
DropCorner.Parent = Dropdown

local Weapons = {
	"Sword",
	"Gun",
	"Magic",
	"Bow"
}

local Current = 1

Dropdown.MouseButton1Click:Connect(function()
	Current += 1

	if Current > #Weapons then
		Current = 1
	end

	Dropdown.Text = "Weapon: "..Weapons[Current]

	print("Selected:", Weapons[Current])
end)

