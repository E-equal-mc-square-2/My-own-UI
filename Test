local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "Ultimate Example Showcase",
    Theme = "LiquidGlass",
    Width = 980,
    Height = 640,
    SaveSettings = true,
    ToggleKey = Enum.KeyCode.RightShift
})

--// =====================================================
--// TAB 1
--// =====================================================

local MainTab = Library:CreateTab("Main")

local CombatSection = MainTab:CreateSection("Combat")

CombatSection:Info("Combat system configuration")

CombatSection:Button("Print Hello", function()
    Window:Notify("Button", "Hello from button!", 2)
    print("Hello!")
end)

CombatSection:Toggle("Auto Attack", false, function(v)
    print("Auto Attack:", v)
    Window:Notify("Toggle", "Auto Attack = "..tostring(v), 2)
end)

CombatSection:Toggle("Silent Aim", true, function(v)
    print("Silent Aim:", v)
end)

CombatSection:Slider("Attack Range", 1, 500, 120, function(v)
    print("Range:", v)
end, 1)

CombatSection:Slider("Attack Speed", 1, 20, 5, function(v)
    print("Speed:", v)
end, 0.1)

CombatSection:Textbox("Target Name", "Enter player...", function(text)
    print("Target:", text)
end)

CombatSection:Dropdown(
    "Combat Mode",
    {"Legit", "Rage", "Hybrid", "Stealth"},
    "Legit",
    function(choice)
        print("Mode:", choice)
    end
)

--// =====================================================
--// VISUAL TAB
--// =====================================================

local VisualTab = Library:CreateTab("Visuals")

local ESPSection = VisualTab:CreateSection("ESP")

ESPSection:Toggle("Box ESP", true, function(v)
    print("Box ESP:", v)
end)

ESPSection:Toggle("Tracer ESP", false, function(v)
    print("Tracer ESP:", v)
end)

ESPSection:Toggle("Health Bar", true, function(v)
    print("Health:", v)
end)

ESPSection:Slider("ESP Distance", 50, 5000, 1200, function(v)
    print("ESP Distance:", v)
end)

ESPSection:Dropdown(
    "ESP Color",
    {"Purple", "Blue", "Green", "White", "Red"},
    "Purple",
    function(v)
        print("ESP Color:", v)
    end
)

local CameraSection = VisualTab:CreateSection("Camera")

CameraSection:Slider("Field Of View", 60, 120, 80, function(v)
    workspace.CurrentCamera.FieldOfView = v
end)

CameraSection:Button("Reset FOV", function()
    workspace.CurrentCamera.FieldOfView = 70
    Window:Notify("Camera", "FOV Reset", 2)
end)

CameraSection:Textbox("Custom Skybox", "Asset ID", function(v)
    print("Skybox ID:", v)
end)

--// =====================================================
--// PLAYER TAB
--// =====================================================

local PlayerTab = Library:CreateTab("Player")

local MovementSection = PlayerTab:CreateSection("Movement")

MovementSection:Toggle("Infinite Jump", false, function(v)
    print("Infinite Jump:", v)
end)

MovementSection:Toggle("Fly", false, function(v)
    print("Fly:", v)
end)

MovementSection:Slider("WalkSpeed", 16, 200, 16, function(v)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = v
    end
end)

MovementSection:Slider("JumpPower", 50, 300, 50, function(v)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.JumpPower = v
    end
end)

MovementSection:Button("Reset Character", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

local MiscSection = PlayerTab:CreateSection("Misc")

MiscSection:Textbox("Chat Message", "Type message...", function(v)
    game.ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(v, "All")
end)

MiscSection:Dropdown(
    "Animation Pack",
    {"Default", "Ninja", "Zombie", "Robot"},
    "Default",
    function(v)
        print("Animation:", v)
    end
)

MiscSection:Info("All player settings are local-side only.")

--// =====================================================
--// SETTINGS TAB
--// =====================================================

local SettingsTab = Library:CreateTab("Settings")

local ThemeSection = SettingsTab:CreateSection("Themes")

ThemeSection:Button("Default Theme", function()
    Window:SetTheme("Default")
end)

ThemeSection:Button("Liquid Glass", function()
    Window:SetTheme("LiquidGlass")
end)

ThemeSection:Button("Cyber Neo", function()
    Window:SetTheme("CyberNeo")
end)

ThemeSection:Button("3066 Years", function()
    Window:SetTheme("Year3066")
end)

ThemeSection:Button("Midnight", function()
    Window:SetTheme("Midnight")
end)

local UtilitySection = SettingsTab:CreateSection("Utilities")

UtilitySection:Button("Hide UI", function()
    Window:Hide()
end)

UtilitySection:Button("Show Notification", function()
    Window:Notify(
        "Kilometres UI",
        "This is a showcase notification.",
        3
    )
end)

UtilitySection:Button("Resize Window", function()
    Window:SetSize(1200, 720)
end)

UtilitySection:Button("Print State", function()
    print(Window:GetState())
end)

UtilitySection:Info("Press RightShift to toggle UI.")

--// =====================================================
--// STARTUP
--// =====================================================

Window:Notify(
    "Kilometres UI X",
    "Loaded successfully.",
    3
)
