--// =========================================================
--// KILOMETRES UI X V4 - FULL EXAMPLE
--// Example Script Using ALL ELEMENTS
--// =========================================================

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

--// WINDOW

local Window = Library:CreateWindow({
	Title = "Kilometres UI X",
	Subtitle = "Ultimate Showcase",
	Theme = "Year3066",
	SaveSettings = true,
	KeySystem = true,
	RequiredKey = "MaMa",
	AutoOpenSettings = false
})

--// =========================================================
--// MAIN TAB
--// =========================================================

local MainTab = Library:CreateTab("Main")
local MainSection = MainTab:CreateSection("Main Features")

MainSection:Button("Print Hello", function()
	print("Hello from Kilometres UI X")
end)

MainSection:Button("Rejoin Server", function()
	game:GetService("TeleportService"):Teleport(game.PlaceId)
end)

MainSection:Toggle("Auto Farm", false, function(v)
	print("Auto Farm:", v)
end)

MainSection:Toggle("Infinite Jump", false, function(v)
	print("Infinite Jump:", v)
end)

MainSection:Slider("WalkSpeed", 16, 100, 16, function(v)
	game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
end, 1)

MainSection:Slider("JumpPower", 50, 200, 50, function(v)
	game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
end, 1)

MainSection:Textbox("Custom Chat", "Type message...", function(text)
	game.ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer(text, "All")
end)

MainSection:Textbox("Set Display Name", "Display name...", function(text)
	print("Display Name:", text)
end)

--// =========================================================
--// VISUAL TAB
--// =========================================================

local VisualTab = Library:CreateTab("Visuals")
local ESPSection = VisualTab:CreateSection("ESP")

ESPSection:Toggle("Player ESP", false, function(v)
	print("ESP Enabled:", v)
end)

ESPSection:Toggle("Box ESP", false, function(v)
	print("Box ESP:", v)
end)

ESPSection:Toggle("Tracer ESP", false, function(v)
	print("Tracer ESP:", v)
end)

ESPSection:Button("Refresh ESP", function()
	print("Refreshing ESP...")
end)

ESPSection:Slider("ESP Distance", 100, 5000, 1000, function(v)
	print("ESP Distance:", v)
end, 50)

local WorldSection = VisualTab:CreateSection("World")

WorldSection:Slider("Brightness", 0, 10, 2, function(v)
	game.Lighting.Brightness = v
end, 0.1)

WorldSection:Slider("Field Of View", 70, 120, 70, function(v)
	workspace.CurrentCamera.FieldOfView = v
end, 1)

WorldSection:Toggle("FullBright", false, function(v)
	if v then
		game.Lighting.ClockTime = 12
	else
		game.Lighting.ClockTime = 18
	end
end)

WorldSection:Textbox("Skybox ID", "rbxassetid://", function(text)
	print("Skybox:", text)
end)

--// =========================================================
--// PLAYER TAB
--// =========================================================

local PlayerTab = Library:CreateTab("Player")

local CharacterSection = PlayerTab:CreateSection("Character")

CharacterSection:Button("Reset Character", function()
	game.Players.LocalPlayer.Character:BreakJoints()
end)

CharacterSection:Toggle("Noclip", false, function(v)
	print("Noclip:", v)
end)

CharacterSection:Toggle("Fly", false, function(v)
	print("Fly:", v)
end)

CharacterSection:Slider("Gravity", 0, 196, 196, function(v)
	workspace.Gravity = v
end, 1)

CharacterSection:Textbox("Animation ID", "Animation ID...", function(text)
	print("Animation:", text)
end)

local MiscPlayer = PlayerTab:CreateSection("Misc")

MiscPlayer:Button("Copy Username", function()
	if setclipboard then
		setclipboard(game.Players.LocalPlayer.Name)
	end
end)

MiscPlayer:Button("Copy UserID", function()
	if setclipboard then
		setclipboard(tostring(game.Players.LocalPlayer.UserId))
	end
end)

MiscPlayer:Textbox("Teleport Player", "Username...", function(text)
	print("Teleport to:", text)
end)

--// =========================================================
--// SETTINGS TAB
--// =========================================================

local SettingsTab = Library:CreateTab("Settings")

local UISection = SettingsTab:CreateSection("UI Controls")

UISection:Button("Hide UI", function()
	Window:Hide()
end)

UISection:Button("Show UI", function()
	Window:Show()
end)

UISection:Button("Destroy UI", function()
	Window:Destroy()
end)

UISection:Button("Cyber Theme", function()
	Window:SetTheme("CyberNeo")
end)

UISection:Button("Midnight Theme", function()
	Window:SetTheme("Midnight")
end)

UISection:Button("LiquidGlass Theme", function()
	Window:SetTheme("LiquidGlass")
end)

UISection:Slider("Window Width", 500, 1400, 900, function(v)
	local State = Window:GetState()
	Window:SetSize(v, State.Height)
end, 1)

UISection:Slider("Window Height", 300, 900, 620, function(v)
	local State = Window:GetState()
	Window:SetSize(State.Width, v)
end, 1)

UISection:Slider("Offset X", -500, 500, 0, function(v)
	local State = Window:GetState()
	Window:SetOffset(v, State.OffsetY)
end, 1)

UISection:Slider("Offset Y", -300, 300, 0, function(v)
	local State = Window:GetState()
	Window:SetOffset(State.OffsetX, v)
end, 1)

local InfoSection = SettingsTab:CreateSection("Information")

InfoSection:Button("Print State", function()
	print(Window:GetState())
end)

InfoSection:Textbox("Executor Name", "Type executor...", function(text)
	print("Executor:", text)
end)

InfoSection:Toggle("Debug Mode", false, function(v)
	print("Debug:", v)
end)

InfoSection:Slider("UI Blur", 0, 50, 0, function(v)
	print("Blur:", v)
end, 1)

