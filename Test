--// =========================================================
--// KilometresUI X — FULL EXAMPLE FOR UI3
--// Simple showcase using all elements
--// =========================================================

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "UI3 Example",
    Theme = "Nebula"
})

--// =========================================================
--// MAIN TAB
--// =========================================================

local MainTab = Window:CreateTab({
    Name = "Main"
})

local MainSection = MainTab:CreateSection({
    Name = "Main Controls",
    Description = "Basic UI elements showcase"
})

MainSection:CreateLabel("Welcome to Kilometres UI X")

MainSection:CreateParagraph(
    "This example demonstrates all UI3 elements including buttons, toggles, sliders, dropdowns, textboxes, and keybinds."
)

MainSection:CreateButton({
    Name = "Show Notification",
    Description = "Simple button example",
    Callback = function()
        Library:Notify({
            Title = "KilometresUI",
            Content = "Button clicked successfully!",
            Duration = 4
        })
    end
})

MainSection:CreateToggle({
    Name = "Auto Farm",
    Description = "Toggle example",
    Default = false,
    Flag = "AutoFarm",
    Callback = function(v)
        print("Auto Farm:", v)
    end
})

MainSection:CreateSlider({
    Name = "WalkSpeed",
    Min = 16,
    Max = 200,
    Increment = 1,
    Default = 16,
    Flag = "WalkSpeed",
    Callback = function(v)
        print("WalkSpeed:", v)

        pcall(function()
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
        end)
    end
})

MainSection:CreateDropdown({
    Name = "Select Mode",
    Options = {
        "Legit",
        "Rage",
        "Balanced",
        "Custom"
    },
    Default = "Balanced",
    Flag = "Mode",
    Callback = function(v)
        print("Selected:", v)
    end
})

MainSection:CreateTextbox({
    Name = "Player Name",
    Placeholder = "Type username...",
    Default = "",
    Flag = "PlayerName",
    Callback = function(v)
        print("Textbox:", v)
    end
})

MainSection:CreateKeybind({
    Name = "Open Menu",
    Default = Enum.KeyCode.RightShift,
    Flag = "MenuBind",
    Callback = function()
        print("Keybind Pressed")
    end
})

--// =========================================================
--// VISUALS TAB
--// =========================================================

local VisualsTab = Window:CreateTab({
    Name = "Visuals"
})

local VisualsSection = VisualsTab:CreateSection({
    Name = "Visual Settings",
    Description = "Visual controls"
})

VisualsSection:CreateToggle({
    Name = "ESP",
    Default = true,
    Flag = "ESP",
    Callback = function(v)
        print("ESP:", v)
    end
})

VisualsSection:CreateToggle({
    Name = "Chams",
    Default = false,
    Flag = "Chams",
    Callback = function(v)
        print("Chams:", v)
    end
})

VisualsSection:CreateSlider({
    Name = "Brightness",
    Min = 0,
    Max = 100,
    Increment = 1,
    Default = 50,
    Flag = "Brightness",
    Callback = function(v)
        print("Brightness:", v)
    end
})

VisualsSection:CreateDropdown({
    Name = "ESP Color",
    Options = {
        "Red",
        "Blue",
        "Green",
        "Purple",
        "Rainbow"
    },
    Default = "Purple",
    Flag = "ESPColor",
    Callback = function(v)
        print("ESP Color:", v)
    end
})

--// =========================================================
--// SETTINGS TAB
--// =========================================================

local SettingsTab = Window:CreateTab({
    Name = "Settings"
})

local ThemeSection = SettingsTab:CreateSection({
    Name = "Themes",
    Description = "Change UI themes"
})

ThemeSection:CreateDropdown({
    Name = "Theme",
    Options = {
        "Nebula",
        "Phantom",
        "Eclipse",
        "Quantum",
        "Nova"
    },
    Default = "Nebula",
    Flag = "Theme",
    Callback = function(v)
        Library:SetTheme(v)

        Library:Notify({
            Title = "Theme Changed",
            Content = "Current theme: " .. v,
            Duration = 3
        })
    end
})

local ConfigSection = SettingsTab:CreateSection({
    Name = "Configs",
    Description = "Save & load configs"
})

ConfigSection:CreateButton({
    Name = "Save Config",
    Callback = function()
        local ok = Library:SaveConfig("MyConfig")

        Library:Notify({
            Title = "Config",
            Content = ok and "Config saved!" or "Executor unsupported.",
            Duration = 3
        })
    end
})

ConfigSection:CreateButton({
    Name = "Load Config",
    Callback = function()
        local ok = Library:LoadConfig("MyConfig")

        Library:Notify({
            Title = "Config",
            Content = ok and "Config loaded!" or "Config not found.",
            Duration = 3
        })
    end
})

ConfigSection:CreateButton({
    Name = "Destroy UI",
    Callback = function()
        Window:Destroy()
    end
})

--// =========================================================
--// COMMAND PALETTE EXAMPLES
--// =========================================================

Window:RegisterCommand("Print Hello", function()
    print("Hello from command palette!")
end, "Examples")

Window:RegisterCommand("Notification Test", function()
    Library:Notify({
        Title = "Command Palette",
        Content = "You executed a command!",
        Duration = 3
    })
end, "Examples")

--// =========================================================
--// STARTUP NOTIFICATION
--// =========================================================

Library:Notify({
    Title = "KilometresUI X",
    Content = "UI3 loaded successfully!",
    Duration = 5
})

print("KilometresUI X Example Loaded")
