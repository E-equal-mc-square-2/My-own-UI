--// ======================================================================
--// KILOMETRES UI X V5 — FULL EXAMPLE
--// Uses ALL ELEMENTS
--// ======================================================================

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "All Elements Showcase",
    Theme = "LiquidGlass",
    Width = 750,
    Height = 360,
    SaveSettings = true,
    ToggleKey = Enum.KeyCode.RightShift,
    SaveFile = "settings.json"
})

--// ======================================================================
--// TAB 1
--// ======================================================================

local MainTab = Window:CreateTab("Main")

local Combat = MainTab:CreateSection("Combat")

Combat:Info("All combat functions here.")

Combat:Button("Kill Aura", function()
    Window:Notify("Combat", "Kill Aura Pressed", 2)
end)

Combat:Toggle("Silent Aim", false, function(v)
    print("Silent Aim:", v)
end)

Combat:Toggle("Auto Shoot", true, function(v)
    print("Auto Shoot:", v)
end)

Combat:Slider("Aim FOV", 0, 360, 120, function(v)
    print("FOV:", v)
end)

Combat:Slider("Prediction", 0, 100, 25, function(v)
    print("Prediction:", v)
end)

Combat:Textbox("Target Name", "Enter player...", function(v)
    print("Target:", v)
end)

Combat:Dropdown("Hit Part", {
    "Head",
    "Torso",
    "HumanoidRootPart",
    "Random"
}, "Head", function(v)
    print("Hit Part:", v)
end)

Combat:List("Aim Type", {
    "Visible",
    "Instant",
    "Never Miss",
    "Legit",
    "Smooth",
    "Rage",
    "Silent",
    "Camera",
    "Lock",
    "Memory",
    "Hybrid",
    "Humanized"
}, "Visible", function(v)
    print("Aim Type:", v)
end)

--// ======================================================================
--// TAB 2
--// ======================================================================

local PlayerTab = Window:CreateTab("Player")

local Movement = PlayerTab:CreateSection("Movement")

Movement:Toggle("Speed Hack", false, function(v)
    print("Speed:", v)
end)

Movement:Slider("WalkSpeed", 16, 300, 16, function(v)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
end)

Movement:Slider("JumpPower", 50, 300, 50, function(v)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
end)

Movement:Toggle("Infinite Jump", false, function(v)
    print(v)
end)

Movement:Dropdown("Fly Mode", {
    "Velocity",
    "CFrame",
    "Tween",
    "Smooth"
}, "Velocity", function(v)
    print(v)
end)

Movement:Button("Reset Character", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

--// ======================================================================
--// TAB 3
--// ======================================================================

local VisualTab = Window:CreateTab("Visuals")

local ESP = VisualTab:CreateSection("ESP")

ESP:Toggle("Box ESP", true, function(v)
    print(v)
end)

ESP:Toggle("Name ESP", true, function(v)
    print(v)
end)

ESP:Toggle("Tracer ESP", false, function(v)
    print(v)
end)

ESP:Toggle("Health ESP", true, function(v)
    print(v)
end)

ESP:Slider("ESP Distance", 50, 5000, 1000, function(v)
    print(v)
end)

ESP:List("ESP Style", {
    "2D",
    "3D",
    "Corner",
    "Filled",
    "Outline",
    "Neon",
    "Minimal"
}, "Corner", function(v)
    print(v)
end)

local World = VisualTab:CreateSection("World")

World:Dropdown("Skybox", {
    "Galaxy",
    "Purple",
    "Blue",
    "Sunset",
    "Void",
    "Classic"
}, "Galaxy", function(v)
    print(v)
end)

World:Slider("Brightness", 0, 10, 2, function(v)
    game.Lighting.Brightness = v
end)

World:Button("FullBright", function()
    game.Lighting.ClockTime = 14
    game.Lighting.FogEnd = 100000
    game.Lighting.Brightness = 5
end)

--// ======================================================================
--// TAB 4
--// ======================================================================

local MiscTab = Window:CreateTab("Misc")

local Utility = MiscTab:CreateSection("Utility")

Utility:Button("Rejoin Server", function()
    game:GetService("TeleportService"):Teleport(
        game.PlaceId,
        game.Players.LocalPlayer
    )
end)

Utility:Button("Copy Discord", function()
    setclipboard("https://discord.gg/example")
    Window:Notify("Copied", "Discord copied", 2)
end)

Utility:Textbox("Custom Notify", "Type text...", function(v)
    Window:Notify("Message", v, 3)
end)

Utility:List("UI Animation", {
    "Smooth",
    "Bounce",
    "Elastic",
    "Fast",
    "Instant"
}, "Smooth", function(v)
    print(v)
end)

Utility:Dropdown("Executor", {
    "Solara",
    "Xeno",
    "Swift",
    "Fluxus",
    "Delta"
}, "Solara", function(v)
    print(v)
end)

Utility:Toggle("Auto Save", true, function(v)
    print(v)
end)

