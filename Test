local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "Ultimate Showcase",
    Theme = "LiquidGlass",
    Width = 750,
    Height = 360,
    SaveSettings = true,
})

--// =====================================================
--// TAB 1
--// =====================================================

local MainTab = Library:CreateTab("Main")

local Combat = MainTab:CreateSection("Combat")

Combat:Info("Combat system showcase")

Combat:Button("Kill Aura", function()
    Window:Notify("Combat", "Kill Aura Activated", 2)
end)

Combat:Toggle("Silent Aim", false, function(v)
    print("Silent Aim:", v)
end)

Combat:Slider("FOV Size", 50, 500, 120, function(v)
    print("FOV:", v)
end, 1)

Combat:Textbox("Target Player", "Enter username...", function(txt)
    print("Target:", txt)
end)

Combat:Dropdown("Aim Part", {
    "Head",
    "Torso",
    "HumanoidRootPart"
}, "Head", function(v)
    print("Aim Part:", v)
end)

Combat:List("Aim Mode", {
    "Visible",
    "Instant",
    "Never Miss",
    "Legit",
    "Aggressive",
    "Prediction",
    "Closest",
    "Silent",
    "Mouse",
    "Dynamic",
    "Camera",
    "Resolver",
    "Sticky",
    "Randomizer",
    "Ultra"
}, "Visible", function(v)
    print("Aim Mode:", v)
end)

--// =====================================================
--// TAB 2
--// =====================================================

local PlayerTab = Library:CreateTab("Player")

local Movement = PlayerTab:CreateSection("Movement")

Movement:Toggle("Speed Enabled", false, function(v)
    print(v)
end)

Movement:Slider("WalkSpeed", 16, 300, 50, function(v)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
end)

Movement:Slider("JumpPower", 50, 300, 80, function(v)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
end)

Movement:Button("Reset Movement", function()
    local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

    hum.WalkSpeed = 16
    hum.JumpPower = 50

    Window:Notify("Player", "Movement Reset", 2)
end)

local Misc = PlayerTab:CreateSection("Misc")

Misc:Textbox("Custom Message", "Type something...", function(txt)
    Window:Notify("Textbox", txt, 3)
end)

Misc:Dropdown("Animation Pack", {
    "Stylish",
    "Zombie",
    "Mage",
    "Robot",
    "Ninja"
}, "Stylish", function(v)
    print(v)
end)

Misc:Info("Dropdown cycles options")

--// =====================================================
--// TAB 3
--// =====================================================

local VisualTab = Library:CreateTab("Visuals")

local ESP = VisualTab:CreateSection("ESP")

ESP:Toggle("Box ESP", true, function(v)
    print(v)
end)

ESP:Toggle("Name ESP", true, function(v)
    print(v)
end)

ESP:Toggle("Tracer ESP", false, function(v)
    print(v)
end)

ESP:Slider("ESP Distance", 50, 5000, 1000, function(v)
    print(v)
end)

ESP:Dropdown("ESP Color", {
    "Red",
    "Green",
    "Blue",
    "Purple",
    "Rainbow"
}, "Purple", function(v)
    print(v)
end)

--// =====================================================
--// TAB 4
--// =====================================================

local SettingsTab = Library:CreateTab("Settings")

local ThemeSection = SettingsTab:CreateSection("Theme Tools")

ThemeSection:Button("Default Theme", function()
    Window:SetTheme("Default")
end)

ThemeSection:Button("Liquid Glass", function()
    Window:SetTheme("LiquidGlass")
end)

ThemeSection:Button("Cyber Neo", function()
    Window:SetTheme("CyberNeo")
end)

ThemeSection:Button("3066 Years", function()
    Window:SetTheme("Year3066")
end)

ThemeSection:Button("Midnight", function()
    Window:SetTheme("Midnight")
end)

local WindowSection = SettingsTab:CreateSection("Window")

WindowSection:Button("Hide UI", function()
    Window:Hide()
end)

WindowSection:Button("Show UI", function()
    Window:Show()
end)

WindowSection:Button("Resize Small", function()
    Window:SetSize(600, 320)
end)

WindowSection:Button("Resize Large", function()
    Window:SetSize(1000, 600)
end)

WindowSection:Button("Print State", function()
    print(Window:GetState())
end)

--// =====================================================
--// STARTUP
--// =====================================================

Window:Notify(
    "Kilometres UI X",
    "Loaded Example Showcase Successfully",
    4
)
