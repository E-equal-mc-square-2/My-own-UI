--// ======================================================================
--// KILOMETRES UI X V5 EXAMPLE
--// FULL SHOWCASE USING ALL ELEMENTS
--// FOR UI3
--// ======================================================================

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

--// WINDOW

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "V5 Showcase",
    Theme = "LiquidGlass",
    Width = 920,
    Height = 650,
    SaveSettings = true
})

--// ======================================================================
--// TAB : PLAYER
--// ======================================================================

local PlayerTab = Library:CreateTab("Player")

local Character = PlayerTab:CreateSection("Character")

Character:Button("Reset Character", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

Character:Toggle("Noclip", false, function(v)
    print("Noclip:", v)
end)

Character:Toggle("Fly", false, function(v)
    print("Fly:", v)
end)

Character:Slider("WalkSpeed", 16, 200, 16, function(v)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
end, 1)

Character:Slider("JumpPower", 50, 300, 50, function(v)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = v
end, 1)

Character:Textbox("Custom Name", "Type name...", function(text)
    print("Name:", text)
end)

--// ======================================================================
--// TAB : VISUALS
--// ======================================================================

local VisualsTab = Library:CreateTab("Visuals")

local ESP = VisualsTab:CreateSection("ESP")

ESP:Toggle("Player ESP", false, function(v)
    print("Player ESP:", v)
end)

ESP:Toggle("Box ESP", false, function(v)
    print("Box ESP:", v)
end)

ESP:Toggle("Tracer ESP", false, function(v)
    print("Tracer ESP:", v)
end)

ESP:Slider("ESP Distance", 50, 5000, 1000, function(v)
    print("Distance:", v)
end, 50)

ESP:Button("Refresh ESP", function()
    print("ESP Refreshed")
end)

local Lighting = VisualsTab:CreateSection("Lighting")

Lighting:Slider("Brightness", 0, 10, 2, function(v)
    game:GetService("Lighting").Brightness = v
end, 0.1)

Lighting:Slider("Clock Time", 0, 24, 14, function(v)
    game:GetService("Lighting").ClockTime = v
end, 0.1)

Lighting:Toggle("FullBright", false, function(v)
    print("FullBright:", v)
end)

--// ======================================================================
--// TAB : COMBAT
--// ======================================================================

local CombatTab = Library:CreateTab("Combat")

local Combat = CombatTab:CreateSection("Combat")

Combat:Toggle("Silent Aim", false, function(v)
    print("Silent Aim:", v)
end)

Combat:Toggle("Aim Assist", false, function(v)
    print("Aim Assist:", v)
end)

Combat:Toggle("Trigger Bot", false, function(v)
    print("Trigger Bot:", v)
end)

Combat:Slider("FOV Radius", 50, 600, 120, function(v)
    print("FOV:", v)
end, 1)

Combat:Slider("Hit Chance", 0, 100, 85, function(v)
    print("Chance:", v)
end, 1)

Combat:Textbox("Target Player", "Username...", function(text)
    print("Target:", text)
end)

--// ======================================================================
--// TAB : TELEPORT
--// ======================================================================

local TeleportTab = Library:CreateTab("Teleport")

local Teleports = TeleportTab:CreateSection("Locations")

Teleports:Button("Spawn", function()
    game.Players.LocalPlayer.Character:MoveTo(Vector3.new(0,5,0))
end)

Teleports:Button("Sky", function()
    game.Players.LocalPlayer.Character:MoveTo(Vector3.new(0,500,0))
end)

Teleports:Button("Secret Room", function()
    game.Players.LocalPlayer.Character:MoveTo(Vector3.new(200,20,150))
end)

Teleports:Textbox("Custom XYZ", "100, 50, 100", function(text)
    print("Teleport:", text)
end)

--// ======================================================================
--// TAB : MISC
--// ======================================================================

local MiscTab = Library:CreateTab("Misc")

local Misc = MiscTab:CreateSection("Utilities")

Misc:Button("Rejoin Server", function()
    game:GetService("TeleportService"):Teleport(
        game.PlaceId,
        game.Players.LocalPlayer
    )
end)

Misc:Button("Copy Discord", function()
    setclipboard("https://discord.gg/example")
end)

Misc:Toggle("Anti AFK", true, function(v)
    print("Anti AFK:", v)
end)

Misc:Toggle("FPS Boost", false, function(v)
    print("FPS Boost:", v)
end)

Misc:Slider("UI Blur", 0, 25, 8, function(v)
    print("Blur:", v)
end)

Misc:Textbox("Execute Command", "/help", function(text)
    print("Command:", text)
end)

--// ======================================================================
--// TAB : THEMES
--// ======================================================================

local ThemeTab = Library:CreateTab("Themes")

local Themes = ThemeTab:CreateSection("Theme Presets")

Themes:Button("Default", function()
    Window:SetTheme("Default")
end)

Themes:Button("Liquid Glass", function()
    Window:SetTheme("LiquidGlass")
end)

Themes:Button("Cyber Neo", function()
    Window:SetTheme("CyberNeo")
end)

Themes:Button("3066 Years", function()
    Window:SetTheme("Year3066")
end)

Themes:Button("Midnight", function()
    Window:SetTheme("Midnight")
end)

--// ======================================================================
--// TAB : WINDOW
--// ======================================================================

local WindowTab = Library:CreateTab("Window")

local WindowSection = WindowTab:CreateSection("Window Controls")

WindowSection:Button("Hide UI", function()
    Window:Hide()
end)

WindowSection:Button("Show UI", function()
    Window:Show()
end)

WindowSection:Button("Destroy UI", function()
    Window:Destroy()
end)

WindowSection:Slider("Window Width", 500, 1400, 920, function(v)
    Window:SetSize(v, Window:GetState().Height)
end)

WindowSection:Slider("Window Height", 400, 900, 650, function(v)
    Window:SetSize(Window:GetState().Width, v)
end)

print("Kilometres UI X Example Loaded")
