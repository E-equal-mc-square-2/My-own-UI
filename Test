local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "All Elements Example",
    Theme = "Nebula",

    -- mobile safe
    Blur = false,
    AutoScale = true,
    SafeInsets = true,
    MobileSidebar = true,
})

--// =====================================================
--// MAIN TAB
--// =====================================================

local Main = Window:CreateTab({
    Name = "Main"
})

local MainSection = Main:CreateSection("Gameplay")

MainSection:CreateLabel("Kilometres UI X Example")

MainSection:CreateButton({
    Name = "Send Notification",
    Callback = function()
        Library:Notify({
            Title = "Notification",
            Content = "Button clicked successfully.",
            Duration = 3
        })
    end
})

MainSection:CreateToggle({
    Name = "Auto Farm",
    Flag = "autofarm",
    Default = false,
    Callback = function(v)
        print("Auto Farm:", v)
    end
})

MainSection:CreateSlider({
    Name = "WalkSpeed",
    Flag = "walkspeed",
    Min = 16,
    Max = 200,
    Increment = 1,
    Default = 16,
    Callback = function(v)
        print("WalkSpeed:", v)
    end
})

MainSection:CreateDropdown({
    Name = "Select Mode",
    Flag = "mode",
    Options = {
        "Legit",
        "Rage",
        "Stealth",
        "Custom"
    },
    Default = "Legit",
    Callback = function(v)
        print("Mode:", v)
    end
})

MainSection:CreateTextbox({
    Name = "Player Name",
    Flag = "playername",
    Placeholder = "Enter username...",
    Default = "",
    Callback = function(v)
        print("Textbox:", v)
    end
})

MainSection:CreateKeybind({
    Name = "Toggle UI",
    Flag = "uikey",
    Default = Enum.KeyCode.RightShift,
    Callback = function(key)
        print("Pressed:", key.Name)
        Window:SetVisible(not Window.Visible)
    end
})

--// =====================================================
--// VISUAL TAB
--// =====================================================

local Visual = Window:CreateTab({
    Name = "Visuals"
})

local VisualSection = Visual:CreateSection("Visual Settings")

VisualSection:CreateToggle({
    Name = "ESP",
    Flag = "esp",
    Default = true,
    Callback = function(v)
        print("ESP:", v)
    end
})

VisualSection:CreateToggle({
    Name = "Tracers",
    Flag = "tracers",
    Default = false,
    Callback = function(v)
        print("Tracers:", v)
    end
})

VisualSection:CreateSlider({
    Name = "Brightness",
    Flag = "brightness",
    Min = 0,
    Max = 100,
    Increment = 1,
    Default = 50,
    Callback = function(v)
        print("Brightness:", v)
    end
})

VisualSection:CreateDropdown({
    Name = "Theme",
    Flag = "theme",
    Options = {
        "Nebula",
        "Phantom",
        "Nova",
        "Quantum",
        "Eclipse"
    },
    Default = "Nebula",
    Callback = function(v)
        Library:SetTheme(v)
    end
})

--// =====================================================
--// CONFIG TAB
--// =====================================================

local Config = Window:CreateTab({
    Name = "Config"
})

local ConfigSection = Config:CreateSection("Configs")

ConfigSection:CreateTextbox({
    Name = "Config Name",
    Flag = "configname",
    Placeholder = "example",
    Default = "default",
})

ConfigSection:CreateButton({
    Name = "Save Config",
    Callback = function()
        local cfg = Library.Flags.configname or "default"

        Library:SaveConfig(cfg)

        Library:Notify({
            Title = "Config",
            Content = "Saved config: "..cfg,
            Duration = 3
        })
    end
})

ConfigSection:CreateButton({
    Name = "Load Config",
    Callback = function()
        local cfg = Library.Flags.configname or "default"

        Library:LoadConfig(cfg)

        Library:Notify({
            Title = "Config",
            Content = "Loaded config: "..cfg,
            Duration = 3
        })
    end
})

ConfigSection:CreateButton({
    Name = "Open Command Palette",
    Callback = function()
        Library:OpenPalette()
    end
})

--// =====================================================
--// EXTRA TAB
--// =====================================================

local Extra = Window:CreateTab({
    Name = "Extra"
})

local ExtraSection = Extra:CreateSection("Extra Stuff")

ExtraSection:CreateButton({
    Name = "Destroy UI",
    Callback = function()
        Window:Destroy()
    end
})

ExtraSection:CreateButton({
    Name = "Change To Nova Theme",
    Callback = function()
        Library:SetTheme("Nova")
    end
})

ExtraSection:CreateButton({
    Name = "Change To Phantom Theme",
    Callback = function()
        Library:SetTheme("Phantom")
    end
})

ExtraSection:CreateButton({
    Name = "Test Notification",
    Callback = function()
        Library:Notify({
            Title = "Kilometres UI X",
            Content = "Everything is working perfectly.",
            Duration = 4
        })
    end
})

--// =====================================================
--// STARTUP
--// =====================================================

Library:Notify({
    Title = "Kilometres UI X",
    Content = "Loaded all UI elements example.",
    Duration = 5
})
