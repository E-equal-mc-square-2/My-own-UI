local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

--// WINDOW

local Window = Library:CreateWindow({
    Title = "Kilometres UI X1",
    Subtitle = "UI3 Full Example"
})

--// TABS

local Main = Library:CreateTab("Main")
local Visuals = Library:CreateTab("Visuals")
local Player = Library:CreateTab("Player")
local Misc = Library:CreateTab("Misc")
local Settings = Library:CreateTab("Settings")

--// =====================================================================
--// MAIN TAB
--// =====================================================================

local Farming = Main:CreateSection("Farming")

Farming:Button("Collect Coins", function()
    print("Collected coins")
end)

Farming:Button("Open Crate", function()
    print("Crate opened")
end)

Farming:Toggle("Auto Farm", false, function(v)
    print("Auto Farm:", v)
end)

Farming:Toggle("Auto Rebirth", false, function(v)
    print("Auto Rebirth:", v)
end)

local Combat = Main:CreateSection("Combat")

Combat:Button("Kill Aura", function()
    print("Aura activated")
end)

Combat:Toggle("Silent Aim", false, function(v)
    print("Silent Aim:", v)
end)

Combat:Toggle("Auto Attack", false, function(v)
    print("Auto Attack:", v)
end)

--// =====================================================================
--// VISUALS TAB
--// =====================================================================

local ESP = Visuals:CreateSection("ESP")

ESP:Toggle("Player ESP", false, function(v)
    print("Player ESP:", v)
end)

ESP:Toggle("Box ESP", false, function(v)
    print("Box ESP:", v)
end)

ESP:Toggle("Name ESP", false, function(v)
    print("Name ESP:", v)
end)

ESP:Toggle("Health ESP", false, function(v)
    print("Health ESP:", v)
end)

local World = Visuals:CreateSection("World")

World:Button("Full Bright", function()
    game:GetService("Lighting").Brightness = 5
end)

World:Button("Remove Fog", function()
    game:GetService("Lighting").FogEnd = 100000
end)

World:Toggle("Rainbow World", false, function(v)
    print("Rainbow World:", v)
end)

--// =====================================================================
--// PLAYER TAB
--// =====================================================================

local Character = Player:CreateSection("Character")

Character:Button("Reset Character", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

Character:Toggle("Infinite Jump", false, function(v)
    print("Infinite Jump:", v)
end)

Character:Toggle("Noclip", false, function(v)
    print("Noclip:", v)
end)

Character:Toggle("Fly", false, function(v)
    print("Fly:", v)
end)

local Movement = Player:CreateSection("Movement")

Movement:Button("Speed x2", function()
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 32
end)

Movement:Button("JumpPower x2", function()
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = 100
end)

Movement:Toggle("Sprint", false, function(v)
    print("Sprint:", v)
end)

--// =====================================================================
--// MISC TAB
--// =====================================================================

local Fun = Misc:CreateSection("Fun")

Fun:Button("Dance", function()
    print("Dance animation")
end)

Fun:Button("Play Sound", function()
    print("Sound played")
end)

Fun:Toggle("Spam Chat", false, function(v)
    print("Spam Chat:", v)
end)

Fun:Toggle("Annoy Mode", false, function(v)
    print("Annoy Mode:", v)
end)

local Server = Misc:CreateSection("Server")

Server:Button("Rejoin Server", function()
    game:GetService("TeleportService"):Teleport(
        game.PlaceId,
        game.Players.LocalPlayer
    )
end)

Server:Button("Copy JobId", function()
    setclipboard(game.JobId)
end)

Server:Toggle("Auto Rejoin", false, function(v)
    print("Auto Rejoin:", v)
end)

--// =====================================================================
--// SETTINGS TAB
--// =====================================================================

local UI = Settings:CreateSection("UI")

UI:Button("Destroy UI", function()

    local gui = game.CoreGui:FindFirstChild("KilometresUIX")

    if gui then
        gui:Destroy()
    end
end)

UI:Button("Print Theme", function()
    print("Theme Loaded")
end)

UI:Toggle("Blur Background", false, function(v)
    print("Blur:", v)
end)

UI:Toggle("Notifications", true, function(v)
    print("Notifications:", v)
end)

--// =====================================================================
--// EXTRA DEMO
--// =====================================================================

local Extra = Settings:CreateSection("Extra")

for i = 1, 10 do

    Extra:Button("Extra Button "..i, function()
        print("Clicked:", i)
    end)

end

print("Kilometres UI Example Loaded")
