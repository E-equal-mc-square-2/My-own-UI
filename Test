--// ======================================================================
--// KILOMETRES UI X V3 - FULL EXAMPLE
--// Uses MOST elements from UI3
--// ======================================================================

local Library = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"
))()

--// WINDOW

local Window = Library:CreateWindow({
    Title = "Kilometres UI X",
    Subtitle = "Ultimate Example",
    Theme = "CyberNeo",
    SaveSettings = true,
    KeySystem = false
})

--// TABS

local Main = Library:CreateTab("Main")
local Player = Library:CreateTab("Player")
local Visuals = Library:CreateTab("Visuals")
local Farming = Library:CreateTab("Farm")
local Misc = Library:CreateTab("Misc")
local Settings = Library:CreateTab("Settings")

--// ======================================================================
--// MAIN TAB
--// ======================================================================

local Welcome = Main:CreateSection("Welcome")

Welcome:Button("Print Hello", function()
    print("Hello from Kilometres UI X")
end)

Welcome:Toggle("Auto Notification", false, function(v)
    print("Notification Toggle:", v)
end)

Welcome:Slider("Notification Volume", 0, 100, 50, function(v)
    print("Volume:", v)
end)

Welcome:Textbox("Custom Message", "Type message...", function(text)
    print("Message:", text)
end)

--// ======================================================================
--// PLAYER TAB
--// ======================================================================

local Character = Player:CreateSection("Character")

Character:Slider("WalkSpeed", 16, 200, 16, function(v)
    local hum = game.Players.LocalPlayer.Character and
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

    if hum then
        hum.WalkSpeed = v
    end
end)

Character:Slider("JumpPower", 50, 250, 50, function(v)
    local hum = game.Players.LocalPlayer.Character and
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

    if hum then
        hum.JumpPower = v
    end
end)

Character:Toggle("Infinite Jump", false, function(v)
    getgenv().InfiniteJump = v
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if getgenv().InfiniteJump then
        local hum = game.Players.LocalPlayer.Character and
            game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

        if hum then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

Character:Button("Reset Character", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)

--// ======================================================================
--// VISUAL TAB
--// ======================================================================

local ESP = Visuals:CreateSection("ESP")

ESP:Toggle("Player ESP", false, function(v)
    print("ESP:", v)
end)

ESP:Toggle("Box ESP", false, function(v)
    print("Box ESP:", v)
end)

ESP:Toggle("Tracer ESP", false, function(v)
    print("Tracer ESP:", v)
end)

ESP:Slider("ESP Distance", 50, 5000, 1000, function(v)
    print("Distance:", v)
end)

ESP:Button("Refresh ESP", function()
    print("Refreshing ESP...")
end)

--// ======================================================================
--// FARM TAB
--// ======================================================================

local AutoFarm = Farming:CreateSection("Automation")

AutoFarm:Toggle("Auto Farm", false, function(v)
    getgenv().AutoFarm = v

    task.spawn(function()
        while getgenv().AutoFarm do
            task.wait(1)
            print("Auto Farming...")
        end
    end)
end)

AutoFarm:Toggle("Auto Sell", false, function(v)
    print("Auto Sell:", v)
end)

AutoFarm:Slider("Farm Speed", 1, 50, 10, function(v)
    print("Farm Speed:", v)
end)

AutoFarm:Textbox("Selected Mob", "Mob Name...", function(text)
    print("Selected Mob:", text)
end)

--// ======================================================================
--// MISC TAB
--// ======================================================================

local Utility = Misc:CreateSection("Utility")

Utility:Button("Rejoin Server", function()
    game:GetService("TeleportService"):Teleport(
        game.PlaceId,
        game.Players.LocalPlayer
    )
end)

Utility:Button("Copy Discord", function()
    if setclipboard then
        setclipboard("discord.gg/example")
    end
end)

Utility:Toggle("Anti AFK", true, function(v)

    if v then
        local vu = game:GetService("VirtualUser")

        game.Players.LocalPlayer.Idled:Connect(function()
            vu:CaptureController()
            vu:ClickButton2(Vector2.new())
        end)
    end
end)

Utility:Textbox("Custom Executor Name", "Fluxus / Delta / Solara", function(text)
    print("Executor:", text)
end)

--// ======================================================================
--// SETTINGS TAB
--// ======================================================================

local UI = Settings:CreateSection("UI Settings")

UI:Button("Theme: Default", function()
    Window:SetTheme("Default")
end)

UI:Button("Theme: Liquid Glass", function()
    Window:SetTheme("LiquidGlass")
end)

UI:Button("Theme: Cyber Neo", function()
    Window:SetTheme("CyberNeo")
end)

UI:Button("Theme: 3066 Years", function()
    Window:SetTheme("Year3066")
end)

UI:Button("Hide UI", function()
    Window:Hide()
end)

UI:Button("Show UI", function()
    Window:Show()
end)

UI:Slider("Window Width", 500, 1400, 900, function(v)
    local state = Window:GetState()

    Window:SetSize(v, state.Height)
end)

UI:Slider("Window Height", 300, 900, 620, function(v)
    local state = Window:GetState()

    Window:SetSize(state.Width, v)
end)

UI:Slider("Window Offset X", -500, 500, 0, function(v)
    local state = Window:GetState()

    Window:SetOffset(v, state.OffsetY)
end)

UI:Slider("Window Offset Y", -300, 300, 0, function(v)
    local state = Window:GetState()

    Window:SetOffset(state.OffsetX, v)
end)

UI:Textbox("Base64 Key", "Paste Base64...", function(text)
    print("Base64:", text)
end)

UI:Button("Destroy UI", function()
    Window:Destroy()
end)

--// ======================================================================
--// STARTUP MESSAGE
--// ======================================================================

print("Kilometres UI X Example Loaded")
