local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/E-equal-mc-square-2/KilometresUI/refs/heads/main/UI3"))()

--// Window
local Window = Library:CreateWindow({
	Title = "Kilometres UI X",
	Subtitle = "All Elements Showcase",
	Theme = "Nebula",
	Blur = true,
	Size = Library.IsMobile and UDim2.fromOffset(430,650) or UDim2.fromOffset(980,620),
})

--// Tabs
local MainTab = Window:CreateTab({
	Name = "Main"
})

local VisualTab = Window:CreateTab({
	Name = "Visuals"
})

local SettingsTab = Window:CreateTab({
	Name = "Settings"
})

--// Sections
local MainSection = MainTab:CreateSection("Gameplay")
local CombatSection = MainTab:CreateSection("Combat")

local VisualSection = VisualTab:CreateSection("Graphics")
local ThemeSection = VisualTab:CreateSection("Themes")

local SystemSection = SettingsTab:CreateSection("System")
local ConfigSection = SettingsTab:CreateSection("Configs")

--// LABEL
MainSection:CreateLabel("Welcome to Kilometres UI X")

--// BUTTON
MainSection:CreateButton({
	Name = "Print Hello",
	Callback = function()
		print("Hello from Kilometres UI X")
		
		Library:Notify({
			Title = "Button Clicked",
			Content = "You pressed the hello button.",
			Duration = 3,
		})
	end,
})

--// TOGGLE
MainSection:CreateToggle({
	Name = "Auto Farm",
	Default = false,
	Flag = "AutoFarm",
	Callback = function(v)
		print("Auto Farm:", v)
	end,
})

CombatSection:CreateToggle({
	Name = "Kill Aura",
	Default = true,
	Flag = "KillAura",
	Callback = function(v)
		print("Kill Aura:", v)
	end,
})

--// SLIDER
MainSection:CreateSlider({
	Name = "WalkSpeed",
	Min = 16,
	Max = 200,
	Default = 16,
	Increment = 1,
	Flag = "WalkSpeed",
	Callback = function(v)
		print("WalkSpeed:", v)
	end,
})

CombatSection:CreateSlider({
	Name = "Hitbox Size",
	Min = 1,
	Max = 30,
	Default = 5,
	Increment = 1,
	Flag = "Hitbox",
	Callback = function(v)
		print("Hitbox:", v)
	end,
})

--// TEXTBOX
VisualSection:CreateTextbox({
	Name = "Custom Preset",
	Placeholder = "Enter preset name...",
	Default = "Nebula",
	Flag = "PresetName",
	Callback = function(v)
		print("Preset:", v)
	end,
})

--// DROPDOWN
VisualSection:CreateDropdown({
	Name = "Graphics Mode",
	Options = {
		"Low",
		"Medium",
		"High",
		"Ultra",
	},
	Default = "High",
	Flag = "GraphicsMode",
	Callback = function(v)
		print("Graphics Mode:", v)
	end,
})

ThemeSection:CreateDropdown({
	Name = "Theme",
	Options = {
		"Nebula",
		"Phantom",
		"Eclipse",
		"Quantum",
		"Nova",
	},
	Default = "Nebula",
	Flag = "Theme",
	Callback = function(v)
		Library:SetTheme(v)

		Library:Notify({
			Title = "Theme Changed",
			Content = "Theme switched to "..v,
			Duration = 3,
		})
	end,
})

--// KEYBIND
SystemSection:CreateKeybind({
	Name = "Open Command Palette",
	Default = Enum.KeyCode.RightShift,
	Flag = "PaletteBind",
	Callback = function()
		Library:OpenPalette()
	end,
})

--// BUTTONS
SystemSection:CreateButton({
	Name = "Show Notification",
	Callback = function()
		Library:Notify({
			Title = "Kilometres UI X",
			Content = "This is a futuristic mobile-first UI library.",
			Duration = 4,
		})
	end,
})

SystemSection:CreateButton({
	Name = "Enable Blur",
	Callback = function()
		Library:EnableBlur(true)

		Library:Notify({
			Title = "Blur",
			Content = "Blur enabled.",
			Duration = 2,
		})
	end,
})

SystemSection:CreateButton({
	Name = "Disable Blur",
	Callback = function()
		Library:EnableBlur(false)

		Library:Notify({
			Title = "Blur",
			Content = "Blur disabled.",
			Duration = 2,
		})
	end,
})

--// CONFIGS
ConfigSection:CreateButton({
	Name = "Save Config",
	Callback = function()
		local ok = Library:SaveConfig("demo")

		Library:Notify({
			Title = "Save Config",
			Content = ok and "Saved demo.json" or "Executor unsupported.",
			Duration = 3,
		})
	end,
})

ConfigSection:CreateButton({
	Name = "Load Config",
	Callback = function()
		local ok = Library:LoadConfig("demo")

		Library:Notify({
			Title = "Load Config",
			Content = ok and "Loaded demo.json" or "Config not found.",
			Duration = 3,
		})
	end,
})

ConfigSection:CreateButton({
	Name = "Destroy UI",
	Callback = function()
		Window:Destroy()
	end,
})

--// COMMANDS
Window:RegisterCommand("Notify Test", function()
	Library:Notify({
		Title = "Command Palette",
		Content = "You executed a custom command.",
		Duration = 3,
	})
end, "Custom")

Window:RegisterCommand("Set Nova Theme", function()
	Library:SetTheme("Nova")
end, "Themes")

Window:RegisterCommand("Set Quantum Theme", function()
	Library:SetTheme("Quantum")
end, "Themes")

--// START NOTIFICATION
Library:Notify({
	Title = "Kilometres UI X",
	Content = "Loaded all UI elements successfully.",
	Duration = 5,
})
