local Effects = {}

function Effects:ApplyShadow(parent, intensity, radius, offset)
    return Utility:Create("ImageLabel", {
        Name = "DropShadow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = Color3.fromRGB(0, 0, 0),
        ImageTransparency = intensity or 0.5,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 250, 250),
        Size = UDim2.new(1, radius * 2, 1, radius * 2),
        Position = UDim2.new(0, -radius + (offset and offset.X or 0), 0, -radius + (offset and offset.Y or 0)),
        ZIndex = parent.ZIndex - 1,
        Parent = parent
    })
end

function Effects:Ripple(parent, input)
    spawn(function()
        local hitX, hitY = input.Position.X, input.Position.Y
        if isMobile and input.UserInputType == Enum.UserInputType.Touch then
            hitX, hitY = input.Position.X, input.Position.Y
        end

        local ripple = Utility:Create("Frame", {
            Name = "Ripple",
            BackgroundColor3 = Library.Theme.Text,
            BackgroundTransparency = 0.8,
            ZIndex = parent.ZIndex + 1,
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, hitX - parent.AbsolutePosition.X, 0, hitY - parent.AbsolutePosition.Y),
            AnchorPoint = Vector2.new(0.5, 0.5),
            Parent = parent,
            ClipsDescendants = true
        }, {
            Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) })
        })

        local maxDim = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
        Utility:Tween(ripple, {Size = UDim2.new(0, maxDim, 0, maxDim), BackgroundTransparency = 1}, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        task.wait(0.5)
        ripple:Destroy()
    end)
end

function Effects:Glow(parent)
    return Utility:Create("ImageLabel", {
        Name = "NeonGlow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857084",
        ImageColor3 = Library.Theme.PrimaryGlow,
        ImageTransparency = 0.6,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(24, 24, 276, 276),
        Size = UDim2.new(1, 30, 1, 30),
        Position = UDim2.new(0, -15, 0, -15),
        ZIndex = parent.ZIndex - 1,
        Parent = parent
    })
end

--//======================================================
--// DRAG & GESTURE SYSTEM
--//======================================================
local Gestures = {}

function Gestures:MakeDraggable(topbar, windowMain)
    local dragging, dragInput, dragStart, startPos
    
    local function update(input)
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        Utility:Tween(windowMain, {Position = targetPos}, 0.1, Enum.EasingStyle.Linear)
    end

    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = windowMain.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

function Gestures:AddSwipeMinimize(windowMain, topbar, minimizeCallback)
    if not isMobile then return end
    local startY, startTime
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            startY = input.Position.Y
            startTime = tick()
        end
    end)
    topbar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and startY then
            local deltaY = input.Position.Y - startY
            local timeDelta = tick() - startTime
            if deltaY > 50 and timeDelta < 0.5 then
                minimizeCallback()
            end
        end
    end)
end

