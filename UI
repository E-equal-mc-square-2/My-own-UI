	local settingsOpen = false
	local function toggleSettings()
		settingsOpen = not settingsOpen
		settingsPanel.Visible = settingsOpen
	end

	settingsBtn.MouseButton1Click:Connect(toggleSettings)

	local dragging = false
	local dragInput: InputObject? = nil
	local dragStart: Vector3? = nil
	local startPos: UDim2? = nil

	local function updateDrag(input)
		if not dragStart or not startPos then return end
		local delta = input.Position - dragStart
		main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		shadow.Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset - 5, main.Position.Y.Scale, main.Position.Y.Offset - 5)
		self._windowPos = main.Position
	end

	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	topbar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and dragInput == input then
			updateDrag(input)
		end
	end)

	local floatingDragging = false
	local floatingDragStart: Vector3? = nil
	local floatingStartPos: UDim2? = nil
	local floatingInput: InputObject? = nil

	local function updateFloatingDrag(input)
		if not floatingDragStart or not floatingStartPos then return end
		local delta = input.Position - floatingDragStart
		floating.Position = UDim2.new(
			floatingStartPos.X.Scale,
			floatingStartPos.X.Offset + delta.X,
			floatingStartPos.Y.Scale,
			floatingStartPos.Y.Offset + delta.Y
		)
		self._floatingPos = floating.Position
	end

	floating.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			floatingDragging = true
			floatingDragStart = input.Position
			floatingStartPos = floating.Position
			floatingInput = input
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					floatingDragging = false
				end
			end)
		end
	end)

	floating.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			floatingInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if floatingDragging and floatingInput == input then
			updateFloatingDrag(input)
		end
	end)

	local function applyTheme(themeTable)
		self.Theme = table.clone(themeTable)
		main.BackgroundColor3 = self.Theme.Background
		topbar.BackgroundColor3 = self.Theme.Topbar
		sidebar.BackgroundColor3 = self.Theme.Panel
		settingsPanel.BackgroundColor3 = self.Theme.Panel
		indicator.BackgroundColor3 = self.Theme.Accent
		hideBtn.BackgroundColor3 = self.Theme.Accent
		floating.BackgroundColor3 = self.Theme.Accent
		settingsBtn.BackgroundColor3 = self.Theme.PanelAlt
		addStroke(main, self.Theme.Stroke, 0.16, 1)
		addStroke(sidebar, self.Theme.Stroke, 0.42, 1)
		addStroke(settingsPanel, self.Theme.Stroke, 0.28, 1)
		avatar.Image = safeGetThumbnail(LocalPlayer.UserId)
		title.TextColor3 = self.Theme.Text
		subtitle.TextColor3 = self.Theme.SubText
		userName.TextColor3 = self.Theme.Text
		userTag.TextColor3 = self.Theme.SubText
	end

	function self:SetThemePreset(presetName: string)
		if THEMES[presetName] then
			self.ThemeName = presetName
			applyTheme(THEMES[presetName])
			self:Notify({Text = presetName .. " theme applied", Duration = 2})
		end
	end

	local window = {}
	window._library = self

	function window:Show()
		self._library._hidden = false
		shadow.Visible = true
		main.Visible = true
		floating.Visible = false
		TweenService:Create(shadow, TweenInfo.new(0.18), {BackgroundTransparency = 0.45}):Play()
		TweenService:Create(main, TweenInfo.new(0.18), {BackgroundTransparency = 0}):Play()
	end

	function window:Hide()
		self._library._hidden = true
		floating.Visible = true
		TweenService:Create(main, TweenInfo.new(0.14), {BackgroundTransparency = 1}):Play()
		TweenService:Create(shadow, TweenInfo.new(0.14), {BackgroundTransparency = 1}):Play()
		task.delay(0.16, function()
			if self._library._hidden then
				main.Visible = false
				shadow.Visible = false
			end
		end)
	end

	function window:Toggle()
		if self._library._hidden then
			window:Show()
		else
			window:Hide()
		end
	end

	function window:SetTitle(text: string)
		title.Text = text
		self._library.Title = text
	end

	function window:SetSubtitle(text: string)
		subtitle.Text = text
		self._library.Subtitle = text
	end

	function window:SetPositionPreset(presetName: string)
		local map = {
			Center = UDim2.new(0.5, -280, 0.5, -190),
			Left = UDim2.new(0.08, 0, 0.5, -190),
			Right = UDim2.new(0.92, -560, 0.5, -190),
			Top = UDim2.new(0.5, -280, 0.12, 0),
			Bottom = UDim2.new(0.5, -280, 0.78, 0),
		}
		if presetName == "Custom" then
			self._library:Notify({Text = "Drag the window anywhere and it will stay there.", Duration = 2})
			return
		end
		local target = map[presetName]
		if target then
			self._library._windowPos = target
			TweenService:Create(main, TweenInfo.new(0.22), {Position = target}):Play()
			TweenService:Create(shadow, TweenInfo.new(0.22), {Position = UDim2.new(target.X.Scale, target.X.Offset - 5, target.Y.Scale, target.Y.Offset - 5)}):Play()
		end
	end

	function window:Notify(info)
		info = info or {}
		local note = mk("Frame", {
			BackgroundColor3 = self._library.Theme.Panel,
			Size = UDim2.new(0, 280, 0, 64),
			Position = UDim2.new(1, -300, 1, -86),
			ZIndex = 100,
			Parent = root,
		})
		addCorner(note, DEFAULT_RADIUS - 2)
		addStroke(note, self._library.Theme.Stroke, 0.35)

		mk("Frame", {
			BackgroundColor3 = info.Type == "error" and self._library.Theme.Danger or self._library.Theme.Accent,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 6, 1, 0),
			ZIndex = 101,
			Parent = note,
		})

		mk("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 8),
			Size = UDim2.new(1, -24, 1, -16),
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			Text = info.Text or "Notification",
			TextColor3 = self._library.Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 14,
			ZIndex = 101,
			Parent = note,
		})

		tween(note, 0.15, {Position = UDim2.new(1, -300, 1, -96)})
		task.delay(info.Duration or 2.5, function()
			if note.Parent then
				tween(note, 0.15, {Position = UDim2.new(1, -300, 1, -56), BackgroundTransparency = 1})
				task.delay(0.16, function()
					if note.Parent then note:Destroy() end
				end)
			end
		end)
	end

	local function animateToggleSwitch(switch, knob, state)
		tween(switch, 0.18, {BackgroundColor3 = state and self.Theme.Accent or self.Theme.Stroke})
		tween(knob, 0.18, {
			Position = state and UDim2.new(1, -25, 0.5, -11) or UDim2.new(0, 3, 0.5, -11),
			BackgroundColor3 = state and self.Theme.Text or Color3.fromRGB(255,255,255),
		})
	end

	function window:CreateTab(tabName: string)
		local tab = {
			Name = tabName,
			Elements = {},
		}

		local tabButton = defaultButton(sidebar, tabName, self._library.Theme)
		tabButton.Size = UDim2.new(1, 0, 0, 36)
		tabButton.ZIndex = 6
		tab.Button = tabButton

		local page = mk("ScrollingFrame", {
			Name = tabName .. "Page",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			Visible = false,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = self._library.Theme.Accent,
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			ZIndex = 4,
			Parent = pages,
		})
		addPadding(page, 2)
		mk("UIListLayout", {
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = page,
		})
		tab.Page = page

		local function activate()
			for _, other in ipairs(self._library._tabs) do
				other.Page.Visible = false
				other.Button.BackgroundColor3 = self._library.Theme.PanelAlt
			end
			page.Visible = true
			tabButton.BackgroundColor3 = self._library.Theme.Accent
			self._library._activeTab = tab
			tween(indicator, 0.16, {Position = UDim2.new(0, 6, 0, tabButton.AbsolutePosition.Y - sidebar.AbsolutePosition.Y + 10)})
		end

		tabButton.MouseButton1Click:Connect(activate)

		function tab:CreateLabel(info)
			info = info or {}
			local lbl = mk("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, info.Height or 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				Text = info.Text or "Label",
				TextColor3 = info.Color or self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = info.Size or 13,
				TextWrapped = true,
				ZIndex = 10,
				Parent = page,
			})
			return lbl
		end

		function tab:CreateDivider()
			return mk("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				BackgroundTransparency = 0.45,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 1),
				ZIndex = 10,
				Parent = page,
			})
		end

		function tab:CreateButton(info)
			info = info or {}
			local btn = defaultButton(page, info.Text or "Button", self._library.Theme)
			btn.MouseEnter:Connect(function()
				tween(btn, 0.12, {BackgroundColor3 = self._library.Theme.Accent})
			end)
			btn.MouseLeave:Connect(function()
				tween(btn, 0.12, {BackgroundColor3 = self._library.Theme.PanelAlt})
			end)
			btn.MouseButton1Click:Connect(function()
				if info.Callback then info.Callback() end
			end)
			return btn
		end

		function tab:CreateToggle(info)
			info = info or {}
			local state = info.Default == true
			local holder = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 46),
				ZIndex = 10,
				Parent = page,
			})
			addCorner(holder, DEFAULT_RADIUS - 4)
			addStroke(holder, self._library.Theme.Stroke, 0.4)

			mk("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Toggle",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 0),
				Size = UDim2.new(1, -82, 1, 0),
				ZIndex = 11,
				Parent = holder,
			})

			local switch = mk("TextButton", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(0, 52, 0, 28),
				Position = UDim2.new(1, -62, 0.5, -14),
				ZIndex = 11,
				Parent = holder,
			})
			addCorner(switch, 999)

			local knob = mk("Frame", {
				BackgroundColor3 = Color3.fromRGB(255,255,255),
				Size = UDim2.new(0, 22, 0, 22),
				Position = UDim2.new(0, 3, 0.5, -11),
				ZIndex = 12,
				Parent = switch,
			})
			addCorner(knob, 999)

			animateToggleSwitch(switch, knob, state)

			switch.MouseButton1Click:Connect(function()
				state = not state
				animateToggleSwitch(switch, knob, state)
				if info.Callback then
					info.Callback(state)
				end
			end)

			return {
				Set = function(_, v)
					state = v and true or false
					animateToggleSwitch(switch, knob, state)
				end,
				Get = function()
					return state
				end,
			}
		end

		function tab:CreateSlider(info)
			info = info or {}
			local min = info.Min or 0
			local max = info.Max or 100
			local value = info.Default or min
			local draggingSlider = false

			local holder = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 62),
				ZIndex = 10,
				Parent = page,
			})
			addCorner(holder, DEFAULT_RADIUS - 4)
			addStroke(holder, self._library.Theme.Stroke, 0.4)

			mk("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Slider",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				ZIndex = 11,
				Parent = holder,
			})

			local valueLabel = mk("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(value),
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				ZIndex = 11,
				Parent = holder,
			})

			local bar = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Position = UDim2.new(0, 12, 0, 38),
				Size = UDim2.new(1, -24, 0, 10),
				ZIndex = 11,
				Parent = holder,
			})
			addCorner(bar, 999)

			local fill = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Accent,
				Size = UDim2.new(0, 0, 1, 0),
				ZIndex = 12,
				Parent = bar,
			})
			addCorner(fill, 999)

			local function setValue(v)
				value = math.clamp(math.floor(v + 0.5), min, max)
				local alpha = (value - min) / math.max(max - min, 1)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				valueLabel.Text = tostring(value)
				if info.Callback then info.Callback(value) end
			end
			setValue(value)

			local function update(input)
				local alpha = math.clamp((input.Position.X - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
				setValue(min + ((max - min) * alpha))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = true
					update(input)
				end
			end)
			bar.InputChanged:Connect(function(input)
				if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = false
				end
			end)

			return {
				Set = function(_, v) setValue(v) end,
				Get = function() return value end,
			}
		end

		function tab:CreateDropdown(info)
			info = info or {}
			local items = info.Items or {}
			local current = info.Default or items[1]
			local open = false

			local holder = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 48),
				ZIndex = 10,
				Parent = page,
			})
			addCorner(holder, DEFAULT_RADIUS - 4)
			addStroke(holder, self._library.Theme.Stroke, 0.4)
			addPadding(holder, 12)

			local header = mk("TextButton", {
				BackgroundTransparency = 1,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(1, 0, 0, 22),
				ZIndex = 11,
				Parent = holder,
			})

			mk("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Dropdown",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				Size = UDim2.new(1, -24, 0, 18),
				ZIndex = 11,
				Parent = holder,
			})

			local selected = mk("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(current or "Select"),
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				Size = UDim2.new(1, -24, 0, 18),
				ZIndex = 11,
				Parent = holder,
			})

			local listHolder = mk("Frame", {
				BackgroundTransparency = 1,
				Visible = false,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 0),
				ZIndex = 11,
				Parent = holder,
			})
			mk("UIListLayout", {
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = listHolder,
			})

			for _, item in ipairs(items) do
				local opt = defaultButton(listHolder, tostring(item), self._library.Theme)
				opt.Size = UDim2.new(1, 0, 0, 32)
				opt.MouseButton1Click:Connect(function()
					current = item
					selected.Text = tostring(current)
					open = false
					listHolder.Visible = false
					if info.Callback then info.Callback(current) end
				end)
			end

			header.MouseButton1Click:Connect(function()
				open = not open
				listHolder.Visible = open
			end)

			return {
				Set = function(_, v)
					current = v
					selected.Text = tostring(current)
				end,
				Get = function() return current end,
			}
		end

		function tab:CreateBox(info)
			info = info or {}
			local box = mk("TextBox", {
				BackgroundColor3 = self._library.Theme.Panel,
				PlaceholderText = info.Placeholder or "Type here",
				Text = info.Default or "",
				TextColor3 = self._library.Theme.Text,
				PlaceholderColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				ClearTextOnFocus = false,
				Size = UDim2.new(1, 0, 0, 40),
				ZIndex = 10,
				Parent = page,
			})
			addCorner(box, DEFAULT_RADIUS - 4)
			addStroke(box, self._library.Theme.Stroke, 0.4)
			addPadding(box, 10)
			box.FocusLost:Connect(function()
				if info.Callback then info.Callback(box.Text) end
			end)
			return box
		end

		function tab:CreateInfoCard(info)
			info = info or {}
			local card = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 84),
				ZIndex = 10,
				Parent = page,
			})
			addCorner(card, DEFAULT_RADIUS - 4)
			addStroke(card, self._library.Theme.Stroke, 0.4)
			addPadding(card, 12)

			mk("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 18),
				Text = info.Title or "Info Card",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.GothamBold,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 11,
				Parent = card,
			})

			mk("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, 22),
				Size = UDim2.new(1, 0, 1, -22),
				Text = info.Text or "A small card for hints, status, or player stats.",
				TextWrapped = true,
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Top,
				ZIndex = 11,
				Parent = card,
			})

			return card
		end

		table.insert(self._library._tabs, tab)
		if not self._library._activeTab then
			page.Visible = true
			tabButton.BackgroundColor3 = self._library.Theme.Accent
			self._library._activeTab = tab
		end

		return tab
	end

	-- Settings UI content
	createSmallSectionLabel("Theme presets")
	createThemeButton("Purple")
	createThemeButton("Blue")
	createThemeButton("Green")
	createThemeButton("Pink")

	createSmallSectionLabel("Window placement")
	createPlacementButton("Center")
	createPlacementButton("Left")
	createPlacementButton("Right")
	createPlacementButton("Top")
	createPlacementButton("Bottom")
	createPlacementButton("Custom")

	createSmallSectionLabel("Quick actions")
	local resetBtn = defaultButton(settingsPanel, "Reset UI Position", self.Theme)
	resetBtn.Size = UDim2.new(1, 0, 0, 32)
	resetBtn.MouseButton1Click:Connect(function()
		window:SetPositionPreset("Center")
	end)

	local hideCardBtn = defaultButton(settingsPanel, "Hide UI", self.Theme)
	hideCardBtn.Size = UDim2.new(1, 0, 0, 32)
	hideCardBtn.MouseButton1Click:Connect(function()
		window:Hide()
	end)

	self.Window = window
	window:Show()
	return window
end

function Library:CreateWindow(config)
	return Library.new(config)
end

return Library
