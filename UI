			page.Visible = true
			button.BackgroundColor3 = self._library.Theme.Accent
			self._library._activeTab = tab
			tween(indicator, 0.16, {Position = UDim2.new(0, 6, 0, button.AbsolutePosition.Y - sidebar.AbsolutePosition.Y + 10)})
		end
		button.MouseButton1Click:Connect(activate)

