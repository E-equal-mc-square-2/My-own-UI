		function tab:CreateInfoCard(info)
			info = info or {}
			local card = makeBlock(86)
			addPadding(card, 12, 12, 12, 12)

			local t = mk("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 18),
