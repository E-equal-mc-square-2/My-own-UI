            local Interact = Utility:Create("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0), Text = "", Parent = tglContainer })

            local Switch = Utility:Create("Frame", {
                BackgroundColor3 = state and Library.Theme.Primary or Library.Theme.Stroke,
                Size = UDim2.new(0, 44, 0, 24),
                Position = UDim2.new(1, -60, 0.5, -12),
                Parent = tglContainer
            }, { Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local Indicator = Utility:Create("Frame", {
                BackgroundColor3 = Color3.new(1, 1, 1),
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(0, state and 23 or 3, 0.5, -9),
                Parent = Switch
            }, { Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            
            local shadow = Effects:ApplyShadow(Indicator, 0.2, 5)

            local function UpdateToggle(newState)
                state = newState
                Library.Flags[flag] = state
                Utility:Tween(Switch, {BackgroundColor3 = state and Library.Theme.Primary or Library.Theme.Stroke}, 0.2)
