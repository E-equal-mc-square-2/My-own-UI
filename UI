        }),
        Utility:Create("TextLabel", {
            Name = "Title",
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 15, 0, 10),
            Size = UDim2.new(1, -25, 0, 16),
            Font = Enum.Font.GothamBold,
            Text = title,
            TextColor3 = accentColor,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left
        }),
        Utility:Create("TextLabel", {
            Name = "Body",
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 15, 0, 30),
            Size = UDim2.new(1, -25, 0, 0),
            Font = Enum.Font.Gotham,
            Text = text,
            TextColor3 = Library.Theme.SubText,
            TextSize = 13,
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top
        })
    })

    Effects:ApplyShadow(notif, 0.5, 20)

    local bodyBounds = Utility:GetTextBounds(text, Enum.Font.Gotham, 13, Vector2.new(275, 1000))
    local totalHeight = 30 + bodyBounds.Y + 10
    notif.Body.Size = UDim2.new(1, -25, 0, bodyBounds.Y)

    Utility:Tween(notif, {Size = UDim2.new(1, 0, 0, totalHeight), BackgroundTransparency = 0.05}, 0.4, Enum.EasingStyle.Back)
    
    task.delay(duration, function()
        Utility:Tween(notif, {Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1}, 0.3)
        task.wait(0.3)
        notif:Destroy()
    end)
end

