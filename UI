        Parent = Tabs,
        PaddingTop = UDim.new(0,15),
        PaddingLeft = UDim.new(0,10),
        PaddingRight = UDim.new(0,10)
    })

    --// PAGE HOLDER
    local Pages = Create("Frame",{
        Parent = Main,
        Size = UDim2.new(1,-170,1,-75),
        Position = UDim2.new(0,160,0,65),
        BackgroundTransparency = 1
    })

    --// OPEN/CLOSE
    FloatButton.MouseButton1Click:Connect(function()

        if Main.Visible == false then

            Main.Visible = true
            Main.Size = UDim2.new(0,0,0,0)

            Tween(
                Main,
                0.35,
                {
                    Size = UISize
                }
            )

        else

            Tween(
                Main,
                0.25,
                {
                    Size = UDim2.new(0,0,0,0)
                }
            )

            task.wait(0.25)

            Main.Visible = false
        end
    end)

    --// CLOSE
    Close.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)

    --// MINIMIZE
    local Minimized = false

    Minimize.MouseButton1Click:Connect(function()

        if not Minimized then

            Minimized = true

            Tween(
                Main,
                0.3,
                {
                    Size = UDim2.new(0,620,0,55)
                }
            )

        else

            Minimized = false

            Tween(
                Main,
                0.3,
                {
                    Size = UISize
                }
            )

        end
    end)

    --// DRAGGING
    MakeDraggable(TopBar,Main)
    MakeDraggable(FloatButton,FloatButton)

    --// WINDOW FUNCTIONS
    local Window = {}

    function Window:CreateTab(TabName)

        local TabButton = Create("TextButton",{
            Parent = Tabs,
            Size = UDim2.new(1,0,0,40),
            BackgroundColor3 = Themes.Background,
            Text = TabName,
            TextColor3 = Themes.Text,
            Font = Enum.Font.GothamSemibold,
            TextSize = 15,
            AutoButtonColor = false
        })

        Create("UICorner",{
            Parent = TabButton,
            CornerRadius = UDim.new(0,12)
        })

        local Page = Create("ScrollingFrame",{
            Parent = Pages,
            Size = UDim2.new(1,0,1,0),
            CanvasSize = UDim2.new(0,0,0,0),
            ScrollBarThickness = 4,
            BackgroundTransparency = 1,
            Visible = false
        })

        local Layout = Create("UIListLayout",{
            Parent = Page,
            Padding = UDim.new(0,10),
            SortOrder = Enum.SortOrder.LayoutOrder
        })

        Create("UIPadding",{
            Parent = Page,
            PaddingTop = UDim.new(0,5)
        })

        Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(
                0,
                0,
                0,
                Layout.AbsoluteContentSize.Y + 20
            )
        end)

        if #Pages:GetChildren() <= 1 then
            Page.Visible = true
            TabButton.BackgroundColor3 = Themes.Accent
        end

        TabButton.MouseButton1Click:Connect(function()

            for _,v in pairs(Pages:GetChildren()) do
                if v:IsA("ScrollingFrame") then
                    v.Visible = false
                end
            end

            for _,v in pairs(Tabs:GetChildren()) do
                if v:IsA("TextButton") then
                    Tween(v,0.2,{
                        BackgroundColor3 = Themes.Background
                    })
                end
            end

            Tween(TabButton,0.2,{
                BackgroundColor3 = Themes.Accent
            })

            Page.Visible = true
        end)

        --// TAB FUNCTIONS
        local Tab = {}

        --// SECTION
        function Tab:CreateSection(Name)

            local Section = Create("Frame",{
                Parent = Page,
                Size = UDim2.new(1,-10,0,50),
                BackgroundColor3 = Themes.Secondary,
                AutomaticSize = Enum.AutomaticSize.Y
            })

            Create("UICorner",{
                Parent = Section,
                CornerRadius = UDim.new(0,14)
            })

            Create("UIStroke",{
                Parent = Section,
                Color = Themes.Stroke
            })

            local SectionTitle = Create("TextLabel",{
                Parent = Section,
                Size = UDim2.new(1,-20,0,40),
                Position = UDim2.new(0,15,0,0),
                BackgroundTransparency = 1,
                Text = Name,
                Font = Enum.Font.GothamBold,
                TextColor3 = Themes.Text,
                TextSize = 16,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local Container = Create("Frame",{
                Parent = Section,
                Position = UDim2.new(0,10,0,40),
                Size = UDim2.new(1,-20,0,0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1
            })

            local ElementLayout = Create("UIListLayout",{
                Parent = Container,
                Padding = UDim.new(0,8)
            })

            --// ELEMENTS
            local Elements = {}

            --// BUTTON
            function Elements:CreateButton(Config)

                local Button = Create("TextButton",{
                    Parent = Container,
                    Size = UDim2.new(1,0,0,40),
                    BackgroundColor3 = Themes.Background,
                    Text = Config.Name or "Button",
                    Font = Enum.Font.GothamSemibold,
                    TextSize = 14,
                    TextColor3 = Themes.Text,
                    AutoButtonColor = false
                })

                Create("UICorner",{
                    Parent = Button,
                    CornerRadius = UDim.new(0,10)
                })

                Button.MouseButton1Click:Connect(function()

                    Tween(Button,0.1,{
                        BackgroundColor3 = Themes.Accent
                    })

                    task.wait(0.1)

                    Tween(Button,0.1,{
                        BackgroundColor3 = Themes.Background
                    })

                    if Config.Callback then
                        Config.Callback()
                    end
                end)
            end

            --// TOGGLE
            function Elements:CreateToggle(Config)

                local State = Config.Default or false

                local Toggle = Create("Frame",{
                    Parent = Container,
                    Size = UDim2.new(1,0,0,40),
                    BackgroundColor3 = Themes.Background
                })

                Create("UICorner",{
                    Parent = Toggle,
                    CornerRadius = UDim.new(0,10)
                })

                local Label = Create("TextLabel",{
                    Parent = Toggle,
                    Size = UDim2.new(1,-70,1,0),
                    Position = UDim2.new(0,15,0,0),
                    BackgroundTransparency = 1,
                    Text = Config.Name or "Toggle",
                    Font = Enum.Font.GothamSemibold,
                    TextSize = 14,
                    TextColor3 = Themes.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local Switch = Create("Frame",{
                    Parent = Toggle,
                    Size = UDim2.new(0,45,0,22),
                    Position = UDim2.new(1,-60,0.5,-11),
                    BackgroundColor3 = Color3.fromRGB(60,60,60)
                })

                Create("UICorner",{
                    Parent = Switch,
                    CornerRadius = UDim.new(1,0)
                })

                local Circle = Create("Frame",{
                    Parent = Switch,
                    Size = UDim2.new(0,18,0,18),
                    Position = UDim2.new(0,2,0.5,-9),
                    BackgroundColor3 = Color3.new(1,1,1)
                })

                Create("UICorner",{
                    Parent = Circle,
                    CornerRadius = UDim.new(1,0)
                })

                local function Update()

                    if State then

                        Tween(Switch,0.2,{
                            BackgroundColor3 = Themes.Accent
                        })

                        Tween(Circle,0.2,{
                            Position = UDim2.new(1,-20,0.5,-9)
                        })

                    else

                        Tween(Switch,0.2,{
                            BackgroundColor3 = Color3.fromRGB(60,60,60)
                        })

                        Tween(Circle,0.2,{
                            Position = UDim2.new(0,2,0.5,-9)
                        })

                    end

                    if Config.Callback then
                        Config.Callback(State)
                    end
                end

                Toggle.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                        State = not State
                        Update()
                    end
                end)

                Update()
            end

            return Elements
        end

        return Tab
    end

    return Window
end

return Library
