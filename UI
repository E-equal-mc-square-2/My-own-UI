local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer

local Nexus = {}

local Theme = {
    Main = Color3.fromRGB(18,18,18),
    Second = Color3.fromRGB(28,28,28),
    Accent = Color3.fromRGB(0,170,255),
    Text = Color3.fromRGB(255,255,255),
    DarkText = Color3.fromRGB(170,170,170),
    Stroke = Color3.fromRGB(45,45,45)
}

local function Tween(Object,Time,Properties)
    TweenService:Create(
        Object,
        TweenInfo.new(Time,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),
        Properties
    ):Play()
end

local function Create(Class,Props)
    local Obj = Instance.new(Class)

    for i,v in pairs(Props) do
        if i ~= "Parent" then
            Obj[i] = v
        end
    end

    Obj.Parent = Props.Parent

    return Obj
end

local function Ripple(Button)
    Button.ClipsDescendants = true

    Button.MouseButton1Down:Connect(function(x,y)
        local Circle = Instance.new("Frame")
        Circle.Parent = Button
        Circle.BackgroundColor3 = Color3.fromRGB(255,255,255)
        Circle.BackgroundTransparency = 0.8
        Circle.BorderSizePixel = 0
        Circle.AnchorPoint = Vector2.new(0.5,0.5)
        Circle.Position = UDim2.new(0,x - Button.AbsolutePosition.X,0,y - Button.AbsolutePosition.Y)
        Circle.Size = UDim2.new(0,0,0,0)

        local Corner = Instance.new("UICorner")
        Corner.CornerRadius = UDim.new(1,0)
        Corner.Parent = Circle

        Tween(Circle,0.45,{
            Size = UDim2.new(0,300,0,300),
            BackgroundTransparency = 1
        })

        task.delay(0.45,function()
            Circle:Destroy()
        end)
    end)
end

function Nexus:CreateWindow(Config)
    Config = Config or {}

    local Name = Config.Name or "Nexus UI"

    local Gui = Create("ScreenGui",{
        Parent = CoreGui,
        Name = "NexusUI",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    })

    local Main = Create("Frame",{
        Parent = Gui,
        BackgroundColor3 = Theme.Main,
        BorderSizePixel = 0,
        Size = UDim2.new(0,760,0,500),
        Position = UDim2.new(0.5,-380,0.5,-250)
    })

    Create("UICorner",{
        Parent = Main,
        CornerRadius = UDim.new(0,20)
    })

    Create("UIStroke",{
        Parent = Main,
        Color = Theme.Stroke,
        Thickness = 1
    })

    local Topbar = Create("Frame",{
        Parent = Main,
        BackgroundColor3 = Theme.Second,
        BorderSizePixel = 0,
        Size = UDim2.new(1,0,0,60)
    })

    Create("UICorner",{
        Parent = Topbar,
        CornerRadius = UDim.new(0,20)
    })

    local Fix = Create("Frame",{
        Parent = Topbar,
        BackgroundColor3 = Theme.Second,
        BorderSizePixel = 0,
        Position = UDim2.new(0,0,1,-20),
        Size = UDim2.new(1,0,0,20)
    })

    local Title = Create("TextLabel",{
        Parent = Topbar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0,20,0,0),
        Size = UDim2.new(1,-40,1,0),
        Font = Enum.Font.GothamBold,
        Text = Name,
        TextSize = 20,
        TextColor3 = Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local TabsHolder = Create("Frame",{
        Parent = Main,
        BackgroundColor3 = Theme.Second,
        BorderSizePixel = 0,
        Position = UDim2.new(0,15,0,75),
        Size = UDim2.new(0,180,1,-90)
    })

    Create("UICorner",{
        Parent = TabsHolder,
        CornerRadius = UDim.new(0,16)
    })

    local TabsPadding = Create("UIPadding",{
        Parent = TabsHolder,
        PaddingTop = UDim.new(0,10),
        PaddingLeft = UDim.new(0,10),
        PaddingRight = UDim.new(0,10)
    })

    local TabsLayout = Create("UIListLayout",{
        Parent = TabsHolder,
        Padding = UDim.new(0,8)
    })

    local Pages = Create("Frame",{
        Parent = Main,
        BackgroundTransparency = 1,
        Position = UDim2.new(0,210,0,75),
        Size = UDim2.new(1,-225,1,-90)
    })

    -- DRAGGING
    do
        local Dragging
        local DragInput
        local MousePos
        local FramePos

        Topbar.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Dragging = true
                MousePos = Input.Position
                FramePos = Main.Position

                Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                    end
                end)
            end
        end)

        Topbar.InputChanged:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement then
                DragInput = Input
            end
        end)

        UIS.InputChanged:Connect(function(Input)
            if Input == DragInput and Dragging then
                local Delta = Input.Position - MousePos

                Main.Position = UDim2.new(
                    FramePos.X.Scale,
                    FramePos.X.Offset + Delta.X,
                    FramePos.Y.Scale,
                    FramePos.Y.Offset + Delta.Y
                )
            end
        end)
    end

    local Window = {}

    function Window:CreateTab(Name)
        local TabButton = Create("TextButton",{
            Parent = TabsHolder,
            BackgroundColor3 = Theme.Main,
            BorderSizePixel = 0,
            Size = UDim2.new(1,0,0,42),
            Font = Enum.Font.GothamBold,
            Text = Name,
            TextColor3 = Theme.DarkText,
            TextSize = 14,
            AutoButtonColor = false
        })

        Create("UICorner",{
            Parent = TabButton,
            CornerRadius = UDim.new(0,12)
        })

        Ripple(TabButton)

        local Page = Create("ScrollingFrame",{
            Parent = Pages,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1,0,1,0),
            Visible = false,
            ScrollBarThickness = 0,
            CanvasSize = UDim2.new(0,0,0,0)
        })

        local Layout = Create("UIListLayout",{
            Parent = Page,
            Padding = UDim.new(0,10)
        })

        Create("UIPadding",{
            Parent = Page,
            PaddingTop = UDim.new(0,5),
            PaddingLeft = UDim.new(0,5),
            PaddingRight = UDim.new(0,5)
        })

        Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Page.CanvasSize = UDim2.new(0,0,0,Layout.AbsoluteContentSize.Y + 10)
        end)

        TabButton.MouseButton1Click:Connect(function()
            for _,v in pairs(Pages:GetChildren()) do
                if v:IsA("ScrollingFrame") then
                    v.Visible = false
                end
            end

            for _,v in pairs(TabsHolder:GetChildren()) do
                if v:IsA("TextButton") then
                    Tween(v,0.2,{BackgroundColor3 = Theme.Main})
                    v.TextColor3 = Theme.DarkText
                end
            end

            Page.Visible = true
            Tween(TabButton,0.2,{BackgroundColor3 = Theme.Accent})
            TabButton.TextColor3 = Theme.Text
        end)

        if #Pages:GetChildren() == 1 then
            Page.Visible = true
            TabButton.BackgroundColor3 = Theme.Accent
            TabButton.TextColor3 = Theme.Text
        end

        local Elements = {}

        function Elements:Button(Config)
            local Button = Create("TextButton",{
                Parent = Page,
                BackgroundColor3 = Theme.Second,
                BorderSizePixel = 0,
                Size = UDim2.new(1,0,0,55),
                Font = Enum.Font.GothamBold,
                Text = Config.Name or "Button",
                TextSize = 15,
                TextColor3 = Theme.Text,
                AutoButtonColor = false
            })

            Create("UICorner",{
                Parent = Button,
                CornerRadius = UDim.new(0,14)
            })

            Ripple(Button)

            Button.MouseButton1Click:Connect(function()
                Tween(Button,0.08,{Size = UDim2.new(1,-4,0,51)})
                task.wait(0.08)
                Tween(Button,0.08,{Size = UDim2.new(1,0,0,55)})

                if Config.Callback then
                    Config.Callback()
                end
            end)
        end

        function Elements:Label(Text)
            local Label = Create("TextLabel",{
                Parent = Page,
                BackgroundColor3 = Theme.Second,
                BorderSizePixel = 0,
                Size = UDim2.new(1,0,0,45),
                Font = Enum.Font.GothamBold,
                Text = Text,
                TextSize = 15,
                TextColor3 = Theme.Text
            })

            Create("UICorner",{
                Parent = Label,
                CornerRadius = UDim.new(0,14)
            })
        end

        function Elements:Toggle(Config)
            local Enabled = Config.Default or false

            local Toggle = Create("Frame",{
                Parent = Page,
                BackgroundColor3 = Theme.Second,
                BorderSizePixel = 0,
                Size = UDim2.new(1,0,0,55)
            })

            Create("UICorner",{
                Parent = Toggle,
                CornerRadius = UDim.new(0,14)
            })

            local Title = Create("TextLabel",{
                Parent = Toggle,
                BackgroundTransparency = 1,
                Position = UDim2.new(0,15,0,0),
                Size = UDim2.new(1,-80,1,0),
                Font = Enum.Font.GothamBold,
                Text = Config.Name or "Toggle",
                TextSize = 15,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left
            })

            local Button = Create("TextButton",{
                Parent = Toggle,
                BackgroundTransparency = 1,
                Size = UDim2.new(1,0,1,0),
                Text = ""
            })

            local Switch = Create("Frame",{
                Parent = Toggle,
                AnchorPoint = Vector2.new(1,0.5),
                Position = UDim2.new(1,-15,0.5,0),
                Size = UDim2.new(0,42,0,22),
                BackgroundColor3 = Color3.fromRGB(50,50,50),
                BorderSizePixel = 0
            })

            Create("UICorner",{
                Parent = Switch,
                CornerRadius = UDim.new(1,0)
            })

            local Circle = Create("Frame",{
                Parent = Switch,
                Size = UDim2.new(0,18,0,18),
                Position = UDim2.new(0,2,0.5,-9),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BorderSizePixel = 0
            })

            Create("UICorner",{
                Parent = Circle,
                CornerRadius = UDim.new(1,0)
            })

            local function SetState(State)
                Enabled = State

                if Enabled then
                    Tween(Switch,0.25,{BackgroundColor3 = Theme.Accent})
                    Tween(Circle,0.25,{Position = UDim2.new(1,-20,0.5,-9)})
                else
                    Tween(Switch,0.25,{BackgroundColor3 = Color3.fromRGB(50,50,50)})
                    Tween(Circle,0.25,{Position = UDim2.new(0,2,0.5,-9)})
                end

                if Config.Callback then
                    Config.Callback(Enabled)
                end
            end

            Button.MouseButton1Click:Connect(function()
                SetState(not Enabled)
            end)

            SetState(Enabled)
        end

        return Elements
    end

    return Window
end

return Nexus
