                Utility:Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder })
            })

            local isOpen = false

            local function RefreshList()
                for _, v in pairs(DropList:GetChildren()) do
                    if v:IsA("TextButton") then v:Destroy() end
                end

                local ySize = 0
                for _, opt in pairs(list) do
                    local btn = Utility:Create("TextButton", {
                        BackgroundColor3 = Library.Theme.Background,
                        Size = UDim2.new(1, 0, 0, 30),
                        Text = "  " .. opt,
                        Font = Enum.Font.Gotham,
                        TextColor3 = opt == selected and Library.Theme.Primary or Library.Theme.Text,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 51,
                        Parent = DropList
                    })
                    
                    btn.MouseButton1Click:Connect(function()
                        selected = opt
                        Library.Flags[flag] = selected
                        MainBtn.SelectedText.Text = selected
                        if options.Callback then options.Callback(selected) end
                        
                        -- Close Dropdown
                        isOpen = false
                        Utility:Tween(MainBtn.Arrow, {Rotation = 90}, 0.2)
                        Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
                        task.wait(0.2)
                        DropList.Visible = false
                        RefreshList() -- Update colors
                    end)
                    ySize = ySize + 30
                end
                DropList.CanvasSize = UDim2.new(0, 0, 0, ySize)
                return ySize
            end

            MainBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local h = math.clamp(RefreshList(), 0, 150)
                    DropList.Visible = true
                    Utility:Tween(MainBtn.Arrow, {Rotation = -90}, 0.2)
                    Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, h)}, 0.2, Enum.EasingStyle.Back)
                else
                    Utility:Tween(MainBtn.Arrow, {Rotation = 90}, 0.2)
                    Utility:Tween(DropList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
                    task.wait(0.2)
                    DropList.Visible = false
                end
            end)

            return {
                Refresh = function(self, newList)
                    list = newList
                    RefreshList()
                end,
                Set = function(self, val)
                    selected = val
                    Library.Flags[flag] = selected
                    MainBtn.SelectedText.Text = selected
                end
            }
        end

