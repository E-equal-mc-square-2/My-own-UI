        Utility:Create("UIStroke", { Color = Library.Theme.Stroke, Thickness = 1 }),
        Utility:Create("UIPadding", { PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10) })
    })

    local wmText = Utility:Create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Enum.Font.GothamMedium,
        Text = "",
        TextColor3 = Library.Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = wmFrame
    })

    Effects:ApplyShadow(wmFrame, 0.4, 15)

    local function updateWatermark()
        local fps = math.floor(1 / RunService.RenderStepped:Wait())
        local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
        local timeStr = os.date("%I:%M %p")
        
        local txt = string.format("<font color='#%s'>Neon</font> | %s FPS | %s ms | %s", 
            Library.Theme.Primary:ToHex(), tostring(fps), tostring(ping), timeStr)
        
        wmText.Text = txt
        wmText.RichText = true
        
        local bounds = Utility:GetTextBounds(wmText.ContentText, Enum.Font.GothamMedium, 14)
        Utility:Tween(wmFrame, {Size = UDim2.new(0, bounds.X + 20, 0, 32)}, 0.2)
    end

    Utility:AddConnection("WatermarkLoop", RunService.RenderStepped:Connect(function()
        if Library.Settings.WatermarkEnabled then
            updateWatermark()
        end
    end))
end

