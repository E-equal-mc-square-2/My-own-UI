		end

		tween(orb, { Size = UDim2.fromOffset(orb and ORB_SIZE or ORB_SIZE, orb and ORB_SIZE or ORB_SIZE) }, 0.12)
	end

	--// Window visibility controlled by orb
	do
		local draggingOrb = false
		local orbInput = nil
		local orbStart = nil
		local orbStartPos = nil
		local orbMoved = false

		local function snapOrb()
			if not orb or not orb.Parent then return end

			local viewport = Camera.ViewportSize
			local topLeft, bottomRight = getInset()
			local current = orb.Position

			local x = current.X.Offset
			local y = current.Y.Offset
			local half = viewport.X / 2

			local snappedX = (orb.AbsolutePosition.X < half) and 16 or (viewport.X - ORB_SIZE - 16)
			local clampedY = math.clamp(y, topLeft.Y + 16, viewport.Y - bottomRight.Y - ORB_SIZE - 16)

			tween(orb, {
				Position = UDim2.fromOffset(snappedX, clampedY),
			}, 0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		end

		orb.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingOrb = true
				orbInput = input
				orbStart = input.Position
				orbStartPos = orb.Position
				orbMoved = false
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if draggingOrb and orbInput == input then
				local delta = input.Position - orbStart
				if delta.Magnitude > 7 then
					orbMoved = true
				end

				local newX = orbStartPos.X.Offset + delta.X
				local newY = orbStartPos.Y.Offset + delta.Y
				newX, newY = clampToScreen(newX, newY, ORB_SIZE, ORB_SIZE, 16)

				orb.Position = UDim2.fromOffset(newX, newY)
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if draggingOrb and orbInput == input then
				draggingOrb = false

				if orbMoved then
					snapOrb()
				else
					setWindowVisible(not opened)
				end
			end
		end)
	end

	--// Drag window by topbar
	do
		local draggingWindow = false
		local dragStart = nil
		local startPos = nil

		topbar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingWindow = true
				dragStart = input.Position
				startPos = main.Position
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if draggingWindow and dragStart and startPos then
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					local delta = input.Position - dragStart
					local x = startPos.X.Offset + delta.X
					local y = startPos.Y.Offset + delta.Y
					local w = main.AbsoluteSize.X
					local h = main.AbsoluteSize.Y
					x, y = clampToScreen(x, y, w, h, 8)
					main.Position = UDim2.fromOffset(x + w * 0.5 - w * 0.5, y + h * 0.5 - h * 0.5)
				end
			end
		end)

		UserInputService.InputEnded:Connect(function(input)
			if draggingWindow and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
				draggingWindow = false
			end
		end)
	end

