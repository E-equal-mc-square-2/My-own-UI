            ColorBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Utility:Tween(cpContainer, {Size = UDim2.new(1, 0, 0, 215)}, 0.3, Enum.EasingStyle.Back)
                    CPFrame.Visible = true
                else
                    Utility:Tween(cpContainer, {Size = UDim2.new(1, 0, 0, 55)}, 0.3)
                    task.wait(0.3)
                    CPFrame.Visible = false
                end
            end)

            -- Creating the gradient map for hue is complex, omitting full interactive map 
            -- and implementing RGB slider alternatives for pure functionality in code constraints.
            local function CreateRGBRow(labelTxt, yPos, colVal, callback)
                local lbl = Utility:Create("TextLabel", {
                    BackgroundTransparency = 1, Position = UDim2.new(0, 10, 0, yPos), Size = UDim2.new(0, 20, 0, 20),
                    Font = Enum.Font.GothamBold, Text = labelTxt, TextColor3 = Library.Theme.Text, TextSize = 12, Parent = CPFrame
                })
                local track = Utility:Create("Frame", {
                    BackgroundColor3 = Library.Theme.Background, Position = UDim2.new(0, 40, 0, yPos+8), Size = UDim2.new(1, -60, 0, 4), Parent = CPFrame
                })
                local fill = Utility:Create("Frame", {
                    BackgroundColor3 = labelTxt == "R" and Color3.new(1,0,0) or labelTxt == "G" and Color3.new(0,1,0) or Color3.new(0,0,1),
                    Size = UDim2.new(colVal/255, 0, 1, 0), Parent = track
                })
                local btn = Utility:Create("TextButton", { BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Position=UDim2.new(0,0,0,-8), Text="", Parent=track })
                
                local dragging = false
                local function update(input)
                    local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    fill.Size = UDim2.new(pct, 0, 1, 0)
                    callback(math.floor(pct * 255))
                end
                
                btn.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                        dragging = true update(inp)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp) if dragging then dragging = false end end)
                UserInputService.InputChanged:Connect(function(inp)
                    if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then update(inp) end
                end)
            end

            local r, g, b = math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)
            local function UpdateColor()
                color = Color3.fromRGB(r, g, b)
                Library.Flags[flag] = color
                ColorBtn.BackgroundColor3 = color
                if options.Callback then options.Callback(color) end
            end

            CreateRGBRow("R", 20, r, function(val) r = val UpdateColor() end)
            CreateRGBRow("G", 60, g, function(val) g = val UpdateColor() end)
            CreateRGBRow("B", 100, b, function(val) b = val UpdateColor() end)

            return {
                Set = function(self, newColor)
                    color = newColor
                    Library.Flags[flag] = color
                    ColorBtn.BackgroundColor3 = color
                end
            }
        end
        
