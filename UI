            -- Extremely simplified ColorPicker logic due to single file constraint,
            -- representing a proper popup or expanding frame.
            local CPFrame = Utility:Create("Frame", {
                BackgroundColor3 = Library.Theme.Container,
                Size = UDim2.new(1, -30, 0, 150),
