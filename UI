local function Create(Class, Properties)
	local Obj = Instance.new(Class)

	for i,v in pairs(Properties or {}) do
		Obj[i] = v
	end

	return Obj
end

local function Tween(Object, Properties, Time, Style, Direction)
	local T = TweenService:Create(
		Object,
		TweenInfo.new(
			Time or CONFIG.AnimationSpeed,
			Style or Enum.EasingStyle.Quint,
			Direction or Enum.EasingDirection.Out
		),
		Properties
	)

	T:Play()
	return T
end

local function IsMobile()
	return UIS.TouchEnabled and workspace.CurrentCamera.ViewportSize.X < CONFIG.MobileBreakpoint
end

local function Ripple(Button)
	local Mouse = UIS:GetMouseLocation()

	local Circle = Create("Frame",{
		BackgroundTransparency = 0.65,
		BackgroundColor3 = Color3.new(1,1,1),
		AnchorPoint = Vector2.new(0.5,0.5),
		Size = UDim2.fromOffset(0,0),
		Position = UDim2.new(
			0,
			Mouse.X - Button.AbsolutePosition.X,
			0,
			Mouse.Y - Button.AbsolutePosition.Y
		),
		ZIndex = 999,
		Parent = Button
	})

	Create("UICorner",{
		CornerRadius = UDim.new(1,0),
		Parent = Circle
	})

	local Size = math.max(Button.AbsoluteSize.X, Button.AbsoluteSize.Y) * 2

	Tween(Circle,{
		Size = UDim2.fromOffset(Size,Size),
		BackgroundTransparency = 1
	},0.6)

	task.delay(0.65,function()
		Circle:Destroy()
	end)
end

--//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
