					TextColor3 = theme.SubText,
					TextSize = 12,
					TextWrapped = true,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 18,
					Parent = section,
				})
			end

			local SectionAPI = {}

			function SectionAPI:CreateLabel(text)
				local label = create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					AutomaticSize = Enum.AutomaticSize.Y,
					Size = UDim2.new(1, 0, 0, 0),
					Font = Enum.Font.GothamMedium,
					Text = tostring(text or "Label"),
					TextColor3 = theme.SubText,
					TextSize = 13,
					TextWrapped = true,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 19,
					Parent = section,
				})
				return label
			end

			function SectionAPI:CreateParagraph(text)
				local box = create("Frame", {
					BackgroundColor3 = theme.Surface,
					BackgroundTransparency = 0.05,
					BorderSizePixel = 0,
					AutomaticSize = Enum.AutomaticSize.Y,
					Size = UDim2.new(1, 0, 0, 0),
					ZIndex = 19,
					Parent = section,
				})
				addCorner(box, 12)
				addStroke(box, theme.Stroke, 0.95, 1)

				create("UIPadding", {
					PaddingTop = UDim.new(0, 10),
					PaddingBottom = UDim.new(0, 10),
					PaddingLeft = UDim.new(0, 12),
					PaddingRight = UDim.new(0, 12),
					Parent = box,
				})

				create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					AutomaticSize = Enum.AutomaticSize.Y,
					Size = UDim2.new(1, 0, 0, 0),
					Font = Enum.Font.Gotham,
					Text = tostring(text or ""),
					TextColor3 = theme.SubText,
					TextSize = 13,
					TextWrapped = true,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextYAlignment = Enum.TextYAlignment.Top,
					ZIndex = 20,
					Parent = box,
				})
				return box
			end

			function SectionAPI:CreateButton(data)
				return (Window._builders and Window._builders.CreateButton or nil)
					and Window._builders.CreateButton(section, theme, data)
					or nil
			end

			function SectionAPI:CreateToggle(data)
				return (Window._builders and Window._builders.CreateToggle or nil)
					and Window._builders.CreateToggle(section, theme, data)
					or nil
			end

			function SectionAPI:CreateSlider(data)
				return (Window._builders and Window._builders.CreateSlider or nil)
					and Window._builders.CreateSlider(section, theme, data)
					or nil
			end

			function SectionAPI:CreateDropdown(data)
				return (Window._builders and Window._builders.CreateDropdown or nil)
					and Window._builders.CreateDropdown(section, theme, data)
					or nil
			end

			return SectionAPI
		end

		return Tab
	end

	Window._builders = {
		CreateButton = function(parentSection, themeRef, buttonData)
			if typeof(buttonData) == "string" then
				buttonData = { Name = buttonData }
			end
			buttonData = buttonData or {}

			local button = create("TextButton", {
				Name = buttonData.Name or "Button",
				BackgroundColor3 = themeRef.Surface,
				BackgroundTransparency = 0.02,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, isMobile() and 46 or 48),
				AutoButtonColor = false,
				Text = buttonData.Name or "Button",
				Font = Enum.Font.GothamSemibold,
				TextColor3 = themeRef.Text,
				TextSize = 14,
				ZIndex = 20,
				ClipsDescendants = true,
				Parent = parentSection,
			})
			addCorner(button, 14)
			addStroke(button, themeRef.Stroke, 0.9, 1)

			if buttonData.Description then
				create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Position = UDim2.new(0, 14, 0, 24),
					Size = UDim2.new(1, -28, 0, 18),
					Font = Enum.Font.Gotham,
					Text = buttonData.Description,
					TextColor3 = themeRef.SubText,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 21,
					Parent = button,
				})
			end

			button.MouseButton1Click:Connect(function()
				ripple(button, themeRef)
				tween(button, { Size = UDim2.new(1, 0, 0, isMobile() and 44 or 46) }, 0.08)
				task.delay(0.08, function()
					if button and button.Parent then
						tween(button, { Size = UDim2.new(1, 0, 0, isMobile() and 46 or 48) }, 0.12)
					end
				end)
				if buttonData.Callback then
					task.spawn(buttonData.Callback)
				end
			end)
			return button
		end,

		CreateToggle = function(parentSection, themeRef, toggleData)
			if typeof(toggleData) == "string" then
				toggleData = { Name = toggleData }
			end
			toggleData = toggleData or {}

			local enabled = toggleData.Default or false

			local holder = create("Frame", {
				BackgroundColor3 = themeRef.Surface,
				BackgroundTransparency = 0.03,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 54),
				ZIndex = 20,
				Parent = parentSection,
			})
			addCorner(holder, 14)
			addStroke(holder, themeRef.Stroke, 0.93, 1)

			create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(1, -100, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = toggleData.Name or "Toggle",
				TextColor3 = themeRef.Text,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 21,
				Parent = holder,
			})

			if toggleData.Description then
				create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Position = UDim2.new(0, 14, 0, 24),
					Size = UDim2.new(1, -100, 0, 18),
					Font = Enum.Font.Gotham,
					Text = toggleData.Description,
					TextColor3 = themeRef.SubText,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 21,
					Parent = holder,
				})
			end

			local track = create("Frame", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -14, 0.5, 0),
				Size = UDim2.fromOffset(52, 28),
				BackgroundColor3 = themeRef.Surface2,
				BorderSizePixel = 0,
				ZIndex = 21,
				Parent = holder,
			})
			addCorner(track, 999)
			addStroke(track, themeRef.Stroke, 0.96, 1)

			local knob = create("Frame", {
				Size = UDim2.fromOffset(22, 22),
				Position = UDim2.new(0, 3, 0.5, -11),
				BackgroundColor3 = Color3.new(1,1,1),
				BorderSizePixel = 0,
				ZIndex = 22,
				Parent = track,
			})
			addCorner(knob, 999)

			local function refresh(noCallback)
				if enabled then
					tween(track, { BackgroundColor3 = themeRef.Accent }, 0.2)
					tween(knob, { Position = UDim2.new(1, -25, 0.5, -11) }, 0.22)
				else
					tween(track, { BackgroundColor3 = themeRef.Surface2 }, 0.2)
					tween(knob, { Position = UDim2.new(0, 3, 0.5, -11) }, 0.22)
				end
				if toggleData.Callback and not noCallback then
					task.spawn(toggleData.Callback, enabled)
				end
			end

			holder.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					enabled = not enabled
					refresh(false)
				end
			end)

			refresh(true)
			return {
				Set = function(v)
					enabled = not not v
					refresh(false)
				end,
				Get = function()
					return enabled
				end,
			}
		end,

		CreateSlider = function(parentSection, themeRef, sliderData)
			if typeof(sliderData) == "string" then
				sliderData = { Name = sliderData }
			end
			sliderData = sliderData or {}

			local min = sliderData.Min or 0
			local max = sliderData.Max or 100
			local value = sliderData.Default or min

			local holder = create("Frame", {
				BackgroundColor3 = themeRef.Surface,
				BackgroundTransparency = 0.03,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 72),
				ZIndex = 20,
				Parent = parentSection,
			})
			addCorner(holder, 14)
			addStroke(holder, themeRef.Stroke, 0.93, 1)

			create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(1, -28, 0, 20),
				Font = Enum.Font.GothamSemibold,
				Text = sliderData.Name or "Slider",
				TextColor3 = themeRef.Text,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 21,
				Parent = holder,
			})

			local valueText = create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(1, 0),
				Position = UDim2.new(1, -14, 0, 0),
				Size = UDim2.new(0, 100, 0, 20),
				Font = Enum.Font.Gotham,
				Text = tostring(value),
				TextColor3 = themeRef.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				ZIndex = 21,
				Parent = holder,
			})

			local bar = create("Frame", {
				BackgroundColor3 = themeRef.Surface2,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 40),
				Size = UDim2.new(1, -28, 0, 12),
				ZIndex = 21,
				Parent = holder,
			})
			addCorner(bar, 999)
			addStroke(bar, themeRef.Stroke, 0.96, 1)

			local fill = create("Frame", {
				BackgroundColor3 = themeRef.Accent,
				BorderSizePixel = 0,
				Size = UDim2.fromScale(0, 1),
				ZIndex = 22,
				Parent = bar,
			})
			addCorner(fill, 999)

			local knob = create("Frame", {
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.fromScale(0, 0.5),
				Size = UDim2.fromOffset(18, 18),
				BackgroundColor3 = Color3.fromRGB(255,255,255),
				BorderSizePixel = 0,
				ZIndex = 23,
				Parent = bar,
			})
			addCorner(knob, 999)

			local dragging = false

			local function setValue(v, silent)
				v = math.clamp(v, min, max)
				value = math.floor(v * 100) / 100
				local alpha = (value - min) / math.max(max - min, 0.0001)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				knob.Position = UDim2.new(alpha, 0, 0.5, 0)
				valueText.Text = tostring(value)
				if sliderData.Callback and not silent then
					task.spawn(sliderData.Callback, value)
				end
			end

			local function setFromInput(input)
				local x = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
				setValue(min + ((max - min) * x))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					setFromInput(input)
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					setFromInput(input)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
					dragging = false
				end
			end)

			setValue(value, true)
			return {
				Set = function(v) setValue(v, false) end,
				Get = function() return value end,
			}
		end,

		CreateDropdown = function(parentSection, themeRef, dropdownData)
			if typeof(dropdownData) == "string" then
				dropdownData = { Name = dropdownData }
			end
			dropdownData = dropdownData or {}

			local options = dropdownData.Options or {}
			local selected = dropdownData.Default or options[1] or "None"
			local open = false

			local holder = create("Frame", {
				BackgroundColor3 = themeRef.Surface,
				BackgroundTransparency = 0.03,
				BorderSizePixel = 0,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 48),
				ZIndex = 20,
				Parent = parentSection,
			})
			addCorner(holder, 14)
			addStroke(holder, themeRef.Stroke, 0.93, 1)

			local button = create("TextButton", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 48),
				Text = "",
				AutoButtonColor = false,
				ZIndex = 21,
				Parent = holder,
			})

			local label = create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(1, -28, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = (dropdownData.Name or "Dropdown") .. "  •  " .. tostring(selected),
				TextColor3 = themeRef.Text,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 22,
				Parent = holder,
			})

			local list = create("Frame", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Visible = false,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 0),
				ZIndex = 22,
				Parent = holder,
			})

			create("UIListLayout", {
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 8),
				Parent = list,
			})

			create("UIPadding", {
				PaddingTop = UDim.new(0, 8),
				PaddingLeft = UDim.new(0, 12),
				PaddingRight = UDim.new(0, 12),
				PaddingBottom = UDim.new(0, 12),
				Parent = list,
			})

			local function refreshText()
				label.Text = (dropdownData.Name or "Dropdown") .. "  •  " .. tostring(selected)
			end

			for _, opt in ipairs(options) do
				local optButton = create("TextButton", {
					Size = UDim2.new(1, 0, 0, 40),
					BackgroundColor3 = themeRef.Surface2,
					BackgroundTransparency = 0.03,
					BorderSizePixel = 0,
					AutoButtonColor = false,
					Text = tostring(opt),
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = themeRef.SubText,
					ZIndex = 23,
					Parent = list,
				})
				addCorner(optButton, 12)
				addStroke(optButton, themeRef.Stroke, 0.96, 1)

				optButton.MouseButton1Click:Connect(function()
					selected = opt
					refreshText()
					open = false
					list.Visible = false
					holder.Size = UDim2.new(1, 0, 0, 48)
					if dropdownData.Callback then
						task.spawn(dropdownData.Callback, selected)
					end
				end)
			end

			button.MouseButton1Click:Connect(function()
				ripple(holder, themeRef)
				open = not open
				list.Visible = open
				holder.Size = UDim2.new(1, 0, 0, open and (48 + (math.min(#options, 5) * 48)) or 48)
			end)

			refreshText()

			return {
				Set = function(v)
					selected = v
					refreshText()
				end,
				Get = function()
					return selected
				end,
			}
		end,
	}

	Window.CreateTab = createTabImpl

	--// Startup controls
	local public = Window

	public:Notify({
		Title = settings.Title or "Nexora",
		Description = "Purple adaptive UI loaded successfully.",
		Duration = 4,
	})

	return public
end

return Nexora

