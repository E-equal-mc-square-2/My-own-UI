    --//======================================================
    --// CONFIG SYSTEM & SERIALIZATION
    --//======================================================
    Library.ConfigManager = {}
    
    function Library.ConfigManager:Save(name)
        if not writefile then 
            Library:Notify({Title = "Error", Text = "Executor does not support saving files.", Type = "Error"})
            return 
        end
        local folder = GetRootFolder()
        local path = folder .. "/" .. name .. ".json"
        
        local savedFlags = {}
        for k, v in pairs(Library.Flags) do
            if typeof(v) == "Color3" then
                savedFlags[k] = {v.R, v.G, v.B, "Color3"}
            elseif typeof(v) == "EnumItem" then
                savedFlags[k] = {tostring(v), "Enum"}
            else
                savedFlags[k] = v
            end
        end
        
        writefile(path, HttpService:JSONEncode(savedFlags))
        Library:Notify({Title = "Config Saved", Text = "Saved successfully to " .. name, Type = "Success"})
    end

    function Library.ConfigManager:Load(name)
        if not readfile then return end
        local folder = GetRootFolder()
        local path = folder .. "/" .. name .. ".json"
        
        if isfile and isfile(path) then
            local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
            if success and decoded then
                for k, v in pairs(decoded) do
                    -- Complex parsing could go here for colors and enums if Elements supported direct Set calls mapped stringently
                    -- In this implementation, Flags update but Elements don't auto-visually update without element references.
                    -- A production approach maps Elements to a table to call Element:Set(v).
                    Library.Flags[k] = v
                end
                Library:Notify({Title = "Config Loaded", Text = "Loaded configuration " .. name, Type = "Success"})
            end
        end
    end

    return Window
end

return Library
