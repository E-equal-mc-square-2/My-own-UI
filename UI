		function tab:CreateToggle(info)
			info = info or {}
			local state = info.Default == true
			local holder = makeBlock(46)

			mk("TextLabel", {
				BackgroundTransparency = 1,
				Text = info.Text or "Toggle",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				Size = UDim2.new(1, -86, 1, 0),
				Position = UDim2.new(0, 12, 0, 0),
				ZIndex = 11,
				Parent = holder,
			})

			local switch = mk("TextButton", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(0, 52, 0, 28),
				Position = UDim2.new(1, -62, 0.5, -14),
				ZIndex = 11,
				Parent = holder,
			})
			addCorner(switch, 999)

			local knob = mk("Frame", {
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				Size = UDim2.new(0, 22, 0, 22),
				Position = UDim2.new(0, 3, 0.5, -11),
				ZIndex = 12,
				Parent = switch,
			})
			addCorner(knob, 999)

			animateToggle(switch, knob, state)
			switch.MouseButton1Click:Connect(function()
				state = not state
				animateToggle(switch, knob, state)
				if info.Callback then info.Callback(state) end
			end)

			return {
				Set = function(_, v)
					state = v and true or false
					animateToggle(switch, knob, state)
				end,
				Get = function() return state end,
			}
		end

		function tab:CreateSlider(info)
			info = info or {}
			local min = info.Min or 0
			local max = info.Max or 100
			local value = info.Default or min
			local draggingSlider = false
			local holder = makeBlock(62)

			local label = mk("TextLabel", {
				BackgroundTransparency = 1,
				Text = info.Text or "Slider",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				ZIndex = 11,
				Parent = holder,
			})
			fitText(label, 14, 11)

			local valueLabel = mk("TextLabel", {
				BackgroundTransparency = 1,
				Text = tostring(value),
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				ZIndex = 11,
				Parent = holder,
			})

			local bar = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Position = UDim2.new(0, 12, 0, 38),
				Size = UDim2.new(1, -24, 0, 10),
				ZIndex = 11,
				Parent = holder,
			})
			addCorner(bar, 999)

			local fill = mk("Frame", {
				BackgroundColor3 = self._library.Theme.Accent,
				Size = UDim2.new(0, 0, 1, 0),
				ZIndex = 12,
				Parent = bar,
			})
			addCorner(fill, 999)

			local function setValue(v)
				value = math.clamp(math.floor(v + 0.5), min, max)
				local alpha = (value - min) / math.max(max - min, 1)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				valueLabel.Text = tostring(value)
				if info.Callback then info.Callback(value) end
			end
			setValue(value)

			local function update(input)
				local alpha = math.clamp((input.Position.X - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
				setValue(min + ((max - min) * alpha))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = true
					update(input)
				end
			end)
			bar.InputChanged:Connect(function(input)
				if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					draggingSlider = false
				end
			end)

			return {
				Set = function(_, v) setValue(v) end,
				Get = function() return value end,
			}
		end

		function tab:CreateDropdown(info)
			info = info or {}
			local items = info.Items or {}
			local current = info.Default or items[1]
			local open = false
			local holder = makeBlock(48)
			addPadding(holder, 12, 12, 12, 12)

			local header = mk("TextButton", {
				BackgroundTransparency = 1,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(1, 0, 0, 22),
				ZIndex = 11,
				Parent = holder,
			})

			local titleLabel = mk("TextLabel", {
				BackgroundTransparency = 1,
				Text = info.Text or "Dropdown",
				TextColor3 = self._library.Theme.Text,
				Font = Enum.Font.Gotham,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				Size = UDim2.new(1, -24, 0, 18),
				ZIndex = 11,
				Parent = holder,
			})
			fitText(titleLabel, 14, 11)

			local selected = mk("TextLabel", {
				BackgroundTransparency = 1,
				Text = tostring(current or "Select"),
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				Size = UDim2.new(1, -24, 0, 18),
				ZIndex = 11,
				Parent = holder,
			})

			local listHolder = mk("Frame", {
				BackgroundTransparency = 1,
				Visible = false,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 0),
				ZIndex = 11,
				Parent = holder,
			})
			mk("UIListLayout", {
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = listHolder,
			})

			for _, item in ipairs(items) do
				local opt = mk("TextButton", {
					BackgroundColor3 = self._library.Theme.PanelAlt,
					Text = tostring(item),
					TextColor3 = self._library.Theme.Text,
					Font = Enum.Font.GothamBold,
					TextSize = 13,
					AutoButtonColor = false,
					Size = UDim2.new(1, 0, 0, 32),
					ZIndex = 12,
					Parent = listHolder,
				})
				addCorner(opt, 10)
				addStroke(opt, self._library.Theme.Stroke, 0.45)
				opt.MouseButton1Click:Connect(function()
					current = item
					selected.Text = tostring(current)
					open = false
					listHolder.Visible = false
					if info.Callback then info.Callback(current) end
				end)
			end

			header.MouseButton1Click:Connect(function()
				open = not open
				listHolder.Visible = open
			end)

			return {
				Set = function(_, v)
					current = v
					selected.Text = tostring(current)
				end,
				Get = function() return current end,
			}
		end

