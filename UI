        function Tab:CreateSlider(options)
            local flag = options.Flag or options.Name
            local min = options.Range[1] or 0
            local max = options.Range[2] or 100
            local value = options.CurrentValue or min
            local increment = options.Increment or 1
            Library.Flags[flag] = value

            local sldContainer = CreateElementContainer(options.Name, options.Description)
            sldContainer.Size = UDim2.new(1, 0, 0, 75)

            local ValueLabel = Utility:Create("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -60, 0, 10),
                Size = UDim2.new(0, 45, 0, 16),
                Font = Enum.Font.GothamMedium,
                Text = tostring(value),
                TextColor3 = Library.Theme.Primary,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = sldContainer
            })

            local Track = Utility:Create("Frame", {
                BackgroundColor3 = Library.Theme.Stroke,
                Size = UDim2.new(1, -30, 0, 6),
                Position = UDim2.new(0, 15, 1, -25),
                Parent = sldContainer
            }, { Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local Fill = Utility:Create("Frame", {
                BackgroundColor3 = Library.Theme.Primary,
                Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
                Parent = Track
            }, { Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local Knob = Utility:Create("Frame", {
                BackgroundColor3 = Color3.new(1, 1, 1),
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new(1, -8, 0.5, -8),
                Parent = Fill
            }, { Utility:Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            Effects:ApplyShadow(Knob, 0.3, 8)

            local Interact = Utility:Create("TextButton", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 30), Position = UDim2.new(0, 0, 1, -35), Text = "", Parent = sldContainer })

            local dragging = false

            local function UpdateSlider(input)
                local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local rawValue = min + (pos * (max - min))
                value = Utility:Round(rawValue, string.find(tostring(increment), "%.") and #tostring(increment):split(".")[2] or 0)
                value = math.clamp(math.floor(value / increment + 0.5) * increment, min, max)
                
                Library.Flags[flag] = value
                ValueLabel.Text = tostring(value)
                Utility:Tween(Fill, {Size = UDim2.new((value - min) / (max - min), 0, 1, 0)}, 0.1)

                if options.Callback then options.Callback(value) end
            end

            Interact.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    UpdateSlider(input)
                    Utility:Tween(Knob, {Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(1, -10, 0.5, -10)}, 0.2)
                end
            end)

            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    if dragging then
                        dragging = false
                        Utility:Tween(Knob, {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -8, 0.5, -8)}, 0.2)
                    end
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)

            return {
                Set = function(self, val)
                    value = math.clamp(val, min, max)
                    Library.Flags[flag] = value
                    ValueLabel.Text = tostring(value)
                    Utility:Tween(Fill, {Size = UDim2.new((value - min) / (max - min), 0, 1, 0)}, 0.2)
                end
            }
        end

