	local function applyTheme(presetName: string)
		local preset = THEME_PRESETS[presetName]
		if not preset then return end
		self.Theme = table.clone(preset)
		self.ThemeName = presetName

		main.BackgroundColor3 = self.Theme.Background
		topbar.BackgroundColor3 = self.Theme.Topbar
		sidebar.BackgroundColor3 = self.Theme.Panel
		settingsPanel.BackgroundColor3 = self.Theme.Panel
		indicator.BackgroundColor3 = self.Theme.Accent
		hideBtn.BackgroundColor3 = self.Theme.Accent
		floating.BackgroundColor3 = self.Theme.Accent
		settingsBtn.BackgroundColor3 = self.Theme.PanelAlt
		avatar.Image = safeThumbnail(LocalPlayer.UserId)
		title.TextColor3 = self.Theme.Text
		subtitle.TextColor3 = self.Theme.SubText
		displayName.TextColor3 = self.Theme.Text
		userTag.TextColor3 = self.Theme.SubText
		self:Notify({Text = presetName .. " theme applied", Duration = 2})
	end

	local dragging = false
	local dragStart: Vector3? = nil
	local dragPos: UDim2? = nil
	local dragInput: InputObject? = nil

	local function updateDrag(input)
		if not dragStart or not dragPos then return end
		local delta = input.Position - dragStart
		local newPos = UDim2.new(dragPos.X.Scale, dragPos.X.Offset + delta.X, dragPos.Y.Scale, dragPos.Y.Offset + delta.Y)
		main.Position = newPos
		shadow.Position = UDim2.new(newPos.X.Scale, newPos.X.Offset - 5, newPos.Y.Scale, newPos.Y.Offset - 5)
		self._windowPos = newPos
	end

	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			dragPos = main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	topbar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and dragInput == input then
			updateDrag(input)
		end
	end)

	local floatDragging = false
	local floatStart: Vector3? = nil
	local floatPos: UDim2? = nil
	local floatInput: InputObject? = nil

	local function updateFloating(input)
		if not floatStart or not floatPos then return end
		local delta = input.Position - floatStart
		local newPos = UDim2.new(floatPos.X.Scale, floatPos.X.Offset + delta.X, floatPos.Y.Scale, floatPos.Y.Offset + delta.Y)
		floating.Position = newPos
		self._floatingPos = newPos
	end

	floating.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			floatDragging = true
			floatStart = input.Position
			floatPos = floating.Position
			floatInput = input
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					floatDragging = false
				end
			end)
		end
	end)
	floating.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			floatInput = input
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if floatDragging and floatInput == input then
			updateFloating(input)
		end
	end)

	local function animateToggle(switch, knob, state)
		tween(switch, 0.18, {BackgroundColor3 = state and self.Theme.Accent or self.Theme.Stroke})
		tween(knob, 0.18, {
			Position = state and UDim2.new(1, -25, 0.5, -11) or UDim2.new(0, 3, 0.5, -11),
			BackgroundColor3 = state and self.Theme.Text or Color3.fromRGB(255, 255, 255),
		})
	end

	local function hideWindow()
		self._hidden = true
		floating.Visible = true
		tween(main, 0.14, {BackgroundTransparency = 1})
		tween(shadow, 0.14, {BackgroundTransparency = 1})
		task.delay(0.16, function()
			if self._hidden then
				main.Visible = false
				shadow.Visible = false
			end
		end)
	end

	local function showWindow()
		self._hidden = false
		shadow.Visible = true
		main.Visible = true
		floating.Visible = false
		main.BackgroundTransparency = 1
		shadow.BackgroundTransparency = 1
		tween(main, 0.18, {BackgroundTransparency = 0})
		tween(shadow, 0.18, {BackgroundTransparency = 0.45})
	end

	self.Notify = function(_, info)
		info = info or {}
		local note = mk("Frame", {
			BackgroundColor3 = self.Theme.Panel,
			Size = UDim2.new(0, 280, 0, 64),
			Position = UDim2.new(1, -300, 1, -86),
			ZIndex = 100,
			Parent = root,
		})
		addCorner(note, 12)
		addStroke(note, self.Theme.Stroke, 0.35)

		mk("Frame", {
			BackgroundColor3 = info.Type == "error" and self.Theme.Danger or self.Theme.Accent,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 6, 1, 0),
			ZIndex = 101,
			Parent = note,
		})

		local txt = mk("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 8),
			Size = UDim2.new(1, -24, 1, -16),
			Text = info.Text or "Notification",
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			TextColor3 = self.Theme.Text,
			Font = Enum.Font.Gotham,
			TextSize = 14,
			ZIndex = 101,
			Parent = note,
		})
		fitText(txt, 14, 12)

		tween(note, 0.16, {Position = UDim2.new(1, -300, 1, -96)})
		task.delay(info.Duration or 2.5, function()
			if note.Parent then
				tween(note, 0.16, {Position = UDim2.new(1, -300, 1, -56), BackgroundTransparency = 1})
				task.delay(0.18, function()
					if note.Parent then
						note:Destroy()
					end
				end)
			end
		end)
	end

	local window = {}
	window._library = self

	function window:Show()
		showWindow()
	end

	function window:Hide()
		hideWindow()
	end

	function window:Toggle()
		if self._library._hidden then
			showWindow()
		else
			hideWindow()
		end
	end

	function window:SetTitle(text)
		title.Text = text
		self._library.Title = text
	end

	function window:SetSubtitle(text)
		subtitle.Text = text
		self._library.Subtitle = text
	end

	function window:SetThemePreset(name)
		applyTheme(name)
	end

	function window:SetPositionPreset(name)
		local presets = {
			Center = UDim2.new(0.5, -WINDOW_SIZE.X / 2, 0.5, -WINDOW_SIZE.Y / 2),
			Left = UDim2.new(0.05, 0, 0.5, -WINDOW_SIZE.Y / 2),
			Right = UDim2.new(0.95, -WINDOW_SIZE.X, 0.5, -WINDOW_SIZE.Y / 2),
			Top = UDim2.new(0.5, -WINDOW_SIZE.X / 2, 0.08, 0),
			Bottom = UDim2.new(0.5, -WINDOW_SIZE.X / 2, 0.78, 0),
		}
		local target = presets[name]
		if not target then
			if name == "Custom" then
				self:Notify({Text = "Drag the window anywhere. The position is saved while the UI is open.", Duration = 2})
			end
			return
		end
		self._library._windowPos = target
		tween(main, 0.2, {Position = target})
		tween(shadow, 0.2, {Position = UDim2.new(target.X.Scale, target.X.Offset - 5, target.Y.Scale, target.Y.Offset - 5)})
	end

	function window:CreateTab(tabName)
		local tab = {Name = tabName, Elements = {}}

		local button = mk("TextButton", {
			BackgroundColor3 = self._library.Theme.PanelAlt,
			Text = tabName,
			TextColor3 = self._library.Theme.Text,
			Font = Enum.Font.GothamBold,
			TextSize = 14,
