				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 11,
				Parent = card,
			})
			fitText(t, 14, 11)

			local d = mk("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 0, 0, 22),
				Size = UDim2.new(1, 0, 1, -22),
				Text = info.Text or "A small card for hints, status, or player stats.",
				TextWrapped = true,
				TextColor3 = self._library.Theme.SubText,
				Font = Enum.Font.Gotham,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Top,
				ZIndex = 11,
				Parent = card,
			})
			fitText(d, 12, 10)
			return card
		end

		self._tabs[#self._tabs + 1] = tab
		if not self._activeTab then
			page.Visible = true
			button.BackgroundColor3 = self.Theme.Accent
			self._activeTab = tab
		end
		return tab
	end

	-- Settings content
	addSection("Theme presets")
	addSettingsButton("Purple", function() applyTheme("Purple") end)
	addSettingsButton("Blue", function() applyTheme("Blue") end)
	addSettingsButton("Green", function() applyTheme("Green") end)
	addSettingsButton("Pink", function() applyTheme("Pink") end)

