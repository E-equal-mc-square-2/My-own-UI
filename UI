local DEFAULT_THEME = THEMES.Purple
local DEFAULT_RADIUS = 14

local function mk(className: string, props: {[string]: any}?)
	local inst = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			inst[k] = v
		end
	end
	return inst
end

local function addCorner(parent: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function addStroke(parent: Instance, color: Color3, transparency: number?, thickness: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Transparency = transparency or 0.3
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

local function addPadding(parent: Instance, pad: number)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, pad)
	p.PaddingBottom = UDim.new(0, pad)
	p.PaddingLeft = UDim.new(0, pad)
	p.PaddingRight = UDim.new(0, pad)
	p.Parent = parent
	return p
end

local function tween(inst: Instance, t: number, props: {[string]: any})
	local tw = TweenService:Create(inst, TweenInfo.new(t, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
	tw:Play()
	return tw
end

local function safeGetThumbnail(userId: number)
	local ok, content = pcall(function()
		return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size180x180)
	end)
	if ok then
		return content
	end
	return ""
end

local function defaultButton(parent: Instance, text: string, theme)
	local btn = mk("TextButton", {
		BackgroundColor3 = theme.PanelAlt,
		AutoButtonColor = false,
		Text = text,
		TextColor3 = theme.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		Size = UDim2.new(1, 0, 0, 36),
		ZIndex = 20,
		Parent = parent,
	})
	addCorner(btn, DEFAULT_RADIUS - 5)
	addStroke(btn, theme.Stroke, 0.4)
	return btn
end

