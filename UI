local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local Library = {}

----------------------------------------------------------------
-- THEMES
----------------------------------------------------------------

local Themes = {
    Purple = {
        Background = Color3.fromRGB(18,18,28),
        Topbar = Color3.fromRGB(30,20,50),
        Container = Color3.fromRGB(28,28,40),
        Accent = Color3.fromRGB(170,85,255),
        AccentDark = Color3.fromRGB(120,60,220),
        Text = Color3.fromRGB(255,255,255),
        TextDark = Color3.fromRGB(190,190,210),
        Stroke = Color3.fromRGB(90,70,130)
    }
}

local Theme = Themes.Purple

----------------------------------------------------------------
-- UTILS
----------------------------------------------------------------

local function Create(class, props)
    local obj = Instance.new(class)

    for i,v in pairs(props) do
        obj[i] = v
    end

    return obj
end

local function Corner(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0,radius)
    c.Parent = obj
end

local function Stroke(obj)
    local s = Instance.new("UIStroke")
    s.Color = Theme.Stroke
    s.Thickness = 1
    s.Transparency = 0.25
    s.Parent = obj
end

local function Ripple(button)

    button.MouseButton1Down:Connect(function(x,y)

        local Circle = Create("Frame",{
            Parent = button,
            BackgroundColor3 = Color3.new(1,1,1),
            BackgroundTransparency = 0.7,
            AnchorPoint = Vector2.new(0.5,0.5),
            Position = UDim2.new(0,(x-button.AbsolutePosition.X),0,(y-button.AbsolutePosition.Y)),
            Size = UDim2.new(0,0,0,0),
            ZIndex = button.ZIndex + 1
        })

        Circle.ClipsDescendants = true

        Corner(Circle,999)

        TweenService:Create(
            Circle,
            TweenInfo.new(0.45),
            {
                Size = UDim2.new(0,300,0,300),
                BackgroundTransparency = 1
            }
        ):Play()

        task.delay(0.45,function()
            Circle:Destroy()
        end)

    end)

end

----------------------------------------------------------------
-- WINDOW
----------------------------------------------------------------

function Library:CreateWindow(info)

    local Title = info.Title or "KilometresUI"
    local Subtitle = info.Subtitle or "V4"

    ------------------------------------------------------------
    -- GUI
    ------------------------------------------------------------

    local ScreenGui = Create("ScreenGui",{
        Parent = PlayerGui,
        Name = "KilometresUI",
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        DisplayOrder = 999999
    })

    ------------------------------------------------------------
    -- MAIN
    ------------------------------------------------------------

    local Main = Create("Frame",{
        Parent = ScreenGui,
        BackgroundColor3 = Theme.Background,
        Size = UDim2.new(0,620,0,390),
        Position = UDim2.new(0.5,-310,0.5,-195),
        ZIndex = 5
    })

    Corner(Main,18)
    Stroke(Main)

    ------------------------------------------------------------
    -- TOPBAR
    ------------------------------------------------------------

    local Topbar = Create("Frame",{
        Parent = Main,
        BackgroundColor3 = Theme.Topbar,
        Size = UDim2.new(1,0,0,55),
