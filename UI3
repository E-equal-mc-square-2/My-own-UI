	local function CreateSlider(parent, text, min, max, default, callback, step)
		local value = Clamp(default or min or 0, min or 0, max or 100)
		step = step or 1

		local slider = New("Frame", {
			Parent = parent,
			Size = UDim2.new(1, 0, 0, 64),
			BackgroundColor3 = Theme().Surface2,
			BorderSizePixel = 0,
			ZIndex = 70
		})
		Corner(slider, 12)
		Stroke(slider, Theme().Stroke, 1)

		local label = New("TextLabel", {
			Parent = slider,
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(14, 8),
			Size = UDim2.new(1, -28, 0, 16),
			Text = text,
			TextColor3 = Theme().Text,
			TextSize = 14,
			Font = Enum.Font.GothamMedium,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 71
		})

		local valueLabel = New("TextLabel", {
			Parent = slider,
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, -14, 0, 8),
			Size = UDim2.fromOffset(80, 16),
			Text = tostring(value),
			TextColor3 = Theme().TextDim,
			TextSize = 12,
			Font = Enum.Font.Gotham,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 71
		})

		local bar = New("Frame", {
			Parent = slider,
			Position = UDim2.fromOffset(14, 36),
			Size = UDim2.new(1, -28, 0, 10),
			BackgroundColor3 = Color3.fromRGB(45, 45, 55),
			BorderSizePixel = 0,
			ZIndex = 71
		})
		Corner(bar, 999)

		local fill = New("Frame", {
			Parent = bar,
			Size = UDim2.fromScale(0, 1),
			BackgroundColor3 = Theme().Accent,
			BorderSizePixel = 0,
			ZIndex = 72
		})
		Corner(fill, 999)

		local knob = New("Frame", {
			Parent = bar,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.fromScale(0, 0.5),
			Size = UDim2.fromOffset(18, 18),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel = 0,
			ZIndex = 73
		})
		Corner(knob, 999)

		local dragging = false

		local function SetValue(v, silent)
			v = Clamp(v, min, max)
			if step and step > 0 then
				v = math.floor((v / step) + 0.5) * step
			end
			value = v
			valueLabel.Text = tostring(value)

			local pct = (value - min) / math.max(1, max - min)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			knob.Position = UDim2.new(pct, 0, 0.5, 0)

			if not silent and callback then
				callback(value)
			end
		end

		local function SetFromInput(input)
			local rel = (input.Position.X - bar.AbsolutePosition.X) / math.max(1, bar.AbsoluteSize.X)
			SetValue(min + (max - min) * Clamp(rel, 0, 1))
		end

		bar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				SetFromInput(input)
			end
		end)

		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
				Persist()
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				SetFromInput(input)
			end
		end)

		AddRefresher(function()
			slider.BackgroundColor3 = Theme().Surface2
			label.TextColor3 = Theme().Text
			valueLabel.TextColor3 = Theme().TextDim
			bar.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
			fill.BackgroundColor3 = Theme().Accent
			Stroke(slider, Theme().Stroke, 1)
		end)

		SetValue(value, true)
		return {
			Frame = slider,
			Set = SetValue,
			Get = function()
				return value
			end,
		}
	end

