		SetTheme = function(_, name)
			if Themes[name] then
				updateTheme(name)
				persist()
			end
		end,
		SaveConfig = function()
			persist()
		end,
		LoadConfig = function()
			local fresh = loadConfigFile()
			if fresh and Themes[fresh.Theme or ""] then
				updateTheme(fresh.Theme)
			end
		end,
		Notify = function(_, data)
			data = data or {}
			local holder = ScreenGui:FindFirstChild("NotificationHolder")
			if not holder then
				holder = create("Frame", {
					Name = "NotificationHolder",
					AnchorPoint = Vector2.new(1, 1),
					Position = UDim2.new(1, -16, 1, -16),
					Size = UDim2.fromOffset(isMobile() and 280 or 340, 520),
