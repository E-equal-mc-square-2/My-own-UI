			function section:CreateKeybind(cfg)
				cfg = cfg or {}
				local flag = cfg.Flag or cfg.Name
				local key = cfg.Default or Enum.KeyCode.RightShift
				local listening = false

				local cardK = New("Frame", {
					Parent = holder,
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 0, 56),
				})
				corner(cardK, 14)
				stroke(cardK, theme.Stroke, 1, 0)

				New("TextLabel", {
					Parent = cardK,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(16, 0),
					Size = UDim2.new(1, -120, 1, 0),
					Font = Enum.Font.GothamMedium,
					Text = cfg.Name or "Keybind",
					TextColor3 = theme.Text,
					TextSize = 15,
					TextXAlignment = Enum.TextXAlignment.Left,
				})

				local bindBtn = New("TextButton", {
					Parent = cardK,
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -16, 0.5, 0),
					Size = UDim2.fromOffset(92, 30),
					BackgroundColor3 = theme.Surface,
					BorderSizePixel = 0,
					Text = "",
				})
				corner(bindBtn, 12)
				stroke(bindBtn, theme.Stroke, 1, 0)

				local bindText = New("TextLabel", {
					Parent = bindBtn,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 1, 0),
					Font = Enum.Font.GothamSemibold,
					Text = key.Name,
					TextColor3 = theme.Text,
					TextSize = 12,
				})

				local selfObj = {
					Instance = cardK,
					Value = key,
				}

				function selfObj:Set(v, silent)
					selfObj.Value = v
					bindText.Text = typeof(v) == "EnumItem" and v.Name or tostring(v)
					if not silent and cfg.Callback then
						task.spawn(cfg.Callback, v)
					end
					if flag then
						Library.Flags[flag] = v and v.Name or nil
					end
				end

				function selfObj:Get() return selfObj.Value end
				function selfObj:Destroy() if cardK then cardK:Destroy() end end

				bindBtn.MouseButton1Click:Connect(function()
					listening = true
					bindText.Text = "..."
				end)

				maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
					if processed then
						return
					end
					if listening then
						if input.KeyCode ~= Enum.KeyCode.Unknown then
							listening = false
							selfObj:Set(input.KeyCode)
						end
						return
					end

					if input.KeyCode == selfObj.Value and not Library:IsTyping() then
						if cfg.Callback then
							task.spawn(cfg.Callback, selfObj.Value)
						end
					end
				end))

				if flag then
					section:_registerElement(flag, selfObj)
				end

				selfObj:Set(key, true)
				return selfObj
			end

			table.insert(tab.Sections, section)
			return section
		end

