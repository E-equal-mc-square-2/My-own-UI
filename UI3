local Library = {}

function Library:CreateWindow(cfg)
	cfg = cfg or {}

	local SaveFile = cfg.SaveFile or "KilometresUIX/settings.json"

	local State = {
		ThemeName = cfg.Theme or cfg.DefaultTheme or "Default",
		Width = (cfg.Width or cfg.WindowWidth or 900),
		Height = (cfg.Height or cfg.WindowHeight or 620),
		OffsetX = (cfg.OffsetX or 0),
		OffsetY = (cfg.OffsetY or 0),
		SaveSettings = (cfg.SaveSettings ~= false),
		KeySystem = (cfg.KeySystem == true),
		RequiredKey = cfg.RequiredKey or cfg.Key or "",
		Hidden = false,
		CurrentTab = nil,
		Ready = false,
		Refreshers = {},
	}

	local function CurrentTheme()
		return Themes[State.ThemeName] or Themes.Default
	end

	local function AddRefresher(fn)
		table.insert(State.Refreshers, fn)
	end

	local function RefreshAll()
		for _, fn in ipairs(State.Refreshers) do
			pcall(fn)
		end
	end

	local function Persist()
		if not State.SaveSettings then
			return
		end

		local payload = {
			ThemeName = State.ThemeName,
			Width = State.Width,
			Height = State.Height,
			OffsetX = State.OffsetX,
			OffsetY = State.OffsetY,
			SaveSettings = State.SaveSettings,
			KeySystem = State.KeySystem,
			RequiredKey = State.RequiredKey,
		}

		local encoded = HttpService:JSONEncode(payload)
		TryWriteFile(SaveFile, encoded)
	end

	local function LoadPersisted()
		if not State.SaveSettings then
			return
		end

		local raw = TryReadFile(SaveFile)
		if not raw then
			return
		end

		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(raw)
		end)

		if ok and type(decoded) == "table" then
			if type(decoded.ThemeName) == "string" and Themes[decoded.ThemeName] then
				State.ThemeName = decoded.ThemeName
			end
			if type(decoded.Width) == "number" then State.Width = decoded.Width end
			if type(decoded.Height) == "number" then State.Height = decoded.Height end
			if type(decoded.OffsetX) == "number" then State.OffsetX = decoded.OffsetX end
			if type(decoded.OffsetY) == "number" then State.OffsetY = decoded.OffsetY end
			if type(decoded.SaveSettings) == "boolean" then State.SaveSettings = decoded.SaveSettings end
			if type(decoded.KeySystem) == "boolean" then State.KeySystem = decoded.KeySystem end
			if type(decoded.RequiredKey) == "string" then State.RequiredKey = decoded.RequiredKey end
