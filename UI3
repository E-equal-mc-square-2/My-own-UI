				PaddingLeft = UDim.new(0, 12),
				PaddingRight = UDim.new(0, 12),
				PaddingBottom = UDim.new(0, 12),
				Parent = list,
			})

			local function refreshText()
				label.Text = (data.Name or "Dropdown") .. "  •  " .. tostring(selected)
			end

			for _, opt in ipairs(options) do
				local optButton = create("TextButton", {
					Size = UDim2.new(1, 0, 0, 40),
					BackgroundColor3 = sectionTheme.Surface2,
					BackgroundTransparency = 0.03,
					BorderSizePixel = 0,
					AutoButtonColor = false,
					Text = tostring(opt),
					Font = Enum.Font.GothamMedium,
					TextSize = 13,
					TextColor3 = sectionTheme.SubText,
					ZIndex = 23,
					Parent = list,
				})
				addCorner(optButton, 12)
				addStroke(optButton, sectionTheme.Stroke, 0.96, 1)

				optButton.MouseButton1Click:Connect(function()
					selected = opt
					refreshText()
					open = false
					list.Visible = false
					holder.Size = UDim2.new(1, 0, 0, 48)
					if data.Callback then
						task.spawn(data.Callback, selected)
					end
				end)
			end

			button.MouseButton1Click:Connect(function()
				ripple(holder)
				open = not open
				list.Visible = open
				holder.Size = UDim2.new(1, 0, 0, open and (48 + (math.min(#options, 5) * 48)) or 48)
			end)

			refreshText()
			return {
				Set = function(v)
					selected = v
					refreshText()
				end,
				Get = function()
					return selected
				end,
			}
		end

		return Section
	end

	function Window:CreateTab(tabData)
		if typeof(tabData) == "string" then
			tabData = { Name = tabData }
		end
		tabData = tabData or {}

		local mobile = isMobile()
		local topbarHeightNow, _, _, sidebarScaleNow = layoutSizes()

		local tabButton = create("TextButton", {
			Name = tabData.Name or "Tab",
			Size = UDim2.new(1, 0, 0, mobile and 42 or 44),
			BackgroundColor3 = theme.Surface2,
			BackgroundTransparency = 0.03,
			BorderSizePixel = 0,
			AutoButtonColor = false,
			Text = tabData.Name or "Tab",
			Font = Enum.Font.GothamSemibold,
			TextSize = 14,
			TextColor3 = theme.SubText,
			ZIndex = 30,
			Parent = sidebar,
		})
		addCorner(tabButton, 14)
		addStroke(tabButton, theme.Stroke, 0.92, 1)

		local page = create("ScrollingFrame", {
			Name = tabData.Name or "Page",
			Visible = false,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			CanvasSize = UDim2.new(),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			ScrollBarThickness = 0,
			ScrollBarImageTransparency = 1,
			ZIndex = 16,
			Parent = pagesRoot,
		})

		create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 12),
			Parent = page,
		})

		create("UIPadding", {
			PaddingTop = UDim.new(0, 2),
			PaddingBottom = UDim.new(0, 8),
			PaddingLeft = UDim.new(0, 2),
			PaddingRight = UDim.new(0, 2),
			Parent = page,
		})

		pages[tabButton] = page

		local function selectTab()
			for btn, pg in pairs(pages) do
				if pg then
					pg.Visible = (pg == page)
				end
				if btn and btn.Parent then
					if btn == tabButton then
						tween(btn, { BackgroundColor3 = theme.Accent, TextColor3 = Color3.fromRGB(255, 255, 255) }, 0.22)
					else
						tween(btn, { BackgroundColor3 = theme.Surface2, TextColor3 = theme.SubText }, 0.22)
					end
				end
			end
			activePage = page
			activeTabButton = tabButton
		end

		tabButton.MouseButton1Click:Connect(function()
			ripple(tabButton)
			selectTab()
		end)

		if not activePage then
			selectTab()
		end

		local Tab = {}

		function Tab:CreateSection(sectionData)
			if typeof(sectionData) == "string" then
				sectionData = { Name = sectionData }
			end
			sectionData = sectionData or {}

			local section = create("Frame", {
				Name = sectionData.Name or "Section",
