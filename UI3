	local function centerWindow()
		local viewport = Camera.ViewportSize
		local w, h = main.AbsoluteSize.X, main.AbsoluteSize.Y
		local x = math.floor((viewport.X - w) / 2)
		local y = math.floor((viewport.Y - h) / 2)
		x, y = clampToSafeArea(x, y, w, h, 12)
		main.Position = UDim2.fromOffset(x, y)
	end

	local function refreshLayout()
		setLayoutMode()
		centerWindow()

		for _, tabData in ipairs(window.Tabs) do
			if tabData.Page then
				tabData.Page.Visible = false
			end
		end

		if window.ActiveTab and window.ActiveTab.Page then
			window.ActiveTab.Page.Visible = true
		elseif window.Tabs[1] then
			window.ActiveTab = window.Tabs[1]
			window.ActiveTab.Page.Visible = true
		end
	end

