	local layoutMode = "Landscape"

	local function setLayoutMode()
		local viewport = Camera.ViewportSize
		local portrait = viewport.Y > viewport.X

		if portrait then
			layoutMode = "Portrait"
			navFrame.Position = UDim2.new(0, 14, 0, 14)
			navFrame.Size = UDim2.new(1, -28, 0, self.IsMobile and 56 or 64)
			navLayout.FillDirection = Enum.FillDirection.Horizontal
			navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
			navLayout.VerticalAlignment = Enum.VerticalAlignment.Center

			pages.Position = UDim2.new(0, 14, 0, 84)
			pages.Size = UDim2.new(1, -28, 1, -98)
		else
			layoutMode = "Landscape"
			local sidebarWidth = self.IsMobile and 130 or 250
			navFrame.Position = UDim2.new(0, 14, 0, 14)
			navFrame.Size = UDim2.new(0, sidebarWidth, 1, -28)
			navLayout.FillDirection = Enum.FillDirection.Vertical
			navLayout.HorizontalAlignment = Enum.HorizontalAlignment.Stretch
			navLayout.VerticalAlignment = Enum.VerticalAlignment.Top

			pages.Position = UDim2.new(0, sidebarWidth + 28, 0, 14)
			pages.Size = UDim2.new(1, -(sidebarWidth + 42), 1, -28)
		end

		for _, tabData in ipairs(window.Tabs) do
			local btn = tabData.Button
			if btn then
				if portrait then
					btn.Size = UDim2.new(0, self.IsMobile and 110 or 140, 1, 0)
				else
					btn.Size = UDim2.new(1, 0, 0, self.IsMobile and 42 or 44)
				end
