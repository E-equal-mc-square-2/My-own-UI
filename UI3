	local orbMoved = false
	local orbDragInput = nil
	local orbStart = nil
	local orbStartPos = nil
	local orbDragging = false

	local function snapOrb()
		local vp = viewportSize()
		local x = (Orb.AbsolutePosition.X < vp.X / 2) and 14 or (vp.X - ORB_SIZE - 14)
		local y = math.clamp(Orb.Position.Y.Offset, 14, vp.Y - ORB_SIZE - 14)
		tween(Orb, { Position = UDim2.fromOffset(x, y) }, 0.22):Play()
	end

	connect(Orb.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			orbDragging = true
			orbDragInput = input
			orbStart = input.Position
			orbStartPos = Orb.Position
			orbMoved = false
		end
	end)

	connect(UserInputService.InputChanged, function(input)
		if orbDragging and orbDragInput == input then
			local delta = input.Position - orbStart
			if delta.Magnitude > 6 then orbMoved = true end
			local x = orbStartPos.X.Offset + delta.X
			local y = orbStartPos.Y.Offset + delta.Y
			x, y = clampToScreen(x, y, ORB_SIZE, ORB_SIZE, 14)
			Orb.Position = UDim2.fromOffset(x, y)
		end
	end)

	connect(UserInputService.InputEnded, function(input)
		if orbDragging and (input == orbDragInput or input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			orbDragging = false
			if orbMoved then
				snapOrb()
			else
				opened = not opened
				Main.Visible = opened
				setBlurVisible(opened)
			end
			persist()
		end
	end)

