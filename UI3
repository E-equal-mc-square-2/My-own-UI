local function safeParent()
	if typeof(gethui) == "function" then
		local ok, gui = pcall(gethui)
		if ok and gui then
			return gui
		end
	end
	return PlayerGui or CoreGui
end

local function New(className, props)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			if k ~= "Parent" then
				obj[k] = v
			end
		end
		obj.Parent = props.Parent
	end
	return obj
end

local function tween(obj, props, time, style, direction)
	local info = TweenInfo.new(
		time or 0.18,
		style or Enum.EasingStyle.Quint,
		direction or Enum.EasingDirection.Out
	)
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function corner(parent, radius)
	return New("UICorner", {
		Parent = parent,
		CornerRadius = UDim.new(0, radius or 14),
	})
end

local function stroke(parent, color, thickness, transparency)
	return New("UIStroke", {
		Parent = parent,
		Color = color or Color3.fromRGB(60, 60, 80),
		Thickness = thickness or 1,
		Transparency = transparency or 0,
	})
end

local function padding(parent, px)
	return New("UIPadding", {
		Parent = parent,
		PaddingTop = UDim.new(0, px),
		PaddingBottom = UDim.new(0, px),
		PaddingLeft = UDim.new(0, px),
		PaddingRight = UDim.new(0, px),
	})
end

local function gradient(parent, c1, c2, rotation)
	return New("UIGradient", {
		Parent = parent,
		Rotation = rotation or 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, c1),
			ColorSequenceKeypoint.new(1, c2),
		}),
	})
end

local function isMobile()
	return UserInputService.TouchEnabled and Camera.ViewportSize.X < 900
end

local function getInset()
	return GuiService:GetGuiInset()
end

local function clampToSafeArea(posX, posY, sizeX, sizeY, margin)
	local topLeft, bottomRight = getInset()
	local viewport = Camera.ViewportSize
	margin = margin or 10

	local minX = topLeft.X + margin
	local minY = topLeft.Y + margin
	local maxX = viewport.X - bottomRight.X - sizeX - margin
	local maxY = viewport.Y - bottomRight.Y - sizeY - margin

	if maxX < minX then maxX = minX end
	if maxY < minY then maxY = minY end

	return math.clamp(posX, minX, maxX), math.clamp(posY, minY, maxY)
end

local function ripple(parent, inputPos)
	if not parent or not parent:IsA("GuiObject") then
		return
	end

	local mouse = inputPos or UserInputService:GetMouseLocation()
	local localPos = mouse - parent.AbsolutePosition

	local circle = New("Frame", {
		Parent = parent,
		ZIndex = parent.ZIndex + 20,
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.55,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromOffset(localPos.X, localPos.Y),
		Size = UDim2.fromOffset(0, 0),
		ClipsDescendants = true,
	})
	corner(circle, 999)

	local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.8
	tween(circle, {
		Size = UDim2.fromOffset(size, size),
		BackgroundTransparency = 1,
	}, 0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

	task.delay(0.55, function()
		if circle then
			circle:Destroy()
		end
	end)
end

local function NewSignal()
	local b = Instance.new("BindableEvent")
	local s = {}

	function s:Connect(fn)
		return b.Event:Connect(fn)
	end

	function s:Fire(...)
		b:Fire(...)
	end

	function s:Destroy()
		b:Destroy()
	end

	return s
end

local function NewMaid()
	local self = { Tasks = {} }

	function self:Add(item)
		if item == nil then
			return item
		end
		table.insert(self.Tasks, item)
		return item
	end

	function self:Clean()
		for _, item in ipairs(self.Tasks) do
			local t = typeof(item)
			if t == "RBXScriptConnection" then
				pcall(function() item:Disconnect() end)
			elseif t == "Instance" then
				pcall(function() item:Destroy() end)
			elseif type(item) == "function" then
				pcall(item)
			elseif type(item) == "table" and item.Destroy then
				pcall(function() item:Destroy() end)
			end
		end
		table.clear(self.Tasks)
	end

	return self
end

