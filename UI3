		LandButton.MouseButton1Click:Connect(Click)
		PortButton.MouseButton1Click:Connect(Click)

		AddRefresher(function()
			LandButton.BackgroundColor3 = Data.Active and Theme().Accent or Theme().Surface2
			PortButton.BackgroundColor3 = Data.Active and Theme().Accent or Theme().Surface2
			LandLabel.TextColor3 = Data.Active and Color3.new(1, 1, 1) or Theme().TextDim
			PortLabel.TextColor3 = Data.Active and Color3.new(1, 1, 1) or Theme().TextDim
			Stroke(LandButton, Theme().Stroke, 1)
			Stroke(PortButton, Theme().Stroke, 1)
		end)

		function Tab:CreateSection(title)
			local Section = {Collapsed = false}

			local Holder = New("Frame", {
				Parent = Page,
				BackgroundColor3 = Theme().Surface,
				BorderSizePixel = 0,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, -2, 0, 0),
				ZIndex = 40
			})
			Corner(Holder, 16)
			Stroke(Holder, Theme().Stroke, 1)

			New("UIPadding", {
				Parent = Holder,
				PaddingTop = UDim.new(0, 12),
				PaddingBottom = UDim.new(0, 12),
				PaddingLeft = UDim.new(0, 12),
				PaddingRight = UDim.new(0, 12)
			})

			local HeaderButton = New("TextButton", {
				Parent = Holder,
				Size = UDim2.new(1, 0, 0, 24),
				BackgroundTransparency = 1,
				Text = "",
				AutoButtonColor = false,
				ZIndex = 41
			})

			local Header = New("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -24, 0, 20),
				Text = title,
				TextColor3 = Theme().Text,
				TextSize = 15,
				Font = Enum.Font.GothamBold,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 41
			})

			local Arrow = New("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				AnchorPoint = Vector2.new(1, 0),
				Position = UDim2.new(1, 0, 0, 0),
				Size = UDim2.fromOffset(20, 20),
				Text = "▾",
				TextColor3 = Theme().TextDim,
				TextSize = 16,
				Font = Enum.Font.GothamBold,
				ZIndex = 41
			})

			local Content = New("Frame", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				ZIndex = 41
			})

			New("UIListLayout", {
				Parent = Content,
				Padding = UDim.new(0, 10),
				SortOrder = Enum.SortOrder.LayoutOrder
			})

			New("UIPadding", {
				Parent = Content,
				PaddingTop = UDim.new(0, 10)
			})

			local function RenderCollapsed()
				Content.Visible = not Section.Collapsed
				Arrow.Text = Section.Collapsed and "▸" or "▾"
			end

			HeaderButton.MouseButton1Click:Connect(function()
				Section.Collapsed = not Section.Collapsed
				RenderCollapsed()
			end)

			AddRefresher(function()
				Holder.BackgroundColor3 = Theme().Surface
				Header.TextColor3 = Theme().Text
				Arrow.TextColor3 = Theme().TextDim
				Stroke(Holder, Theme().Stroke, 1)
			end)

			RenderCollapsed()

			function Section:Button(text, callback)
				return CreateButton(Content, text, callback)
			end

			function Section:Toggle(text, default, callback)
				return CreateToggle(Content, text, default, callback)
			end

			function Section:Slider(text, min, max, default, callback, step)
				return CreateSlider(Content, text, min, max, default, callback, step)
			end

			function Section:Textbox(text, placeholder, callback)
				return CreateTextbox(Content, text, placeholder, callback)
			end

			function Section:Dropdown(text, options, default, callback)
				return CreateDropdown(Content, text, options, default, callback)
			end

			function Section:Info(text)
				return CreateInfo(Content, text)
			end

			return Section
		end

		return setmetatable(Tab, {
			__index = function(_, key)
				return Data[key]
			end
		})
	end

	--// REFRESH ALL
	AddRefresher(function()
		local T = Theme()

		Main.BackgroundColor3 = T.Background
		Stroke(Main, T.Stroke, 1)

		Title.TextColor3 = T.Text
		Subtitle.TextColor3 = T.TextDim

		SettingsButton.BackgroundColor3 = T.Surface2
		SettingsButton.TextColor3 = T.Text
		HideButton.BackgroundColor3 = T.Surface2
		HideButton.TextColor3 = T.Text

		LandscapeNav.BackgroundColor3 = T.Surface
		PortraitNav.BackgroundColor3 = T.Surface
		SettingsPanel.BackgroundColor3 = T.Surface

		SettingsTitle.TextColor3 = T.Text
		SettingsClose.BackgroundColor3 = T.Surface2
		SettingsClose.TextColor3 = T.Text

		KeyCard.BackgroundColor3 = T.Surface
		KeyTitle.TextColor3 = T.Text
		KeyInfo.TextColor3 = T.TextDim
		KeyBox.BackgroundColor3 = T.Surface2
		KeyBox.TextColor3 = T.Text
		KeyBox.PlaceholderColor3 = T.TextDim
		KeySubmit.BackgroundColor3 = T.Accent
		KeyStatus.TextColor3 = T.TextDim

		Orb.BackgroundColor3 = T.Accent
	end)

	--// KEY SYSTEM
	local function UnlockUI()
		KeyOverlay.Visible = false
		Main.Visible = true
		UpdateLayout()
	end

	local function TryUnlockWithKey(rawKey)
		rawKey = tostring(rawKey or ""):gsub("^%s+", ""):gsub("%s+$", "")
		if not Base64LooksValid(rawKey) then
			KeyStatus.Text = "Invalid Base64."
			KeyStatus.TextColor3 = Color3.fromRGB(255, 120, 120)
			return false
		end

		if State.RequiredKey ~= "" and rawKey ~= State.RequiredKey then
			KeyStatus.Text = "Wrong key."
			KeyStatus.TextColor3 = Color3.fromRGB(255, 120, 120)
			return false
		end

		KeyStatus.Text = "Accepted."
		KeyStatus.TextColor3 = Color3.fromRGB(120, 255, 160)
		task.wait(0.12)
		UnlockUI()
		Notify("Unlocked", "Welcome back.", 1.8)
		return true
	end

	KeySubmit.MouseButton1Click:Connect(function()
		TryUnlockWithKey(KeyBox.Text)
	end)

	KeyBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			TryUnlockWithKey(KeyBox.Text)
		end
	end)

	if not State.KeySystem then
		KeyOverlay.Visible = false
		Main.Visible = true
	else
		Main.Visible = true
		KeyOverlay.Visible = true
	end

	--// API
	local API = {}

	function API:Notify(title, text, duration)
		Notify(title, text, duration)
	end

	function API:SetTheme(name)
		SetTheme(name)
	end

	function API:Hide()
		SetHidden(true)
	end

	function API:Show()
		SetHidden(false)
	end

	function API:Destroy()
		if Screen then
			Screen:Destroy()
		end
	end

	function API:SetSize(w, h)
		State.Width = Clamp(tonumber(w) or State.Width, 340, 1400)
		State.Height = Clamp(tonumber(h) or State.Height, 260, 900)
		UpdateLayout()
		Persist()
	end

	function API:SetOffset(x, y)
		State.OffsetX = Clamp(tonumber(x) or State.OffsetX, -600, 600)
		State.OffsetY = Clamp(tonumber(y) or State.OffsetY, -400, 400)
		UpdateLayout()
		Persist()
	end

	function API:GetState()
		return {
			ThemeName = State.ThemeName,
			Width = State.Width,
			Height = State.Height,
			OffsetX = State.OffsetX,
			OffsetY = State.OffsetY,
			SaveSettings = State.SaveSettings,
			KeySystem = State.KeySystem,
			RequiredKey = State.RequiredKey,
			Hidden = State.Hidden,
		}
	end

	function API:SetKeySystemEnabled(enabled)
		State.KeySystem = enabled and true or false
		Persist()
	end

	UpdateLayout()
	RefreshAll()

	task.defer(function()
		if #Tabs > 0 and Tabs[1].LandButton then
			Tabs[1].LandButton:Activate()
		end
	end)

	return setmetatable(Library, {
		__index = API
	})
end

