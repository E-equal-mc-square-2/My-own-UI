				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -16, 0.5, 0),
				Size = UDim2.fromOffset(92, 30),
				BackgroundColor3 = theme.Surface,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
			})
			corner(bindBtn, 12)
			stroke(bindBtn, theme.Stroke, 1, 0.95)

			local bindText = New("TextLabel", {
				Parent = bindBtn,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = key.Name,
				TextColor3 = theme.Text,
				TextSize = 12,
			})

			local controller = {
				Instance = card,
				Value = key,
			}

			function controller:Set(v, noCallback)
				self.Value = v
				bindText.Text = typeof(v) == "EnumItem" and v.Name or tostring(v)
				if not noCallback and cfg.Callback then
					task.spawn(cfg.Callback, v)
				end
				if flag then
					Library.Flags[flag] = typeof(v) == "EnumItem" and v.Name or tostring(v)
				end
			end

			function controller:Get()
				return self.Value
			end

			function controller:Destroy()
				if card then
					card:Destroy()
				end
			end

			bindBtn.MouseButton1Click:Connect(function()
				listening = true
				bindText.Text = "..."
			end)

			maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
				if processed then
					return
				end

				if listening then
					if input.KeyCode ~= Enum.KeyCode.Unknown then
						listening = false
						controller:Set(input.KeyCode)
					end
					return
				end

				if input.KeyCode == controller.Value and not Library:IsTyping() then
					if cfg.Callback then
						task.spawn(cfg.Callback, controller.Value)
					end
				end
			end))

			controller:Set(key, true)
			attachElementFlag(flag, controller)
			return controller
		end

		return Section
	end

	--// ======================================================================
	--// Public methods
	--// ======================================================================

	function window:RegisterCommand(name, callback, category)
		Library:RegisterCommand(name, callback, category)
	end

	function window:SetVisible(state)
		self.Visible = state and true or false
		main.Visible = self.Visible
	end

	function window:Destroy()
		maid:Clean()
		if main then main:Destroy() end
		if paletteOverlay then paletteOverlay:Destroy() end
	end

	function window:CreateTab(tabCfg)
		tabCfg = type(tabCfg) == "string" and { Name = tabCfg } or (tabCfg or {})

		local tab = {
			Name = tabCfg.Name or "Tab",
			Icon = tabCfg.Icon,
			Sections = {},
		}

		local tabButton = New("TextButton", {
			Parent = navFrame,
			Size = UDim2.new(1, 0, 0, self.IsMobile and 42 or 44),
			BackgroundColor3 = theme.Surface2,
			BorderSizePixel = 0,
			AutoButtonColor = false,
			Text = "",
		})
		corner(tabButton, 14)
		stroke(tabButton, theme.Stroke, 1, 0)

		local tabLabel = New("TextLabel", {
			Parent = tabButton,
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(16, 0),
			Size = UDim2.new(1, -32, 1, 0),
			Font = Enum.Font.GothamMedium,
			Text = tab.Name,
			TextColor3 = theme.TextDim,
			TextSize = self.IsMobile and 14 or 15,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTransparency = 0,
			ZIndex = 17,
		})

		local page = New("ScrollingFrame", {
			Parent = pages,
			Visible = false,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.fromScale(1, 1),
			CanvasSize = UDim2.new(),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			ScrollBarThickness = 4,
			ScrollBarImageTransparency = 0.35,
		})

		New("UIListLayout", {
			Parent = page,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 12),
		})

		padding(page, 6)

		tab.Button = tabButton
		tab.Label = tabLabel
		tab.Page = page

		function tab:Select()
			window:SelectTab(tab)
		end

		function tab:CreateSection(sectionCfg)
			local section = makeSection(page, sectionCfg)
			table.insert(tab.Sections, section)
			return section
		end

		tabButton.MouseButton1Click:Connect(function()
			ripple(tabButton)
			window:SelectTab(tab)
		end)

		table.insert(window.Tabs, tab)

		task.defer(function()
			refreshLayout()
			if not window.ActiveTab then
				window:SelectTab(tab)
			end
		end)

		return tab
	end

	function window:RefreshLayout()
		refreshLayout()
	end

	Library:OnThemeChanged(function(newTheme)
		if not main or not main.Parent then
			return
		end
		theme = newTheme
		main.BackgroundColor3 = newTheme.Background
		navFrame.BackgroundColor3 = newTheme.Surface
		title.TextColor3 = newTheme.Text
		subtitle.TextColor3 = newTheme.TextDim
		topbarLine.BackgroundColor3 = newTheme.Accent
		mainStroke.Color = newTheme.Stroke
	end)

	maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
		if processed then
			return
		end
		if input.KeyCode == Enum.KeyCode.K and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			window:OpenCommandPalette()
		end
	end))

	maid:Add(Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
		Library.IsMobile = isMobile()
		refreshLayout()
	end))

	if cfg.Theme then
		Library:SetTheme(cfg.Theme)
	end

	if cfg.AutoShow == false then
		main.Visible = false
	end

	table.insert(Library.Windows, window)

	--// Default commands
	window:RegisterCommand("Toggle Palette", function()
		window:OpenCommandPalette()
	end, "System")

	window:RegisterCommand("Toggle Visibility", function()
		window:SetVisible(not window.Visible)
	end, "System")

	window:RegisterCommand("Show Notification", function()
		Library:Notify({
			Title = "Kilometres UI X",
			Content = "Safe-edge mobile framework loaded.",
			Duration = 3,
		})
	end, "System")

	--// Example initial page selection
	task.defer(function()
		refreshLayout()
		if #window.Tabs > 0 then
			window:SelectTab(window.Tabs[1])
		end
	end)

	return window
end

