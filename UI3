	LoadBtn.Parent = SaveCard
	LoadBtn.MouseButton1Click:Connect(function()
		local fresh = loadConfigFile()
		if fresh then
			if Themes[fresh.Theme or ""] then updateTheme(fresh.Theme) end
			if type(fresh.Overlay) == "table" then
				for k, v in pairs(fresh.Overlay) do state.Overlay[k] = v end
			end
			if type(fresh.Performance) == "table" then
				for k, v in pairs(fresh.Performance) do state.Performance[k] = v end
			end
			if type(fresh.Window) == "table" then
				for k, v in pairs(fresh.Window) do state.Window[k] = v end
			end
			if type(fresh.Chat) == "table" then
				for k, v in pairs(fresh.Chat) do state.Chat[k] = v end
				ChatBox.Text = state.Chat.Draft or ""
			end
			if type(fresh.Flags) == "table" then state.Flags = fresh.Flags end
			Overlay.Visible = state.Overlay.Visible
			FPSLabel.Visible = state.Overlay.ShowFPS
