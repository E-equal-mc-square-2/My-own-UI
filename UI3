		Parent = sidebar,
	})

	create("UIListLayout", {
		Padding = UDim.new(0, 10),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = sidebar,
	})

	pagesRoot = create("Frame", {
		Name = "Pages",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(sidebarScale, 0, 0, topbarHeight),
		Size = UDim2.new(1 - sidebarScale, 0, 1, -topbarHeight),
		ZIndex = 15,
		Parent = contentRoot,
	})

	create("UIPadding", {
		PaddingTop = UDim.new(0, 12),
		PaddingLeft = UDim.new(0, 12),
		PaddingRight = UDim.new(0, 12),
		PaddingBottom = UDim.new(0, 12),
		Parent = pagesRoot,
	})

	--// Orb
	orb = create("TextButton", {
		Name = "Orb",
		Size = UDim2.fromOffset(ORB_SIZE, ORB_SIZE),
		Position = UDim2.fromOffset(getViewport().X - 92, getViewport().Y - 150),
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = theme.Surface,
		BackgroundTransparency = 0.05,
		Text = "N",
		Font = Enum.Font.GothamBold,
		TextSize = 20,
		TextColor3 = theme.Text,
		AutoButtonColor = false,
		BorderSizePixel = 0,
		ZIndex = 10000,
		Parent = screenGui,
	})
	addCorner(orb, 999)
	addStroke(orb, theme.Stroke, 0.35, 1.5)

	orbGlow = create("ImageLabel", {
		Name = "Glow",
		BackgroundTransparency = 1,
		Image = GLOW_IMAGE,
		ImageColor3 = theme.Glow,
		ImageTransparency = 0.42,
		Size = UDim2.new(1, 30, 1, 30),
		Position = UDim2.fromScale(0.5, 0.5),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = 9999,
		Parent = orb,
	})
	addGradient(orb, theme.Accent, theme.Accent2, 40)

	--// Orb pulse
	task.spawn(function()
		while screenGui.Parent do
			tween(orbGlow, { ImageTransparency = 0.62, Size = UDim2.new(1, 40, 1, 40) }, 1.1)
			task.wait(1.1)
			if not orb or not orb.Parent then
				break
			end
			tween(orbGlow, { ImageTransparency = 0.42, Size = UDim2.new(1, 30, 1, 30) }, 1.1)
			task.wait(1.1)
		end
	end)

	--// Orb drag and toggle
	do
		local draggingOrb = false
		local orbInput = nil
		local orbStart = nil
		local orbStartPos = nil
		local orbMoved = false

		local function snapOrb()
			if not orb or not orb.Parent then
				return
			end

			local viewport = getViewport()
			local topLeft, bottomRight = getInset()
			local x = orb.Position.X.Offset
			local y = orb.Position.Y.Offset
			local snappedX = (orb.AbsolutePosition.X < viewport.X / 2) and 16 or (viewport.X - ORB_SIZE - 16)
			local clampedY = math.clamp(y, topLeft.Y + 16, viewport.Y - bottomRight.Y - ORB_SIZE - 16)
			tween(orb, { Position = UDim2.fromOffset(snappedX, clampedY) }, 0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
		end

		connect(orb.InputBegan, function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingOrb = true
				orbInput = input
				orbStart = input.Position
				orbStartPos = orb.Position
				orbMoved = false
			end
		end)

		connect(UserInputService.InputChanged, function(input)
			if draggingOrb and orbInput == input then
				local delta = input.Position - orbStart
				if delta.Magnitude > 7 then
					orbMoved = true
				end

				local newX = orbStartPos.X.Offset + delta.X
				local newY = orbStartPos.Y.Offset + delta.Y
				newX, newY = clampPosition(newX, newY, ORB_SIZE, ORB_SIZE, 16)
				orb.Position = UDim2.fromOffset(newX, newY)
			end
		end)

		connect(UserInputService.InputEnded, function(input)
			if draggingOrb and orbInput == input then
				draggingOrb = false
				if orbMoved then
					snapOrb()
				else
					setWindowVisible(not opened)
				end
			end
		end)
	end

	--// Window drag
	do
		local dragging = false
		local dragStart = nil
		local startPos = nil

		connect(topbar.InputBegan, function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = main.Position
			end
		end)

		connect(UserInputService.InputChanged, function(input)
			if dragging and dragStart and startPos then
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					local delta = input.Position - dragStart
					local targetX = startPos.X.Offset + delta.X
					local targetY = startPos.Y.Offset + delta.Y
					local w = main.AbsoluteSize.X
					local h = main.AbsoluteSize.Y
					targetX, targetY = clampPosition(targetX, targetY, w, h, 8)
					main.Position = UDim2.fromOffset(targetX, targetY)
				end
			end
		end)

		connect(UserInputService.InputEnded, function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
				dragging = false
			end
		end)
	end

	--// Window API
	local Window = {
		ScreenGui = screenGui,
		Main = main,
		Themes = Themes,
		CurrentTheme = themeName,
		Open = function()
			setWindowVisible(true)
		end,
		Close = function()
			setWindowVisible(false)
		end,
		Toggle = function()
			setWindowVisible(not opened)
		end,
	}

	function Window:SetTheme(name)
		if Themes[name] then
			applyTheme(name)
			self.CurrentTheme = name
		end
	end

	function Window:Destroy()
		for _, c in ipairs(connections) do
			pcall(function()
				c:Disconnect()
			end)
		end
		if screenGui then
			screenGui:Destroy()
		end
	end

	function Window:Notify(data)
		data = data or {}

		local holder = screenGui:FindFirstChild("NotificationHolder")
		if not holder then
			holder = create("Frame", {
				Name = "NotificationHolder",
				AnchorPoint = Vector2.new(1, 1),
				Position = UDim2.new(1, -16, 1, -16),
				Size = UDim2.fromOffset(isMobile() and 280 or 340, 520),
				BackgroundTransparency = 1,
				ZIndex = 20000,
				Parent = screenGui,
			})

			create("UIListLayout", {
				HorizontalAlignment = Enum.HorizontalAlignment.Right,
				VerticalAlignment = Enum.VerticalAlignment.Bottom,
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 10),
				Parent = holder,
			})
		end

		local note = create("Frame", {
			Size = UDim2.new(1, 0, 0, 78),
			BackgroundColor3 = theme.Surface,
			BackgroundTransparency = 0.04,
			BorderSizePixel = 0,
			ZIndex = 20001,
			Parent = holder,
		})
		addCorner(note, 16)
		addStroke(note, theme.Stroke, 0.78, 1)

		local nTitle = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 14, 0, 10),
			Size = UDim2.new(1, -24, 0, 18),
			Font = Enum.Font.GothamBold,
			Text = data.Title or "Nexora",
			TextColor3 = theme.Text,
			TextSize = 15,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 20002,
			Parent = note,
		})

		local nDesc = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 14, 0, 31),
			Size = UDim2.new(1, -24, 0, 30),
			Font = Enum.Font.Gotham,
			Text = data.Description or "",
			TextColor3 = theme.SubText,
			TextSize = 13,
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			ZIndex = 20002,
			Parent = note,
		})

		local bar = create("Frame", {
			BackgroundColor3 = theme.Accent,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 0, 3),
			Position = UDim2.new(0, 0, 1, -3),
			ZIndex = 20003,
			Parent = note,
		})

		note.Position = UDim2.new(1, 120, 0, 0)
		tween(note, { Position = UDim2.new(0, 0, 0, 0) }, 0.35)
		tween(bar, { Size = UDim2.new(0, 0, 0, 3) }, data.Duration or 4, Enum.EasingStyle.Linear)

		task.delay(data.Duration or 4, function()
			if note and note.Parent then
				tween(note, { BackgroundTransparency = 1 }, 0.25)
				tween(nTitle, { TextTransparency = 1 }, 0.2)
				tween(nDesc, { TextTransparency = 1 }, 0.2)
				tween(bar, { BackgroundTransparency = 1 }, 0.2)
				task.delay(0.25, function()
					if note then
						note:Destroy()
					end
				end)
			end
		end)
	end

	local function setActivePage(page, tabButton)
		for btn, pg in pairs(pages) do
			if pg then
				pg.Visible = (pg == page)
			end
			if btn and btn.Parent then
				if btn == tabButton then
					tween(btn, {
						BackgroundColor3 = theme.Accent,
						TextColor3 = Color3.fromRGB(255, 255, 255),
					}, 0.22)
				else
					tween(btn, {
						BackgroundColor3 = theme.Surface2,
