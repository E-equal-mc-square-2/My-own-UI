				function controller:Set(v, noCallback)
					self.Value = v
					selected = v
					refreshText()

					if not noCallback and cfg.Callback then
						task.spawn(cfg.Callback, v)
					end
					if flag then
						Library.Flags[flag] = v
					end
				end

				function controller:Get()
					return self.Value
				end

				function controller:Destroy()
					if holder then
						holder:Destroy()
					end
				end

				head.MouseButton1Click:Connect(function()
					open = not open
					rebuild()
					list.Visible = open
					chevron.Text = open and "⌃" or "⌄"
					if open then
						holder.Size = UDim2.new(1, 0, 0, 58 + (#options * 48) + 16)
					else
						holder.Size = UDim2.new(1, 0, 0, 58)
					end
					ripple(holder)
				end)

				refreshText()
				Section:_register(flag, controller)
				return controller
			end

			function Section:CreateKeybind(cfg)
				cfg = cfg or {}
				local flag = cfg.Flag or cfg.Name
				local key = cfg.Default or Enum.KeyCode.RightShift
				local listening = false

				local card = New("Frame", {
					Parent = section,
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 0, 56),
				})
				corner(card, 14)
				stroke(card, theme.Stroke, 1, 0.93)

				New("TextLabel", {
					Parent = card,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(14, 0),
					Size = UDim2.new(1, -120, 1, 0),
					Font = Enum.Font.GothamMedium,
					Text = cfg.Name or "Keybind",
					TextColor3 = theme.Text,
					TextSize = 15,
					TextXAlignment = Enum.TextXAlignment.Left,
				})

				local bindBtn = New("TextButton", {
					Parent = card,
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -16, 0.5, 0),
					Size = UDim2.fromOffset(92, 30),
					BackgroundColor3 = theme.Surface,
					BorderSizePixel = 0,
					Text = "",
					AutoButtonColor = false,
				})
				corner(bindBtn, 12)
				stroke(bindBtn, theme.Stroke, 1, 0.95)

				local bindText = New("TextLabel", {
					Parent = bindBtn,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 1, 0),
					Font = Enum.Font.GothamSemibold,
					Text = key.Name,
					TextColor3 = theme.Text,
					TextSize = 12,
				})

				local controller = {
					Instance = card,
					Value = key,
				}

				function controller:Set(v, noCallback)
					self.Value = v
					bindText.Text = typeof(v) == "EnumItem" and v.Name or tostring(v)
					if not noCallback and cfg.Callback then
						task.spawn(cfg.Callback, v)
					end
					if flag then
						Library.Flags[flag] = typeof(v) == "EnumItem" and v.Name or tostring(v)
					end
				end

				function controller:Get()
					return self.Value
				end

				function controller:Destroy()
					if card then
						card:Destroy()
					end
				end

				bindBtn.MouseButton1Click:Connect(function()
					listening = true
					bindText.Text = "..."
				end)

				maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
					if processed then
						return
					end

					if listening then
						if input.KeyCode ~= Enum.KeyCode.Unknown then
							listening = false
							controller:Set(input.KeyCode)
						end
						return
					end

					if input.KeyCode == controller.Value and not Library:IsTyping() then
						if cfg.Callback then
							task.spawn(cfg.Callback, controller.Value)
						end
					end
				end))

				controller:Set(key, true)
				Section:_register(flag, controller)
				return controller
			end

			table.insert(tab.Sections, section)
			return Section
		end

		tabButton.MouseButton1Click:Connect(function()
			ripple(tabButton)
			window:SelectTab(tab)
		end)

		table.insert(window.Tabs, tab)
		return tab
	end

	--// ==================================================================
	--// Window methods
	--// ==================================================================

	function window:RegisterCommand(name, callback, category)
		Library:RegisterCommand(name, callback, category)
	end

	function window:SetVisible(state)
		self.Visible = state and true or false
		if main then
			main.Visible = self.Visible
		end
	end

	function window:Destroy()
		maid:Clean()
		if main then
			main:Destroy()
		end
		if paletteOverlay then
			paletteOverlay:Destroy()
		end
	end

	function window:OpenCommandPalette()
		Library:OpenPalette()
	end

	--// ==================================================================
	--// Safe-edge aware positioning
	--// ==================================================================

	local function centerWindow()
		local insetTopLeft, insetBottomRight = getInset()
		local viewport = Camera.ViewportSize

		local w, h = main.AbsoluteSize.X, main.AbsoluteSize.Y
		local x = math.floor((viewport.X - w) / 2)
		local y = math.floor((viewport.Y - h) / 2)

		x, y = clampToSafeArea(x, y, w, h, 12)
		main.Position = UDim2.fromOffset(x, y)
	end

	local function snapOrb(orb)
		local viewport = Camera.ViewportSize
		local x = orb.Position.X.Offset
		local y = orb.Position.Y.Offset
		local half = viewport.X / 2
		local snappedX = (orb.AbsolutePosition.X < half) and 16 or (viewport.X - 62 - 16)
		local clampedY = clampToSafeArea(snappedX, y, 62, 62, 16)
		tween(orb, {
			Position = UDim2.fromOffset(snappedX, clampedY),
		}, 0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	end

	centerWindow()

	--// Orb controller
	local orb = New("TextButton", {
		Parent = self.Root,
		Name = "Orb",
		Size = UDim2.fromOffset(62, 62),
		Position = UDim2.fromOffset(Camera.ViewportSize.X - 92, Camera.ViewportSize.Y - 150),
		AnchorPoint = Vector2.new(0, 0),
		BackgroundColor3 = theme.Surface,
		BackgroundTransparency = 0.05,
		Text = "N",
		Font = Enum.Font.GothamBold,
		TextSize = 20,
		TextColor3 = theme.Text,
		AutoButtonColor = false,
		BorderSizePixel = 0,
		ZIndex = 10000,
	})
	corner(orb, 999)
	local orbStroke = stroke(orb, theme.Stroke, 1.5, 0.35)
	local orbGlow = New("ImageLabel", {
		Parent = orb,
		Name = "Glow",
		BackgroundTransparency = 1,
		Image = "rbxassetid://4996891970",
		ImageColor3 = theme.Glow,
		ImageTransparency = 0.42,
		Size = UDim2.new(1, 30, 1, 30),
		Position = UDim2.fromScale(0.5, 0.5),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = 9999,
	})
	gradient(orb, theme.Accent, theme.Accent2, 40)

	local opened = true
	local draggingOrb = false
	local orbDragInput = nil
	local orbDragStart = nil
	local orbStartPos = nil
	local orbMoved = false

	local function setWindowVisible(visible)
		opened = visible

		if visible then
			main.Visible = true
			main.BackgroundTransparency = 1
			mainStroke.Transparency = 1
			title.TextTransparency = 1
			subtitle.TextTransparency = 1
			topbarLine.BackgroundTransparency = 1
			bgGlow.ImageTransparency = 1

			tween(main, { BackgroundTransparency = 0.12 }, 0.22)
			tween(mainStroke, { Transparency = 0 }, 0.22)
			tween(title, { TextTransparency = 0 }, 0.18)
			tween(subtitle, { TextTransparency = 0 }, 0.18)
			tween(topbarLine, { BackgroundTransparency = 0.65 }, 0.18)
			tween(bgGlow, { ImageTransparency = 0.6 }, 0.22)
		else
			tween(main, { BackgroundTransparency = 1 }, 0.18)
			tween(mainStroke, { Transparency = 1 }, 0.18)
			tween(title, { TextTransparency = 1 }, 0.12)
			tween(subtitle, { TextTransparency = 1 }, 0.12)
			tween(topbarLine, { BackgroundTransparency = 1 }, 0.12)
			tween(bgGlow, { ImageTransparency = 1 }, 0.15)

			task.delay(0.2, function()
				if not opened and main then
					main.Visible = false
				end
			end)
		end
	end

	orb.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingOrb = true
			orbDragInput = input
			orbDragStart = input.Position
			orbStartPos = orb.Position
			orbMoved = false
		end
	end)

	maid:Add(UserInputService.InputChanged:Connect(function(input)
		if draggingOrb and orbDragInput == input then
			local delta = input.Position - orbDragStart
			if delta.Magnitude > 7 then
				orbMoved = true
			end

			local newX = orbStartPos.X.Offset + delta.X
			local newY = orbStartPos.Y.Offset + delta.Y
			newX, newY = clampToSafeArea(newX, newY, 62, 62, 16)
			orb.Position = UDim2.fromOffset(newX, newY)
		end
	end))

	maid:Add(UserInputService.InputEnded:Connect(function(input)
		if draggingOrb and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
			draggingOrb = false

			if orbMoved then
				snapOrb(orb)
			else
				setWindowVisible(not opened)
			end
		end
	end))

	--// Drag window by topbar
	do
		local draggingWindow = false
		local dragStart = nil
		local startPos = nil

		topbar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				draggingWindow = true
				dragStart = input.Position
				startPos = main.Position
			end
		end)

		maid:Add(UserInputService.InputChanged:Connect(function(input)
			if draggingWindow and dragStart and startPos then
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					local delta = input.Position - dragStart
					local x = startPos.X.Offset + delta.X
					local y = startPos.Y.Offset + delta.Y
					local w = main.AbsoluteSize.X
					local h = main.AbsoluteSize.Y
					x, y = clampToSafeArea(x, y, w, h, 10)
					main.Position = UDim2.fromOffset(x, y)
				end
			end
		end))

		maid:Add(UserInputService.InputEnded:Connect(function(input)
			if draggingWindow and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
				draggingWindow = false
			end
		end))
	end

	--// Command palette init
	maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
		if processed then
			return
		end
		if input.KeyCode == Enum.KeyCode.K and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			window:OpenCommandPalette()
		end
	end))

	--// Theme sync for core visuals
	Library:OnThemeChanged(function(newTheme)
		if not main or not main.Parent then
			return
		end
		theme = newTheme

		main.BackgroundColor3 = newTheme.Background
		sidebar.BackgroundColor3 = newTheme.Surface
		title.TextColor3 = newTheme.Text
		subtitle.TextColor3 = newTheme.TextDim
		topbarLine.BackgroundColor3 = newTheme.Accent
		bgGlow.ImageColor3 = newTheme.Glow
		orb.BackgroundColor3 = newTheme.Surface
		orb.TextColor3 = newTheme.Text
		orbStroke.Color = newTheme.Stroke
	end)

	--// Window palette open methods
	function Library:OpenPalette()
		if window and window.OpenCommandPalette then
			window:OpenCommandPalette()
		end
	end

	--// Theme config
	if cfg.Theme then
		Library:SetTheme(cfg.Theme)
	end

	if cfg.AutoShow == false then
		main.Visible = false
	end

	if cfg.Blur then
		Library:EnableBlur(true)
	end

	table.insert(Library.Windows, window)

	task.defer(function()
		if #window.Tabs > 0 then
			window:SelectTab(window.Tabs[1])
		end
	end)

	--// Provide initial commands
	window:RegisterCommand("Toggle Blur", function()
		local blur = Lighting:FindFirstChild("KilometresUIX_Blur")
		Library:EnableBlur(not blur)
	end, "System")

	window:RegisterCommand("Open Palette", function()
		window:OpenCommandPalette()
	end, "System")

	window:RegisterCommand("Show Notification", function()
		Library:Notify({
			Title = "Kilometres UI X",
			Content = "Safe-edge mobile framework loaded.",
			Duration = 3,
		})
	end, "System")

	Library:Notify({
		Title = cfg.Title or "Kilometres UI X",
		Content = "Loaded successfully.",
		Duration = 4,
	})

	return window
end

