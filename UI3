			create("UIPadding", {
				PaddingTop = UDim.new(0, 14),
				PaddingBottom = UDim.new(0, 14),
				PaddingLeft = UDim.new(0, 14),
				PaddingRight = UDim.new(0, 14),
				Parent = section,
			})

			create("UIListLayout", {
				SortOrder = Enum.SortOrder.LayoutOrder,
				Padding = UDim.new(0, 10),
				Parent = section,
			})

			create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 0),
				Font = Enum.Font.GothamBold,
				Text = sectionData.Name or "Section",
				TextColor3 = theme.Text,
				TextSize = 16,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 18,
				Parent = section,
			})

			if sectionData.Description then
				create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					AutomaticSize = Enum.AutomaticSize.Y,
					Size = UDim2.new(1, 0, 0, 0),
					Font = Enum.Font.Gotham,
					Text = sectionData.Description,
					TextColor3 = theme.SubText,
					TextSize = 12,
					TextWrapped = true,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 18,
					Parent = section,
				})
			end

			return buildSectionAPI(section, theme)
		end

		return Tab
	end

	--// Stabilize on resize / rotation
	connect(RunService.RenderStepped, function()
		refreshMobileScale()
		if not main or not main.Parent then
			return
		end
		if orb and orb.Parent then
			local viewport = getViewport()
			local pos = orb.Position
			local x = pos.X.Offset
			local y = pos.Y.Offset
			x, y = clampPosition(x, y, ORB_SIZE, ORB_SIZE, 16)
			if x ~= pos.X.Offset or y ~= pos.Y.Offset then
				orb.Position = UDim2.fromOffset(x, y)
			end
		end
	end)

	--// Expose API
	local public = Window

	public:Notify({
		Title = settings.Title or "Nexora",
		Description = "Purple adaptive UI loaded successfully.",
		Duration = 4,
	})

	return public
end

return Nexora

