-------------------------------------------------
-- FPS COUNTER
-------------------------------------------------

local Frames = 0
local Last = tick()

RunService.RenderStepped:Connect(function()
    Frames += 1

    if tick() - Last >= 1 then
        FPSLabel.Text = "FPS: "..Frames

        local Ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        PingLabel.Text = "Ping: "..Ping

        CPULabel.Text = "GPU: Mobile"

        Frames = 0
        Last = tick()
    end
end)

