local function SafeParent()
	if gethui then
		local ok, ui = pcall(gethui)
		if ok and ui then
			return ui
		end
	end
	return PlayerGui or CoreGui
end

local function New(class, props)
	local obj = Instance.new(class)
	for i, v in pairs(props or {}) do
		if i ~= "Parent" then
			obj[i] = v
		end
	end
	if props and props.Parent then
		obj.Parent = props.Parent
	end
	return obj
end

local function Corner(obj, radius)
	return New("UICorner", {
		Parent = obj,
		CornerRadius = UDim.new(0, radius or 14)
	})
end

local function Stroke(obj, color, thickness)
	return New("UIStroke", {
		Parent = obj,
		Color = color,
		Thickness = thickness or 1
	})
end

local function Tween(obj, props, speed)
	local tw = TweenService:Create(
		obj,
		TweenInfo.new(speed or 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
		props
	)
	tw:Play()
	return tw
end

local function Clamp(v, mn, mx)
	return math.max(mn, math.min(mx, v))
end

local function IsPortrait()
	local vp = Camera and Camera.ViewportSize or Vector2.new(1280, 720)
	return vp.Y > vp.X
end

local function Base64LooksValid(str)
	if type(str) ~= "string" or str == "" then
		return false
	end

	local cleaned = str:gsub("%s+", "")
	local ok, decoded = pcall(function()
		return HttpService:Base64Decode(cleaned)
	end)
	if not ok or type(decoded) ~= "string" then
		return false
	end

	local re = HttpService:Base64Encode(decoded):gsub("%s+", "")
	return cleaned:gsub("=+$", "") == re:gsub("=+$", "")
end

local function TryReadFile(path)
	if type(isfile) == "function" and isfile(path) and type(readfile) == "function" then
		local ok, data = pcall(readfile, path)
		if ok then
			return data
		end
	end
	return nil
end

local function TryWriteFile(path, data)
	if type(makefolder) == "function" then
		local folder = path:match("^(.*)/[^/]+$")
		if folder and folder ~= "" then
			pcall(function()
				if not isfolder(folder) then
					makefolder(folder)
				end
			end)
		end
	end

	if type(writefile) == "function" then
		pcall(writefile, path, data)
	end
end

