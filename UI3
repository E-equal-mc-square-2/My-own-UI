			function Section:CreateSlider(cfg)
				cfg = cfg or {}
				local flag = cfg.Flag or cfg.Name
				local min = cfg.Min or 0
				local max = cfg.Max or 100
				local increment = cfg.Increment or 1
				local value = cfg.Default or min

				local holder = New("Frame", {
					Parent = section,
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 0, 72),
				})
				corner(holder, 14)
				stroke(holder, theme.Stroke, 1, 0.93)

				New("TextLabel", {
					Parent = holder,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(14, 8),
					Size = UDim2.new(1, -28, 0, 20),
					Font = Enum.Font.GothamMedium,
					Text = cfg.Name or "Slider",
					TextColor3 = theme.Text,
					TextSize = 15,
					TextXAlignment = Enum.TextXAlignment.Left,
				})

				local valueLabel = New("TextLabel", {
					Parent = holder,
					BackgroundTransparency = 1,
					AnchorPoint = Vector2.new(1, 0),
					Position = UDim2.new(1, -14, 0, 8),
					Size = UDim2.fromOffset(90, 20),
					Font = Enum.Font.GothamBold,
					Text = tostring(value),
					TextColor3 = theme.Accent,
					TextSize = 14,
					TextXAlignment = Enum.TextXAlignment.Right,
				})

				local bar = New("Frame", {
					Parent = holder,
					Position = UDim2.fromOffset(14, 42),
					Size = UDim2.new(1, -28, 0, 12),
					BackgroundColor3 = Color3.fromRGB(52, 52, 60),
					BorderSizePixel = 0,
				})
				corner(bar, 999)
				stroke(bar, theme.Stroke, 1, 0.96)

				local fill = New("Frame", {
					Parent = bar,
					Size = UDim2.new(0, 0, 1, 0),
					BackgroundColor3 = theme.Accent,
					BorderSizePixel = 0,
				})
				corner(fill, 999)
				gradient(fill, theme.Accent, theme.Accent2)

				local knob = New("Frame", {
					Parent = bar,
					AnchorPoint = Vector2.new(0.5, 0.5),
					Position = UDim2.new(0, 0, 0.5, 0),
					Size = UDim2.fromOffset(18, 18),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					BorderSizePixel = 0,
				})
				corner(knob, 999)

				local dragging = false
				local controller = {
					Instance = holder,
					Value = value,
				}

				local function apply(v, noCallback)
					v = math.clamp(v, min, max)
					if increment > 0 then
						v = math.floor((v / increment) + 0.5) * increment
					end

					controller.Value = v
					local alpha = (v - min) / math.max((max - min), 0.0001)

					fill.Size = UDim2.new(alpha, 0, 1, 0)
					knob.Position = UDim2.new(alpha, 0, 0.5, 0)
					valueLabel.Text = tostring(v)

					if not noCallback and cfg.Callback then
						task.spawn(cfg.Callback, v)
					end
					if flag then
						Library.Flags[flag] = v
					end
				end

				function controller:Set(v, noCallback)
					apply(v, noCallback)
				end

				function controller:Get()
					return controller.Value
				end

				function controller:Destroy()
					if holder then
						holder:Destroy()
					end
				end

				local function setFromInput(input)
					local x = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
					apply(min + ((max - min) * x))
				end

				bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
						ripple(holder)
						setFromInput(input)
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						setFromInput(input)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end)

				apply(value, true)
				Section:_register(flag, controller)
				return controller
			end

