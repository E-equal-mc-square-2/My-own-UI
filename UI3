-------------------------------------------------
-- SAVE SYSTEM
-------------------------------------------------

function UI:Save()
    if writefile then
        local Data = {
            Theme = UI.Theme,
            Flags = UI.Flags
        }

        writefile(UI.StorageName..".json", HttpService:JSONEncode(Data))
    end
end

function UI:Load()
    if readfile and isfile and isfile(UI.StorageName..".json") then
        local Data = HttpService:JSONDecode(readfile(UI.StorageName..".json"))

        UI.Theme = Data.Theme or "Midnight"
        UI.Flags = Data.Flags or {}
    end
end

UI:Load()

