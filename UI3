				TextColor3 = Theme().Text,
				TextSize = 15,
				Font = Enum.Font.GothamBold,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 41,
			})

			local Arrow = New("TextButton", {
				Parent = HeaderRow,
				AnchorPoint = Vector2.new(1, 0),
				Position = UDim2.new(1, 0, 0, -2),
				Size = UDim2.fromOffset(24, 24),
				BackgroundTransparency = 1,
				Text = "▾",
				TextColor3 = Theme().TextDim,
				TextSize = 16,
				Font = Enum.Font.GothamBold,
				AutoButtonColor = false,
				ZIndex = 41,
			})

			local Content = New("Frame", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				ZIndex = 41,
			})
			New("UIListLayout", {Parent = Content, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder})
			New("UIPadding", {Parent = Content, PaddingTop = UDim.new(0, 2)})

			local function RenderCollapse()
				Content.Visible = not Section.Collapsed
				Arrow.Text = Section.Collapsed and "▸" or "▾"
			end

			Arrow.MouseButton1Click:Connect(function()
				Section.Collapsed = not Section.Collapsed
				RenderCollapse()
			end)

			AddRefresher(function()
				Holder.BackgroundColor3 = Theme().Surface
				Holder.BackgroundTransparency = Theme().SurfaceTransparency
				HeaderTitle.TextColor3 = Theme().Text
				Arrow.TextColor3 = Theme().TextDim
				Stroke(Holder, Theme().Stroke, 1)
			end)

			function Section:Button(text, callback)
				return CreateButton(Content, text, callback)
			end
			function Section:Toggle(text, default, callback)
				return CreateToggle(Content, text, default, callback)
			end
			function Section:Slider(text, min, max, default, callback, step)
				return CreateSlider(Content, text, min, max, default, callback, step)
			end
			function Section:Textbox(text, placeholder, callback)
				return CreateTextbox(Content, text, placeholder, callback)
			end
			function Section:Dropdown(text, options, default, callback)
				return CreateDropdown(Content, text, options, default, callback)
			end
			function Section:Info(text)
				return CreateInfo(Content, text)
			end

			RenderCollapse()
			return Section
		end

		return setmetatable(Tab, {__index = function(_, k) return Data[k] end})
	end

	-- refreshers for top-level colors
	AddRefresher(function()
		local T = Theme()
		Main.BackgroundColor3 = T.Background
		Main.BackgroundTransparency = T.BackgroundTransparency
		Stroke(Main, T.Stroke, 1)
		Topbar.BackgroundTransparency = 1
		SettingsButton.BackgroundColor3 = T.Surface2
		SettingsButton.BackgroundTransparency = T.Surface2Transparency
		SettingsButton.TextColor3 = T.Text
		HideButton.BackgroundColor3 = T.Surface2
		HideButton.BackgroundTransparency = T.Surface2Transparency
		HideButton.TextColor3 = T.Text
		LandscapeNav.BackgroundColor3 = T.Surface
		LandscapeNav.BackgroundTransparency = T.SurfaceTransparency
		PortraitNav.BackgroundColor3 = T.Surface
		PortraitNav.BackgroundTransparency = T.SurfaceTransparency
		SettingsOverlay.BackgroundTransparency = 1
		SettingsPanel.BackgroundColor3 = T.Surface
		SettingsPanel.BackgroundTransparency = T.SurfaceTransparency
		SettingsTitle.TextColor3 = T.Text
		SettingsClose.BackgroundColor3 = T.Surface2
		SettingsClose.BackgroundTransparency = T.Surface2Transparency
		SettingsClose.TextColor3 = T.Text
		Orb.BackgroundColor3 = T.Accent
	end)

	UpdateLayout()
	RefreshAll()
	ClampOffsets()

	task.defer(function()
		if #Tabs > 0 and Tabs[1].LandButton then
			Tabs[1].LandButton:Activate()
		end
	end)

	local API = {}

	function API:Notify(title, text, duration)
		Notify(title, text, duration)
	end

	function API:SetTheme(name)
		SetTheme(name)
	end

	function API:Hide()
		SetHidden(true)
	end

	function API:Show()
		SetHidden(false)
		PageHolder.Visible = true
		if IsPortrait() then
			PortraitNav.Visible = true
		else
			LandscapeNav.Visible = true
		end
	end

	function API:Destroy()
		if Screen then
			Screen:Destroy()
		end
	end

	function API:SetSize(width, height)
		State.Width = Clamp(tonumber(width) or State.Width, 340, 1400)
		State.Height = Clamp(tonumber(height) or State.Height, 260, 900)
		WidthSlider.Set(State.Width)
		HeightSlider.Set(State.Height)
		UpdateLayout()
		Persist()
	end

	function API:GetState()
		return {
			ThemeName = State.ThemeName,
			Width = State.Width,
			Height = State.Height,
			SaveSettings = State.SaveSettings,
			Hidden = State.Hidden,
			Hotkey = State.Hotkey,
		}
	end

	return setmetatable(Library, {__index = API})
end

return Library
