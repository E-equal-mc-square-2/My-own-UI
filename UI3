		ZIndex = 22,
		Parent = topbar,
	})

	--// Sidebar
	sidebar = create("Frame", {
		Name = "Sidebar",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 0, topbarHeight),
		Size = UDim2.new(sidebarScale, 0, 1, -topbarHeight),
		ZIndex = 15,
		Parent = contentRoot,
	})

	create("UIPadding", {
		PaddingLeft = UDim.new(0, 12),
		PaddingRight = UDim.new(0, 12),
