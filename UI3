--// Utilities
local function create(className, props)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	return obj
end

local function tween(obj, props, duration, style, direction)
	local info = TweenInfo.new(
		duration or 0.25,
		style or Enum.EasingStyle.Quint,
		direction or Enum.EasingDirection.Out
	)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

local function isMobile()
	local camera = workspace.CurrentCamera
	return UserInputService.TouchEnabled and camera and camera.ViewportSize.X < MOBILE_BREAKPOINT
end

local function getViewport()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function getInset()
	return GuiService:GetGuiInset()
end

local function addCorner(parent, radius)
	return create("UICorner", {
		CornerRadius = UDim.new(0, radius or 14),
		Parent = parent,
	})
end

local function addStroke(parent, color, transparency, thickness)
	return create("UIStroke", {
		Color = color or Color3.new(1, 1, 1),
		Transparency = transparency or 0.75,
		Thickness = thickness or 1,
		Parent = parent,
	})
end

local function addGradient(parent, c1, c2, rotation)
	return create("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, c1),
			ColorSequenceKeypoint.new(1, c2),
		}),
		Rotation = rotation or 45,
		Parent = parent,
	})
end

local function ripple(parent, inputPos)
	if not parent or not parent:IsA("GuiObject") then
		return
	end

	local mouse = inputPos or UserInputService:GetMouseLocation()
	local localPos = mouse - parent.AbsolutePosition

	local circle = create("Frame", {
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.55,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(0, 0),
		Position = UDim2.fromOffset(localPos.X, localPos.Y),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = parent.ZIndex + 20,
		ClipsDescendants = true,
		Parent = parent,
	})
	addCorner(circle, 999)

	local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.8
	tween(circle, {
		Size = UDim2.fromOffset(size, size),
		BackgroundTransparency = 1,
	}, 0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

	task.delay(0.55, function()
		if circle then
			circle:Destroy()
		end
	end)
end

local function clampPosition(x, y, w, h, margin)
	local topLeft, bottomRight = getInset()
	local viewport = getViewport()
	margin = margin or 10

	local minX = margin
	local minY = topLeft.Y + margin
	local maxX = math.max(minX, viewport.X - w - margin)
	local maxY = math.max(minY, viewport.Y - bottomRight.Y - h - margin)

	return math.clamp(x, minX, maxX), math.clamp(y, minY, maxY)
end

local function bindColor(bindings, obj, prop, theme, key)
	table.insert(bindings, {
		Object = obj,
		Property = prop,
		Key = key,
	})
	obj[prop] = theme[key]
end

--// Main
function Nexora:CreateWindow(settings)
	settings = settings or {}
	local themeName = settings.Theme or "Nova"
	local theme = Themes[themeName] or Themes.Nova

	local screenGui = create("ScreenGui", {
		Name = settings.Name or "Nexora",
		IgnoreGuiInset = true,
		ResetOnSpawn = false,
		ClipToDeviceSafeArea = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Global,
		DisplayOrder = settings.DisplayOrder or DEFAULT_DISPLAY_ORDER,
		Parent = PlayerGui,
	})

	local uiScale = create("UIScale", {
		Scale = isMobile() and 0.93 or 1,
		Parent = screenGui,
	})

	local bindings = {}
	local connections = {}
	local pages = {}
	local activePage = nil
	local activeTabButton = nil
	local opened = true

	local main
	local orb
	local sidebar
	local pagesRoot
	local titleLabel
	local subtitleLabel
	local topbarLine
	local mainStroke
	local shadow
	local orbGlow
	local currentMainSize = nil

	local function connect(signal, fn)
		local c = signal:Connect(fn)
		table.insert(connections, c)
		return c
	end

	local function applyTheme(newThemeName)
		local newTheme = Themes[newThemeName]
		if not newTheme then
			return
		end

		themeName = newThemeName
		theme = newTheme

		for _, item in ipairs(bindings) do
			if item.Object and item.Object.Parent then
				tween(item.Object, {
					[item.Property] = newTheme[item.Key],
				}, 0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
			end
		end
	end

	local function refreshMobileScale()
		uiScale.Scale = isMobile() and 0.93 or 1
	end

	local function layoutSizes()
		local mobile = isMobile()
		local topbarHeight = mobile and 56 or 60
		local windowW = mobile and 0.94 or 0.72
		local windowH = mobile and 0.86 or 0.78
		local sidebarScale = mobile and 0.28 or 0.23
		return topbarHeight, windowW, windowH, sidebarScale
	end

	local function setWindowVisible(visible)
		opened = visible
		if not main then
			return
		end

		local mobile = isMobile()
		local _, windowW, windowH = layoutSizes()
		local targetSize = UDim2.fromScale(windowW, windowH)
		local hiddenSize = UDim2.fromScale(mobile and 0.90 or 0.70, mobile and 0.82 or 0.74)

		if visible then
			main.Visible = true
			main.BackgroundTransparency = 1
			main.Size = hiddenSize
			titleLabel.TextTransparency = 1
			subtitleLabel.TextTransparency = 1
			topbarLine.BackgroundTransparency = 1
			shadow.ImageTransparency = 1
			mainStroke.Transparency = 1

			tween(main, { BackgroundTransparency = 0.12, Size = targetSize }, 0.34)
			tween(titleLabel, { TextTransparency = 0 }, 0.25)
			tween(subtitleLabel, { TextTransparency = 0 }, 0.25)
			tween(topbarLine, { BackgroundTransparency = 0.65 }, 0.25)
			tween(shadow, { ImageTransparency = 0.72 }, 0.3)
			tween(mainStroke, { Transparency = 0.72 }, 0.3)
		else
			tween(main, { BackgroundTransparency = 1, Size = hiddenSize }, 0.25)
			tween(titleLabel, { TextTransparency = 1 }, 0.18)
			tween(subtitleLabel, { TextTransparency = 1 }, 0.18)
			tween(topbarLine, { BackgroundTransparency = 1 }, 0.18)
			tween(shadow, { ImageTransparency = 1 }, 0.22)
			tween(mainStroke, { Transparency = 1 }, 0.18)

			task.delay(0.25, function()
				if not opened and main then
					main.Visible = false
				end
			end)
		end
	end

	--// Main container
	local topbarHeight, windowW, windowH, sidebarScale = layoutSizes()
	main = create("Frame", {
		Name = "Main",
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromScale(windowW, windowH),
		BackgroundColor3 = theme.Surface,
		BackgroundTransparency = 0.12,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		Active = true,
		Visible = true,
		ZIndex = 10,
		Parent = screenGui,
	})
	addCorner(main, WINDOW_CORNER)
	mainStroke = addStroke(main, theme.Stroke, 0.72, 1)
	addGradient(main, theme.Surface, theme.Surface2, 90)

	shadow = create("ImageLabel", {
		Name = "Shadow",
		BackgroundTransparency = 1,
		Image = SHADOW_IMAGE,
		ImageTransparency = 0.72,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(49, 49, 450, 450),
		Size = UDim2.new(1, 60, 1, 60),
		Position = UDim2.fromScale(0.5, 0.5),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ZIndex = 1,
		Parent = main,
	})

	local contentRoot = create("Frame", {
		Name = "ContentRoot",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		ZIndex = 11,
		Parent = main,
	})

	--// Topbar
	topbarHeight = layoutSizes()
	local topbar = create("Frame", {
		Name = "Topbar",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, topbarHeight),
		ZIndex = 20,
		Parent = contentRoot,
	})

	topbarLine = create("Frame", {
		Name = "Line",
		BackgroundTransparency = 0.65,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 1),
		Position = UDim2.new(0, 0, 1, -1),
		ZIndex = 21,
		Parent = topbar,
