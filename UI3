			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = Orb.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)

		Orb.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if input == dragInput and dragging and startPos then
				local delta = input.Position - dragStart
				Orb.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end
		end)
	end

	--// RESIZE / POS
	local function UpdateLayout()
		local vp = Camera and Camera.ViewportSize or Vector2.new(1280, 720)
		State.Width = Clamp(State.Width, 340, math.max(340, vp.X - 20))
		State.Height = Clamp(State.Height, 260, math.max(260, vp.Y - 20))

		Main.Size = UDim2.fromOffset(State.Width, State.Height)
		Main.Position = UDim2.new(0.5, State.OffsetX, 0.5, State.OffsetY)

		local portrait = IsPortrait()
		if portrait then
			LandscapeNav.Visible = false
			PortraitNav.Visible = true
			PortraitNav.Position = UDim2.new(0, 10, 0, 68)
			PortraitNav.Size = UDim2.new(1, -20, 0, 54)

			PageHolder.Position = UDim2.new(0, 10, 0, 132)
			PageHolder.Size = UDim2.new(1, -20, 1, -142)

			SettingsPanel.Position = UDim2.new(0, 10, 0, 132)
			SettingsPanel.Size = UDim2.new(1, -20, 1, -142)
		else
			LandscapeNav.Visible = true
			PortraitNav.Visible = false
			LandscapeNav.Position = UDim2.new(0, 12, 0, 68)
			LandscapeNav.Size = UDim2.new(0, 220, 1, -80)

			PageHolder.Position = UDim2.new(0, 244, 0, 68)
			PageHolder.Size = UDim2.new(1, -256, 1, -80)

			SettingsPanel.Position = UDim2.new(0, 244, 0, 68)
			SettingsPanel.Size = UDim2.new(1, -256, 1, -80)
		end

		if State.Hidden then
			Main.Visible = false
			SettingsPanel.Visible = false
			Orb.Visible = true
		end
	end

	Camera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateLayout)

