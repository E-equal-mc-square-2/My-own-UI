--////////////////////////////////////////////////////////////
-- Helpers
--////////////////////////////////////////////////////////////

local function create(className, props)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	return obj
end

local function tween(obj, props, duration, style, direction)
	return TweenService:Create(
		obj,
		TweenInfo.new(duration or 0.24, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out),
		props
	)
end

local function isMobile()
	local camera = workspace.CurrentCamera
	return UserInputService.TouchEnabled and camera and camera.ViewportSize.X < MOBILE_BREAKPOINT
end

local function viewportSize()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function guiInset()
	return GuiService:GetGuiInset()
end

local function corner(parent, radius)
	return create("UICorner", { CornerRadius = UDim.new(0, radius or 14), Parent = parent })
end

local function stroke(parent, color, transparency, thickness)
	return create("UIStroke", {
		Color = color or Color3.new(1, 1, 1),
		Transparency = transparency or 0.8,
		Thickness = thickness or 1,
		Parent = parent,
	})
end

local function gradient(parent, c1, c2, rotation)
	return create("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, c1),
			ColorSequenceKeypoint.new(1, c2),
		}),
		Rotation = rotation or 45,
		Parent = parent,
	})
end

local function ripple(parent, inputPos)
	if not parent or not parent:IsA("GuiObject") then return end
	local mouse = inputPos or UserInputService:GetMouseLocation()
	local localPos = mouse - parent.AbsolutePosition

	local blob = create("Frame", {
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.62,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(0, 0),
		Position = UDim2.fromOffset(localPos.X, localPos.Y),
		AnchorPoint = Vector2.new(0.5, 0.5),
		ClipsDescendants = true,
		ZIndex = parent.ZIndex + 20,
		Parent = parent,
	})
	corner(blob, 999)

	local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.9
	tween(blob, {
		Size = UDim2.fromOffset(size, size),
		BackgroundTransparency = 1,
	}, 0.5):Play()

	task.delay(0.55, function()
		if blob then blob:Destroy() end
	end)
end

local function clampToScreen(x, y, w, h, margin)
	local topLeft, bottomRight = guiInset()
	local vp = viewportSize()
	margin = margin or 10
	local minX = margin
	local minY = topLeft.Y + margin
	local maxX = math.max(minX, vp.X - w - margin)
	local maxY = math.max(minY, vp.Y - bottomRight.Y - h - margin)
	return math.clamp(x, minX, maxX), math.clamp(y, minY, maxY)
end

local function safeDisconnect(conn)
	if conn then
		pcall(function() conn:Disconnect() end)
	end
end

local function readPing()
	local ok, value = pcall(function()
		return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
	end)
	if ok and type(value) == "number" then
		return math.floor(value)
	end
	return nil
end

local function trySendChat(text)
	if type(text) ~= "string" or text == "" then return false, "empty" end
	local channels = TextChatService:FindFirstChild("TextChannels")
	if not channels then return false, "chat unavailable" end
	local general = channels:FindFirstChild("RBXGeneral")
	if not general then return false, "general channel missing" end
	local ok, err = pcall(function()
		general:SendAsync(text)
	end)
	return ok, err
end

local function getFrameTimeMs(delta)
	return math.floor((delta * 1000) + 0.5)
end

--////////////////////////////////////////////////////////////
-- Persistence
--////////////////////////////////////////////////////////////

local function makeSaveable(state)
	return {
		Theme = state.Theme,
		Overlay = state.Overlay,
		Performance = state.Performance,
		Window = state.Window,
		Chat = state.Chat,
		Flags = state.Flags,
	}
end

local function loadConfigFile()
	if readfile and isfile and isfile(STORAGE_NAME) then
		local ok, data = pcall(function()
			return HttpService:JSONDecode(readfile(STORAGE_NAME))
		end)
		if ok and type(data) == "table" then
			return data
		end
	end
	return nil
end

local function saveConfigFile(data)
	if writefile then
		pcall(function()
			writefile(STORAGE_NAME, HttpService:JSONEncode(data))
		end)
	end
end

