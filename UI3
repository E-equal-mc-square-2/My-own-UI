				BorderSizePixel = 0,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, -2, 0, 0),
				ZIndex = 40
			})
			Corner(Holder, 16)
			Stroke(Holder, CurrentTheme().Stroke, 1)

			New("UIPadding", {
				Parent = Holder,
				PaddingTop = UDim.new(0, 14),
				PaddingBottom = UDim.new(0, 14),
				PaddingLeft = UDim.new(0, 14),
				PaddingRight = UDim.new(0, 14)
			})

			New("UIListLayout", {
				Parent = Holder,
				Padding = UDim.new(0, 10),
				SortOrder = Enum.SortOrder.LayoutOrder
			})

			local Header = New("TextLabel", {
				Parent = Holder,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 20),
				Text = title,
				TextColor3 = CurrentTheme().Text,
				TextSize = 15,
				Font = Enum.Font.GothamBold,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 41
			})

			AddRefresher(function()
				local T = CurrentTheme()
				Holder.BackgroundColor3 = T.Surface
				Header.TextColor3 = T.Text
				Stroke(Holder, T.Stroke, 1)
			end)

			function Section:Button(text, callback)
				return CreateButton(Holder, text, callback)
			end

			function Section:Toggle(text, default, callback)
				return CreateToggle(Holder, text, default, callback)
			end

			function Section:Slider(text, min, max, default, callback, step)
				return CreateSlider(Holder, text, min, max, default, callback, step)
			end

			function Section:Textbox(text, placeholder, callback)
				return CreateTextbox(Holder, text, placeholder, callback)
			end

			return Section
		end

		function SectionEnd()
			-- no-op placeholder
		end

		return setmetatable(Tab, {
			__index = function(_, key)
				return Data[key]
			end
		})
	end

	--// FINAL THEME REFRESH
	AddRefresher(function()
		local T = CurrentTheme()
		Stroke(Main, T.Stroke, 1)
		Stroke(KeyCard, T.Stroke, 1)
		Stroke(KeyBox, T.Stroke, 1)
		Stroke(KeySubmit, T.Stroke, 0)
		Stroke(SettingsPanel, T.Stroke, 1)
		Stroke(SettingsClose, T.Stroke, 1)
		Stroke(LandscapeNav, T.Stroke, 1)
		Stroke(PortraitNav, T.Stroke, 1)

		Main.BackgroundColor3 = T.Background
		LandscapeNav.BackgroundColor3 = T.Surface
		PortraitNav.BackgroundColor3 = T.Surface
		SettingsPanel.BackgroundColor3 = T.Surface

		Title.TextColor3 = T.Text
		Subtitle.TextColor3 = T.TextDim
		SettingsTitle.TextColor3 = T.Text
		SettingsClose.BackgroundColor3 = T.Surface2
		SettingsClose.TextColor3 = T.Text
		SettingsButton.BackgroundColor3 = T.Surface2
		SettingsButton.TextColor3 = T.Text
		HideButton.BackgroundColor3 = T.Surface2
		HideButton.TextColor3 = T.Text

		KeyCard.BackgroundColor3 = T.Surface
		KeyTitle.TextColor3 = T.Text
		KeyInfo.TextColor3 = T.TextDim
		KeyBox.BackgroundColor3 = T.Surface2
		KeyBox.TextColor3 = T.Text
		KeyBox.PlaceholderColor3 = T.TextDim
		KeySubmit.BackgroundColor3 = T.Accent
		KeySubmit.TextColor3 = Color3.new(1, 1, 1)
		KeyStatus.TextColor3 = T.TextDim

		Orb.BackgroundColor3 = T.Accent

		ThemeSection.BackgroundColor3 = T.Surface2
		LayoutSection.BackgroundColor3 = T.Surface2
		MiscSection.BackgroundColor3 = T.Surface2

		ThemeHeader.TextColor3 = T.Text
		LayoutHeader.TextColor3 = T.Text
		MiscHeader.TextColor3 = T.Text
	end)

	--// APPLY INITIAL VALUES
	UpdateLayout()
	RefreshAll()

	--// FIRST TAB AUTO SELECT
	task.defer(function()
		if #Tabs > 0 and Tabs[1].LandButton then
			Tabs[1].LandButton.MouseButton1Click:Fire()
		end
	end)

	--// MAKE THE WINDOW SAFE ON LOAD
	SetHidden(false)

	--// EXTERNAL API
	local API = {}

	function API:Destroy()
		if Screen then
			Screen:Destroy()
		end
	end

	function API:SetTheme(name)
		SetTheme(name)
	end

	function API:Show()
		SetHidden(false)
	end

	function API:Hide()
		SetHidden(true)
	end

	function API:GetState()
		return {
			ThemeName = State.ThemeName,
			Width = State.Width,
			Height = State.Height,
			OffsetX = State.OffsetX,
			OffsetY = State.OffsetY,
			SaveSettings = State.SaveSettings,
			KeySystem = State.KeySystem,
			RequiredKey = State.RequiredKey,
			Hidden = State.Hidden,
		}
	end

	function API:SetSize(width, height)
		State.Width = Clamp(tonumber(width) or State.Width, 340, 1400)
		State.Height = Clamp(tonumber(height) or State.Height, 260, 900)
		WidthSlider.Set(State.Width)
		HeightSlider.Set(State.Height)
		UpdateLayout()
		Persist()
	end

	function API:SetOffset(x, y)
		State.OffsetX = Clamp(tonumber(x) or State.OffsetX, -600, 600)
		State.OffsetY = Clamp(tonumber(y) or State.OffsetY, -400, 400)
		XOffsetSlider.Set(State.OffsetX)
		YOffsetSlider.Set(State.OffsetY)
		UpdateLayout()
		Persist()
	end

	function API:SetKeySystemEnabled(enabled)
		State.KeySystem = enabled and true or false
		Persist()
	end

	if cfg.AutoOpenSettings == true then
		SettingsPanel.Visible = true
	end

	return setmetatable(Library, {
		__index = API
	})
end

