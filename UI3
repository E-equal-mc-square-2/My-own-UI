			Position = UDim2.fromOffset(14, 0),
			Size = UDim2.new(1, -80, 1, 0),
			Text = text,
			TextColor3 = Theme().Text,
			TextSize = 14,
			Font = Enum.Font.GothamMedium,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 71
		})

		local valueLabel = New("TextLabel", {
			Parent = wrap,
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, -14, 0.5, 0),
			Size = UDim2.fromOffset(180, 20),
			Text = tostring(options[index] or ""),
			TextColor3 = Theme().TextDim,
			TextSize = 13,
			Font = Enum.Font.Gotham,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 71
		})

		wrap.MouseButton1Click:Connect(function()
			if #options == 0 then return end
			index += 1
			if index > #options then
				index = 1
			end
			valueLabel.Text = tostring(options[index])
			if callback then
				callback(options[index], index)
			end
			Persist()
		end)

		AddRefresher(function()
			wrap.BackgroundColor3 = Theme().Surface2
			label.TextColor3 = Theme().Text
			valueLabel.TextColor3 = Theme().TextDim
			Stroke(wrap, Theme().Stroke, 1)
		end)

		return {
			Frame = wrap,
			Get = function() return options[index] end,
			Set = function(v)
				for i, opt in ipairs(options) do
					if opt == v then
						index = i
						valueLabel.Text = tostring(v)
						break
					end
				end
			end
		}
	end

