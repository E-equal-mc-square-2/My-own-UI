	-- Safe-edge clamp for dragging: keeps the window inside the screen.
	local function ClampOffsets()
		local vp = Camera and Camera.ViewportSize or Vector2.new(1280, 720)
		local margin = 10
		local maxX = math.floor(vp.X / 2 - margin - State.Width / 2)
		local maxY = math.floor(vp.Y / 2 - margin - State.Height / 2)
		local minX = -maxX
		local minY = -maxY
		State.OffsetX = Clamp(State.OffsetX, minX, maxX)
		State.OffsetY = Clamp(State.OffsetY, minY, maxY)
		Main.Position = UDim2.new(0.5, State.OffsetX, 0.5, State.OffsetY)
	end

	do
		local dragging = false
		local dragInput, dragStart, startOffsetX, startOffsetY

		Topbar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startOffsetX = State.OffsetX
				startOffsetY = State.OffsetY
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
						Persist()
					end
				end)
			end
		end)

		Topbar.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and input == dragInput and dragStart then
				local delta = input.Position - dragStart
				State.OffsetX = (startOffsetX or 0) + delta.X
				State.OffsetY = (startOffsetY or 0) + delta.Y
				ClampOffsets()
			end
		end)
	end

