		function Section:CreateToggle(data)
			if typeof(data) == "string" then
				data = { Name = data }
			end
			data = data or {}

			local enabled = data.Default or false

			local holder = create("Frame", {
				Name = data.Name or "Toggle",
				BackgroundColor3 = sectionTheme.Surface,
				BackgroundTransparency = 0.03,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 54),
				ZIndex = 20,
				Parent = section,
			})
			addCorner(holder, 14)
			addStroke(holder, sectionTheme.Stroke, 0.93, 1)

			create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(1, -100, 1, 0),
				Font = Enum.Font.GothamSemibold,
				Text = data.Name or "Toggle",
				TextColor3 = sectionTheme.Text,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 21,
				Parent = holder,
			})

			if data.Description then
				create("TextLabel", {
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					Position = UDim2.new(0, 14, 0, 24),
					Size = UDim2.new(1, -100, 0, 18),
					Font = Enum.Font.Gotham,
					Text = data.Description,
					TextColor3 = sectionTheme.SubText,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 21,
					Parent = holder,
				})
			end

			local track = create("Frame", {
				AnchorPoint = Vector2.new(1, 0.5),
				Position = UDim2.new(1, -14, 0.5, 0),
				Size = UDim2.fromOffset(52, 28),
				BackgroundColor3 = sectionTheme.Surface2,
				BorderSizePixel = 0,
				ZIndex = 21,
				Parent = holder,
			})
			addCorner(track, 999)
			addStroke(track, sectionTheme.Stroke, 0.96, 1)

			local knob = create("Frame", {
				Size = UDim2.fromOffset(22, 22),
				Position = UDim2.new(0, 3, 0.5, -11),
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				ZIndex = 22,
				Parent = track,
			})
			addCorner(knob, 999)

			local function refresh(noCallback)
				if enabled then
					tween(track, { BackgroundColor3 = sectionTheme.Accent }, 0.2)
					tween(knob, { Position = UDim2.new(1, -25, 0.5, -11) }, 0.22)
				else
					tween(track, { BackgroundColor3 = sectionTheme.Surface2 }, 0.2)
					tween(knob, { Position = UDim2.new(0, 3, 0.5, -11) }, 0.22)
				end

				if data.Callback and not noCallback then
					task.spawn(data.Callback, enabled)
				end
			end

			holder.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					enabled = not enabled
					refresh(false)
				end
			end)

			refresh(true)
			return {
				Set = function(v)
					enabled = not not v
					refresh(false)
				end,
				Get = function()
					return enabled
				end,
			}
		end

		function Section:CreateSlider(data)
			if typeof(data) == "string" then
				data = { Name = data }
			end
			data = data or {}

			local min = data.Min or 0
			local max = data.Max or 100
			local value = data.Default or min

			local holder = create("Frame", {
				BackgroundColor3 = sectionTheme.Surface,
				BackgroundTransparency = 0.03,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 72),
				ZIndex = 20,
				Parent = section,
			})
			addCorner(holder, 14)
			addStroke(holder, sectionTheme.Stroke, 0.93, 1)

			create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 0),
				Size = UDim2.new(1, -28, 0, 20),
				Font = Enum.Font.GothamSemibold,
				Text = data.Name or "Slider",
				TextColor3 = sectionTheme.Text,
				TextSize = 14,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 21,
				Parent = holder,
			})

			local valueText = create("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				AnchorPoint = Vector2.new(1, 0),
				Position = UDim2.new(1, -14, 0, 0),
				Size = UDim2.new(0, 100, 0, 20),
				Font = Enum.Font.Gotham,
				Text = tostring(value),
				TextColor3 = sectionTheme.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				ZIndex = 21,
				Parent = holder,
			})

			local bar = create("Frame", {
				BackgroundColor3 = sectionTheme.Surface2,
				BorderSizePixel = 0,
				Position = UDim2.new(0, 14, 0, 40),
				Size = UDim2.new(1, -28, 0, 12),
				ZIndex = 21,
				Parent = holder,
			})
			addCorner(bar, 999)
			addStroke(bar, sectionTheme.Stroke, 0.96, 1)

			local fill = create("Frame", {
				BackgroundColor3 = sectionTheme.Accent,
				BorderSizePixel = 0,
				Size = UDim2.fromScale(0, 1),
				ZIndex = 22,
				Parent = bar,
			})
			addCorner(fill, 999)

			local knob = create("Frame", {
				AnchorPoint = Vector2.new(0.5, 0.5),
				Position = UDim2.fromScale(0, 0.5),
				Size = UDim2.fromOffset(18, 18),
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0,
				ZIndex = 23,
				Parent = bar,
			})
			addCorner(knob, 999)

			local dragging = false

			local function setValue(v, silent)
				v = math.clamp(v, min, max)
				value = math.floor(v * 100) / 100
				local alpha = (value - min) / math.max(max - min, 0.0001)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				knob.Position = UDim2.new(alpha, 0, 0.5, 0)
				valueText.Text = tostring(value)

				if data.Callback and not silent then
					task.spawn(data.Callback, value)
				end
			end

			local function setFromInput(input)
				local x = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
				setValue(min + ((max - min) * x))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					setFromInput(input)
				end
			end)

			connect(UserInputService.InputChanged, function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					setFromInput(input)
				end
			end)

			connect(UserInputService.InputEnded, function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
					dragging = false
				end
			end)

			setValue(value, true)
			return {
				Set = function(v)
					setValue(v, false)
				end,
				Get = function()
					return value
				end,
			}
		end

		function Section:CreateDropdown(data)
