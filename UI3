	local content = New("TextLabel", {
		Parent = notif,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(16, 34),
		Size = UDim2.new(1, -28, 0, 34),
		AutomaticSize = Enum.AutomaticSize.Y,
