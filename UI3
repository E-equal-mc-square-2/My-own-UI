	local Window = {
		ScreenGui = ScreenGui,
		Main = Main,
		Overlay = Overlay,
		SettingsPanel = SettingsPanel,
		Themes = Themes,
		CurrentTheme = state.Theme,
		Open = function() setWindowVisible(true) end,
		Close = function() setWindowVisible(false) end,
