		end

		local q = string.lower(paletteBox.Text or "")
		for _, item in ipairs(self.Commands) do
			local hay = string.lower(item.Name .. " " .. (item.Category or ""))
			if q == "" or string.find(hay, q, 1, true) then
				local row = New("TextButton", {
					Parent = paletteResults,
					Size = UDim2.new(1, -2, 0, 50),
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
