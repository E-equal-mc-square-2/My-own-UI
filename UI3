UI.Tabs = {}

function UI:CreateTab(Name)
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(1,-20,0,45)
    TabButton.Position = UDim2.new(0,10,0,0)
    TabButton.Text = Name
    TabButton.Font = Enum.Font.GothamBold
    TabButton.TextSize = 15
    TabButton.BackgroundColor3 = UI.Themes[UI.Theme].Background
    TabButton.TextColor3 = UI.Themes[UI.Theme].Text
    TabButton.Parent = Sidebar

    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0,12)
    ButtonCorner.Parent = TabButton

    local TabFrame = Instance.new("ScrollingFrame")
    TabFrame.Size = UDim2.new(1,0,1,0)
    TabFrame.CanvasSize = UDim2.new(0,0,5,0)
    TabFrame.ScrollBarThickness = 0
    TabFrame.BackgroundTransparency = 1
    TabFrame.Visible = false
    TabFrame.Parent = Content

    local Layout = Instance.new("UIListLayout")
    Layout.Padding = UDim.new(0,10)
    Layout.Parent = TabFrame

    UI.Tabs[Name] = TabFrame

    TabButton.MouseButton1Click:Connect(function()
        for _,v in pairs(UI.Tabs) do
            v.Visible = false
        end

        TabFrame.Visible = true

        TweenService:Create(TabButton,TweenInfo.new(0.25),{
            BackgroundColor3 = UI.Themes[UI.Theme].Accent
        }):Play()
    end)

    return TabFrame
end

