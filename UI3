	local function closePalette()
		window.PaletteOpen = false
		paletteOverlay.Visible = false
		paletteBox.Text = ""
	end

	local function refreshPalette()
		for _, child in ipairs(paletteResults:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end

		local q = string.lower(paletteBox.Text or "")
		for _, item in ipairs(self.Commands) do
			local hay = string.lower(item.Name .. " " .. (item.Category or ""))
			if q == "" or string.find(hay, q, 1, true) then
				local row = New("TextButton", {
					Parent = paletteResults,
					Size = UDim2.new(1, -2, 0, 50),
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
					Text = "",
					ZIndex = 52,
				})
				corner(row, 14)
				stroke(row, theme.Stroke, 1, 0)

				New("TextLabel", {
					Parent = row,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(14, 7),
					Size = UDim2.new(1, -28, 0, 18),
					Font = Enum.Font.GothamSemibold,
					Text = item.Name,
					TextColor3 = theme.Text,
					TextSize = 14,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 53,
				})

				New("TextLabel", {
					Parent = row,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(14, 26),
					Size = UDim2.new(1, -28, 0, 16),
					Font = Enum.Font.Gotham,
					Text = item.Category or "General",
					TextColor3 = theme.TextDim,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 53,
				})

				row.MouseButton1Click:Connect(function()
					closePalette()
					if item.Callback then
						pcall(item.Callback)
					end
				end)

				row.MouseEnter:Connect(function()
					tween(row, { BackgroundColor3 = theme.Accent }, 0.12)
				end)
				row.MouseLeave:Connect(function()
					tween(row, { BackgroundColor3 = theme.Surface2 }, 0.12)
				end)
			end
		end
	end

	maid:Add(paletteBox:GetPropertyChangedSignal("Text"):Connect(refreshPalette))
	maid:Add(UserInputService.InputBegan:Connect(function(input, processed)
		if processed then
			return
		end
		if input.KeyCode == Enum.KeyCode.K and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
			window:OpenCommandPalette()
		elseif input.KeyCode == Enum.KeyCode.Escape and window.PaletteOpen then
			closePalette()
		end
	end))

	function window:OpenCommandPalette()
		self.PaletteOpen = true
		paletteOverlay.Visible = true
		refreshPalette()
		task.defer(function()
			paletteBox:CaptureFocus()
		end)
	end

	function window:CloseCommandPalette()
		closePalette()
	end

