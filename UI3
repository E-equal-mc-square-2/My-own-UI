local Library = {}

function Library:CreateWindow(cfg)
	cfg = cfg or {}
	local SaveFile = cfg.SaveFile or "KilometresUIX/settings.json"

	local State = {
		ThemeName = cfg.Theme or "Default",
		Width = Clamp(cfg.Width or 900, 340, 1400),
		Height = Clamp(cfg.Height or 620, 260, 900),
		SaveSettings = (cfg.SaveSettings ~= false),
		Hidden = false,
		Refreshers = {},
		ActiveTab = nil,
		Hotkey = cfg.ToggleKey or Enum.KeyCode.RightShift,
		OffsetX = 0,
		OffsetY = 0,
	}

	local function Theme()
		return Themes[State.ThemeName] or Themes.Default
	end

	local function AddRefresher(fn)
		table.insert(State.Refreshers, fn)
	end

	local function RefreshAll()
		for _, fn in ipairs(State.Refreshers) do
			pcall(fn)
		end
	end

	local function Persist()
		if not State.SaveSettings then return end
		local payload = {
			ThemeName = State.ThemeName,
			Width = State.Width,
			Height = State.Height,
			SaveSettings = State.SaveSettings,
			Hotkey = tostring(State.Hotkey),
		}
		TryWriteFile(SaveFile, HttpService:JSONEncode(payload))
	end

	local function LoadPersisted()
		if not State.SaveSettings then return end
		local raw = TryReadFile(SaveFile)
		if not raw then return end
		local ok, data = pcall(function()
			return HttpService:JSONDecode(raw)
		end)
		if ok and type(data) == "table" then
			if type(data.ThemeName) == "string" and Themes[data.ThemeName] then
				State.ThemeName = data.ThemeName
			end
			if type(data.Width) == "number" then State.Width = Clamp(data.Width, 340, 1400) end
			if type(data.Height) == "number" then State.Height = Clamp(data.Height, 260, 900) end
			if type(data.SaveSettings) == "boolean" then State.SaveSettings = data.SaveSettings end
		end
	end

