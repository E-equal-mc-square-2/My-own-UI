	local function CreateSlider(parent, text, min, max, default, callback, step)
		local Value = Clamp(default or min or 0, min or 0, max or 100)
		step = step or 1

		local Slider = New("Frame", {
			Parent = parent,
			Size = UDim2.new(1, 0, 0, 64),
			BackgroundColor3 = CurrentTheme().Surface2,
			BorderSizePixel = 0,
			ZIndex = 70
		})
		Corner(Slider, 12)
		Stroke(Slider, CurrentTheme().Stroke, 1)

		local Label = New("TextLabel", {
			Parent = Slider,
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(14, 8),
			Size = UDim2.new(1, -28, 0, 16),
			Text = text,
			TextColor3 = CurrentTheme().Text,
			TextSize = 14,
			Font = Enum.Font.GothamMedium,
			TextXAlignment = Enum.TextXAlignment.Left,
			ZIndex = 71
		})

		local ValueLabel = New("TextLabel", {
			Parent = Slider,
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(1, 0),
			Position = UDim2.new(1, -14, 0, 8),
			Size = UDim2.fromOffset(80, 16),
			Text = tostring(Value),
			TextColor3 = CurrentTheme().TextDim,
			TextSize = 12,
			Font = Enum.Font.Gotham,
			TextXAlignment = Enum.TextXAlignment.Right,
			ZIndex = 71
		})

		local Bar = New("Frame", {
			Parent = Slider,
			Position = UDim2.fromOffset(14, 36),
			Size = UDim2.new(1, -28, 0, 10),
			BackgroundColor3 = Color3.fromRGB(45, 45, 55),
			BorderSizePixel = 0,
			ZIndex = 71
		})
		Corner(Bar, 999)

		local Fill = New("Frame", {
			Parent = Bar,
			Size = UDim2.fromScale(0, 1),
			BackgroundColor3 = CurrentTheme().Accent,
			BorderSizePixel = 0,
			ZIndex = 72
		})
		Corner(Fill, 999)

		local Knob = New("Frame", {
			Parent = Bar,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.fromScale(0, 0.5),
			Size = UDim2.fromOffset(18, 18),
			BackgroundColor3 = Color3.new(1, 1, 1),
			BorderSizePixel = 0,
			ZIndex = 73
		})
		Corner(Knob, 999)

		local dragging = false
		local function SetValue(v, silent)
			v = Clamp(v, min, max)
			if step and step > 0 then
				v = math.floor((v / step) + 0.5) * step
			end
			Value = v
			ValueLabel.Text = tostring(Value)

			local pct = (Value - min) / math.max(1, (max - min))
			Fill.Size = UDim2.new(pct, 0, 1, 0)
			Knob.Position = UDim2.new(pct, 0, 0.5, 0)

			if not silent and callback then
				callback(Value)
			end
		end

		local function UpdateFromInput(input)
			local rel = (input.Position.X - Bar.AbsolutePosition.X) / math.max(1, Bar.AbsoluteSize.X)
			SetValue(min + (max - min) * Clamp(rel, 0, 1))
		end

		Bar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				UpdateFromInput(input)
			end
		end)

		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
				Persist()
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				UpdateFromInput(input)
			end
		end)

		AddRefresher(function()
			local T = CurrentTheme()
			Slider.BackgroundColor3 = T.Surface2
			Label.TextColor3 = T.Text
			ValueLabel.TextColor3 = T.TextDim
			Bar.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
			Fill.BackgroundColor3 = T.Accent
			Knob.BackgroundColor3 = Color3.new(1, 1, 1)
			Stroke(Slider, T.Stroke, 1)
		end)

		SetValue(Value, true)
		return {
			Frame = Slider,
			Set = SetValue,
			Get = function()
				return Value
			end,
		}
	end

