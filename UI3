					tween(tabData.Button, { BackgroundColor3 = theme.Accent }, 0.16)
					tween(tabData.Label, { TextColor3 = Color3.new(1, 1, 1) }, 0.16)
				else
					tween(tabData.Button, { BackgroundColor3 = theme.Surface2 }, 0.16)
					tween(tabData.Label, { TextColor3 = theme.TextDim }, 0.16)
				end
			end
		end
		window.ActiveTab = tab
	end

	window._SelectTab = selectTab

