	local OrbScale = New("UIScale", {
		Parent = Orb,
		Scale = 1,
	})

	-- moveable orb + idle/click animation
	do
		local dragging = false
		local dragInput, dragStart, startPos

		Orb.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				Tween(OrbScale, {Scale = 0.9}, 0.08)
				dragging = true
				dragStart = input.Position
				startPos = Orb.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
						Tween(OrbScale, {Scale = 1}, 0.12)
					end
				end)
			end
		end)

		Orb.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				dragInput = input
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if input == dragInput and dragging and startPos and Orb.Visible then
				local delta = input.Position - dragStart
				Orb.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end
		end)

		task.spawn(function()
			while Orb and Orb.Parent do
				if Orb.Visible and not dragging then
					Tween(OrbScale, {Scale = 1.05}, 0.7)
					task.wait(0.7)
					if Orb and Orb.Parent and Orb.Visible and not dragging then
						Tween(OrbScale, {Scale = 0.98}, 0.7)
						task.wait(0.7)
					end
				else
					task.wait(0.2)
				end
			end
		end)
	end

