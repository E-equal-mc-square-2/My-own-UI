	local function TryUnlockWithKey(rawKey)
		rawKey = tostring(rawKey or ""):gsub("^%s+", ""):gsub("%s+$", "")
		if not Base64LooksValid(rawKey) then
			KeyStatus.Text = "Invalid Base64."
			KeyStatus.TextColor3 = Color3.fromRGB(255, 120, 120)
			return false
		end

		if State.RequiredKey ~= "" then
			if rawKey ~= State.RequiredKey then
				KeyStatus.Text = "Wrong key."
				KeyStatus.TextColor3 = Color3.fromRGB(255, 120, 120)
				return false
			end
		end

		KeyStatus.Text = "Accepted."
		KeyStatus.TextColor3 = Color3.fromRGB(120, 255, 160)
		task.wait(0.12)
		UnlockUI()
		return true
	end

	KeySubmit.MouseButton1Click:Connect(function()
		TryUnlockWithKey(KeyBox.Text)
	end)

	KeyBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			TryUnlockWithKey(KeyBox.Text)
		end
	end)

	if not State.KeySystem then
		KeyOverlay.Visible = false
		Main.Visible = true
	else
		Main.Visible = false
		KeyOverlay.Visible = true
	end

