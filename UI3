-------------------------------------------------
-- TOGGLE CREATOR
-------------------------------------------------

function UI:CreateToggle(Parent,Name,Default,Callback)
    local Toggle = Instance.new("TextButton")
    Toggle.Size = UDim2.new(1,-10,0,45)
    Toggle.BackgroundColor3 = UI.Themes[UI.Theme].Secondary
    Toggle.Text = Name
    Toggle.Font = Enum.Font.GothamBold
    Toggle.TextColor3 = UI.Themes[UI.Theme].Text
    Toggle.TextSize = 14
    Toggle.Parent = Parent

    local Enabled = Default

    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0,12)
    ToggleCorner.Parent = Toggle

    Toggle.MouseButton1Click:Connect(function()
        Enabled = not Enabled

        TweenService:Create(Toggle,TweenInfo.new(0.2),{
            BackgroundColor3 = Enabled and UI.Themes[UI.Theme].Accent or UI.Themes[UI.Theme].Secondary
        }):Play()

        Callback(Enabled)

        UI.Flags[Name] = Enabled
        UI:Save()
    end)
end

