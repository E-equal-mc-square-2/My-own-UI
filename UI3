local Library = {
	Version = "2.2",
	ThemeName = "Nebula",
	Theme = Themes.Nebula,
	Themes = Themes,
	Windows = {},
	Flags = {},
	Objects = {},
	Commands = {},
	ThemeHooks = {},
	Root = nil,
	IsMobile = isMobile(),
	ThemeChanged = NewSignal(),
}

function Library:SetTheme(themeName)
	local newTheme = self.Themes[themeName]
	if not newTheme then
		return
	end

	self.ThemeName = themeName
	self.Theme = newTheme

	for _, hook in ipairs(self.ThemeHooks) do
		task.spawn(hook, self.Theme)
	end
	self.ThemeChanged:Fire(self.Theme)
end

function Library:OnThemeChanged(fn)
	table.insert(self.ThemeHooks, fn)
	task.spawn(fn, self.Theme)
end

function Library:RegisterCommand(name, callback, category)
	table.insert(self.Commands, {
		Name = name,
		Callback = callback,
		Category = category or "General",
	})
end

function Library:BindFlag(flag, object)
	if not flag or not object then
		return
	end
	self.Objects[flag] = object
end

function Library:IsTyping()
	return UserInputService:GetFocusedTextBox() ~= nil
end

function Library:ApplyLoadedConfig(data)
	for k, v in pairs(data or {}) do
		self.Flags[k] = v
		local obj = self.Objects[k]
		if obj and obj.Set then
			pcall(function()
				obj:Set(v, true)
			end)
		end
	end
end

function Library:SaveConfig(name)
	if not (writefile and isfolder and makefolder) then
		return false
	end

	local folder = "KilometresUIX"
	local path = folder .. "/" .. tostring(name) .. ".json"

	pcall(function()
		if not isfolder(folder) then
			makefolder(folder)
		end
	end)

	local ok, encoded = pcall(function()
		return HttpService:JSONEncode(self.Flags)
	end)

	if not ok then
		return false
	end

	pcall(function()
		writefile(path, encoded)
	end)

	return true
end

function Library:LoadConfig(name)
	if not (readfile and isfile) then
		return false
	end

	local path = "KilometresUIX/" .. tostring(name) .. ".json"
	if not isfile(path) then
		return false
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(readfile(path))
	end)

	if ok and type(decoded) == "table" then
		self:ApplyLoadedConfig(decoded)
		return true
	end

	return false
end

