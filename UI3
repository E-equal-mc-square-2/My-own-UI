			function section:CreateSlider(cfg)
				cfg = cfg or {}
				local flag = cfg.Flag or cfg.Name
				local min = cfg.Min or 0
				local max = cfg.Max or 100
				local increment = cfg.Increment or 1
				local value = cfg.Default or min

				local cardS = New("Frame", {
					Parent = holder,
					BackgroundColor3 = theme.Surface2,
					BorderSizePixel = 0,
					Size = UDim2.new(1, 0, 0, 72),
				})
				corner(cardS, 14)
				stroke(cardS, theme.Stroke, 1, 0)

				local label = New("TextLabel", {
					Parent = cardS,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(16, 8),
					Size = UDim2.new(1, -32, 0, 20),
					Font = Enum.Font.GothamMedium,
					Text = cfg.Name or "Slider",
					TextColor3 = theme.Text,
					TextSize = 15,
					TextXAlignment = Enum.TextXAlignment.Left,
				})

				local valueLabel = New("TextLabel", {
					Parent = cardS,
					BackgroundTransparency = 1,
					Position = UDim2.new(1, -88, 0, 8),
					Size = UDim2.fromOffset(72, 20),
					Font = Enum.Font.GothamBold,
					Text = tostring(value),
					TextColor3 = theme.Accent,
					TextSize = 14,
					TextXAlignment = Enum.TextXAlignment.Right,
				})

				local bar = New("Frame", {
					Parent = cardS,
					Position = UDim2.fromOffset(16, 42),
					Size = UDim2.new(1, -32, 0, 10),
					BackgroundColor3 = Color3.fromRGB(52, 52, 60),
					BorderSizePixel = 0,
				})
				corner(bar, 999)

				local fill = New("Frame", {
					Parent = bar,
					Size = UDim2.new(0, 0, 1, 0),
					BackgroundColor3 = theme.Accent,
					BorderSizePixel = 0,
				})
				corner(fill, 999)
				gradient(fill, theme.Accent, theme.Accent2)

				local dragging = false
				local selfObj = {
					Instance = cardS,
					Value = value,
				}

				local function apply(v, silent)
					v = math.clamp(v, min, max)
					if increment > 0 then
						v = math.floor((v / increment) + 0.5) * increment
					end
					selfObj.Value = v

					local pct = (v - min) / math.max((max - min), 1)
					fill.Size = UDim2.new(pct, 0, 1, 0)
					valueLabel.Text = tostring(v)

					if not silent and cfg.Callback then
						task.spawn(cfg.Callback, v)
					end
					if flag then
						Library.Flags[flag] = v
					end
				end

				function selfObj:Set(v, silent) apply(v, silent) end
				function selfObj:Get() return selfObj.Value end
				function selfObj:Destroy() if cardS then cardS:Destroy() end end

				bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
						ripple(cardS, theme)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end)

				maid:Add(UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						local x = input.Position.X - bar.AbsolutePosition.X
						local pct = math.clamp(x / math.max(bar.AbsoluteSize.X, 1), 0, 1)
						local v = min + ((max - min) * pct)
						apply(v)
					end
				end))

				apply(value, true)
				if flag then
					section:_registerElement(flag, selfObj)
				end
				return selfObj
			end

