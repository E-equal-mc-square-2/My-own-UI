					ZIndex = 20000,
					Parent = ScreenGui,
				})
				create("UIListLayout", {
					HorizontalAlignment = Enum.HorizontalAlignment.Right,
					VerticalAlignment = Enum.VerticalAlignment.Bottom,
					SortOrder = Enum.SortOrder.LayoutOrder,
					Padding = UDim.new(0, 10),
					Parent = holder,
				})
			end
			local note = create("Frame", {
				Size = UDim2.new(1, 0, 0, 78),
				BackgroundColor3 = theme.Surface,
				BackgroundTransparency = 0.04,
				BorderSizePixel = 0,
				ZIndex = 20001,
				Parent = holder,
			})
			corner(note, 16)
			stroke(note, theme.Stroke, 0.78, 1)
			create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 14, 0, 10),
				Size = UDim2.new(1, -24, 0, 18),
				Font = Enum.Font.GothamBold,
				Text = data.Title or "Nexora",
				TextColor3 = theme.Text,
				TextSize = 15,
				TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 20002,
				Parent = note,
			})
			create("TextLabel", {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, 14, 0, 31),
				Size = UDim2.new(1, -24, 0, 30),
				Font = Enum.Font.Gotham,
				Text = data.Description or "",
				TextColor3 = theme.SubText,
				TextSize = 13,
				TextWrapped = true,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Top,
				ZIndex = 20002,
				Parent = note,
			})
			note.Position = UDim2.new(1, 120, 0, 0)
			tween(note, { Position = UDim2.new(0, 0, 0, 0) }, 0.28):Play()
			task.delay(data.Duration or 4, function()
				if note and note.Parent then note:Destroy() end
			end)
		end,
		Destroy = function()
			for _, c in ipairs(connections) do safeDisconnect(c) end
			if Blur then Blur:Destroy() end
			if ScreenGui then ScreenGui:Destroy() end
		end,
	}

	Window:Notify({
		Title = settings.Title or "Nexora",
		Description = "Modern UI loaded successfully.",
		Duration = 4,
	})

	setWindowVisible(true)
	Overlay.Visible = state.Overlay.Visible
	FPSLabel.Visible = state.Overlay.ShowFPS
	PingLabel.Visible = state.Overlay.ShowPing
	CPULabel.Visible = state.Overlay.ShowCPU
	GPULabel.Visible = state.Overlay.ShowGPU
	ChatBox.Text = state.Chat.Draft or ""
	setBlurVisible(true)
	persist()

	local fpsAccumulator = 0
	local fpsValue = 0
	local fpsTime = 0
	local lastHeartbeat = os.clock()

	connect(RunService.RenderStepped, function(delta)
		fpsAccumulator += 1
		fpsTime += delta
		if fpsTime >= 1 then
			fpsValue = fpsAccumulator
			fpsAccumulator = 0
			fpsTime = 0
		end

		if Overlay.Visible then
			FPSLabel.Visible = state.Overlay.ShowFPS
			PingLabel.Visible = state.Overlay.ShowPing
			CPULabel.Visible = state.Overlay.ShowCPU
			GPULabel.Visible = state.Overlay.ShowGPU

			if state.Overlay.ShowFPS then
				FPSLabel.Text = "FPS: " .. tostring(fpsValue)
			end
			if state.Overlay.ShowPing then
				local ping = readPing()
				PingLabel.Text = "Ping: " .. tostring(ping or "n/a")
			end
			if state.Overlay.ShowCPU then
				CPULabel.Text = "CPU: " .. tostring(getFrameTimeMs(delta)) .. " ms"
			end
			if state.Overlay.ShowGPU then
				GPULabel.Text = "GPU: n/a"
			end
		end
	end)

	connect(UserInputService.WindowFocused, function()
		resizeLayout()
		MainScale.Scale = isMobile() and 0.94 or 1
	end)

	connect(UserInputService.InputEnded, function()
		resizeLayout()
	end)

	return Window
end

return Nexora
