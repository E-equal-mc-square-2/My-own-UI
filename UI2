		label.TextColor3 = th.Text
		holder.BackgroundColor3 = th.Input
		holderText.TextColor3 = current and th.Text or th.SubText
		arrow.TextColor3 = th.Text
		list.BackgroundColor3 = th.Background
		theme = th
		local s = card:FindFirstChildOfClass("UIStroke")
		if s then
			s.Color = th.Stroke
		end
		local hs = holder:FindFirstChildOfClass("UIStroke")
		if hs then
