local WindowMT = {}
WindowMT.__index = WindowMT

function Library:CreateWindow(options)
	self:_initRoot()
	self._windowCounter += 1

	local window = setmetatable({}, WindowMT)
	window.Library = self
	window.Id = self._windowCounter
	window.Title = tostring(options and options.Title or "NeonVX")
	window.Subtitle = tostring(options and options.Subtitle or "Mobile-first UI")
	window.Size = options and options.Size or nil
	window.Keybind = options and options.Keybind or Enum.KeyCode.RightShift
	window.Visible = true
	window.Minimized = false
	window.Maximized = false
	window.Destroyed = false
	window.Sections = {}
	window.Tabs = {}
	window.ActiveTab = nil
	window.SearchQuery = ""
	window._lastRestore = nil
	window._themeObjects = {}
	window._connections = Maid.new()
	window._dragging = false
	window._touchTracking = nil
	window._touchStart = nil
	window._dragStart = nil
	window._dragOrigin = nil
	window._gestureStart = nil
	window._layoutDirty = false
	window._searchBoxes = {}
	window._flags = {}
	window._containerPadding = 10
	window._contentPadding = 10
	window._bodyHeight = 0

	table.insert(self.Windows, window)

	window:_build()
	window:ApplyTheme(self.Theme)

	if options and options.Theme then
		self:SetTheme(options.Theme)
	end

	if options and options.Visible == false then
		window:Hide(true)
	end

	return window
end

function WindowMT:_bindTheme(fn)
	table.insert(self._themeObjects, fn)
	fn(self.Library.Theme)
end

function WindowMT:ApplyTheme(theme)
	if self.Destroyed then
		return
	end
	for _, fn in ipairs(self._themeObjects) do
		pcall(fn, theme)
	end
end

function WindowMT:_viewportScaledSize()
	local vp = GetViewport()
	local isMobile = IsTouch()
	if self.Maximized then
		local w = math.clamp(vp.X * 0.96, 320, 1000)
		local h = math.clamp(vp.Y * 0.92, 280, 760)
		return UDim2.fromOffset(w, h)
	end
	if isMobile then
		local w = math.clamp(vp.X * 0.94, 300, 720)
		local h = math.clamp(vp.Y * 0.82, 330, 720)
		return UDim2.fromOffset(w, h)
	end
	local w = math.clamp(vp.X * 0.50, 380, 860)
	local h = math.clamp(vp.Y * 0.66, 360, 760)
	return UDim2.fromOffset(w, h)
end

function WindowMT:_updateScale()
	if not self.Main or not self.Scale then
		return
	end
	local vp = GetViewport()
	local scale = Clamp(math.min(vp.X / 900, vp.Y / 760), 0.84, 1.10)
	if IsTouch() then
		scale = Clamp(math.min(vp.X / 840, vp.Y / 780), 0.92, 1.05)
	end
	self.Scale.Scale = scale
end

function WindowMT:_applyBaseLayout()
	if self.Destroyed then
		return
	end
	local theme = self.Library.Theme
	self.Main.BackgroundColor3 = theme.Background
	self.Header.BackgroundColor3 = theme.Card
	self.Body.BackgroundColor3 = theme.Background2
	self.TabStrip.BackgroundColor3 = theme.Card2
	self.Content.BackgroundColor3 = theme.Background2
	self.WindowShadow.BackgroundColor3 = theme.Shadow
	self.WindowShadow.BackgroundTransparency = 0.58
	self.TitleLabel.TextColor3 = theme.Text
	self.SubtitleLabel.TextColor3 = theme.SubText
	self.TabStripStroke.Color = theme.Stroke
	self.MainStroke.Color = theme.Stroke
	self.ReopenButton = self.Library:_createReopenButton(self)
	self.Library:_setBlur(self.Visible)
	self.Library:_updateAllWindowTabs()
end

function WindowMT:_build()
	local theme = self.Library.Theme
	local gui = self.Library._rootGui
	local screen = New("Frame", {
		Name = "Window_" .. tostring(self.Id),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = gui
	})
	self.Root = screen

	local shadow = New("Frame", {
		Name = "Shadow",
		BackgroundColor3 = theme.Shadow,
		BackgroundTransparency = 0.64,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = self:_viewportScaledSize(),
		Parent = screen
	})
	ApplyCorner(shadow, 22)
	self.WindowShadow = shadow

	local main = New("Frame", {
		Name = "Main",
		BackgroundColor3 = theme.Background,
		BackgroundTransparency = 0,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = self:_viewportScaledSize(),
		ClipsDescendants = true,
		Parent = screen
	})
	ApplyCorner(main, 22)
	self.Main = main
	local mainStroke = ApplyStroke(main, theme.Stroke, 0.35, 1)
	self.MainStroke = mainStroke

	local gradient = ApplyGradient(main, theme.Background, theme.Background2, 90)
	self.MainGradient = gradient

	local scale = New("UIScale", {
		Scale = 1,
		Parent = main
	})
	self.Scale = scale
	self:_updateScale()

	local header = New("Frame", {
		Name = "Header",
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, 0, 0, 58),
		Parent = main
	})
	self.Header = header
	ApplyGradient(header, theme.Card2, theme.Card, 0)

	local headerStroke = ApplyStroke(header, theme.Stroke, 0.42, 1)
	self.HeaderStroke = headerStroke

	local titleHolder = New("Frame", {
		Name = "TitleHolder",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(16, 8),
		Size = UDim2.new(1, -180, 1, -16),
		Parent = header
	})

	local titleLabel = New("TextLabel", {
		Name = "Title",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Font = Enum.Font.GothamBold,
		Text = self.Title,
		TextColor3 = theme.Text,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		Parent = titleHolder
	})
	self.TitleLabel = titleLabel

	local subtitleLabel = New("TextLabel", {
		Name = "Subtitle",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 22),
		Size = UDim2.new(1, 0, 0, 16),
		Font = Enum.Font.GothamMedium,
		Text = self.Subtitle,
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		Parent = titleHolder
	})
	self.SubtitleLabel = subtitleLabel

	local controls = New("Frame", {
		Name = "Controls",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -10, 0.5, 0),
		Size = UDim2.fromOffset(156, 44),
		Parent = header
	})
	AddListLayout(controls, 8, Enum.SortOrder.LayoutOrder)
	controls.FillDirection = Enum.FillDirection.Horizontal
	controls.HorizontalAlignment = Enum.HorizontalAlignment.Right

	local function controlButton(text, accent)
		local b = New("TextButton", {
			BackgroundColor3 = theme.Card2,
			BackgroundTransparency = 0.05,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(44, 44),
			Text = text,
			Font = Enum.Font.GothamBold,
			TextSize = 16,
			TextColor3 = accent and theme.Accent or theme.Text,
			AutoButtonColor = false,
			Parent = controls
		})
		ApplyCorner(b, 14)
		ApplyStroke(b, theme.Stroke, 0.48, 1)
		return b
	end

	local minimizeBtn = controlButton("–", false)
	local maximizeBtn = controlButton("▢", false)
	local closeBtn = controlButton("×", true)

	local body = New("Frame", {
		Name = "Body",
		BackgroundColor3 = theme.Background2,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 58),
		Size = UDim2.new(1, 0, 1, -58),
		ClipsDescendants = true,
		Parent = main
	})
	self.Body = body

	local topStrip = New("Frame", {
		Name = "TabStrip",
		BackgroundColor3 = theme.Card2,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 56),
		Parent = body
	})
	ApplyStroke(topStrip, theme.Stroke, 0.5, 1)
	self.TabStrip = topStrip
	self.TabStripStroke = topStrip:FindFirstChildOfClass("UIStroke")
	ApplyGradient(topStrip, theme.Card2, theme.Background2, 0)

	local tabScroller = New("ScrollingFrame", {
		Name = "TabScroller",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -18, 1, 0),
		Position = UDim2.fromOffset(9, 0),
		ScrollBarImageColor3 = theme.Accent,
		ScrollBarThickness = 0,
		ScrollingDirection = Enum.ScrollingDirection.X,
		AutomaticCanvasSize = Enum.AutomaticSize.X,
		CanvasSize = UDim2.fromOffset(0, 0),
		Parent = topStrip
	})
	self.TabScroller = tabScroller
	AddListLayout(tabScroller, 8).FillDirection = Enum.FillDirection.Horizontal
	AddPadding(tabScroller, 2, 2, 7, 7)
	tabScroller.VerticalScrollBarInset = Enum.ScrollBarInset.Always

	local content = New("Frame", {
		Name = "Content",
		BackgroundColor3 = theme.Background2,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 56),
		Size = UDim2.new(1, 0, 1, -56),
		Parent = body
	})
	self.Content = content
	AddPadding(content, 10, 10, 10, 10)

	local contentStack = New("Frame", {
		Name = "Pages",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = content
	})
	self.PagesHolder = contentStack
	AddListLayout(contentStack, 0)

	-- Global container for pages
	local pagesHolder = New("Frame", {
		Name = "PageHost",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = content
	})
	self.PageHost = pagesHolder

	local pageStack = New("Frame", {
		Name = "PageStack",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = pagesHolder
	})
	self.PageStack = pageStack

	-- buttons
	minimizeBtn.MouseButton1Click:Connect(function()
		self:Minimize()
	end)

	maximizeBtn.MouseButton1Click:Connect(function()
		self:Maximize(not self.Maximized)
	end)

	closeBtn.MouseButton1Click:Connect(function()
		self:Hide()
	end)

	local function setControlPress(btn)
		btn.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.Touch or inp.UserInputType == Enum.UserInputType.MouseButton1 then
				Rippler(btn, theme, inp.Position - btn.AbsolutePosition)
			end
		end)
	end
	setControlPress(minimizeBtn)
	setControlPress(maximizeBtn)
	setControlPress(closeBtn)

	-- drag handling
	local dragArea = header
	self._connections:Give(dragArea.InputBegan:Connect(function(input)
		if self.Minimized then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			self._dragging = true
			self._dragStart = input.Position
			self._dragOrigin = self.Main.Position
			self._connections:Give(input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					self._dragging = false
				end
			end))
		end
	end))

	self._connections:Give(UserInputService.InputChanged:Connect(function(input)
		if self._dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - self._dragStart
			self.Main.Position = UDim2.new(
				self._dragOrigin.X.Scale,
				self._dragOrigin.X.Offset + delta.X,
				self._dragOrigin.Y.Scale,
				self._dragOrigin.Y.Offset + delta.Y
			)
			self.WindowShadow.Position = self.Main.Position + UDim2.fromOffset(0, 0)
		end
	end))

	-- swipe gestures for mobile
	self._connections:Give(dragArea.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch then
			self._gestureStart = input.Position
		end
	end))

	self._connections:Give(dragArea.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch and self._gestureStart then
			local delta = input.Position - self._gestureStart
			if math.abs(delta.Y) > 70 and math.abs(delta.Y) > math.abs(delta.X) then
				if delta.Y > 0 then
					self:Minimize()
				else
					self:Maximize(true)
				end
			end
			self._gestureStart = nil
		end
	end))

	self._connections:Give(UserInputService.InputBegan:Connect(function(input, gp)
		if gp or self.Destroyed then
			return
		end
		if input.KeyCode == self.Keybind then
			self:Toggle()
		end
	end))

	self._connections:Give(Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
		self:_updateScale()
		self:_recenterIfNeeded()
	end))

	self._connections:Give(RunService.RenderStepped:Connect(function()
		if self.Visible and self.Main and self.WindowShadow then
			self.WindowShadow.Position = self.Main.Position + UDim2.fromOffset(0, 0)
		end
	end))

	self._connections:Give(screen.AncestryChanged:Connect(function(_, parent)
		if not parent and not self.Destroyed then
			self:Destroy()
		end
	end))

	self:_applyBaseLayout()
	self.Library:_setBlur(true)
end

function WindowMT:_recenterIfNeeded()
	if self.Destroyed then
		return
	end
	if self.Maximized then
		self.Main.Size = self:_viewportScaledSize()
		self.WindowShadow.Size = self.Main.Size + UDim2.fromOffset(16, 18)
		return
	end
	if not self._dragging and self.Visible then
		local size = self:_viewportScaledSize()
		self.Main.Size = size
		self.WindowShadow.Size = size + UDim2.fromOffset(16, 18)
	end
end

function WindowMT:SetKeybind(keyCode)
	self.Keybind = keyCode
end

function WindowMT:Show(noTween)
	if self.Destroyed then
		return
	end
	self.Visible = true
	self.Main.Visible = true
	self.WindowShadow.Visible = true
	if self.ReopenButton then
		self.ReopenButton.Visible = false
	end
	self.Library:_setBlur(true)
	if not noTween then
		self.Main.BackgroundTransparency = 1
		Tween(self.Main, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0
		})
	end
end

function WindowMT:Hide(noTween)
	if self.Destroyed then
		return
	end
	self.Visible = false
	if self.Main then
		if not noTween then
			Tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1
			})
		end
		task.delay(noTween and 0 or 0.22, function()
			if self.Main and not self.Visible then
				self.Main.Visible = false
			end
			if self.WindowShadow then
				self.WindowShadow.Visible = false
			end
			if self.ReopenButton then
				self.ReopenButton.Visible = true
			end
		end)
	end
	self.Library:_setBlur(false)
end

function WindowMT:Toggle()
	if self.Visible then
		self:Hide()
	else
		self:Show()
	end
end

function WindowMT:Minimize()
	if self.Destroyed or self.Minimized then
		return
	end
	self.Minimized = true
	self._lastRestore = self.Main.Size
	local target = UDim2.fromOffset(self.Main.AbsoluteSize.X, 58)
	Tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = target
	})
	Tween(self.WindowShadow, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = target + UDim2.fromOffset(16, 18)
	})
	task.delay(0.12, function()
		if self.Body then
			self.Body.Visible = false
		end
		if self.TabStrip then
			self.TabStrip.Visible = false
		end
	end)
end

function WindowMT:Maximize(state)
	if self.Destroyed then
		return
	end
	local targetState = (state == nil) and (not self.Maximized) or state
	self.Maximized = targetState and true or false
	self.Minimized = false

	if self.Body then
		self.Body.Visible = true
	end
	if self.TabStrip then
		self.TabStrip.Visible = true
	end

	local targetSize = self:_viewportScaledSize()
	self.Main.Size = targetSize
	self.WindowShadow.Size = targetSize + UDim2.fromOffset(16, 18)

	Tween(self.Main, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = targetSize
	})
	Tween(self.WindowShadow, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = targetSize + UDim2.fromOffset(16, 18)
	})
end

function WindowMT:Restore()
	if self.Destroyed then
		return
	end
	if self._lastRestore then
		self.Main.Size = self._lastRestore
		self.WindowShadow.Size = self._lastRestore + UDim2.fromOffset(16, 18)
	end
	self.Minimized = false
	self.Maximized = false
	if self.Body then self.Body.Visible = true end
	if self.TabStrip then self.TabStrip.Visible = true end
end

function WindowMT:Destroy()
	if self.Destroyed then
		return
	end
	self.Destroyed = true
	self.Library:_removeReopenButton(self)
	self._connections:Cleanup()
	for _, tab in ipairs(self.Tabs) do
		if tab and tab.Destroy then
			pcall(function()
				tab:Destroy()
			end)
		end
	end
	DestroyIfExists(self.Root)
	self.Library:_setBlur(false)

	for i, w in ipairs(self.Library.Windows) do
		if w == self then
			table.remove(self.Library.Windows, i)
			break
		end
	end
end

function WindowMT:_updateTabButtonActive(tab)
	for _, t in ipairs(self.Tabs) do
		local active = (t == tab)
		if t.Button then
			Tween(t.Button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundColor3 = active and self.Library.Theme.Accent or self.Library.Theme.Card2
			})
			if t.ActiveBar then
				Tween(t.ActiveBar, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundTransparency = active and 0 or 1
				})
			end
			if t.ButtonStroke then
				Tween(t.ButtonStroke, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Transparency = active and 0.18 or 0.52
				})
			end
		end
		if t.Page then
			t.Page.Visible = active
		end
	end
	self.ActiveTab = tab
end

function Library:_updateAllWindowTabs()
	for _, w in ipairs(self.Windows) do
		if w and w.ActiveTab then
			w:_updateTabButtonActive(w.ActiveTab)
		end
	end
end

