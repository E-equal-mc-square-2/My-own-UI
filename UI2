SectionMT = {}
SectionMT.__index = SectionMT

function SectionMT:_theme()
	return self.Window.Library.Theme
end

function SectionMT:_registerElement(meta)
	table.insert(self.Elements, meta)
	return meta
end

function SectionMT:_makeElementFrame(height)
	local theme = self:_theme()
	local frame = New("Frame", {
		BackgroundColor3 = theme.Background2,
		BackgroundTransparency = 0.03,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, height or 54),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = self.Container
	})
	ApplyCorner(frame, 14)
	ApplyStroke(frame, theme.Stroke, 0.5, 1)
	AddPadding(frame, 12, 12, 10, 10)
	return frame
end

function SectionMT:ApplySearch(query)
	self.SearchQuery = string.lower(tostring(query or ""))
	for _, obj in ipairs(self.Elements) do
		local text = string.lower(obj.SearchText or "")
		local visible = true
		if self.SearchQuery ~= "" then
			visible = string.find(text, self.SearchQuery, 1, true) ~= nil
		end
		if obj.Frame then
			obj.Frame.Visible = visible
		end
	end
end

function SectionMT:SetSearch(query)
	self:ApplySearch(query)
end

function SectionMT:Destroy()
	if self.Destroyed then
		return
	end
	self.Destroyed = true
	if self.Frame then
		self.Frame:Destroy()
	end
end

