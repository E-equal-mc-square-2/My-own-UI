    function Window:SetTheme(themeName)
        if Themes[themeName] then
            local oldTheme = CurrentTheme
            CurrentTheme = Themes[themeName]
            
            -- Animate theme transition
            local function updateColor(instance, property, newColor)
                if instance and instance[property] then
                    Utility:Tween(instance, {[property] = newColor}, THEME_TRANSITION_SPEED)
                end
            end
            
            updateColor(mainFrame, "BackgroundColor3", CurrentTheme.Background)
            updateColor(header, "BackgroundColor3", CurrentTheme.BackgroundSecondary)
            updateColor(headerAccent, "BackgroundColor3", CurrentTheme.Primary)
            updateColor(tabContainer, "BackgroundColor3", CurrentTheme.BackgroundSecondary)
            updateColor(closeButton, "BackgroundColor3", CurrentTheme.Accent)
            updateColor(reopenButton, "BackgroundColor3", CurrentTheme.Primary)
            
            NotificationSystem:Send({
                Title = "Theme Changed",
                Description = "Switched to " .. CurrentTheme.Name,
                Type = "Success",
                Duration = 3
            })
        end
