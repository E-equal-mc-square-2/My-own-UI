        Parent = self.Container,
        ClipsDescendants = true
    })
    
    Utility:AddCorner(notif)
    Utility:AddStroke(notif, Theme.Stroke)
    Utility:CreateShadow(notif)
    
    local titleLbl = Utility:Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 15, 0, 10),
        Size = UDim2.new(1, -30, 0, 20),
        Font = Theme.BoldFont,
        Text = title,
        TextColor3 = Theme.Accent,
        TextSize = Theme.TextSize + 2,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notif
    })
    
    local descLbl = Utility:Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 15, 0, 32),
        Size = UDim2.new(1, -30, 0, 20),
        Font = Theme.Font,
        Text = text,
        TextColor3 = Theme.SubText,
        TextSize = Theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = notif
    })
    
    -- Auto-size height based on text
    local bounds = TextService:GetTextSize(text, Theme.TextSize, Theme.Font, Vector2.new(270, math.huge))
    local targetHeight = 45 + bounds.Y
    
    -- Accent line indicator
    local line = Utility:Create("Frame", {
        BackgroundColor3 = Theme.Accent,
        Size = UDim2.new(0, 3, 1, -16),
        Position = UDim2.new(0, 4, 0, 8),
        BorderSizePixel = 0,
        Parent = notif
    })
    Utility:AddCorner(line, UDim.new(1, 0))
    
    -- Entrance Animation
    notif.Size = UDim2.new(0, 300, 0, targetHeight)
    notif.Position = UDim2.new(1, 50, 0, 0)
    Utility:Tween(notif, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Back)
    
    -- Exit Logic
    task.delay(duration, function()
        local exitTween = Utility:Tween(notif, {Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1}, 0.3)
        Utility:Tween(titleLbl, {TextTransparency = 1}, 0.3)
        Utility:Tween(descLbl, {TextTransparency = 1}, 0.3)
        Utility:Tween(line, {BackgroundTransparency = 1}, 0.3)
        
        exitTween.Completed:Connect(function()
            notif:Destroy()
        end)
    end)
end

