function WindowMT:SetSearch(query)
	self.SearchQuery = tostring(query or "")
	for _, tab in ipairs(self.Tabs) do
		for _, section in ipairs(tab.Sections) do
			if section and section.ApplySearch then
				section:ApplySearch(self.SearchQuery)
			end
		end
	end
end

function WindowMT:_updateTabSearch(query)
	self:SetSearch(query)
end

function WindowMT:SetTitle(title)
	self.Title = tostring(title or self.Title)
	if self.TitleLabel then
		self.TitleLabel.Text = self.Title
	end
end

function WindowMT:SetSubtitle(text)
	self.Subtitle = tostring(text or self.Subtitle)
	if self.SubtitleLabel then
		self.SubtitleLabel.Text = self.Subtitle
	end
end

--//======================================================
--// LIBRARY UTILITY METHODS
--//======================================================

function Library:FindWindowByTitle(title)
	for _, w in ipairs(self.Windows) do
		if w.Title == title then
			return w
		end
	end
	return nil
end

function Library:Destroy()
	for _, w in ipairs(self.Windows) do
		pcall(function()
			w:Destroy()
		end)
	end
	self.Windows = {}

	if self._statsConn then
		self._statsConn:Disconnect()
		self._statsConn = nil
	end
	if self._blurTweenConn then
		self._blurTweenConn:Disconnect()
		self._blurTweenConn = nil
	end
	DestroyIfExists(self._rootGui)
	DestroyIfExists(self._blur)

	self._initialized = false
end

function Library:GetExecutor()
	return self._executor
end

function Library:GetFlags()
	return self.Flags
end

function Library:SetFlag(name, value)
	self:_setFlag(name, value)
	if self._flagSetters and self._flagSetters[name] then
		self._flagSetters[name](value, false)
	end
end

function Library:GetFlag(name)
	return self.Flags[name]
end

function Library:NotifySuccess(title, text, duration)
	return self:Notify(title or "Success", text or "", duration or 3)
end

function Library:NotifyError(title, text, duration)
	local n = self:Notify(title or "Error", text or "", duration or 4)
	return n
end

function Library:SetupDefaults()
	self:SetTheme("Dark")
	self:SetAutoSave(false)
end

--//======================================================
--// PRE-INSTALLED GLOBALS
--//======================================================

Library:_initRoot()
Library:SetupDefaults()

--//======================================================
--// RETURN
--//======================================================

return Library
