function SectionMT:AddSlider(text, min, max, default, callback, flag)
	local theme = self:_theme()
	local card = self:_makeElementFrame(72)

	min = tonumber(min) or 0
	max = tonumber(max) or 100
	local value = tonumber(default) or min
	local sliderFlag = flag or text or ("Slider_" .. tostring(#self.Window.Library.Flags + 1))

	local topRow = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Parent = card
	})

	local label = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -60, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tostring(text or "Slider"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = topRow
	})

	local valLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, 0, 0, 0),
		Size = UDim2.fromOffset(56, 18),
		Font = Enum.Font.GothamMedium,
		Text = tostring(value),
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = topRow
	})

	local track = New("Frame", {
		BackgroundColor3 = theme.Muted,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 34),
		Size = UDim2.new(1, 0, 0, 14),
		Parent = card
	})
	ApplyCorner(track, 999)

	local fill = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		Parent = track
	})
	ApplyCorner(fill, 999)
	ApplyGradient(fill, theme.Accent, theme.Accent2, 0)

	local handle = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(250, 250, 252),
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0, 0, 0.5, 0),
		Size = UDim2.fromOffset(20, 20),
		Parent = track
	})
	ApplyCorner(handle, 999)
	ApplyStroke(handle, theme.Accent2, 0.2, 1)

	local dragging = false
	local function set(v, silent)
		value = Clamp(tonumber(v) or min, min, max)
		local alpha = (value - min) / math.max(max - min, 1)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		handle.Position = UDim2.new(alpha, 0, 0.5, 0)
		valLabel.Text = tostring(math.floor(value * 100) / 100)
		if not silent then
			self.Window.Library:_setFlag(sliderFlag, value)
			if callback then
				task.spawn(callback, value)
			end
		end
	end

	local function updateFromInput(input)
		local pos = Clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		set(min + ((max - min) * pos), false)
	end

	local function beginDrag(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromInput(input)
		end
	end

	track.InputBegan:Connect(beginDrag)
	handle.InputBegan:Connect(beginDrag)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromInput(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	self.Window.Library:_registerFlag(sliderFlag, function(v, silent)
		set(v, silent)
	end)
	self.Window.Library.Flags[sliderFlag] = value
	set(value, true)

	local meta = { Frame = card, SearchText = tostring(text or "") }
	self:_registerElement(meta)

	return {
		Set = function(_, v) set(v, false) end,
		Get = function() return value end
	}
end

