                Utility:AddStroke(dropdownList, CurrentTheme.Border, 1, 0.3)
                Utility:AddPadding(dropdownList, {All = 5})
                
                local listLayout = Utility:Create("UIListLayout", {
                    Padding = UDim.new(0, 3),
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Parent = dropdownList
                })
                
                local function updateDropdown(value, skipCallback)
                    selectedValue = value
                    dropdownButton.Text = value
                    
                    if flag then
                        ConfigSystem:SetFlag(flag, value)
                    end
                    
                    if not skipCallback then
                        pcall(callback, value)
                    end
                end
                
                local function toggleDropdown()
                    dropdownOpen = not dropdownOpen
                    dropdownList.Visible = dropdownOpen
                    
                    if dropdownOpen then
                        local maxHeight = math.min(#options * 35, 150)
                        Utility:Tween(dropdownList, {Size = UDim2.new(1, 0, 0, maxHeight)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                        Utility:Tween(dropdownArrow, {Rotation = 180}, 0.2)
                        Utility:Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, 75 + maxHeight + 5)}, 0.2)
                    else
                        Utility:Tween(dropdownList, {Size = UDim2.new(1, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
                        Utility:Tween(dropdownArrow, {Rotation = 0}, 0.2)
                        Utility:Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, 75)}, 0.2)
                    end
                end
                
                dropdownButton.MouseButton1Click:Connect(function()
                    toggleDropdown()
                end)
                
                for _, option in ipairs(options) do
                    local optionButton = Utility:Create("TextButton", {
                        Name = "Option",
                        BackgroundColor3 = CurrentTheme.BackgroundTertiary,
                        Font = Enum.Font.Gotham,
                        Text = option,
                        TextColor3 = CurrentTheme.Text,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Size = UDim2.new(1, 0, 0, 30),
                        AutoButtonColor = false,
                        ZIndex = 101,
                        Parent = dropdownList
                    })
                    
                    Utility:AddCorner(optionButton, UDim.new(0, 5))
                    Utility:AddPadding(optionButton, {Left = 10, Right = 10})
                    
                    optionButton.MouseEnter:Connect(function()
                        Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.Primary}, 0.15)
                    end)
                    
                    optionButton.MouseLeave:Connect(function()
                        Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.BackgroundTertiary}, 0.15)
                    end)
                    
                    optionButton.MouseButton1Click:Connect(function()
                        updateDropdown(option)
                        toggleDropdown()
                    end)
                end
                
                listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    dropdownList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
                end)
                
                updateDropdown(selectedValue, true)
                
                local Dropdown = {}
                function Dropdown:Set(value)
                    updateDropdown(value, false)
                end
                
                function Dropdown:Refresh(newOptions, newDefault)
                    for _, child in ipairs(dropdownList:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    
                    options = newOptions
                    
                    for _, option in ipairs(options) do
                        local optionButton = Utility:Create("TextButton", {
                            Name = "Option",
                            BackgroundColor3 = CurrentTheme.BackgroundTertiary,
                            Font = Enum.Font.Gotham,
                            Text = option,
                            TextColor3 = CurrentTheme.Text,
                            TextSize = 12,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Size = UDim2.new(1, 0, 0, 30),
                            AutoButtonColor = false,
                            ZIndex = 101,
                            Parent = dropdownList
                        })
                        
                        Utility:AddCorner(optionButton, UDim.new(0, 5))
                        Utility:AddPadding(optionButton, {Left = 10, Right = 10})
                        
                        optionButton.MouseEnter:Connect(function()
                            Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.Primary}, 0.15)
                        end)
                        
                        optionButton.MouseLeave:Connect(function()
                            Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.BackgroundTertiary}, 0.15)
                        end)
                        
                        optionButton.MouseButton1Click:Connect(function()
                            updateDropdown(option)
                            toggleDropdown()
                        end)
                    end
                    
                    if newDefault then
                        updateDropdown(newDefault, false)
                    end
                end
                
                return Dropdown
            end
            
