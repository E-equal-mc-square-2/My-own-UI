                    Parent = colorPickerFrame
                })
                
                Utility:AddCorner(hueSelector, UDim.new(0, 6))
                
                local hueIndicator = Utility:Create("Frame", {
                    Name = "Indicator",
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
