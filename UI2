		return
	end
	self._initialized = true

	local parentGui = PickParentGui()

	if self._rootGui then
		DestroyIfExists(self._rootGui)
	end

	local gui = New("ScreenGui", {
		Name = "NeonVX_Root",
		IgnoreGuiInset = true,
		ResetOnSpawn = false,
		ScreenInsets = Enum.ScreenInsets.DeviceSafeInsets,
		DisplayOrder = 999999,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = parentGui
	})
	self._rootGui = gui

	local blur = Lighting:FindFirstChild("NeonVX_Blur")
	if blur then
		blur:Destroy()
	end
	blur = New("BlurEffect", {
		Name = "NeonVX_Blur",
		Size = 0,
		Parent = Lighting
	})
	self._blur = blur

	local top = New("Frame", {
		Name = "TopLayer",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = gui
	})
