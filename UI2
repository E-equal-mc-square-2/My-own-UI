function SectionClass:ApplySearch(query)
	query = string.lower(tostring(query or ""))
	local sectionMatch = query == "" or string.find(string.lower(self.Title .. " " .. self.Subtitle), query, 1, true)

	local anyVisible = false
	for _, meta in ipairs(self.Elements) do
		local text = string.lower(meta.SearchText or "")
		local visible = query == "" or string.find(text, query, 1, true) ~= nil
		if meta.Frame then
			meta.Frame.Visible = visible
		end
		anyVisible = anyVisible or visible
	end

	if self.Frame then
		self.Frame.Visible = sectionMatch or anyVisible or query == ""
	end
end

