            Utility:Tween(TabButton, 0.2, {BackgroundColor3 = Color3.fromRGB(25,20,35)})
            Utility:Tween(TabStroke, 0.2, {Color = Library.Theme.Accent})
            Utility:Tween(TabText, 0.2, {TextColor3 = Library.Theme.Text})
            Utility:Tween(TabIcon, 0.2, {ImageColor3 = Library.Theme.AccentLight})

