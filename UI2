
--!strict
-- KilometresUI / KilometresVoid
-- Single-file Roblox ModuleScript
-- Mobile-first, purple default accent, floating hide/show toggle, tabs, notifications, and core controls

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local Library = {}
Library.__index = Library

local DEFAULT_THEME = {
	Background = Color3.fromRGB(18, 16, 26),
	Topbar = Color3.fromRGB(26, 21, 38),
	Panel = Color3.fromRGB(28, 24, 42),
	Panel2 = Color3.fromRGB(34, 29, 51),
	Stroke = Color3.fromRGB(72, 58, 102),
	Accent = Color3.fromRGB(165, 92, 255),
	Accent2 = Color3.fromRGB(201, 150, 255),
	Text = Color3.fromRGB(245, 242, 255),
	SubText = Color3.fromRGB(180, 170, 205),
	Danger = Color3.fromRGB(255, 100, 120),
	Success = Color3.fromRGB(88, 214, 141),
	Radius = 14,
	Padding = 10,
	Font = Enum.Font.Gotham,
	FontBold = Enum.Font.GothamBold,
}

local function create(className: string, props: {[string]: any}?)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	return obj
end

local function corner(parent: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function stroke(parent: Instance, color: Color3, transparency: number?, thickness: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Transparency = transparency or 0.3
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

local function padding(parent: Instance, pad: number)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, pad)
	p.PaddingBottom = UDim.new(0, pad)
	p.PaddingLeft = UDim.new(0, pad)
	p.PaddingRight = UDim.new(0, pad)
	p.Parent = parent
	return p
end

local function tween(instance: Instance, time: number, props: {[string]: any})
	local info = TweenInfo.new(time, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function makeButton(parent: Instance, text: string, theme)
	local btn = create("TextButton", {
		BackgroundColor3 = theme.Panel2,
		AutoButtonColor = false,
		Text = text,
		TextColor3 = theme.Text,
		Font = theme.FontBold,
		TextSize = 14,
		Size = UDim2.new(1, 0, 0, 36),
		Parent = parent,
	})
	corner(btn, theme.Radius - 4)
	stroke(btn, theme.Stroke, 0.45)
	return btn
end

