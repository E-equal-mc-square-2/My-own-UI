    --//======================================================
    --// FPS COUNTER - FIXED
    --//======================================================

    function Window:CreateFPSCounter()
        local FPSFrame = Utility:Create("Frame", {
            Parent = ScreenGui,
            AnchorPoint = Vector2.new(1,0),
            Position = UDim2.new(1,-16,0,16),
            Size = UDim2.new(0,92,0,34),
            BackgroundColor3 = Library.Theme.Secondary,
            BorderSizePixel = 0
        })

        Utility:Corner(FPSFrame,12)
        Utility:Stroke(FPSFrame, Library.Theme.Stroke, 1)

        local FPSLabel = Utility:Create("TextLabel", {
            Parent = FPSFrame,
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(1,1),
            Text = "FPS: 0",
            Font = Enum.Font.GothamBold,
            TextSize = Mobile:Scale(12),
            TextColor3 = Library.Theme.Text
        })

        local Frames = 0
        local Last = tick()

        table.insert(Library.Connections, RunService.RenderStepped:Connect(function()
            Frames += 1
            if tick() - Last >= 1 then
                FPSLabel.Text = "FPS: ".. tostring(Frames)
                Frames = 0
                Last = tick()
            end
        end))

        return FPSFrame
    end

    --//======================================================
    --// MOBILE GESTURES - FIXED
    --//======================================================

    if Mobile:IsMobile() then
        local TouchStart
        local StartPos

        Main.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch then
                TouchStart = Input.Position
                StartPos = Main.Position
            end
        end)

        Main.InputChanged:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.Touch and TouchStart then
                local Delta = Input.Position - TouchStart

                if math.abs(Delta.Y) > 120 then
                    if Delta.Y > 0 then
                        Minimized = true
                        Sidebar.Visible = false
                        Pages.Visible = false
                        Utility:Tween(Main, 0.25, {Size = UDim2.new(0,260,0,60)})
                    else
                        Minimized = false
                        Sidebar.Visible = true
                        Pages.Visible = true
                        Utility:Tween(Main, 0.25, {Size = OriginalSize})
                    end
                    TouchStart = nil
                end
            end
        end)
    end

    --//======================================================
    --// THEME SYSTEM
    --//======================================================

    function Library:SetTheme(NewTheme)
        for Property, Value in pairs(NewTheme) do
            if Library.Theme[Property] then
                Library.Theme[Property] = Value
            end
        end
    end

    --//======================================================
    --// DESTROY
    --//======================================================

    function Window:Destroy()
        for _, Connection in pairs(Library.Connections) do
            pcall(function()
                Connection:Disconnect()
            end)
        end
        ScreenGui:Destroy()
    end

    return Window
end

return Library
