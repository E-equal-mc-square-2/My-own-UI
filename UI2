	local notifications = New("Frame", {
		Name = "Notifications",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -16, 0, 16),
		Size = UDim2.new(0, 340, 1, -32),
		Parent = top
	})
	AddListLayout(notifications, 10)
	self._notificationHolder = notifications

	local wmFrame = New("Frame", {
		Name = "Watermark",
		BackgroundColor3 = self.Theme.Card,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 16, 0, 16),
		Size = UDim2.fromOffset(270, 34),
		Parent = top
	})
	ApplyCorner(wmFrame, 12)
	ApplyStroke(wmFrame, self.Theme.Stroke, 0.45, 1)
	ApplyGradient(wmFrame, self.Theme.Card2, self.Theme.Card, 0)
	self._watermarkFrame = wmFrame

	local wm = New("TextLabel", {
		Name = "Text",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(10, 0),
		Size = UDim2.new(1, -20, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = "NeonVX | " .. self._executor,
		TextColor3 = self.Theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = wmFrame
	})
	self._watermark = wm

	local fpsFrame = New("Frame", {
		Name = "FPS",
		BackgroundColor3 = self.Theme.Card,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 16, 0, 56),
		Size = UDim2.fromOffset(98, 28),
		Parent = top
	})
	ApplyCorner(fpsFrame, 10)
	ApplyStroke(fpsFrame, self.Theme.Stroke, 0.45, 1)

	local fpsText = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(8, 0),
		Size = UDim2.new(1, -12, 1, 0),
		Font = Enum.Font.GothamMedium,
		Text = "FPS 0",
		TextColor3 = self.Theme.Text,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = fpsFrame
	})
	self._fpsLabel = fpsText

	local fpsAcc = 0
	local fpsCount = 0

	self._fpsConn = RunService.RenderStepped:Connect(function(dt)
		fpsAcc += dt
		fpsCount += 1
		if fpsAcc >= 1 then
			local fps = math.floor((fpsCount / fpsAcc) + 0.5)
			if self._fpsLabel then
				self._fpsLabel.Text = "FPS " .. tostring(fps)
			end
			fpsAcc = 0
			fpsCount = 0
		end
		if self._watermark then
			self._watermark.Text = ("NeonVX | %s | %s"):format(self._executor, os.date("%H:%M:%S"))
		end
		if self._blur then
			self._blur.Size = self._blur.Size + ((self._blurGoal or 0) - self._blur.Size) * 0.15
		end
	end)
end

