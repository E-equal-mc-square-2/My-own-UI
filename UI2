local ConnectionManager = {}
ConnectionManager.Connections = {}

function ConnectionManager:Add(connection)
    table.insert(self.Connections, connection)
    return connection
end

function ConnectionManager:DisconnectAll()
    for _, connection in ipairs(self.Connections) do
        if connection.Connected then
            connection:Disconnect()
        end
    end
    self.Connections = {}
end

--//======================================================
--// CONFIG SYSTEM
--//======================================================

local ConfigSystem = {}
ConfigSystem.Flags = {}
ConfigSystem.AutoSaveEnabled = true
ConfigSystem.SaveFileName = "NexusUI_Config.json"

function ConfigSystem:SetFlag(flag, value)
    self.Flags[flag] = value
    if self.AutoSaveEnabled then
        task.delay(1, function()
            self:SaveConfig()
        end)
    end
end

function ConfigSystem:GetFlag(flag, default)
    return self.Flags[flag] or default
end

function ConfigSystem:SaveConfig()
    local success, result = pcall(function()
        local data = HttpService:JSONEncode(self.Flags)
        writefile(self.SaveFileName, data)
        return true
    end)
    return success
end

function ConfigSystem:LoadConfig()
    local success, result = pcall(function()
        if isfile(self.SaveFileName) then
            local data = readfile(self.SaveFileName)
            self.Flags = HttpService:JSONDecode(data)
            return true
        end
        return false
    end)
    return success
end

function ConfigSystem:DeleteConfig()
    local success = pcall(function()
        if isfile(self.SaveFileName) then
            delfile(self.SaveFileName)
        end
    end)
    return success
end

