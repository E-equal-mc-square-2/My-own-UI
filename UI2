                function tb:Set(val)
                    tb.Value = val
                    InputField.Text = val
                    NeonPrime.Flags[tb.Flag] = val
                    task.spawn(tb.Callback, val)
                end
                
                Utility:Connection(InputField.Focused, function()
                    Utility:Tween(Stroke, {Color = NeonPrime.Theme.Primary}, 0.3)
                end)
                
                Utility:Connection(InputField.FocusLost, function()
                    Utility:Tween(Stroke, {Color = NeonPrime.Theme.StrokeLight}, 0.3)
                    tb:Set(InputField.Text)
                end)
                
                return tb
            end

            --// KEYBIND
            function Section:CreateKeybind(options)
                local kb = {
                    Name = options.Name or "Keybind",
                    Flag = options.Flag or tostring(math.random(1000,9999)),
                    Key = options.Default or Enum.KeyCode.E,
                    Callback = options.Callback or function() end,
                    Binding = false
                }
                NeonPrime.Flags[kb.Flag] = kb.Key.Name
                
                local KbFrame = Utility:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, NeonPrime.Theme.Sizes.ElementHeight),
                    BackgroundTransparency = 1,
                    Parent = SectionFrame
                })
                
                local Title = Utility:Create("TextLabel", {
                    Size = UDim2.new(1, -100, 1, 0),
                    BackgroundTransparency = 1,
                    Text = kb.Name,
                    TextColor3 = NeonPrime.Theme.Text,
                    FontFace = NeonPrime.Theme.Font,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = KbFrame
                })
                
                local BindBtn = Utility:Create("TextButton", {
                    Size = UDim2.new(0, 80, 0, 32),
                    Position = UDim2.new(1, -80, 0.5, -16),
                    BackgroundColor3 = NeonPrime.Theme.SurfaceLight,
                    Text = kb.Key.Name,
                    TextColor3 = NeonPrime.Theme.Primary,
                    FontFace = NeonPrime.Theme.FontBold,
                    TextSize = 14,
                    AutoButtonColor = false,
                    Parent = KbFrame
                })
                Utility:AddCorner(BindBtn)
                local Stroke = Utility:AddStroke(BindBtn, NeonPrime.Theme.StrokeLight)
                
                function kb:Set(key)
                    kb.Key = key
                    BindBtn.Text = key.Name
                    NeonPrime.Flags[kb.Flag] = key.Name
                end
                
                Utility:Connection(BindBtn.MouseButton1Click, function()
                    kb.Binding = true
                    BindBtn.Text = "..."
                    Utility:Tween(Stroke, {Color = NeonPrime.Theme.Primary}, 0.2)
                end)
                
                Utility:Connection(UserInputService.InputBegan, function(input, gpe)
                    if kb.Binding then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            local key = input.KeyCode
                            if key == Enum.KeyCode.Escape then
                                kb:Set(kb.Key) -- Cancel
                            else
                                kb:Set(key)
                            end
                            kb.Binding = false
                            Utility:Tween(Stroke, {Color = NeonPrime.Theme.StrokeLight}, 0.2)
                        end
                    elseif not gpe and input.KeyCode == kb.Key then
                        task.spawn(kb.Callback)
                    end
                end)
                
                return kb
            end
            
            --// COLOR PICKER (Advanced)
            function Section:CreateColorPicker(options)
                local cp = {
                    Name = options.Name or "Color Picker",
                    Flag = options.Flag or tostring(math.random(1000,9999)),
                    Color = options.Default or Color3.new(1,0,0),
                    Callback = options.Callback or function() end,
                    Expanded = false
                }
                NeonPrime.Flags[cp.Flag] = cp.Color
                
                local H, S, V = cp.Color:ToHSV()
                
                local CpFrame = Utility:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, NeonPrime.Theme.Sizes.ElementHeight),
                    BackgroundColor3 = NeonPrime.Theme.SurfaceLight,
                    ClipsDescendants = true,
                    Parent = SectionFrame
                })
                Utility:AddCorner(CpFrame)
                local Stroke = Utility:AddStroke(CpFrame, NeonPrime.Theme.StrokeLight)
                
                local HeaderBtn = Utility:Create("TextButton", {
                    Size = UDim2.new(1, 0, 0, NeonPrime.Theme.Sizes.ElementHeight),
                    BackgroundTransparency = 1,
                    Text = "",
                    Parent = CpFrame
                })
                
                local Title = Utility:Create("TextLabel", {
                    Size = UDim2.new(1, -60, 1, 0),
                    Position = UDim2.new(0, 12, 0, 0),
                    BackgroundTransparency = 1,
                    Text = cp.Name,
                    TextColor3 = NeonPrime.Theme.Text,
                    FontFace = NeonPrime.Theme.Font,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = HeaderBtn
                })
                
                local ColorDisplay = Utility:Create("Frame", {
                    Size = UDim2.new(0, 36, 0, 24),
                    Position = UDim2.new(1, -48, 0.5, -12),
                    BackgroundColor3 = cp.Color,
                    Parent = HeaderBtn
                })
                Utility:AddCorner(ColorDisplay, 6)
                Utility:AddStroke(ColorDisplay, NeonPrime.Theme.StrokeDark)
                
                -- Expanded Content
                local PickerArea = Utility:Create("Frame", {
                    Size = UDim2.new(1, -24, 0, 150),
                    Position = UDim2.new(0, 12, 0, 50),
                    BackgroundTransparency = 1,
                    Parent = CpFrame
                })
                
                local SatValMap = Utility:Create("TextButton", {
                    Size = UDim2.new(1, -40, 1, -10),
                    BackgroundColor3 = Color3.fromHSV(H, 1, 1),
                    Text = "",
                    AutoButtonColor = false,
                    Parent = PickerArea
                })
                Utility:AddCorner(SatValMap, 6)
                
                local ValGradient = Utility:Create("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                        ColorSequenceKeypoint.new(1, Color3.new(0,0,0))
                    },
                    Rotation = 90,
                    Parent = SatValMap
                })
                
                local SatGradient = Utility:Create("ImageLabel", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Image = "rbxassetid://3887014957", -- White to trans map
                    Parent = SatValMap
                })
                Utility:AddCorner(SatGradient, 6)
                
                local MapCursor = Utility:Create("Frame", {
                    Size = UDim2.new(0, 10, 0, 10),
                    Position = UDim2.new(S, -5, 1 - V, -5),
                    BackgroundColor3 = Color3.new(1,1,1),
                    Parent = SatValMap
                })
                Utility:AddCorner(MapCursor, 5)
                Utility:AddStroke(MapCursor, Color3.new(0,0,0))
                
                local HueSlider = Utility:Create("TextButton", {
                    Size = UDim2.new(0, 24, 1, -10),
                    Position = UDim2.new(1, -24, 0, 0),
                    Text = "",
                    AutoButtonColor = false,
                    Parent = PickerArea
                })
                Utility:AddCorner(HueSlider, 6)
                Utility:Create("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.new(1,0,0)),
                        ColorSequenceKeypoint.new(0.167, Color3.new(1,1,0)),
                        ColorSequenceKeypoint.new(0.333, Color3.new(0,1,0)),
                        ColorSequenceKeypoint.new(0.5, Color3.new(0,1,1)),
                        ColorSequenceKeypoint.new(0.667, Color3.new(0,0,1)),
                        ColorSequenceKeypoint.new(0.833, Color3.new(1,0,1)),
                        ColorSequenceKeypoint.new(1, Color3.new(1,0,0))
                    },
                    Rotation = 90,
                    Parent = HueSlider
                })
                
                local HueCursor = Utility:Create("Frame", {
                    Size = UDim2.new(1, 4, 0, 6),
                    Position = UDim2.new(0, -2, H, -3),
                    BackgroundColor3 = Color3.new(1,1,1),
                    Parent = HueSlider
                })
                Utility:AddCorner(HueCursor, 3)
                Utility:AddStroke(HueCursor, Color3.new(0,0,0))
                
                local function UpdateColor()
                    local col = Color3.fromHSV(H, S, V)
                    cp.Color = col
                    NeonPrime.Flags[cp.Flag] = col
                    SatValMap.BackgroundColor3 = Color3.fromHSV(H, 1, 1)
                    ColorDisplay.BackgroundColor3 = col
                    task.spawn(cp.Callback, col)
                end
                
                function cp:Set(color)
                    H, S, V = color:ToHSV()
                    MapCursor.Position = UDim2.new(S, -5, 1 - V, -5)
                    HueCursor.Position = UDim2.new(0, -2, H, -3)
                    UpdateColor()
                end
                
                local draggingMap, draggingHue = false, false
                
                Utility:Connection(SatValMap.InputBegan, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                        draggingMap = true
                    end
                end)
                Utility:Connection(HueSlider.InputBegan, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                        draggingHue = true
                    end
                end)
                Utility:Connection(UserInputService.InputEnded, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                        draggingMap = false
                        draggingHue = false
                    end
                end)
                
                Utility:Connection(UserInputService.InputChanged, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
                        if draggingMap then
                            local x = math.clamp((inp.Position.X - SatValMap.AbsolutePosition.X) / SatValMap.AbsoluteSize.X, 0, 1)
                            local y = math.clamp((inp.Position.Y - SatValMap.AbsolutePosition.Y) / SatValMap.AbsoluteSize.Y, 0, 1)
                            S, V = x, 1 - y
                            MapCursor.Position = UDim2.new(S, -5, 1 - V, -5)
                            UpdateColor()
                        elseif draggingHue then
                            local y = math.clamp((inp.Position.Y - HueSlider.AbsolutePosition.Y) / HueSlider.AbsoluteSize.Y, 0, 1)
                            H = y
                            HueCursor.Position = UDim2.new(0, -2, H, -3)
                            UpdateColor()
                        end
                    end
                end)
                
                Utility:Connection(HeaderBtn.MouseButton1Click, function()
                    cp.Expanded = not cp.Expanded
                    Utility:Tween(CpFrame, {Size = UDim2.new(1, 0, 0, cp.Expanded and 210 or NeonPrime.Theme.Sizes.ElementHeight)}, 0.3, Enum.EasingStyle.Quint)
                    Utility:Tween(Stroke, {Color = cp.Expanded and NeonPrime.Theme.Primary or NeonPrime.Theme.StrokeLight}, 0.3)
                end)
                
                return cp
            end
            
            --// LABEL
            function Section:CreateLabel(text)
                local lbl = {}
                local LabelText = Utility:Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 24),
                    BackgroundTransparency = 1,
                    Text = text,
                    TextColor3 = NeonPrime.Theme.SubText,
                    FontFace = NeonPrime.Theme.Font,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = SectionFrame
                })
                function lbl:Set(newText) LabelText.Text = newText end
                return lbl
            end

            --// PARAGRAPH
            function Section:CreateParagraph(options)
                local para = {}
                local PFrame = Utility:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 0), -- Auto size
                    BackgroundColor3 = NeonPrime.Theme.Background,
                    Parent = SectionFrame
                })
                Utility:AddCorner(PFrame)
                Utility:AddPadding(PFrame, 10)
                Utility:AddStroke(PFrame, NeonPrime.Theme.StrokeDark)
                
                local Title = Utility:Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text = options.Title or "Paragraph",
                    TextColor3 = NeonPrime.Theme.Primary,
                    FontFace = NeonPrime.Theme.FontBold,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = PFrame
                })
                
                local Content = Utility:Create("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 0),
                    Position = UDim2.new(0, 0, 0, 24),
                    BackgroundTransparency = 1,
                    Text = options.Content or "",
                    TextColor3 = NeonPrime.Theme.SubText,
                    FontFace = NeonPrime.Theme.FontRegular,
                    TextSize = 13,
                    TextWrapped = true,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    Parent = PFrame
                })
                
                local function UpdateSize()
                    local bounds = Utility:GetTextBounds(Content.Text, NeonPrime.Theme.FontRegular, 13, PFrame.AbsoluteSize.X - 20)
                    Content.Size = UDim2.new(1, 0, 0, bounds.Y)
                    PFrame.Size = UDim2.new(1, 0, 0, 24 + bounds.Y + 20)
                end
                
                function para:Set(newContent)
                    Content.Text = newContent
                    UpdateSize()
                end
                
                UpdateSize()
                Utility:Connection(PFrame:GetPropertyChangedSignal("AbsoluteSize"), UpdateSize)
                
                return para
            end
            
            --// SEPARATOR
            function Section:CreateSeparator()
                local Sep = Utility:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Parent = SectionFrame
                })
                Utility:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 1),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = NeonPrime.Theme.StrokeDark,
                    BorderSizePixel = 0,
                    Parent = Sep
                })
            end

            return Section
        end
        return Tab
    end
    
    return Window
end

--//=======================================================================================
--// INITIALIZATION & RETURN
--//=======================================================================================

ConfigSystem:Init()

function NeonPrime:SaveConfig(name)
    ConfigSystem:Save(name)
end

function NeonPrime:LoadConfig(name)
    ConfigSystem:Load(name)
end

function NeonPrime:Notify(title, text, duration, typeIcon)
    NotificationSystem:Notify(title, text, duration, typeIcon)
end

function NeonPrime:SetThemeColor(property, color)
    if NeonPrime.Theme[property] then
        NeonPrime.Theme[property] = color
        -- Note: In a fully reactive system, this would fire an event. For this scale,
        -- it updates the table. New elements use the new color.
    end
end

-- Cleanup Logic for Re-execution
function NeonPrime:Destroy()
    for _, conn in pairs(self.Connections) do
        if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
    end
    for _, inst in pairs(self.Instances) do
        if typeof(inst) == "Instance" and inst.Parent then inst:Destroy() end
    end
    table.clear(self.Connections)
    table.clear(self.Instances)
end

return Library
