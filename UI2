local TabMT = {}
TabMT.__index = TabMT

function WindowMT:AddTab(name, icon)
	local tab = setmetatable({}, TabMT)
	tab.Window = self
	tab.Name = tostring(name or "Tab")
	tab.Icon = tostring(icon or "◉")
	tab.Sections = {}
	tab.Elements = {}
	tab.Destroyed = false
	tab.Page = nil
	tab.Button = nil
	tab.ButtonStroke = nil
	tab.ActiveBar = nil
	tab.SectionCount = 0

	local theme = self.Library.Theme

	local button = New("TextButton", {
		BackgroundColor3 = theme.Card2,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(120, 42),
		AutoButtonColor = false,
		Text = "",
		Parent = self.TabScroller
	})
	ApplyCorner(button, 14)
	local stroke = ApplyStroke(button, theme.Stroke, 0.5, 1)

	local iconLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(12, 0),
		Size = UDim2.fromOffset(18, 42),
		Font = Enum.Font.GothamBold,
		Text = tab.Icon,
		TextColor3 = theme.Accent,
		TextSize = 15,
		Parent = button
	})

	local nameLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(34, 0),
		Size = UDim2.new(1, -40, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tab.Name,
		TextColor3 = theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = button
	})

	local activeBar = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 12, 1, -4),
		Size = UDim2.new(1, -24, 0, 2),
		BackgroundTransparency = 1,
		Parent = button
	})
	ApplyCorner(activeBar, 999)
	ApplyGradient(activeBar, theme.Accent, theme.Accent2, 0)

	button.MouseButton1Click:Connect(function()
		self:_updateTabButtonActive(tab)
	end)

	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(button, theme, input.Position - button.AbsolutePosition)
		end
	end)

	local page = New("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Visible = false,
		Size = UDim2.new(1, 0, 1, 0),
		CanvasSize = UDim2.fromOffset(0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollBarThickness = 4,
		ScrollBarImageColor3 = theme.Accent,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		Parent = self.PageStack
	})
	AddPadding(page, 0, 4, 0, 8)
	AddListLayout(page, 12).HorizontalAlignment = Enum.HorizontalAlignment.Center

	tab.Page = page
	tab.Button = button
	tab.ButtonStroke = stroke
	tab.ActiveBar = activeBar

	table.insert(self.Tabs, tab)
	self.ActiveTab = self.ActiveTab or tab
	self:_updateTabButtonActive(self.ActiveTab or tab)

	return tab
end

function TabMT:_searchMatch(query)
	query = string.lower(tostring(query or ""))
	if query == "" then
		return true
	end
	return string.find(string.lower(self.Name), query, 1, true) ~= nil
end

function TabMT:Show()
	self.Window:_updateTabButtonActive(self)
end

function TabMT:AddSection(title, subtitle)
	local section = setmetatable({}, SectionMT)
	section.Tab = self
	section.Window = self.Window
	section.Title = tostring(title or "Section")
	section.Subtitle = tostring(subtitle or "")
	section.Elements = {}
	section.SearchQuery = ""
	section.Destroyed = false

	local theme = self.Window.Library.Theme

	local card = New("Frame", {
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = self.Page
	})
	ApplyCorner(card, 18)
	ApplyStroke(card, theme.Stroke, 0.42, 1)
