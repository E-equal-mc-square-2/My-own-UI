--//======================================================
--// UTILITIES
--//======================================================

local function SafeCall(fn, ...)
	local ok, res = pcall(fn, ...)
	if ok then
		return res
	end
	return nil
end

local function IsExecutorFunction(name)
	return type(rawget(getfenv and getfenv() or _G, name)) ~= "nil"
end

local function Clamp(v, a, b)
	return math.max(a, math.min(b, v))
end

local function Round(n)
	return math.floor(n + 0.5)
end

local function UDim2Offset(x, y)
	return UDim2.fromOffset(x, y)
end

local function ColorSequenceFrom(a, b)
	return ColorSequence.new({
		ColorSequenceKeypoint.new(0, a),
		ColorSequenceKeypoint.new(1, b)
	})
end

local function New(className, props)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	return obj
end

local function DestroyIfExists(obj)
	if obj then
		pcall(function()
			obj:Destroy()
		end)
	end
end

local function Tween(inst, info, props)
	local t = TweenService:Create(inst, info, props)
	t:Play()
	return t
end

local function SetTextBounds(label, maxWidth, font, size)
	local textService = game:GetService("TextService")
	return textService:GetTextSize(label.Text, size, font, Vector2.new(maxWidth, 1000))
end

local function ApplyCorner(inst, radius)
	local c = New("UICorner", { CornerRadius = UDim.new(0, radius or 12), Parent = inst })
	return c
end

local function ApplyStroke(inst, themeColor, transparency, thickness)
	local s = New("UIStroke", {
		Color = themeColor,
		Transparency = transparency or 0.35,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = inst
	})
	return s
end

local function ApplyGradient(inst, c1, c2, rotation)
	local g = New("UIGradient", {
		Color = ColorSequenceFrom(c1, c2),
		Rotation = rotation or 0,
		Parent = inst
	})
	return g
end

local function AddPadding(inst, left, right, top, bottom)
	return New("UIPadding", {
		PaddingLeft = UDim.new(0, left or 0),
		PaddingRight = UDim.new(0, right or 0),
		PaddingTop = UDim.new(0, top or 0),
		PaddingBottom = UDim.new(0, bottom or 0),
		Parent = inst
	})
end

local function AddListLayout(parent, pad, sortOrder)
	return New("UIListLayout", {
		Padding = UDim.new(0, pad or 0),
		SortOrder = sortOrder or Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Top,
		Parent = parent
	})
end

local function AddShadow(parent, theme)
	local shadow = New("Frame", {
		BackgroundColor3 = theme.Shadow,
		BackgroundTransparency = 0.56,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 16, 1, 18),
		Position = UDim2.new(0, -8, 0, -2),
		ZIndex = parent.ZIndex - 1,
		Parent = parent
	})
	ApplyCorner(shadow, 22)
	local stroke = ApplyStroke(shadow, theme.Shadow, 0.95, 1)
	stroke.Enabled = false
	return shadow
end

local function Rippler(parent, theme, inputPosition)
	local circle = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BackgroundTransparency = 0.72,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromOffset(inputPosition.X, inputPosition.Y),
		Size = UDim2.fromOffset(0, 0),
		ZIndex = parent.ZIndex + 20,
		Parent = parent
	})
	ApplyCorner(circle, 999)
	local maxDim = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.4
	Tween(circle, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(maxDim, maxDim),
		BackgroundTransparency = 1
	})
	task.delay(0.5, function()
		DestroyIfExists(circle)
	end)
end

local function IsTouch()
	return UserInputService.TouchEnabled
end

local function GetViewport()
	local cam = workspace.CurrentCamera
	if cam then
		return cam.ViewportSize
	end
	return Vector2.new(1280, 720)
end

local function PickParentGui()
