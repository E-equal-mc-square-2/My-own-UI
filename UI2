local Utility = {}

function Utility:Create(class, props)
    local obj = Instance.new(class)

    for i,v in pairs(props or {}) do
        obj[i] = v
    end

    return obj
end

function Utility:Tween(obj, info, props)
    local tween = TweenService:Create(obj, info, props)
    tween:Play()
    return tween
end

function Utility:Ripple(button)
    local mouse = UserInputService:GetMouseLocation()

    local ripple = Utility:Create("Frame", {
        Parent = button,
        BackgroundColor3 = Color3.new(1,1,1),
        BackgroundTransparency = 0.7,
        AnchorPoint = Vector2.new(0.5,0.5),
        Size = UDim2.new(0,0,0,0),
        Position = UDim2.new(0, mouse.X - button.AbsolutePosition.X, 0, mouse.Y - button.AbsolutePosition.Y),
        ZIndex = 999
    })

    local corner = Utility:Create("UICorner", {
        CornerRadius = UDim.new(1,0),
        Parent = ripple
    })

    Utility:Tween(
        ripple,
        TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        {
            Size = UDim2.new(0,300,0,300),
            BackgroundTransparency = 1
        }
    )

    task.delay(0.5, function()
        ripple:Destroy()
    end)
end

function Utility:Shadow(parent, transparency)
    local shadow = Utility:Create("ImageLabel", {
        Name = "Shadow",
        Parent = parent,
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageTransparency = transparency or 0.5,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49,49,450,450),
        Size = UDim2.new(1,60,1,60),
        Position = UDim2.new(0,-30,0,-30),
        ZIndex = parent.ZIndex - 1
    })

    return shadow
end

function Utility:Stroke(parent, color, thickness)
    return Utility:Create("UIStroke", {
        Parent = parent,
        Color = color,
        Thickness = thickness or 1,
        Transparency = 0.2
    })
end

function Utility:Gradient(parent, c1, c2, rotation)
    return Utility:Create("UIGradient", {
        Parent = parent,
        Color = ColorSequence.new(c1,c2),
        Rotation = rotation or 45
    })
end

function Utility:Round(parent, radius)
    return Utility:Create("UICorner", {
        Parent = parent,
        CornerRadius = UDim.new(0, radius or 12)
    })
end

function Utility:Padding(parent, padding)
    return Utility:Create("UIPadding", {
        Parent = parent,
        PaddingTop = UDim.new(0,padding),
        PaddingBottom = UDim.new(0,padding),
        PaddingLeft = UDim.new(0,padding),
        PaddingRight = UDim.new(0,padding)
    })
end

function Utility:Drag(frame, dragHandle)
    dragHandle = dragHandle or frame

    local dragging = false
    local dragInput
    local dragStart
    local startPos

    local function update(input)
        local delta = input.Position - dragStart

        local position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )

        Utility:Tween(frame, TweenInfo.new(0.05), {
            Position = position
        })
    end

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

