--//======================================================
--// CONFIG SYSTEM
--//======================================================

function Library:_makeConfigTable()
	local data = {}
	for flag, value in pairs(self.Flags) do
		data[flag] = EncodeValue(value)
	end
	return data
end

function Library:_applyConfigTable(data)
	for flag, entry in pairs(data) do
		local value = DecodeValue(entry)
		self.Flags[flag] = value
		if self._flagSetters and self._flagSetters[flag] then
			pcall(function()
				self._flagSetters[flag](value, true)
			end)
		end
	end
end

function Library:SaveConfig(name)
	local configName = tostring(name or self._autoSaveName or "default")
	local encoded = HttpService:JSONEncode(self:_makeConfigTable())

	if SafeFileSystem() then
		SafeMakeFolder(self._configDir)
		writefile(self._configDir .. "/" .. configName .. ".json", encoded)
	else
		self._memoryConfigs[configName] = encoded
	end
	return true
end

function Library:LoadConfig(name)
	local configName = tostring(name or self._autoSaveName or "default")
	local encoded

	if SafeFileSystem() then
		local path = self._configDir .. "/" .. configName .. ".json"
		if isfile(path) then
			encoded = readfile(path)
		end
	else
		encoded = self._memoryConfigs[configName]
	end

	if not encoded or encoded == "" then
		return false
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(encoded)
	end)

	if ok and type(decoded) == "table" then
		self:_applyConfigTable(decoded)
		return true
	end

	return false
end

function Library:SetAutoSave(enabled, name)
	self._autoSave = enabled and true or false
	if name then
		self._autoSaveName = tostring(name)
	end
end

function Library:_registerFlag(flag, setter)
	if not self._flagSetters then
		self._flagSetters = {}
	end
	self._flagSetters[flag] = setter
end

function Library:_setFlag(flag, value)
	self.Flags[flag] = value
	if self._autoSave then
		task.spawn(function()
			self:SaveConfig(self._autoSaveName)
		end)
	end
end

