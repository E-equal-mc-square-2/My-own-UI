                Utility:AddCorner(hueIndicator, UDim.new(1, 0))
                Utility:AddStroke(hueIndicator, Color3.fromRGB(0, 0, 0), 1)
                
                local function updateColor(newColor, skipCallback)
                    currentColor = newColor
                    colorDisplay.BackgroundColor3 = newColor
                    
                    if flag then
                        ConfigSystem:SetFlag(flag, newColor)
                    end
                    
                    if not skipCallback then
                        pcall(callback, newColor)
                    end
                end
                
                local draggingSatVal = false
                local draggingHue = false
                
                satValSelector.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingSatVal = true
                        
                        local function update()
                            local mousePos = UserInputService:GetMouseLocation()
                            local selectorPos = satValSelector.AbsolutePosition
                            local selectorSize = satValSelector.AbsoluteSize
                            
                            sat = math.clamp((mousePos.X - selectorPos.X) / selectorSize.X, 0, 1)
                            val = 1 - math.clamp((mousePos.Y - selectorPos.Y) / selectorSize.Y, 0, 1)
                            
                            satValIndicator.Position = UDim2.new(sat, -4, 1 - val, -4)
                            
                            local newColor = Color3.fromHSV(hue, sat, val)
                            updateColor(newColor)
                        end
                        
                        update()
                        
                        local connection
                        connection = UserInputService.InputChanged:Connect(function(input2)
                            if draggingSatVal and (input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch) then
                                update()
                            end
                        end)
                        
                        local endConnection
                        endConnection = UserInputService.InputEnded:Connect(function(input2)
                            if input2.UserInputType == Enum.UserInputType.MouseButton1 or input2.UserInputType == Enum.UserInputType.Touch then
                                draggingSatVal = false
                                connection:Disconnect()
                                endConnection:Disconnect()
                            end
                        end)
                    end
                end)
                
                hueSelector.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        draggingHue = true
                        
                        local function update()
                            local mousePos = UserInputService:GetMouseLocation()
                            local selectorPos = hueSelector.AbsolutePosition
                            local selectorSize = hueSelector.AbsoluteSize
                            
                            hue = math.clamp((mousePos.X - selectorPos.X) / selectorSize.X, 0, 1)
                            
                            hueIndicator.Position = UDim2.new(hue, -2, 0, 0)
                            satValSelector.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
                            
                            local newColor = Color3.fromHSV(hue, sat, val)
                            updateColor(newColor)
                        end
                        
                        update()
                        
                        local connection
                        connection = UserInputService.InputChanged:Connect(function(input2)
                            if draggingHue and (input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch) then
                                update()
                            end
                        end)
                        
                        local endConnection
                        endConnection = UserInputService.InputEnded:Connect(function(input2)
                            if input2.UserInputType == Enum.UserInputType.MouseButton1 or input2.UserInputType == Enum.UserInputType.Touch then
                                draggingHue = false
                                connection:Disconnect()
                                endConnection:Disconnect()
                            end
                        end)
                    end
                end)
                
                colorDisplay.MouseButton1Click:Connect(function()
                    colorPickerOpen = not colorPickerOpen
                    colorPickerFrame.Visible = colorPickerOpen
                    
                    if colorPickerOpen then
                        Utility:Tween(colorPickerFrame, {Size = UDim2.new(0, 220, 0, 200)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    else
                        Utility:Tween(colorPickerFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In, function()
                            colorPickerFrame.Visible = false
                        end)
                    end
                end)
                
                local ColorPicker = {}
                function ColorPicker:Set(color)
                    hue, sat, val = color:ToHSV()
                    satValIndicator.Position = UDim2.new(sat, -4, 1 - val, -4)
                    hueIndicator.Position = UDim2.new(hue, -2, 0, 0)
                    satValSelector.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
                    updateColor(color, false)
                end
                
