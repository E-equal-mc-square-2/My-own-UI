                    TextColor3 = Theme.Accent,
                    TextSize = Theme.TextSize,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = SliderFrame
                })
                
                local Track = Utility:Create("Frame", {
                    BackgroundColor3 = Theme.Tertiary,
                    Position = UDim2.new(0, 0, 0, 35),
                    Size = UDim2.new(1, 0, 0, 8),
                    Parent = SliderFrame
                })
                Utility:AddCorner(Track, UDim.new(1, 0))
                Utility:AddStroke(Track, Theme.Stroke)
                
                local Fill = Utility:Create("Frame", {
                    BackgroundColor3 = Theme.Accent,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                    Parent = Track
                })
                Utility:AddCorner(Fill, UDim.new(1, 0))
                Utility:CreateGlow(Fill, Theme.Accent)
                
                local Thumb = Utility:Create("Frame", {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.new(0, 16, 0, 16),
                    Parent = Fill
                })
                Utility:AddCorner(Thumb, UDim.new(1, 0))
                Utility:CreateShadow(Thumb, 0.3)
                
                local TouchArea = Utility:Create("TextButton", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, -10),
                    Size = UDim2.new(1, 0, 1, 20),
                    Text = "",
                    Parent = Track
                })

                local function SetValue(val)
                    val = math.clamp(tonumber(val) or min, min, max)
                    val = math.floor(val * 10) / 10 -- 1 decimal place
                    Value = val
                    Utility.Flags[flag] = {Value = Value, Set = SetValue}
                    
                    local percent = (Value - min) / (max - min)
                    Utility:Tween(Fill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
                    ValueBox.Text = tostring(Value) .. suffix
                    pcall(callback, Value)
                end
                
                Utility.Flags[flag] = {Value = Value, Set = SetValue}
                
                local dragging = false
                local function UpdateSlider(input)
                    local percent = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    local val = min + (max - min) * percent
                    SetValue(val)
                end
                
                TouchArea.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        UpdateSlider(input)
                        Utility:Tween(Thumb, {Size = UDim2.new(0, 20, 0, 20)}, 0.2)
                    end
                end)
                
                TouchArea.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                        Utility:Tween(Thumb, {Size = UDim2.new(0, 16, 0, 16)}, 0.2)
                    end
                end)
                
                Utility:Connect(UserInputService.InputChanged, function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        UpdateSlider(input)
                    end
                end)
                
                ValueBox.FocusLost:Connect(function()
                    SetValue(ValueBox.Text:gsub(suffix, ""))
                end)
            end

            -- DROPDOWN (Inline Expander)
            function Section:CreateDropdown(options)
                local name = options.Name or "Dropdown"
                local list = options.Options or {}
                local default = options.Default or list[1]
                local flag = options.Flag or name:gsub("%s+", "")
                local multi = options.Multiple or false
                local callback = options.Callback or function() end
                
                local CurrentSelected = multi and (type(default) == "table" and default or {default}) or default
                local Expanded = false
                
                local DropdownFrame = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 65),
