		TextColor3 = theme.Text,
		TextSize = 14,
		Parent = holder
	})

	local listHeight = math.min(#listItems * 42 + 8, 188)
	local list = New("ScrollingFrame", {
		BackgroundColor3 = theme.Background,
		BorderSizePixel = 0,
		Visible = false,
		Position = UDim2.fromOffset(0, 56),
		Size = UDim2.new(1, 0, 0, listHeight),
		CanvasSize = UDim2.fromOffset(0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		ScrollBarThickness = IsTouch() and 3 or 4,
		ScrollBarImageColor3 = theme.Accent,
		Parent = card
	})
	ApplyCorner(list, 12)
	ApplyStroke(list, theme.Stroke, 0.55, 1)
	AddPadding(list, 6, 6, 6, 6)
	local listLayout = AddListLayout(list, 6)
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder

	local expanded = false

	local function refreshText()
		local arr = {}
		for k, v in pairs(selected) do
			if v then
				table.insert(arr, k)
			end
		end
		table.sort(arr)
		holderText.Text = (#arr > 0) and table.concat(arr, ", ") or "None"
		holderText.TextColor3 = (#arr > 0) and theme.Text or theme.SubText
	end

	local function apply(v, silent)
		selected = {}
		if type(v) == "table" then
			for _, item in ipairs(v) do
				selected[item] = true
			end
		end
		self.Window.Library.Flags[flag] = v or {}
		refreshText()
		if not silent and callback then
			local out = {}
			for k, isOn in pairs(selected) do
				if isOn then
					table.insert(out, k)
				end
			end
			task.spawn(callback, out)
		end
	end

	local function getArray()
		local out = {}
		for k, isOn in pairs(selected) do
			if isOn then
				table.insert(out, k)
			end
		end
		table.sort(out)
		return out
	end

	local function rebuild()
		for _, child in ipairs(list:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end
		for _, opt in ipairs(listItems) do
			local isOn = selected[opt] and true or false
			local item = New("TextButton", {
				BackgroundColor3 = theme.Card2,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 38),
				Text = "",
				AutoButtonColor = false,
				Parent = list
			})
			ApplyCorner(item, 10)
			ApplyStroke(item, theme.Stroke, 0.6, 1)

			local box = New("Frame", {
				BackgroundColor3 = isOn and theme.Accent or theme.Muted,
				BorderSizePixel = 0,
				Position = UDim2.fromOffset(10, 9),
				Size = UDim2.fromOffset(20, 20),
				Parent = item
			})
			ApplyCorner(box, 6)

			local txt = New("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -44, 1, 0),
				Position = UDim2.fromOffset(38, 0),
				Font = Enum.Font.GothamMedium,
				Text = tostring(opt),
				TextColor3 = theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = item
			})

			item.MouseButton1Click:Connect(function()
				selected[opt] = not selected[opt]
				box.BackgroundColor3 = selected[opt] and theme.Accent or theme.Muted
				local out = getArray()
				self.Window.Library:SetFlag(flag, out)
				refreshText()
				if callback then
					task.spawn(callback, out)
				end
			end)

			item.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
					Rippler(item, theme, input.Position)
				end
			end)
		end
	end

	self.Window.Library:_registerFlag(flag, apply)
	self.Window.Library.Flags[flag] = {}
	apply(options.Default or {}, true)
	rebuild()

	holder.MouseButton1Click:Connect(function()
		expanded = not expanded
		list.Visible = expanded
		arrow.Text = expanded and "⌃" or "⌄"
	end)

	holder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(holder, theme, input.Position)
		end
	end)

	self:_bindTheme(function(th)
		card.BackgroundColor3 = th.Background
		label.TextColor3 = th.Text
		holder.BackgroundColor3 = th.Input
		holderText.TextColor3 = (#getArray() > 0) and th.Text or th.SubText
		arrow.TextColor3 = th.Text
		list.BackgroundColor3 = th.Background
		theme = th
		local s = card:FindFirstChildOfClass("UIStroke")
		if s then
			s.Color = th.Stroke
		end
	end)

	self:_registerElement({ Frame = card, SearchText = name .. " " .. table.concat(listItems, " ") })
	return {
		Set = function(_, arr)
			self.Window.Library:SetFlag(flag, arr)
			apply(arr, false)
		end,
		Get = function()
			return getArray()
		end
	}
end

function SectionClass:CreateKeybind(options)
	options = options or {}
