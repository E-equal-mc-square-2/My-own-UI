			local txt = New("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -18, 1, 0),
				Position = UDim2.fromOffset(10, 0),
				Font = Enum.Font.GothamMedium,
				Text = tostring(opt),
				TextColor3 = theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = item
			})
			item.MouseButton1Click:Connect(function()
				setValue(opt, false)
				expanded = false
				list.Visible = false
				arrow.Text = "⌄"
				self:_registerElement({ Frame = card, SearchText = tostring(text or "") .. " " .. tostring(opt) })
			end)
			item.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					Rippler(item, theme, input.Position - item.AbsolutePosition)
				end
			end)
		end
	end

	rebuild()

	holder.MouseButton1Click:Connect(function()
		expanded = not expanded
		list.Visible = expanded
		arrow.Text = expanded and "⌃" or "⌄"
	end)

	holder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			Rippler(holder, theme, input.Position - holder.AbsolutePosition)
		end
	end)

	self.Window.Library:_registerFlag(dropdownFlag, function(v, silent)
		setValue(v, silent)
	end)
	if #options > 0 then
		self.Window.Library.Flags[dropdownFlag] = options[1]
		setValue(options[1], true)
	end

	local meta = { Frame = card, SearchText = tostring(text or "") }
	self:_registerElement(meta)
	return {
		Set = function(_, v) setValue(v, false) end,
		Get = function() return current end,
		SetOptions = function(_, newOpts)
