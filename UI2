
--!strict
-- KilometresVoid UI Library
-- Single-file ModuleScript

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")

local LocalPlayer = Players.LocalPlayer

local Library = {}
Library.__index = Library

local DEFAULT_THEME = {
	Background = Color3.fromRGB(18, 18, 20),
	Topbar = Color3.fromRGB(24, 24, 28),
	Section = Color3.fromRGB(28, 28, 34),
	Stroke = Color3.fromRGB(60, 60, 72),
	Accent = Color3.fromRGB(0, 170, 255),
	AccentHover = Color3.fromRGB(35, 185, 255),
	Text = Color3.fromRGB(245, 245, 245),
	SubText = Color3.fromRGB(180, 180, 190),
	Danger = Color3.fromRGB(255, 95, 95),
	Radius = 12,
	Padding = 10,
	Font = Enum.Font.Gotham,
	FontBold = Enum.Font.GothamBold,
}

local function Create(className: string, props: {[string]: any}?)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	return obj
end

local function AddCorner(parent: Instance, radius: number)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function AddStroke(parent: Instance, color: Color3, thickness: number?)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness or 1
	s.Transparency = 0.25
	s.Parent = parent
	return s
end

local function AddPadding(parent: Instance, pad: number)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, pad)
	p.PaddingBottom = UDim.new(0, pad)
	p.PaddingLeft = UDim.new(0, pad)
	p.PaddingRight = UDim.new(0, pad)
	p.Parent = parent
	return p
end

local function Tween(instance: Instance, time: number, props: {[string]: any})
	local info = TweenInfo.new(time, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function MakeButton(parent: Instance, text: string, theme)
	local btn = Create("TextButton", {
		BackgroundColor3 = theme.Section,
		AutoButtonColor = false,
		Text = text,
		TextColor3 = theme.Text,
		Font = theme.Font,
		TextSize = 14,
		Size = UDim2.new(1, 0, 0, 36),
		Parent = parent,
	})
	AddCorner(btn, theme.Radius - 4)
	AddStroke(btn, theme.Stroke)
	return btn
end

function Library.new(config)
	config = config or {}

	local self = setmetatable({}, Library)
	self.Theme = table.clone(DEFAULT_THEME)
	if config.Theme then
		for k, v in pairs(config.Theme) do
			self.Theme[k] = v
		end
	end

	self.Title = config.Title or "KilometresVoid"
	self.Subtitle = config.Subtitle or "Roblox UI Library"
	self.Watermark = config.Watermark ~= false
	self.Tabs = {}
	self._activeTab = nil
	self._hidden = false

	local gui = Create("ScreenGui", {
		Name = "KilometresVoid",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})
	gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	self.Gui = gui

	local root = Create("Frame", {
		Name = "Root",
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Parent = gui,
	})
	self.Root = root

	local main = Create("Frame", {
		Name = "Main",
		BackgroundColor3 = self.Theme.Background,
		Size = UDim2.new(0, 560, 0, 380),
		Position = UDim2.new(0.5, -280, 0.5, -190),
		Parent = root,
	})
	self.Main = main
	AddCorner(main, self.Theme.Radius)
	AddStroke(main, self.Theme.Stroke)

	local topbar = Create("Frame", {
		Name = "Topbar",
		BackgroundColor3 = self.Theme.Topbar,
		Size = UDim2.new(1, 0, 0, 52),
		Parent = main,
	})
	AddCorner(topbar, self.Theme.Radius)
	self.Topbar = topbar

	local topMask = Create("Frame", {
		BackgroundColor3 = self.Theme.Topbar,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Position = UDim2.new(0, 0, 1, -18),
		Parent = topbar,
	})
	
	local title = Create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 16, 0, 6),
		Size = UDim2.new(1, -120, 0, 20),
		TextXAlignment = Enum.TextXAlignment.Left,
		Text = self.Title,
		TextColor3 = self.Theme.Text,
		Font = self.Theme.FontBold,
		TextSize = 18,
		Parent = topbar,
	})
	self.TitleLabel = title

	local subtitle = Create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 16, 0, 26),
		Size = UDim2.new(1, -120, 0, 16),
		TextXAlignment = Enum.TextXAlignment.Left,
		Text = self.Subtitle,
		TextColor3 = self.Theme.SubText,
		Font = self.Theme.Font,
		TextSize = 12,
		Parent = topbar,
	})
	self.SubtitleLabel = subtitle

	local hideBtn = Create("TextButton", {
		Name = "HideButton",
		BackgroundColor3 = self.Theme.Accent,
		Text = "UI",
		TextColor3 = self.Theme.Text,
		Font = self.Theme.FontBold,
		TextSize = 14,
		AutoButtonColor = false,
		Size = UDim2.new(0, 44, 0, 32),
		Position = UDim2.new(1, -58, 0, 10),
		Parent = topbar,
	})
	AddCorner(hideBtn, 10)
	self.HideButton = hideBtn

	local body = Create("Frame", {
		Name = "Body",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, -52),
		Position = UDim2.new(0, 0, 0, 52),
		Parent = main,
	})
	self.Body = body

	local tabsBar = Create("Frame", {
		Name = "Tabs",
		BackgroundColor3 = self.Theme.Section,
		Size = UDim2.new(0, 140, 1, 0),
		Parent = body,
	})
	AddCorner(tabsBar, self.Theme.Radius)
	self.TabsBar = tabsBar
	AddPadding(tabsBar, 10)

	local tabList = Create("UIListLayout", {
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = tabsBar,
	})
	self.TabList = tabList

	local pages = Create("Frame", {
		Name = "Pages",
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 150, 0, 0),
		Size = UDim2.new(1, -150, 1, 0),
		Parent = body,
	})
	self.Pages = pages

	local pagePadding = Create("UIPadding", {
		PaddingTop = UDim.new(0, 10),
		PaddingBottom = UDim.new(0, 10),
		PaddingLeft = UDim.new(0, 10),
		PaddingRight = UDim.new(0, 10),
		Parent = pages,
	})
	self.PagePadding = pagePadding

	local pageLayout = Create("UIListLayout", {
		Padding = UDim.new(0, 10),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = pages,
	})
	self.PageLayout = pageLayout

	local drag = false
	local dragStart
	local startPos

	local function updateDrag(input)
		local delta = input.Position - dragStart
		main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end

	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			drag = true
			dragStart = input.Position
			startPos = main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					drag = false
				end
			end)
		end
	end)

	topbar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			if drag then
				updateDrag(input)
			end
		end
	end)

	local function setVisible(visible: boolean)
		self._hidden = not visible
		if visible then
			main.Visible = true
			main.Size = UDim2.new(0, 520, 0, 0)
			Tween(main, 0.25, {Size = UDim2.new(0, 560, 0, 380)})
			Tween(main, 0.2, {BackgroundTransparency = 0})
		else
			Tween(main, 0.2, {BackgroundTransparency = 1, Size = UDim2.new(0, 560, 0, 0)})
			task.delay(0.21, function()
				if self._hidden then
					main.Visible = false
				end
			end)
		end
	end

	hideBtn.MouseButton1Click:Connect(function()
		setVisible(self._hidden)
	end)

	local floating = Create("TextButton", {
		Name = "FloatingToggle",
		BackgroundColor3 = self.Theme.Accent,
		Text = "UI",
		TextColor3 = self.Theme.Text,
		Font = self.Theme.FontBold,
		TextSize = 14,
		AutoButtonColor = false,
		Size = UDim2.new(0, 48, 0, 48),
		Position = UDim2.new(0, 18, 1, -66),
		Parent = root,
	})
	AddCorner(floating, 14)
	floating.Visible = false
	self.FloatingToggle = floating

	floating.MouseButton1Click:Connect(function()
		setVisible(true)
		floating.Visible = false
	end)

	setVisible(true)

	local function refreshFloatingButton()
		floating.Visible = self._hidden
	end

	local window = {}
	window._library = self

	function window:SetTitle(text: string)
		self.Title = text
		title.Text = text
	end

	function window:SetSubtitle(text: string)
		self.Subtitle = text
		subtitle.Text = text
	end

	function window:Show()
		setVisible(true)
		refreshFloatingButton()
	end

	function window:Hide()
		setVisible(false)
		refreshFloatingButton()
	end

	function window:Toggle()
		setVisible(self._library._hidden)
		refreshFloatingButton()
	end

	function window:CreateTab(tabName: string)
		local tab = {}
		tab.Name = tabName
		tab.Elements = {}

		local tabBtn = MakeButton(tabsBar, tabName, self._library.Theme)
		tabBtn.LayoutOrder = #self._library.Tabs + 1
		local page = Create("ScrollingFrame", {
			Name = tabName .. "Page",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			Visible = false,
			ScrollBarThickness = 4,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			Parent = pages,
		})
		AddPadding(page, 4)
		local list = Create("UIListLayout", {
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = page,
		})
		page.LayoutOrder = #self._library.Tabs + 1
		tab.Page = page

		local function activate()
			for _, t in ipairs(self._library.Tabs) do
				t.Page.Visible = false
			end
			page.Visible = true
			self._library._activeTab = tab
		end

		tabBtn.MouseButton1Click:Connect(activate)

		function tab:CreateSection(sectionName: string)
			local section = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Section,
				Size = UDim2.new(1, 0, 0, 44),
				AutomaticSize = Enum.AutomaticSize.Y,
				Parent = page,
			})
			AddCorner(section, self._library.Theme.Radius)
			AddStroke(section, self._library.Theme.Stroke)
			AddPadding(section, 12)

			local label = Create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = sectionName,
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.FontBold,
				TextSize = 15,
				Parent = section,
			})

			local container = Create("Frame", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				Parent = section,
			})
			local layout = Create("UIListLayout", {
				Padding = UDim.new(0, 8),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = container,
			})
			return container
		end

		function tab:CreateButton(info)
			info = info or {}
			local button = MakeButton(page, info.Text or "Button", self._library.Theme)
			button.MouseButton1Click:Connect(function()
				if info.Callback then
					info.Callback()
				end
			end)
			table.insert(tab.Elements, button)
			return button
		end

		function tab:CreateToggle(info)
			info = info or {}
			local holder = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Section,
				Size = UDim2.new(1, 0, 0, 44),
				Parent = page,
			})
			AddCorner(holder, self._library.Theme.Radius - 2)
			AddStroke(holder, self._library.Theme.Stroke)

			local label = Create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Toggle",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 0),
				Size = UDim2.new(1, -70, 1, 0),
				Parent = holder,
			})

			local switch = Create("TextButton", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(0, 46, 0, 26),
				Position = UDim2.new(1, -58, 0.5, -13),
				Parent = holder,
			})
			AddCorner(switch, 999)

			local knob = Create("Frame", {
				BackgroundColor3 = Color3.fromRGB(255,255,255),
				Size = UDim2.new(0, 20, 0, 20),
				Position = UDim2.new(0, 3, 0.5, -10),
				Parent = switch,
			})
			AddCorner(knob, 999)

			local state = info.Default or false
			local function render()
				Tween(switch, 0.15, {BackgroundColor3 = state and self._library.Theme.Accent or self._library.Theme.Stroke})
				Tween(knob, 0.15, {Position = state and UDim2.new(1, -23, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)})
			end
			render()

			switch.MouseButton1Click:Connect(function()
				state = not state
				render()
				if info.Callback then
					info.Callback(state)
				end
			end)

			return {
				Set = function(_, v)
					state = v and true or false
					render()
				end,
				Get = function()
					return state
				end,
			}
		end

		function tab:CreateSlider(info)
			info = info or {}
			local min = info.Min or 0
			local max = info.Max or 100
			local value = info.Default or min

			local holder = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Section,
				Size = UDim2.new(1, 0, 0, 56),
				Parent = page,
			})
			AddCorner(holder, self._library.Theme.Radius - 2)
			AddStroke(holder, self._library.Theme.Stroke)

			local label = Create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Slider",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				Parent = holder,
			})

			local valueLabel = Create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(value),
				TextColor3 = self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = 12,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				Parent = holder,
			})

			local bar = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Position = UDim2.new(0, 12, 0, 34),
				Size = UDim2.new(1, -24, 0, 10),
				Parent = holder,
			})
			AddCorner(bar, 999)

			local fill = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Accent,
				Size = UDim2.new(0, 0, 1, 0),
				Parent = bar,
			})
			AddCorner(fill, 999)

			local dragging = false
			local function setValue(v)
				value = math.clamp(math.floor(v + 0.5), min, max)
				local alpha = (value - min) / math.max((max - min), 1)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				valueLabel.Text = tostring(value)
				if info.Callback then
					info.Callback(value)
				end
			end
			setValue(value)

			local function update(input)
				local x = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
				setValue(min + ((max - min) * x))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					update(input)
				end
			end)
			bar.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			return {
				Set = function(_, v) setValue(v) end,
				Get = function() return value end,
			}
		end

		function tab:CreateDropdown(info)
			info = info or {}
			local items = info.Items or {}
			local current = info.Default or items[1]
			local open = false

			local holder = Create("Frame", {
				BackgroundColor3 = self._library.Theme.Section,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 44),
				Parent = page,
			})
			AddCorner(holder, self._library.Theme.Radius - 2)
			AddStroke(holder, self._library.Theme.Stroke)
			AddPadding(holder, 12)

			local mainBtn = Create("TextButton", {
				BackgroundTransparency = 1,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(1, 0, 0, 20),
				Parent = holder,
			})

			local title = Create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Dropdown",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Size = UDim2.new(1, -24, 0, 18),
				Parent = holder,
			})
			local selected = Create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(current or "Select"),
				TextColor3 = self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = 12,
				Position = UDim2.new(0, 0, 0, 0),
				Size = UDim2.new(1, -24, 0, 18),
				Parent = holder,
			})

			local listHolder = Create("Frame", {
				BackgroundTransparency = 1,
				AutomaticSize = Enum.AutomaticSize.Y,
				Visible = false,
				Size = UDim2.new(1, 0, 0, 0),
				Parent = holder,
			})
			local layout = Create("UIListLayout", {
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = listHolder,
			})

			local function rebuild()
				for _, child in ipairs(listHolder:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				for _, item in ipairs(items) do
					local opt = MakeButton(listHolder, tostring(item), self._library.Theme)
					opt.Size = UDim2.new(1, 0, 0, 32)
					opt.MouseButton1Click:Connect(function()
						current = item
						selected.Text = tostring(current)
						open = false
						listHolder.Visible = false
						holder.Size = UDim2.new(1, 0, 0, 44)
						if info.Callback then
							info.Callback(current)
						end
					end)
				end
			end
			rebuild()

			mainBtn.MouseButton1Click:Connect(function()
				open = not open
				listHolder.Visible = open
				holder.Size = open and UDim2.new(1, 0, 0, 44) or UDim2.new(1, 0, 0, 44)
			end)

			listHolder.Parent = holder
			listHolder.Position = UDim2.new(0, 0, 0, 38)
			listHolder.Size = UDim2.new(1, 0, 0, 0)

			return {
				Set = function(_, v)
					current = v
					selected.Text = tostring(current)
				end,
				Get = function() return current end,
			}
		end

		table.insert(self._library.Tabs, tab)
		if not self._library._activeTab then
			activate()
		end
		return tab
	end

	function window:Notify(info)
		info = info or {}
		local note = Create("Frame", {
			BackgroundColor3 = self._library.Theme.Section,
			Size = UDim2.new(0, 260, 0, 60),
			Position = UDim2.new(1, -280, 1, -80),
			Parent = self._library.Root,
		})
		AddCorner(note, self._library.Theme.Radius - 2)
		AddStroke(note, self._library.Theme.Stroke)

		local txt = Create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 12, 0, 8),
			Size = UDim2.new(1, -24, 1, -16),
			TextWrapped = true,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			Text = info.Text or "Notification",
			TextColor3 = self._library.Theme.Text,
			Font = self._library.Theme.Font,
			TextSize = 14,
			Parent = note,
		})

		Tween(note, 0.2, {Position = UDim2.new(1, -280, 1, -96)})
		task.delay(info.Duration or 2, function()
			if note.Parent then
				Tween(note, 0.2, {Position = UDim2.new(1, -280, 1, -60), BackgroundTransparency = 1})
				task.delay(0.22, function()
					if note.Parent then note:Destroy() end
				end)
			end
		end)
	end

	self.Window = window
	return window
end

function Library:CreateWindow(config)
	return Library.new(config)
end

return Library
