                    local Label = Button:FindFirstChildOfClass("TextLabel")
                    local IconImage = Button:FindFirstChildOfClass("ImageLabel")

                    Utility:Tween(Button, 0.2, {BackgroundColor3 = Library.Theme.Secondary})
                    if Stroke then Utility:Tween(Stroke, 0.2, {Color = Library.Theme.Stroke}) end
                    if Label then Utility:Tween(Label, 0.2, {TextColor3 = Library.Theme.DarkText}) end
                    if IconImage then Utility:Tween(IconImage, 0.2, {ImageColor3 = Library.Theme.DarkText}) end
                end
            end

