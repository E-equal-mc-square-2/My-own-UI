        -- Tab Switching Logic
        function Tab:Select()
            if Window.CurrentTab == self then return end
            
            if Window.CurrentTab then
                Window.CurrentTab:Deselect()
            end
            
            Window.CurrentTab = self
            self.Selected = true
            Page.Visible = true
            
            -- Animations
            Utility:Tween(TabButton, {BackgroundTransparency = Window.IsMobile and 1 or 0}, 0.3)
            Utility:Tween(TabLabel, {TextColor3 = Theme.Accent}, 0.3)
            
            if hasIcon then
                Utility:Tween(TabContent:FindFirstChildOfClass("ImageLabel"), {ImageColor3 = Theme.Accent}, 0.3)
            end
            
            Utility:Tween(TabIndicator, {
                BackgroundTransparency = 0,
                Size = Window.IsMobile and UDim2.new(1, -20, 0, 3) or UDim2.new(0, 3, 0.6, 0)
            }, 0.3, Enum.EasingStyle.Back)
            
            -- Page Entrance Animation
            Page.Position = UDim2.new(0, 0, 0, 20)
            Page.GroupTransparency = 1 -- Needs CanvasGroup for proper transparency, but standard works too if we just position tween
            Utility:Tween(Page, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        end

        function Tab:Deselect()
            self.Selected = false
            Page.Visible = false
            
            Utility:Tween(TabButton, {BackgroundTransparency = 1}, 0.3)
            Utility:Tween(TabLabel, {TextColor3 = Theme.SubText}, 0.3)
            
            if hasIcon then
                Utility:Tween(TabContent:FindFirstChildOfClass("ImageLabel"), {ImageColor3 = Theme.SubText}, 0.3)
            end
            
            Utility:Tween(TabIndicator, {
                BackgroundTransparency = 1,
                Size = Window.IsMobile and UDim2.new(1, -10, 0, 3) or UDim2.new(0, 3, 0, 0)
            }, 0.3)
        end

        TabButton.MouseButton1Click:Connect(function()
            Tab:Select()
        end)

        -- Auto select first tab
        if #Window.Tabs == 0 then
            Tab:Select()
        end
        
        table.insert(Window.Tabs, Tab)

