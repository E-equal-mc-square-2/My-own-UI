		end
	end

	local function pickSV(input)
		local x = Clamp((input.Position.X - square.AbsolutePosition.X) / math.max(square.AbsoluteSize.X, 1), 0, 1)
		local y = Clamp((input.Position.Y - square.AbsolutePosition.Y) / math.max(square.AbsoluteSize.Y, 1), 0, 1)
		s = x
		v = 1 - y
		self.Window.Library:SetFlag(flag, Color3.fromHSV(h, s, v))
		refresh(false)
	end

	local function pickHue(input)
		local y = Clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / math.max(hueBar.AbsoluteSize.Y, 1), 0, 1)
		h = y
		self.Window.Library:SetFlag(flag, Color3.fromHSV(h, s, v))
		refresh(false)
	end

	square.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingSV = true
			pickSV(input)
		end
	end)
	hueBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingHue = true
			pickHue(input)
		end
	end)

	self.Window._connections:Give(UserInputService.InputChanged:Connect(function(input)
		if draggingSV and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			pickSV(input)
		elseif draggingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			pickHue(input)
		end
	end))
	self.Window._connections:Give(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSV = false
			draggingHue = false
		end
	end))

	self.Window.Library:_registerFlag(flag, function(v2, silent)
		if typeof(v2) == "Color3" then
			color = v2
			h, s, v = Color3.toHSV(v2)
			refresh(silent)
		end
	end)
	self.Window.Library.Flags[flag] = color
	refresh(true)

	self:_bindTheme(function(th)
		card.BackgroundColor3 = th.Background
		label.TextColor3 = th.Text
		preview.BackgroundColor3 = color
		square.BackgroundColor3 = color
		svBase.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
		local s1 = card:FindFirstChildOfClass("UIStroke")
		if s1 then s1.Color = th.Stroke end
		local s2 = square:FindFirstChildOfClass("UIStroke")
		if s2 then s2.Color = th.Stroke end
		local s3 = hueBar:FindFirstChildOfClass("UIStroke")
		if s3 then s3.Color = th.Stroke end
		marker.BackgroundColor3 = th.Text
		hueMarker.BackgroundColor3 = th.Text
	end)

	self:_registerElement({ Frame = card, SearchText = name })
	return {
		Set = function(_, c)
			if typeof(c) == "Color3" then
				self.Window.Library:SetFlag(flag, c)
				local hh, ss, vv = Color3.toHSV(c)
				h, s, v = hh, ss, vv
				refresh(false)
			end
		end,
		Get = function()
			return color
		end
	}
end

--//======================================================
--// WINDOW / LIBRARY PUBLIC API
--//======================================================

function Library:CreateWindow(options)
	options = options or {}
	self:_initRoot()

	self._windowCounter += 1
	local window = setmetatable({}, WindowClass)
	window.Library = self
	window.Id = self._windowCounter
	window.Title = tostring(options.Title or "NeonVX")
	window.Subtitle = tostring(options.Subtitle or "Mobile-first UI")
	window.Visible = options.Visible ~= false
	window.Minimized = false
	window.Maximized = false
	window.Destroyed = false
	window.Tabs = {}
	window.ActiveTab = nil
	window.SearchQuery = ""
	window._connections = Maid.new()
	window._themeHooks = {}
	window._restoreSize = nil
	window._normalSize = options.Size or DefaultWindowSize()

	table.insert(self.Windows, window)
	window:_build(options)

	if options.Theme then
		self:SetTheme(options.Theme)
	end

	if options.Keybind then
		window.Keybind = ResolveKey(options.Keybind) or Enum.KeyCode.RightShift
	else
		window.Keybind = Enum.KeyCode.RightShift
	end

	self._connections = self._connections or Maid.new()
	self._connections:Give(UserInputService.InputBegan:Connect(function(input, gp)
		if gp or window.Destroyed then
			return
		end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == window.Keybind then
			window:Toggle()
		end
	end))

	return window
end

function Library:CreateTab(...)
	error("Use Window:CreateTab(options) on a created window.", 2)
end

function Library:Destroy()
	for _, window in ipairs(self.Windows) do
		if window and window.Destroy then
			pcall(function()
				window:Destroy()
			end)
		end
	end
	self.Windows = {}
	if self._fpsConn then
		self._fpsConn:Disconnect()
		self._fpsConn = nil
	end
	if self._blur then
		self._blur:Destroy()
		self._blur = nil
	end
	if self._rootGui then
		self._rootGui:Destroy()
		self._rootGui = nil
	end
	self._initialized = false
end

function Library:SetupDefaults()
	self.Theme = self.Themes.Dark
	self._themeName = "Dark"
	self._autoSave = false
	self._autoSaveName = "default"
end

Library:SetupDefaults()
Library:_initRoot()

return Library
