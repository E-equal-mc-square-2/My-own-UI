		return gethui and gethui()
	end)
	if ok and typeof(hui) == "Instance" then
		return hui
	end
	if PlayerGui then
		return PlayerGui
	end
	return CoreGui
end

local function GetExecutorName()
	local name = "Unknown"
	pcall(function()
		if identifyexecutor then
			name = identifyexecutor()
		end
	end)
	return name
end

Library._executor = GetExecutorName()

local function SafeFileSystem()
	return type(isfile) == "function" and type(readfile) == "function" and type(writefile) == "function" and type(makefolder) == "function"
end

local function SafeIsFolder(path)
	if type(isfolder) == "function" then
		return pcall(function()
			return isfolder(path)
		end)
	end
	return false
end

local function SafeMakeFolder(path)
	if type(makefolder) == "function" then
		pcall(function()
			if not SafeIsFolder(path) then
				makefolder(path)
			end
		end)
	end
end

local function EncodeValue(value)
	local t = typeof(value)
	if t == "Color3" then
		return { __type = "Color3", v = { value.R, value.G, value.B } }
	elseif t == "EnumItem" then
		return { __type = "EnumItem", v = tostring(value) }
	elseif t == "table" then
		return { __type = "table", v = value }
	elseif t == "boolean" or t == "number" or t == "string" then
		return { __type = t, v = value }
	end
	return { __type = "string", v = tostring(value) }
end

local function DecodeValue(entry)
	if type(entry) ~= "table" then
		return entry
	end
	if entry.__type == "Color3" and type(entry.v) == "table" then
		return Color3.new(entry.v[1] or 1, entry.v[2] or 1, entry.v[3] or 1)
	elseif entry.__type == "EnumItem" and type(entry.v) == "string" then
		local enumName = entry.v:match("Enum%.%w+%.(%w+)")
		if enumName then
			local ok, enumVal = pcall(function()
				return Enum.KeyCode[enumName]
			end)
			if ok and enumVal then
				return enumVal
			end
		end
		return entry.v
	elseif entry.__type == "table" then
		return entry.v
	else
		return entry.v
	end
end

--//======================================================
--// MAID / CONNECTION MANAGER
--//======================================================

local Maid = {}
Maid.__index = Maid

function Maid.new()
	return setmetatable({ Tasks = {} }, Maid)
end

function Maid:Give(taskObj)
	table.insert(self.Tasks, taskObj)
	return taskObj
end

function Maid:Cleanup()
	for _, taskObj in ipairs(self.Tasks) do
		pcall(function()
			local t = typeof(taskObj)
			if t == "RBXScriptConnection" then
				taskObj:Disconnect()
			elseif t == "Instance" then
				taskObj:Destroy()
			elseif type(taskObj) == "function" then
				taskObj()
			elseif type(taskObj) == "thread" then
				task.cancel(taskObj)
			elseif taskObj and taskObj.Destroy then
				taskObj:Destroy()
			end
		end)
	end
	table.clear(self.Tasks)
end

--//======================================================
--// THEME ENGINE
--//======================================================

function Library:_resolveTheme(nameOrTheme)
	if type(nameOrTheme) == "string" then
		return self.Themes[nameOrTheme] or self.Theme
	elseif type(nameOrTheme) == "table" then
		return nameOrTheme
	end
	return self.Theme
end

function Library:_applyThemeToAll()
	for _, w in ipairs(self.Windows) do
		if w and w.ApplyTheme then
			pcall(function()
				w:ApplyTheme(self.Theme)
			end)
		end
	end
	if self._watermark then
		self._watermark.TextColor3 = self.Theme.Text
	end
	if self._fpsLabel then
		self._fpsLabel.TextColor3 = self.Theme.Text
	end
end

function Library:SetTheme(nameOrTheme)
	self.Theme = self:_resolveTheme(nameOrTheme)
	if type(nameOrTheme) == "string" then
		self._themeName = nameOrTheme
	end
	self:_applyThemeToAll()
end

function Library:GetTheme()
	return self.Theme, self._themeName
end

