function NotificationSystem:Notify(title, text, duration)
    duration = duration or 3
    
    local notif = Utility:Create("Frame", {
        Name = "Notification",
        BackgroundColor3 = Theme.Secondary,
        Size = UDim2.new(1, 40, 0, 0), -- Starts hidden (right)
