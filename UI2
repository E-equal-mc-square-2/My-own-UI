		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(96, 34),
		Text = "",
		AutoButtonColor = false,
		Parent = card
	})
	ApplyCorner(holder, 12)
	ApplyStroke(holder, theme.Stroke, 0.55, 1)

