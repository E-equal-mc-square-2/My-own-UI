		end
	}
end

function SectionMT:AddMultiDropdown(text, options, callback, flag)
	local theme = self:_theme()
	local card = self:_makeElementFrame(54)
	local expanded = false
	local selected = {}
	options = options or {}
	local multiFlag = flag or text or ("MultiDropdown_" .. tostring(#self.Window.Library.Flags + 1))

	local label = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -90, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tostring(text or "Multi Dropdown"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = card
	})

	local holder = New("TextButton", {
		BackgroundColor3 = theme.Input,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(110, 34),
		Text = "",
		AutoButtonColor = false,
		Parent = card
	})
	ApplyCorner(holder, 12)
	ApplyStroke(holder, theme.Stroke, 0.55, 1)

	local holderText = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -24, 1, 0),
		Position = UDim2.fromOffset(10, 0),
		Font = Enum.Font.GothamMedium,
		Text = "None",
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = holder
	})

	local arrow = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(16, 34),
		Position = UDim2.new(1, -16, 0, 0),
		Font = Enum.Font.GothamBold,
		Text = "⌄",
		TextColor3 = theme.Text,
		TextSize = 14,
		Parent = holder
	})

	local list = New("Frame", {
		BackgroundColor3 = theme.Background2,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Visible = false,
		Parent = card
	})
	ApplyCorner(list, 12)
	ApplyStroke(list, theme.Stroke, 0.55, 1)
	AddPadding(list, 6, 6, 6, 6)
	AddListLayout(list, 6)

	local function refreshText()
		local arr = {}
		for k, v in pairs(selected) do
			if v then table.insert(arr, k) end
		end
		table.sort(arr)
		holderText.Text = (#arr > 0) and table.concat(arr, ", ") or "None"
		holderText.TextColor3 = (#arr > 0) and theme.Text or theme.SubText
	end

	local function fireCallback()
		local arr = {}
		for k, v in pairs(selected) do
			if v then table.insert(arr, k) end
		end
		self.Window.Library:_setFlag(multiFlag, arr)
		if callback then
			task.spawn(callback, arr)
		end
	end

	local function rebuild()
		for _, c in ipairs(list:GetChildren()) do
			if c:IsA("TextButton") then
				c:Destroy()
			end
		end
		for _, opt in ipairs(options) do
			selected[opt] = selected[opt] or false
			local item = New("TextButton", {
				BackgroundColor3 = theme.Card2,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 38),
				Text = "",
				AutoButtonColor = false,
				Parent = list
			})
			ApplyCorner(item, 10)
			ApplyStroke(item, theme.Stroke, 0.6, 1)

			local box = New("Frame", {
				BackgroundColor3 = selected[opt] and theme.Accent or theme.Muted,
				BorderSizePixel = 0,
				Position = UDim2.fromOffset(10, 9),
				Size = UDim2.fromOffset(20, 20),
				Parent = item
			})
			ApplyCorner(box, 6)

			local txt = New("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, -44, 1, 0),
				Position = UDim2.fromOffset(38, 0),
				Font = Enum.Font.GothamMedium,
				Text = tostring(opt),
				TextColor3 = theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				Parent = item
			})

			item.MouseButton1Click:Connect(function()
				selected[opt] = not selected[opt]
				box.BackgroundColor3 = selected[opt] and theme.Accent or theme.Muted
				refreshText()
				fireCallback()
			end)

			item.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					Rippler(item, theme, input.Position - item.AbsolutePosition)
				end
			end)
		end
	end

	rebuild()

	holder.MouseButton1Click:Connect(function()
		expanded = not expanded
		list.Visible = expanded
		arrow.Text = expanded and "⌃" or "⌄"
	end)

	self.Window.Library:_registerFlag(multiFlag, function(v, silent)
		selected = {}
		if type(v) == "table" then
			for _, item in ipairs(v) do
				selected[item] = true
			end
		end
		rebuild()
		refreshText()
		if not silent then
			fireCallback()
		end
	end)

	self.Window.Library.Flags[multiFlag] = {}
	refreshText()

	local meta = { Frame = card, SearchText = tostring(text or "") }
	self:_registerElement(meta)
	return {
		Set = function(_, arr)
			self.Window.Library:_setFlag(multiFlag, arr)
			self.Window.Library._flagSetters[multiFlag](arr, false)
		end,
		Get = function()
			local arr = {}
			for k, v in pairs(selected) do
				if v then table.insert(arr, k) end
			end
			return arr
		end
	}
end

function SectionMT:AddKeybind(text, defaultKey, callback, flag)
	local theme = self:_theme()
	local card = self:_makeElementFrame(54)
	local listening = false
	local key = defaultKey or Enum.KeyCode.RightShift
	local keyFlag = flag or text or ("Keybind_" .. tostring(#self.Window.Library.Flags + 1))

	local label = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -96, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tostring(text or "Keybind"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = card
	})

	local keyBtn = New("TextButton", {
		BackgroundColor3 = theme.Input,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, 0, 0.5, 0),
		Size = UDim2.fromOffset(88, 34),
		Text = "",
		AutoButtonColor = false,
		Parent = card
	})
	ApplyCorner(keyBtn, 12)
	ApplyStroke(keyBtn, theme.Stroke, 0.55, 1)

	local keyText = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -12, 1, 0),
		Position = UDim2.fromOffset(6, 0),
		Font = Enum.Font.GothamMedium,
		Text = key and key.Name or "None",
		TextColor3 = theme.Text,
		TextSize = 12,
		Parent = keyBtn
	})

	local function set(v, silent)
		key = v
		keyText.Text = v and v.Name or "None"
		if not silent then
			self.Window.Library:_setFlag(keyFlag, key and key.Name or "None")
			if callback then
				task.spawn(callback, key)
			end
		end
	end

	keyBtn.MouseButton1Click:Connect(function()
		listening = true
		keyText.Text = "Press..."
	end)

	self.Window.Library:_registerFlag(keyFlag, function(v, silent)
		local newKey = nil
		if typeof(v) == "EnumItem" and v.EnumType == Enum.KeyCode then
			newKey = v
		elseif type(v) == "string" and Enum.KeyCode[v] then
			newKey = Enum.KeyCode[v]
		end
		if newKey then
			set(newKey, silent)
		end
	end)

	self.Window.Library.Flags[keyFlag] = key and key.Name or "None"
	set(key, true)

	local conn = UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			listening = false
			set(input.KeyCode, false)
			return
		end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == key then
			if callback then
				task.spawn(callback, key)
			end
		end
	end)

	self.Window._connections:Give(conn)

	local meta = { Frame = card, SearchText = tostring(text or "") .. " " .. tostring(key and key.Name or "") }
	self:_registerElement(meta)
	return {
		Set = function(_, v) set(v, false) end,
		Get = function() return key end
	}
end

function SectionMT:AddColorPicker(text, defaultColor, callback, flag)
	local theme = self:_theme()
	local card = self:_makeElementFrame(188)
	local color = defaultColor or theme.Accent
	local pickerFlag = flag or text or ("ColorPicker_" .. tostring(#self.Window.Library.Flags + 1))

	local top = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Parent = card
	})

	local label = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -70, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tostring(text or "Color"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = top
	})

	local preview = New("Frame", {
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, 0, 0, 0),
		Size = UDim2.fromOffset(54, 18),
		Parent = top
	})
	ApplyCorner(preview, 8)
	ApplyStroke(preview, theme.Stroke, 0.55, 1)

	local square = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 28),
		Size = UDim2.new(1, -20, 0, 96),
