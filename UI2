function Library:_startStatsLoop()
	if self._statsConn then
		self._statsConn:Disconnect()
	end

	local fpsAcc = 0
	local frames = 0
	local lastTick = os.clock()

	self._statsConn = RunService.RenderStepped:Connect(function(dt)
		fpsAcc += dt
		frames += 1
		if fpsAcc >= 1 then
			local fps = math.floor((frames / fpsAcc) + 0.5)
			fpsAcc = 0
			frames = 0
			if self._fpsLabel then
				self._fpsLabel.Text = "FPS " .. tostring(fps)
			end
		end

		if self._watermark then
			local now = os.date("%H:%M:%S")
			self._watermark.Text = ("NeonVX | %s | %s"):format(self._executor, now)
		end
	end)
end

function Library:_startAutofade()
	if self._blurTweenConn then
		self._blurTweenConn:Disconnect()
	end
	self._blurTweenConn = RunService.RenderStepped:Connect(function()
		if self._blur then
			self._blur.Size = self._blur.Size + ((self._blurGoal or 0) - self._blur.Size) * 0.12
		end
	end)
end

function Library:_setBlur(enabled)
