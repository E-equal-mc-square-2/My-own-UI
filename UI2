	return {
		Set = function(_, v)
			self.Window.Library:SetFlag(flag, v)
			apply(v, false)
		end,
		Get = function()
			return current
		end,
		SetOptions = function(_, opts)
			listItems = opts or {}
			listHeight = math.min(#listItems * 42 + 8, 188)
			list.Size = UDim2.new(1, 0, 0, listHeight)
			rebuild()
		end
	}
