        Font = Theme.BoldFont,
        Text = text or "Neon Vortex",
        TextColor3 = Theme.Text,
        TextSize = 13,
        Parent = self.Frame
    })
    
    self.Enabled = true
    
    local frames = 0
    Utility:Connect(RunService.RenderStepped, function()
        frames = frames + 1
    end)
    
    task.spawn(function()
        while self.Enabled and task.wait(1) do
            local fps = frames
            frames = 0
            local ping = tonumber(string.match(Stats.Network.ServerStatsItem["Data Ping"]:GetValueString(), "%d+")) or 0
            local timeStr = os.date("%I:%M %p")
            
            self.Text.Text = string.format("%s | %d FPS | %dms | %s", text or "Neon Vortex", fps, ping, timeStr)
        end
    end)
end

--//======================================================
--// CONFIG SYSTEM
--//======================================================
local ConfigSystem = {}

function ConfigSystem:Save(name)
    if not writefile then return false end
    local saveTable = {}
    for key, flag in pairs(Utility.Flags) do
        saveTable[key] = flag.Value
    end
    local json = HttpService:JSONEncode(saveTable)
    writefile(FOLDER_NAME .. "/" .. name .. ".json", json)
    NotificationSystem:Notify("Config Saved", "Successfully saved config: " .. name, 3)
    return true
end

function ConfigSystem:Load(name)
    if not readfile or not isfile then return false end
    local path = FOLDER_NAME .. "/" .. name .. ".json"
    if isfile(path) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(path))
        end)
        if success then
            for key, val in pairs(result) do
                if Utility.Flags[key] then
                    Utility.Flags[key]:Set(val)
                end
            end
            NotificationSystem:Notify("Config Loaded", "Successfully loaded config: " .. name, 3)
            return true
        end
    end
    NotificationSystem:Notify("Error", "Failed to load config.", 3)
    return false
end

