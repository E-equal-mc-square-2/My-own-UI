                })

                Utility:Round(ToggleButton, 16)

                local Circle = Utility:Create("Frame", {
                    Parent = ToggleButton,
                    BackgroundColor3 = Color3.new(1,1,1),
                    Position = State and UDim2.new(1,-28,0.5,-12) or UDim2.new(0,4,0.5,-12),
                    Size = UDim2.new(0,24,0,24)
                })

                Utility:Round(Circle, 12)

                local function Set(value)
                    State = value
                    Framework.Flags[cfg.Flag or cfg.Text] = value

                    Utility:Tween(ToggleButton, TweenInfo.new(0.25), {
                        BackgroundColor3 = value and self.Theme.Accent or self.Theme.Secondary
                    })

                    Utility:Tween(Circle, TweenInfo.new(0.25), {
                        Position = value and UDim2.new(1,-28,0.5,-12) or UDim2.new(0,4,0.5,-12)
                    })

                    if cfg.Callback then
                        cfg.Callback(value)
                    end
                end

                ToggleButton.MouseButton1Click:Connect(function()
                    Utility:Ripple(ToggleButton)
                    Set(not State)
                end)

                return {
                    Set = Set
                }
            end

            --//======================================================
            --// SLIDER
            --//======================================================

            function Section:AddSlider(cfg)
                cfg = cfg or {}

                local Min = cfg.Min or 0
                local Max = cfg.Max or 100
                local Default = cfg.Default or Min
                local Value = Default

                Framework.Flags[cfg.Flag or cfg.Text] = Value

                local Holder = Utility:Create("Frame", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    Size = UDim2.new(1,0,0,72)
                })

                Utility:Round(Holder, 14)

                local Text = Utility:Create("TextLabel", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,14,0,8),
                    Size = UDim2.new(1,-80,0,20),
                    Font = Enum.Font.GothamMedium,
                    Text = cfg.Text or "Slider",
                    TextColor3 = self.Theme.Text,
                    TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local ValueText = Utility:Create("TextLabel", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1,-60,0,8),
                    Size = UDim2.new(0,50,0,20),
                    Font = Enum.Font.GothamBold,
                    Text = tostring(Value),
                    TextColor3 = self.Theme.Accent,
                    TextSize = 14
                })

                local Bar = Utility:Create("Frame", {
                    Parent = Holder,
                    BackgroundColor3 = self.Theme.Secondary,
                    Position = UDim2.new(0,14,1,-24),
                    Size = UDim2.new(1,-28,0,10)
                })

                Utility:Round(Bar, 10)

                local Fill = Utility:Create("Frame", {
                    Parent = Bar,
                    BackgroundColor3 = self.Theme.Accent,
                    Size = UDim2.new((Value-Min)/(Max-Min),0,1,0)
                })

                Utility:Round(Fill, 10)
                Utility:Gradient(Fill, self.Theme.AccentLight, self.Theme.Accent)

                local dragging = false

                local function Set(input)
                    local percent = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X,0,1)
                    Value = math.floor(Min + ((Max-Min) * percent))

                    Framework.Flags[cfg.Flag or cfg.Text] = Value

                    Fill.Size = UDim2.new(percent,0,1,0)
                    ValueText.Text = tostring(Value)

                    if cfg.Callback then
                        cfg.Callback(Value)
                    end
                end

                Bar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        Set(input)
                    end
                end)

                Bar.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        Set(input)
                    end
                end)
            end

            --//======================================================
            --// TEXTBOX
            --//======================================================

            function Section:AddTextbox(cfg)
                cfg = cfg or {}

                local Box = Utility:Create("TextBox", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    Size = UDim2.new(1,0,0,52),
                    PlaceholderText = cfg.Placeholder or "Input",
                    Text = cfg.Default or "",
                    Font = Enum.Font.Gotham,
                    TextColor3 = self.Theme.Text,
                    PlaceholderColor3 = self.Theme.TextDark,
                    TextSize = 15,
                    ClearTextOnFocus = false
                })

                Utility:Round(Box, 14)
                Utility:Padding(Box, 14)

                Box.FocusLost:Connect(function()
                    Framework.Flags[cfg.Flag or cfg.Placeholder] = Box.Text

                    if cfg.Callback then
                        cfg.Callback(Box.Text)
                    end
                end)
            end

            --//======================================================
            --// DROPDOWN
            --//======================================================

            function Section:AddDropdown(cfg)
                cfg = cfg or {}

                local Open = false
                local Selected = cfg.Default or "None"

                Framework.Flags[cfg.Flag or cfg.Text] = Selected

                local Holder = Utility:Create("Frame", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Size = UDim2.new(1,0,0,52),
                    ClipsDescendants = true
                })

                Utility:Round(Holder, 14)

                local MainButton = Utility:Create("TextButton", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,52),
                    Text = ""
                })

                local Title = Utility:Create("TextLabel", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,14,0,0),
                    Size = UDim2.new(1,-50,0,52),
                    Font = Enum.Font.GothamMedium,
                    Text = (cfg.Text or "Dropdown") .. ": " .. Selected,
                    TextColor3 = self.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local List = Utility:Create("Frame", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,0,0,52),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Size = UDim2.new(1,0,0,0)
                })

                local Layout = Utility:Create("UIListLayout", {
                    Parent = List,
                    Padding = UDim.new(0,8)
                })

                Utility:Padding(List, 10)

                for _, option in pairs(cfg.Options or {}) do
                    local Opt = Utility:Create("TextButton", {
                        Parent = List,
                        BackgroundColor3 = self.Theme.Secondary,
                        Size = UDim2.new(1,0,0,42),
                        Text = option,
                        Font = Enum.Font.Gotham,
                        TextColor3 = self.Theme.Text,
                        TextSize = 14,
                        AutoButtonColor = false
                    })

                    Utility:Round(Opt, 10)

                    Opt.MouseButton1Click:Connect(function()
                        Selected = option
                        Framework.Flags[cfg.Flag or cfg.Text] = option
                        Title.Text = (cfg.Text or "Dropdown") .. ": " .. option

                        if cfg.Callback then
                            cfg.Callback(option)
                        end
                    end)
                end

                MainButton.MouseButton1Click:Connect(function()
                    Open = not Open

                    Utility:Tween(Holder, TweenInfo.new(0.25), {
                        Size = Open and UDim2.new(1,0,0,52 + (#(cfg.Options or {}) * 50)) or UDim2.new(1,0,0,52)
                    })
                end)
            end

            --//======================================================
            --// SEARCH BOX
            --//======================================================

            function Section:AddSearchBox(cfg)
                local Search = Utility:Create("TextBox", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    Size = UDim2.new(1,0,0,50),
                    PlaceholderText = "Search...",
                    Font = Enum.Font.Gotham,
                    Text = "",
                    TextColor3 = self.Theme.Text,
                    PlaceholderColor3 = self.Theme.TextDark,
                    TextSize = 15
                })

                Utility:Round(Search, 14)
                Utility:Padding(Search, 14)

                Search:GetPropertyChangedSignal("Text"):Connect(function()
                    local Query = string.lower(Search.Text)

                    for _, child in pairs(Container:GetChildren()) do
                        if child:IsA("Frame") or child:IsA("TextButton") then
                            local found = false

                            for _, sub in pairs(child:GetDescendants()) do
                                if sub:IsA("TextLabel") then
                                    if string.find(string.lower(sub.Text), Query) then
                                        found = true
                                    end
                                end
                            end

                            if child ~= Search then
                                child.Visible = found or Query == ""
                            end
                        end
                    end
                end)
            end

            --//======================================================
            --// SEPARATOR
            --//======================================================

            function Section:AddSeparator()
                local Sep = Utility:Create("Frame", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Stroke,
                    Size = UDim2.new(1,0,0,1)
                })
            end

            --//======================================================
            --// KEYBIND
            --//======================================================

            function Section:AddKeybind(cfg)
                cfg = cfg or {}

                local Current = cfg.Default or Enum.KeyCode.E
                local Waiting = false

                Framework.Flags[cfg.Flag or cfg.Text] = Current.Name

                local Button = Utility:Create("TextButton", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    Size = UDim2.new(1,0,0,52),
                    Text = (cfg.Text or "Keybind") .. ": " .. Current.Name,
                    Font = Enum.Font.GothamMedium,
                    TextColor3 = self.Theme.Text,
                    TextSize = 15,
                    AutoButtonColor = false
                })

                Utility:Round(Button, 14)

                Button.MouseButton1Click:Connect(function()
                    Waiting = true
                    Button.Text = "Press any key..."
                end)

                UserInputService.InputBegan:Connect(function(input,gp)
                    if gp then return end

                    if Waiting then
                        if input.KeyCode ~= Enum.KeyCode.Unknown then
                            Current = input.KeyCode
                            Framework.Flags[cfg.Flag or cfg.Text] = Current.Name
                            Button.Text = (cfg.Text or "Keybind") .. ": " .. Current.Name
                            Waiting = false
                        end
                    elseif input.KeyCode == Current then
                        if cfg.Callback then
                            cfg.Callback()
                        end
                    end
                end)
            end

            --//======================================================
            --// COLOR PICKER
            --//======================================================

            function Section:AddColorPicker(cfg)
                cfg = cfg or {}

                local Selected = cfg.Default or Color3.fromRGB(255,255,255)

                local Holder = Utility:Create("Frame", {
                    Parent = Container,
                    BackgroundColor3 = self.Theme.Tertiary,
                    Size = UDim2.new(1,0,0,58)
                })

                Utility:Round(Holder, 14)

                local Label = Utility:Create("TextLabel", {
                    Parent = Holder,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,14,0,0),
                    Size = UDim2.new(1,-80,1,0),
                    Font = Enum.Font.GothamMedium,
                    Text = cfg.Text or "Color Picker",
                    TextColor3 = self.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local Preview = Utility:Create("TextButton", {
                    Parent = Holder,
                    BackgroundColor3 = Selected,
                    Position = UDim2.new(1,-58,0.5,-18),
                    Size = UDim2.new(0,36,0,36),
                    Text = ""
                })

                Utility:Round(Preview, 12)

                local hue = 0

                Preview.MouseButton1Click:Connect(function()
                    hue += 0.15

                    if hue > 1 then
                        hue = 0
                    end

                    Selected = Color3.fromHSV(hue,1,1)
                    Preview.BackgroundColor3 = Selected

                    if cfg.Callback then
                        cfg.Callback(Selected)
                    end
                end)
            end

            return Section
        end

        return Tab
    end

    --//======================================================
    --// CONFIG SYSTEM
    --//======================================================

    local ConfigFolder = "PremiumFrameworkConfigs"

    if Executor.SaveSupport then
        if not isfolder(ConfigFolder) then
            makefolder(ConfigFolder)
        end
    end

    function Window:SaveConfig(name)
        if not Executor.SaveSupport then return end

        local Data = HttpService:JSONEncode(Framework.Flags)
        writefile(ConfigFolder .. "/" .. name .. ".json", Data)

        Window:Notify("Config Saved", name .. " has been saved.")
    end

    function Window:LoadConfig(name)
        if not Executor.SaveSupport then return end

        local path = ConfigFolder .. "/" .. name .. ".json"

        if isfile(path) then
            local Data = HttpService:JSONDecode(readfile(path))

            for i,v in pairs(Data) do
                Framework.Flags[i] = v
            end

            Window:Notify("Config Loaded", name .. " has been loaded.")
        end
    end

    task.spawn(function()
        while task.wait(10) do
            if Executor.SaveSupport then
                writefile(ConfigFolder .. "/autosave.json", HttpService:JSONEncode(Framework.Flags))
            end
        end
    end)

    Window:Notify("Framework Loaded", "Premium mobile framework initialized.")

    return Window
end

