		BackgroundTransparency = 1,
		Size = UDim2.new(1, -12, 1, 0),
		Position = UDim2.fromOffset(6, 0),
		Font = Enum.Font.GothamMedium,
		Text = key.Name,
		TextColor3 = theme.Text,
		TextSize = 12,
		Parent = holder
	})

	local function apply(v, silent)
		local newKey = ResolveKey(v) or key
		key = newKey
		self.Window.Library.Flags[flag] = key.Name
		holderText.Text = key.Name
		if not silent and callback then
			task.spawn(callback, key)
		end
	end

	self.Window.Library:_registerFlag(flag, apply)
	self.Window.Library.Flags[flag] = key.Name
	apply(key, true)

	holder.MouseButton1Click:Connect(function()
		listening = true
		holderText.Text = "Press..."
	end)

	self.Window._connections:Give(UserInputService.InputBegan:Connect(function(input, gp)
		if gp or self.Destroyed then
			return
		end
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			listening = false
			self.Window.Library:SetFlag(flag, input.KeyCode)
			apply(input.KeyCode, false)
			return
		end
		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == key then
			if callback then
				task.spawn(callback, key)
			end
		end
	end))

	holder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(holder, theme, input.Position)
		end
	end)

	self:_bindTheme(function(th)
		card.BackgroundColor3 = th.Background
		label.TextColor3 = th.Text
		holder.BackgroundColor3 = th.Input
		holderText.TextColor3 = th.Text
		local s = card:FindFirstChildOfClass("UIStroke")
		if s then
			s.Color = th.Stroke
		end
	end)

	self:_registerElement({ Frame = card, SearchText = name .. " " .. key.Name })

	return {
		Set = function(_, v)
			self.Window.Library:SetFlag(flag, v)
			apply(v, false)
		end,
		Get = function()
			return key
		end
	}
end

