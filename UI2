local Utility = {}

function Utility:Create(className, properties)
    local instance = Instance.new(className)
    for property, value in pairs(properties) do
        if property == "Parent" then
            continue
        end
        instance[property] = value
    end
    if properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility:Tween(instance, properties, duration, easingStyle, easingDirection, callback)
    duration = duration or ANIMATION_SPEED
    easingStyle = easingStyle or Enum.EasingStyle.Quad
    easingDirection = easingDirection or Enum.EasingDirection.Out
    
    local tweenInfo = TweenInfo.new(duration, easingStyle, easingDirection)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    
    if callback then
        tween.Completed:Connect(callback)
    end
    
    tween:Play()
    return tween
end

function Utility:AddGradient(instance, color1, color2, rotation)
    rotation = rotation or 90
    local gradient = self:Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, color1),
            ColorSequenceKeypoint.new(1, color2)
        }),
        Rotation = rotation,
        Parent = instance
    })
    return gradient
end

function Utility:AddStroke(instance, color, thickness, transparency)
    thickness = thickness or 1
    transparency = transparency or 0
    local stroke = self:Create("UIStroke", {
        Color = color,
        Thickness = thickness,
        Transparency = transparency,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = instance
    })
    return stroke
end

function Utility:AddCorner(instance, radius)
    radius = radius or UDim.new(0, 8)
    local corner = self:Create("UICorner", {
        CornerRadius = radius,
        Parent = instance
    })
    return corner
end

function Utility:AddPadding(instance, padding)
    local pad = self:Create("UIPadding", {
        PaddingTop = UDim.new(0, padding.Top or padding.All or 0),
        PaddingBottom = UDim.new(0, padding.Bottom or padding.All or 0),
        PaddingLeft = UDim.new(0, padding.Left or padding.All or 0),
        PaddingRight = UDim.new(0, padding.Right or padding.All or 0),
        Parent = instance
    })
    return pad
end

