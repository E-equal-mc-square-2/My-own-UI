                    Size = UDim2.new(1, -45, 1, 0),
                    Font = Theme.Font,
                    Text = multi and table.concat(CurrentSelected, ", ") or tostring(CurrentSelected),
                    TextColor3 = Theme.SubText,
                    TextSize = Theme.TextSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    Parent = SelectBG
                })
                
                local Arrow = Utility:Create("ImageLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -30, 0.5, -9),
                    Size = UDim2.new(0, 18, 0, 18),
                    Image = "rbxassetid://10736894956", -- Arrow Down
                    ImageColor3 = Theme.SubText,
                    Parent = SelectBG
                })
                
                local OptionContainer = Utility:Create("ScrollingFrame", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 70),
                    Size = UDim2.new(1, 0, 1, -70),
                    CanvasSize = UDim2.new(0, 0, 0, 0),
                    AutomaticCanvasSize = Enum.AutomaticSize.Y,
                    ScrollBarThickness = 2,
                    ScrollBarImageColor3 = Theme.Accent,
                    Parent = DropdownFrame
                })
                
                Utility:Create("UIListLayout", {
                    Parent = OptionContainer,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 2)
                })
                Utility:AddPadding(OptionContainer, UDim.new(0, 5))
                
                local SelectButton = Utility:Create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = SelectBG
                })

                local function UpdateDropdownState()
                    local targetHeight = Expanded and math.min(65 + (#list * 35) + 10, 250) or 65
                    Utility:Tween(DropdownFrame, {Size = UDim2.new(1, 0, 0, targetHeight)}, 0.3, Enum.EasingStyle.Quart)
                    Utility:Tween(Arrow, {Rotation = Expanded and 180 or 0}, 0.3)
                    Utility:Tween(SelectStroke, {Color = Expanded and Theme.Accent or Theme.Stroke}, 0.3)
                end

                SelectButton.MouseButton1Click:Connect(function()
                    Expanded = not Expanded
                    UpdateDropdownState()
                end)
                
                local OptionInstances = {}
                
                local function BuildOptions()
                    for _, child in ipairs(OptionContainer:GetChildren()) do
                        if child:IsA("Frame") then child:Destroy() end
                    end
                    table.clear(OptionInstances)
                    
                    for i, option in ipairs(list) do
                        local OptFrame = Utility:Create("Frame", {
                            BackgroundColor3 = Theme.Tertiary,
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, -10, 0, 33),
                            Parent = OptionContainer
                        })
                        Utility:AddCorner(OptFrame, UDim.new(0, 4))
                        
                        local OptText = Utility:Create("TextLabel", {
                            BackgroundTransparency = 1,
                            Position = UDim2.new(0, 10, 0, 0),
                            Size = UDim2.new(1, -20, 1, 0),
                            Font = Theme.Font,
                            Text = tostring(option),
                            TextColor3 = Theme.SubText,
                            TextSize = Theme.TextSize,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Parent = OptFrame
                        })
                        
                        local CheckIcon = Utility:Create("ImageLabel", {
                            BackgroundTransparency = 1,
                            Position = UDim2.new(1, -25, 0.5, -9),
                            Size = UDim2.new(0, 18, 0, 18),
                            Image = "rbxassetid://10736904294", -- Checkmark
                            ImageColor3 = Theme.Accent,
                            ImageTransparency = 1,
                            Parent = OptFrame
                        })
                        
                        local OptBtn = Utility:Create("TextButton", {
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, 0, 1, 0),
                            Text = "",
                            Parent = OptFrame
                        })
                        
                        local isSelected = multi and table.find(CurrentSelected, option) or (not multi and CurrentSelected == option)
                        if isSelected then
                            OptText.TextColor3 = Theme.Accent
                            CheckIcon.ImageTransparency = 0
                            OptFrame.BackgroundTransparency = 0.5
                        end
                        
                        table.insert(OptionInstances, {
                            Frame = OptFrame,
                            Text = OptText,
                            Check = CheckIcon,
                            Value = option
                        })
                        
                        OptBtn.MouseButton1Click:Connect(function()
                            if multi then
                                local idx = table.find(CurrentSelected, option)
                                if idx then
                                    table.remove(CurrentSelected, idx)
                                else
                                    table.insert(CurrentSelected, option)
                                end
                                SelectedText.Text = #CurrentSelected > 0 and table.concat(CurrentSelected, ", ") or "None"
                                Utility.Flags[flag] = {Value = CurrentSelected, Set = BuildOptions}
                                pcall(callback, CurrentSelected)
                                BuildOptions() -- Rebuild to update visual state correctly
                            else
                                CurrentSelected = option
                                SelectedText.Text = tostring(option)
                                Utility.Flags[flag] = {Value = CurrentSelected, Set = function(v) CurrentSelected = v; SelectedText.Text = v; BuildOptions() end}
                                pcall(callback, CurrentSelected)
                                Expanded = false
                                UpdateDropdownState()
                                BuildOptions()
                            end
                        end)
                        
                        OptBtn.MouseEnter:Connect(function()
                            Utility:Tween(OptFrame, {BackgroundTransparency = 0.5}, 0.2)
                        end)
                        OptBtn.MouseLeave:Connect(function()
                            if not (multi and table.find(CurrentSelected, option) or (not multi and CurrentSelected == option)) then
                                Utility:Tween(OptFrame, {BackgroundTransparency = 1}, 0.2)
                            end
                        end)
                    end
                end
                
                Utility.Flags[flag] = {Value = CurrentSelected, Set = function(val) CurrentSelected = val; BuildOptions() end}
                BuildOptions()
                pcall(callback, CurrentSelected)
                
                function DropdownFrame:Refresh(newList)
                    list = newList
                    BuildOptions()
                end
                
                return DropdownFrame
            end
