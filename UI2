function Framework:SetTheme(theme)
    if not self.Themes[theme] then return end

    self.Theme = self.Themes[theme]

    for _, object in pairs(self.Objects) do
        if object and object.UpdateTheme then
            task.spawn(function()
                object:UpdateTheme()
            end)
        end
    end
end

--//======================================================
--// CONNECTION MANAGER
--//======================================================

function Framework:Connect(signal, callback)
    local connection = signal:Connect(callback)
    table.insert(self.Connections, connection)
    return connection
end

function Framework:Cleanup()
    for _, connection in pairs(self.Connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end

    self.Connections = {}
end

--//======================================================
--// UTILITY SYSTEM
