function TabMT:Destroy()
	if self.Destroyed then
		return
	end
	self.Destroyed = true
	for _, sec in ipairs(self.Sections) do
		if sec and sec.Destroy then
			pcall(function()
				sec:Destroy()
			end)
		end
	end
	if self.Page then self.Page:Destroy() end
	if self.Button then self.Button:Destroy() end
end

