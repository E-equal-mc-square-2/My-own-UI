		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Visible = false,
		Parent = card
	})
	ApplyCorner(list, 12)
	ApplyStroke(list, theme.Stroke, 0.55, 1)
	AddPadding(list, 6, 6, 6, 6)
	local listLayout = AddListLayout(list, 6)

	local function setValue(v, silent)
		current = v
		holderText.Text = tostring(v)
		holderText.TextColor3 = theme.Text
		self.Window.Library:_setFlag(dropdownFlag, v)
		if not silent and callback then
			task.spawn(callback, v)
		end
	end

	local function rebuild()
		for _, c in ipairs(list:GetChildren()) do
			if c:IsA("TextButton") then
				c:Destroy()
			end
		end
		for _, opt in ipairs(options) do
			local item = New("TextButton", {
				BackgroundColor3 = theme.Card2,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 38),
