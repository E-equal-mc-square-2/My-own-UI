--//======================================================
--// UTILITIES
--//======================================================

local function New(className, props)
	local obj = Instance.new(className)
	if props then
		for k, v in pairs(props) do
			obj[k] = v
		end
	end
	return obj
end

local function IsTouch()
	return UserInputService.TouchEnabled
end

local function GetViewport()
	local cam = workspace.CurrentCamera
	if cam then
		return cam.ViewportSize
	end
	return Vector2.new(1280, 720)
end

local function Clamp(v, a, b)
	return math.max(a, math.min(b, v))
end

local function SafeCall(fn, ...)
	local ok, result = pcall(fn, ...)
	if ok then
		return result
	end
	return nil
end

local function DestroyIfExists(inst)
	if inst then
		pcall(function()
			inst:Destroy()
		end)
	end
end

local function Tween(inst, info, props)
	local t = TweenService:Create(inst, info, props)
	t:Play()
	return t
end

local function ApplyCorner(inst, radius)
	return New("UICorner", {
		CornerRadius = UDim.new(0, radius or 12),
		Parent = inst
	})
end

local function ApplyStroke(inst, color, transparency, thickness)
	return New("UIStroke", {
		Color = color,
		Transparency = transparency or 0.35,
		Thickness = thickness or 1,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = inst
	})
end

local function ApplyGradient(inst, c1, c2, rotation)
	return New("UIGradient", {
		Color = ColorSequence.new(c1, c2),
		Rotation = rotation or 0,
		Parent = inst
	})
end

local function AddPadding(inst, left, right, top, bottom)
	return New("UIPadding", {
		PaddingLeft = UDim.new(0, left or 0),
		PaddingRight = UDim.new(0, right or 0),
		PaddingTop = UDim.new(0, top or 0),
		PaddingBottom = UDim.new(0, bottom or 0),
		Parent = inst
	})
end

local function AddListLayout(parent, pad, sortOrder)
	return New("UIListLayout", {
		Padding = UDim.new(0, pad or 0),
		SortOrder = sortOrder or Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Top,
		Parent = parent
	})
end

local function Rippler(parent, theme, inputPosition)
	local localPos = inputPosition - parent.AbsolutePosition
	local circle = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BackgroundTransparency = 0.72,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromOffset(localPos.X, localPos.Y),
		Size = UDim2.fromOffset(0, 0),
		ZIndex = parent.ZIndex + 10,
		Parent = parent
	})
	ApplyCorner(circle, 999)
	local maxDim = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.6
	Tween(circle, TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(maxDim, maxDim),
		BackgroundTransparency = 1
	})
	task.delay(0.48, function()
		DestroyIfExists(circle)
	end)
end

local function SafeFileSystem()
	return type(isfile) == "function" and type(readfile) == "function" and type(writefile) == "function" and type(makefolder) == "function"
end

local function SafeIsFolder(path)
	if type(isfolder) ~= "function" then
		return false
	end
	local ok, res = pcall(function()
		return isfolder(path)
	end)
	return ok and res
end

local function SafeMakeFolder(path)
	if type(makefolder) ~= "function" then
		return
	end
	pcall(function()
		if not SafeIsFolder(path) then
			makefolder(path)
		end
	end)
end

local function EncodeValue(value)
	local t = typeof(value)
	if t == "Color3" then
		return { __type = "Color3", r = value.R, g = value.G, b = value.B }
	elseif t == "EnumItem" then
		return { __type = "EnumItem", enum = tostring(value.EnumType), name = value.Name }
	elseif t == "table" then
		return { __type = "table", value = value }
	else
		return { __type = t, value = value }
	end
end

local function DecodeValue(entry)
	if type(entry) ~= "table" then
		return entry
	end
	if entry.__type == "Color3" then
		return Color3.new(entry.r or 1, entry.g or 1, entry.b or 1)
	end
	if entry.__type == "EnumItem" then
		if entry.enum == "Enum.KeyCode" and entry.name and Enum.KeyCode[entry.name] then
			return Enum.KeyCode[entry.name]
		end
		return entry.name
	end
	return entry.value
end

local function GetExecutorName()
	local name = "Unknown"
	pcall(function()
		if identifyexecutor then
			name = identifyexecutor()
		end
	end)
	return name
end

Library._executor = GetExecutorName()

local function PickParentGui()
	local ok, hui = pcall(function()
		return gethui and gethui()
	end)
	if ok and typeof(hui) == "Instance" then
		return hui
	end
	if PlayerGui then
		return PlayerGui
	end
	return CoreGui
end

local function ResolveTheme(input, fallback)
	if type(input) == "string" then
		return Library.Themes[input] or fallback or Library.Theme
	elseif type(input) == "table" then
		local base = {}
		for k, v in pairs(fallback or Library.Theme) do
			base[k] = v
		end
		for k, v in pairs(input) do
			base[k] = v
		end
		return base
	end
	return fallback or Library.Theme
end

local function ResolveKey(key)
	if typeof(key) == "EnumItem" and key.EnumType == Enum.KeyCode then
		return key
	end
	if type(key) == "string" and Enum.KeyCode[key] then
		return Enum.KeyCode[key]
	end
	return nil
end

local function ResolveIconIcon(icon)
	if type(icon) ~= "string" then
		return nil, nil
	end
	if icon:match("^rbxassetid://") or icon:match("^%d+$") then
		return icon, true
	end
	return icon, false
end

--//======================================================
--// MAID / CONNECTION MANAGER
--//======================================================

local Maid = {}
Maid.__index = Maid

function Maid.new()
	return setmetatable({ Tasks = {} }, Maid)
end

function Maid:Give(taskObj)
	table.insert(self.Tasks, taskObj)
	return taskObj
end

function Maid:Cleanup()
	for _, taskObj in ipairs(self.Tasks) do
		pcall(function()
			local t = typeof(taskObj)
			if t == "RBXScriptConnection" then
				taskObj:Disconnect()
			elseif t == "Instance" then
				taskObj:Destroy()
			elseif type(taskObj) == "function" then
				taskObj()
			elseif type(taskObj) == "thread" then
				task.cancel(taskObj)
			end
		end)
	end
	table.clear(self.Tasks)
end

