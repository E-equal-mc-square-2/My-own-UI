                        TextSize = 16,
                        Position = UDim2.new(0, 10, 0, 0),
                        Size = UDim2.new(0, 20, 1, 0),
                        Visible = isSelected(option),
                        ZIndex = 102,
                        Parent = optionButton
                    })
                    
                    optionButtons[option] = {Button = optionButton, Checkmark = checkmark}
                    
                    optionButton.MouseEnter:Connect(function()
                        Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.Primary}, 0.15)
                    end)
                    
                    optionButton.MouseLeave:Connect(function()
                        Utility:Tween(optionButton, {BackgroundColor3 = CurrentTheme.BackgroundTertiary}, 0.15)
                    end)
                    
                    optionButton.MouseButton1Click:Connect(function()
                        toggleValue(option)
                        checkmark.Visible = isSelected(option)
                    end)
                end
                
                listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    dropdownList.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
                end)
                
                updateDropdown(true)
                
                local MultiDropdown = {}
                function MultiDropdown:Set(values)
                    selectedValues = values
                    for option, components in pairs(optionButtons) do
                        components.Checkmark.Visible = isSelected(option)
                    end
                    updateDropdown(false)
                end
                
                return MultiDropdown
            end
            
            return Section
        end
        
        return Tab
    end
    
    --//======================================================
    --// WATERMARK
    --//======================================================
    
    function Window:CreateWatermark(text)
        local watermark = Utility:Create("Frame", {
            Name = "Watermark",
            BackgroundColor3 = CurrentTheme.BackgroundSecondary,
            Size = UDim2.new(0, 200, 0, 35),
            Position = UDim2.new(0, 10, 0, 10),
            ZIndex = 9999,
            Parent = screenGui
        })
        
        Utility:AddCorner(watermark, UDim.new(0, 8))
        Utility:AddStroke(watermark, CurrentTheme.Border, 1, 0.3)
        Utility:AddGlow(watermark, CurrentTheme.Glow, 0.3)
        
        local watermarkAccent = Utility:Create("Frame", {
            Name = "Accent",
            BackgroundColor3 = CurrentTheme.Primary,
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BorderSizePixel = 0,
            ZIndex = 10000,
            Parent = watermark
        })
        
        Utility:AddGradient(watermarkAccent, CurrentTheme.Primary, CurrentTheme.PrimaryLight, 90)
        
        local watermarkText = Utility:Create("TextLabel", {
            Name = "Text",
            BackgroundTransparency = 1,
            Font = Enum.Font.GothamBold,
            Text = text or "Nexus UI",
            TextColor3 = CurrentTheme.Text,
            TextSize = 13,
            Size = UDim2.new(1, -20, 1, -2),
            Position = UDim2.new(0, 10, 0, 0),
            ZIndex = 10000,
            Parent = watermark
        })
        
        return watermark
    end
    
    --//======================================================
    --// FPS COUNTER
    --//======================================================
    
    function Window:CreateFPSCounter()
        local fpsCounter = Utility:Create("Frame", {
            Name = "FPSCounter",
            BackgroundColor3 = CurrentTheme.BackgroundSecondary,
            Size = UDim2.new(0, 100, 0, 35),
            Position = UDim2.new(1, -110, 0, 10),
            ZIndex = 9999,
            Parent = screenGui
        })
        
        Utility:AddCorner(fpsCounter, UDim.new(0, 8))
        Utility:AddStroke(fpsCounter, CurrentTheme.Border, 1, 0.3)
        
        local fpsAccent = Utility:Create("Frame", {
            Name = "Accent",
            BackgroundColor3 = CurrentTheme.Primary,
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BorderSizePixel = 0,
            ZIndex = 10000,
            Parent = fpsCounter
        })
        
        local fpsText = Utility:Create("TextLabel", {
            Name = "Text",
            BackgroundTransparency = 1,
            Font = Enum.Font.GothamBold,
            Text = "FPS: 60",
            TextColor3 = CurrentTheme.Text,
            TextSize = 13,
            Size = UDim2.new(1, 0, 1, -2),
            ZIndex = 10000,
            Parent = fpsCounter
        })
        
        local lastUpdate = tick()
        local frameCount = 0
        
        RunService.RenderStepped:Connect(function()
            frameCount = frameCount + 1
            
            if tick() - lastUpdate >= 1 then
                local fps = frameCount
                fpsText.Text = "FPS: " .. fps
                
                if fps >= 60 then
                    fpsText.TextColor3 = CurrentTheme.Success
                elseif fps >= 30 then
                    fpsText.TextColor3 = CurrentTheme.Warning
                else
                    fpsText.TextColor3 = CurrentTheme.Error
                end
                
                frameCount = 0
                lastUpdate = tick()
            end
        end)
        
        return fpsCounter
    end
    
    --//======================================================
    --// KEYBIND TOGGLE
    --//======================================================
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed and input.KeyCode == Enum.KeyCode.RightControl then
            Window:Toggle()
        end
    end)
    
    --//======================================================
    --// CLEANUP ON DESTROY
    --//======================================================
    
    function Window:Destroy()
        ConnectionManager:DisconnectAll()
        Utility:Tween(blur, {Size = 0}, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In, function()
            blur:Destroy()
        end)
        screenGui:Destroy()
    end
    
    --//======================================================
    --// NOTIFICATION
    --//======================================================
    
    function Window:Notify(config)
        return NotificationSystem:Send(config)
    end
    
    --//======================================================
    --// CONFIG MANAGEMENT
    --//======================================================
    
    function Window:SaveConfig()
        return ConfigSystem:SaveConfig()
    end
    
    function Window:LoadConfig()
        return ConfigSystem:LoadConfig()
    end
    
    function Window:DeleteConfig()
        return ConfigSystem:DeleteConfig()
    end
    
    --//======================================================
    --// WELCOME NOTIFICATION
    --//======================================================
    
    task.delay(0.5, function()
        Window:Notify({
            Title = "Welcome!",
            Description = "Nexus UI loaded successfully",
            Type = "Success",
            Duration = 4
        })
    end)
    
    return Window
end

