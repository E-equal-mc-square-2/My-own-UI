                local SliderTitle = Utility:Create("TextLabel", {
                    Parent = SliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0,14,0,0),
                    Size = UDim2.new(1,-60,0,26),
                    Text = Settings.Name or "Slider",
                    Font = Enum.Font.GothamMedium,
                    TextSize = Mobile:Scale(13),
                    TextColor3 = Library.Theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                })

                local ValueLabel = Utility:Create("TextLabel", {
                    Parent = SliderFrame,
                    BackgroundTransparency = 1,
                    AnchorPoint = Vector2.new(1,0),
                    Position = UDim2.new(1,-14,0,0),
                    Size = UDim2.new(0,50,0,26),
                    Text = tostring(Value),
                    Font = Enum.Font.GothamBold,
                    TextSize = Mobile:Scale(13),
                    TextColor3 = Library.Theme.AccentLight,
                    TextXAlignment = Enum.TextXAlignment.Right
                })

                local SliderBar = Utility:Create("Frame", {
                    Parent = SliderFrame,
                    Position = UDim2.new(0,14,0,42),
                    Size = UDim2.new(1,-28,0,8),
                    BackgroundColor3 = Library.Theme.Secondary,
                    BorderSizePixel = 0
                })

                Utility:Corner(SliderBar,999)

                local Fill = Utility:Create("Frame", {
                    Parent = SliderBar,
                    Size = UDim2.new(0,0,1,0),
                    BackgroundColor3 = Library.Theme.Accent,
                    BorderSizePixel = 0
                })

                Utility:Corner(Fill,999)
                Utility:Gradient(Fill, Library.Theme.AccentLight, Library.Theme.Accent, 0)

                local Circle = Utility:Create("Frame", {
                    Parent = Fill,
                    AnchorPoint = Vector2.new(1,0.5),
                    Position = UDim2.new(1,0,0.5,0),
                    Size = UDim2.new(0,16,0,16),
                    BackgroundColor3 = Color3.new(1,1,1),
                    BorderSizePixel = 0
                })

                Utility:Corner(Circle,999)

                local function Update(ValueX)
                    local Percent = math.clamp((ValueX - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
                    local Number = math.floor(((Max - Min) * Percent) + Min)

                    Value = Number
                    Fill.Size = UDim2.new(Percent, 0, 1, 0)
                    ValueLabel.Text = tostring(Number)

                    if Settings.Flag then
                        Library.Flags[Settings.Flag] = Number
                    end

                    if Settings.Callback then
                        pcall(function() Settings.Callback(Number) end)
                    end
                end

                -- Set initial value
                Fill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)

                table.insert(Library.Connections, UserInputService.InputEnded:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Sliding = false
                        Utility:Tween(SliderStroke, 0.2, {Color = Library.Theme.Stroke})
                    end
                end))

                SliderBar.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Sliding = true
                        Utility:Tween(SliderStroke, 0.2, {Color = Library.Theme.Accent})
                        Update(Input.Position.X)
                    end
                end)

                table.insert(Library.Connections, UserInputService.InputChanged:Connect(function(Input)
                    if Sliding then
                        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
                            Update(Input.Position.X)
                        end
                    end
                end))

                return {
                    Set = function(_, Number)
                        Number = math.clamp(Number, Min, Max)
                        local Percent = (Number - Min) / (Max - Min)
                        Fill.Size = UDim2.new(Percent, 0, 1, 0)
                        ValueLabel.Text = tostring(Number)
                        Value = Number
                    end,
                    Get = function()
                        return Value
                    end
                }
            end

