function Library:Notify(title, text, duration)
	self:_initRoot()

	local theme = self.Theme
	local holder = self._notificationHolder
	local notif = New("Frame", {
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(320, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ClipsDescendants = true,
		Parent = holder
	})
	ApplyCorner(notif, 14)
	ApplyStroke(notif, theme.Stroke, 0.44, 1)
	AddPadding(notif, 12, 12, 10, 10)

	local bar = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, 0, 0, 3),
		Parent = notif
	})
	ApplyGradient(bar, theme.Accent, theme.Accent2, 0)

	local body = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = notif
	})
	AddListLayout(body, 4)

	local t = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 18),
		Font = Enum.Font.GothamSemibold,
		Text = tostring(title or "Notification"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = body
	})

	local d = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 16),
		Font = Enum.Font.Gotham,
		Text = tostring(text or ""),
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = body
	})

	notif.Size = UDim2.fromOffset(320, 0)
	notif.Position = UDim2.new(1, 0, 0, 0)
	notif.BackgroundTransparency = 1

	task.defer(function()
		Tween(notif, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.08
		})
		Tween(notif, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromOffset(0, 0)
		})
	end)

	local life = duration or 3.2
	task.delay(life, function()
		if notif and notif.Parent then
			Tween(notif, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(340, 0)
			})
			task.delay(0.28, function()
				DestroyIfExists(notif)
			end)
		end
	end)

	return notif
end

