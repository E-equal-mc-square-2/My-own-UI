            BackgroundTransparency = 1,
            Position = UDim2.new(0,16,0,10),
            Size = UDim2.new(1,-26,0,22),
            Text = Settings.Title or "Notification",
            Font = Enum.Font.GothamBold,
            TextSize = Mobile:Scale(14),
            TextColor3 = Library.Theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left
        })

        local NotificationText = Utility:Create("TextLabel", {
            Parent = Notification,
            BackgroundTransparency = 1,
            Position = UDim2.new(0,16,0,30),
            Size = UDim2.new(1,-26,0,30),
            Text = Settings.Content or "Content",
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            TextSize = Mobile:Scale(12),
            TextColor3 = Library.Theme.DarkText,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top
        })

        Notification.Position = UDim2.new(1,400,0,0)
        Utility:Tween(Notification, 0.35, {Position = UDim2.new(0,0,0,0)}, Enum.EasingStyle.Back)

        task.delay(Settings.Duration or 4, function()
            Utility:Tween(Notification, 0.3, {BackgroundTransparency = 1})

            for _, Child in pairs(Notification:GetDescendants()) do
                if Child:IsA("TextLabel") then
                    Utility:Tween(Child, 0.25, {TextTransparency = 1})
                elseif Child:IsA("Frame") then
                    Utility:Tween(Child, 0.25, {BackgroundTransparency = 1})
                elseif Child:IsA("UIStroke") then
                    Utility:Tween(Child, 0.25, {Transparency = 1})
                end
            end

            task.wait(0.3)
            Notification:Destroy()
        end)
    end

    --//======================================================
    --// WATERMARK
    --//======================================================

