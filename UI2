                swipeStartPos = input.Position
            end
        end)
        
        header.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch and swipeStart then
                local swipeDuration = tick() - swipeStart
                local swipeDelta = input.Position - swipeStartPos
                
                if swipeDuration < 0.3 and math.abs(swipeDelta.Y) > 50 then
