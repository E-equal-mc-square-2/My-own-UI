function Utility:MakeDraggable(gui, dragHandle)
    local dragging, dragInput, dragStart, startPos
    
    local function update(input)
        local delta = input.Position - dragStart
        self:Tween(gui, {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        }, 0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    end
    
    self:Connect(dragHandle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    self:Connect(dragHandle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    self:Connect(UserInputService.InputChanged, function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

function Utility:Ripple(button, x, y)
    local ripple = self:Create("ImageLabel", {
        Name = "Ripple",
        BackgroundTransparency = 1,
        Image = "rbxassetid://4560909609",
        ImageColor3 = Color3.fromRGB(255, 255, 255),
        ImageTransparency = 0.6,
        ZIndex = button.ZIndex + 1,
        Parent = button
    })
    
    local isTouch = UserInputService:GetLastInputType() == Enum.UserInputType.Touch
    local posX, posY
    
    if isTouch then
        posX = x - button.AbsolutePosition.X
        posY = y - button.AbsolutePosition.Y
    else
        posX = Mouse.X - button.AbsolutePosition.X
        posY = Mouse.Y - button.AbsolutePosition.Y
    end
    
    ripple.Position = UDim2.new(0, posX, 0, posY)
    ripple.Size = UDim2.new(0, 0, 0, 0)
    
    local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.5
    
    local tween = self:Tween(ripple, {
        Size = UDim2.new(0, size, 0, size),
        Position = UDim2.new(0, posX - size/2, 0, posY - size/2),
        ImageTransparency = 1
    }, 0.5)
    
    task.delay(0.5, function()
        ripple:Destroy()
    end)
end

