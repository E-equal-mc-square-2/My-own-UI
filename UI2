function Library:_createReopenButton(window)
	if self._reopenButtons[window] then
		return self._reopenButtons[window]
	end

	local theme = self.Theme
	local btn = New("TextButton", {
		Name = "ReopenButton_" .. tostring(window.Id),
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.new(1, -18, 1, -18),
		Size = UDim2.fromOffset(60, 60),
		Text = "",
		AutoButtonColor = false,
		Visible = false,
		ZIndex = 1000,
		Parent = self._topLayer
	})
	ApplyCorner(btn, 18)
	ApplyStroke(btn, theme.Accent, 0.25, 1)

	local glow = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BackgroundTransparency = 0.87,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = btn
	})
	ApplyCorner(glow, 18)
	ApplyGradient(glow, theme.Accent, theme.Accent2, 40)

	local txt = New("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Font = Enum.Font.GothamBold,
		Text = "≡",
		TextColor3 = theme.Text,
		TextSize = 24,
		Parent = btn
	})

	btn.MouseButton1Click:Connect(function()
		window:Show()
	end)

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			Rippler(btn, theme, input.Position)
		end
	end)

	self._reopenButtons[window] = btn
	return btn
end

function Library:_removeReopenButton(window)
	if self._reopenButtons[window] then
		self._reopenButtons[window]:Destroy()
		self._reopenButtons[window] = nil
	end
end

function Library:_updateAllWindowsTheme(theme)
	for _, window in ipairs(self.Windows) do
		if window and window.ApplyTheme then
			window:ApplyTheme(theme)
		end
	end
end

