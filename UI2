                })
                
                local TrackBg = Utility:Create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 8),
                    Position = UDim2.new(0, 0, 1, -15),
                    BackgroundColor3 = NeonPrime.Theme.SurfaceLight,
                    Text = "",
                    AutoButtonColor = false,
                    Parent = SliderFrame
                })
                Utility:AddCorner(TrackBg, 4)
                
                local Fill = Utility:Create("Frame", {
                    Size = UDim2.new((sld.Value - sld.Min) / (sld.Max - sld.Min), 0, 1, 0),
                    BackgroundColor3 = NeonPrime.Theme.Primary,
                    Parent = TrackBg
                })
                Utility:AddCorner(Fill, 4)
                Utility:AddGradient(Fill, NeonPrime.Theme.Primary, NeonPrime.Theme.PrimaryDark, 0)
                
                local Knob = Utility:Create("Frame", {
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(1, -8, 0.5, -8),
                    BackgroundColor3 = Color3.new(1,1,1),
                    Parent = Fill
                })
                Utility:AddCorner(Knob, 8)
                Utility:CreateShadow(Knob, 8, 0.3)
                
                function sld:Set(val)
                    val = math.clamp(val, sld.Min, sld.Max)
                    local formatStr = "%." .. sld.Decimals .. "f"
                    val = tonumber(string.format(formatStr, val))
                    sld.Value = val
                    NeonPrime.Flags[sld.Flag] = val
                    
                    ValueLabel.Text = tostring(val)
                    local percent = (val - sld.Min) / (sld.Max - sld.Min)
                    Utility:Tween(Fill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
                    task.spawn(sld.Callback, val)
                end
                
                local dragging = false
                Utility:Connection(TrackBg.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                    end
                end)
                
                Utility:Connection(UserInputService.InputEnded, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                Utility:Connection(UserInputService.InputChanged, function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local inputPos = input.Position.X
                        local trackPos = TrackBg.AbsolutePosition.X
                        local trackSize = TrackBg.AbsoluteSize.X
                        local percent = math.clamp((inputPos - trackPos) / trackSize, 0, 1)
                        local val = sld.Min + (sld.Max - sld.Min) * percent
                        sld:Set(val)
                    end
                end)
                
                return sld
            end
            
