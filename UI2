function Library:Notify(title, text, duration)
	self:_initRoot()

	local theme = self.Theme
	local holder = self._notificationHolder
	if not holder then
		return
	end

	local card = New("Frame", {
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(320, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		ClipsDescendants = true,
		Parent = holder
	})
	ApplyCorner(card, 14)
	ApplyStroke(card, theme.Stroke, 0.45, 1)
	AddPadding(card, 12, 12, 10, 10)

	local bar = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 3),
		Parent = card
	})
	ApplyGradient(bar, theme.Accent, theme.Accent2, 0)

	local titleLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Font = Enum.Font.GothamBold,
		Text = tostring(title or "Notification"),
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = card
	})

	local contentLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 16),
		Font = Enum.Font.Gotham,
		Text = tostring(text or ""),
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = card
	})

	card.BackgroundTransparency = 1
	card.Position = UDim2.fromOffset(340, 0)

	Tween(card, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.06,
		Position = UDim2.fromOffset(0, 0)
	})

	task.delay(duration or 3, function()
		if card and card.Parent then
			Tween(card, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(340, 0)
			})
			task.delay(0.24, function()
				DestroyIfExists(card)
			end)
		end
	end)

	return card
end

function Library:NotifySuccess(title, text, duration)
	return self:Notify(title or "Success", text or "", duration or 3)
end

function Library:NotifyError(title, text, duration)
	return self:Notify(title or "Error", text or "", duration or 4)
end

--//======================================================
--// CONFIG SYSTEM
--//======================================================

function Library:_encodeFlags()
	local data = {}
	for flag, value in pairs(self.Flags) do
		data[flag] = EncodeValue(value)
	end
	return data
end

function Library:_applyConfigTable(data)
	for flag, encoded in pairs(data) do
		local value = DecodeValue(encoded)
		self.Flags[flag] = value
		local setter = self._flagSetters[flag]
		if setter then
			pcall(function()
				setter(value, true)
			end)
		end
	end
end

function Library:SaveConfig(name)
	local configName = tostring(name or self._autoSaveName or "default")
	local json = HttpService:JSONEncode(self:_encodeFlags())

	if SafeFileSystem() then
		SafeMakeFolder(self._configDir)
		writefile(self._configDir .. "/" .. configName .. ".json", json)
	else
		self._memoryConfigs[configName] = json
	end
	return true
end

function Library:LoadConfig(name)
	local configName = tostring(name or self._autoSaveName or "default")
	local json

	if SafeFileSystem() then
		local path = self._configDir .. "/" .. configName .. ".json"
		if isfile(path) then
			json = readfile(path)
		end
	else
		json = self._memoryConfigs[configName]
	end

	if not json or json == "" then
		return false
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(json)
	end)

	if ok and type(decoded) == "table" then
		self:_applyConfigTable(decoded)
		return true
	end

	return false
end

function Library:SetAutoSave(enabled, name)
	self._autoSave = enabled and true or false
	if name then
		self._autoSaveName = tostring(name)
	end
end

function Library:_setFlag(flag, value)
	self.Flags[flag] = value
	if self._autoSave then
		task.spawn(function()
			self:SaveConfig(self._autoSaveName)
		end)
	end
end

function Library:_registerFlag(flag, setter)
	self._flagSetters[flag] = setter
end

function Library:SetFlag(flag, value)
	self:_setFlag(flag, value)
	local setter = self._flagSetters[flag]
	if setter then
		setter(value, true)
	end
end

function Library:GetFlag(flag)
	return self.Flags[flag]
end

--//======================================================
--// THEME ENGINE
--//======================================================

function Library:_resolveTheme(input)
	return ResolveTheme(input, self.Theme)
end

function Library:SetTheme(theme)
	self.Theme = self:_resolveTheme(theme)
	if type(theme) == "string" then
		self._themeName = theme
	end
	for _, window in ipairs(self.Windows) do
		if window and window.ApplyTheme then
			window:ApplyTheme(self.Theme)
		end
	end
	if self._watermarkFrame then
		self._watermarkFrame.BackgroundColor3 = self.Theme.Card
	end
	if self._watermark then
		self._watermark.TextColor3 = self.Theme.Text
	end
	if self._fpsLabel then
		self._fpsLabel.TextColor3 = self.Theme.Text
	end
end

function Library:GetTheme()
	return self.Theme, self._themeName
end

