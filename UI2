        TextColor3 = color,
        FontFace = NeonPrime.Theme.FontBold,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = notifCard
    })
    
    local textLabel = Utility:Create("TextLabel", {
        Size = UDim2.new(1, -24, 0, 0),
        Position = UDim2.new(0, 12, 0, 36),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = NeonPrime.Theme.SubText,
        FontFace = NeonPrime.Theme.FontRegular,
        TextSize = 14,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Parent = notifCard
    })
    
    -- Calc height
    local bounds = Utility:GetTextBounds(text, NeonPrime.Theme.FontRegular, 14, 296)
    local totalHeight = 36 + bounds.Y + 12
    
    -- Progress bar
    local progressBg = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        BackgroundColor3 = NeonPrime.Theme.Background,
        BorderSizePixel = 0,
        Parent = notifCard
    })
    
    local progressBar = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Parent = progressBg
    })
    Utility:AddGradient(progressBar, color, NeonPrime.Theme.PrimaryDark, 0)
    
    -- Animation in
    Utility:Tween(notif, {Size = UDim2.new(1, 0, 0, totalHeight)}, 0.3, Enum.EasingStyle.Back)
    task.wait(0.1)
    Utility:Tween(notifCard, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0}, 0.4, Enum.EasingStyle.Quint)
    
    -- Progress animation
    Utility:Tween(progressBar, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)
    
    task.delay(duration, function()
        local out = Utility:Tween(notifCard, {Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1}, 0.3)
        out.Completed:Connect(function()
            local collapse = Utility:Tween(notif, {Size = UDim2.new(1, 0, 0, 0)}, 0.2)
            collapse.Completed:Connect(function()
                notif:Destroy()
            end)
        end)
    end)
end

