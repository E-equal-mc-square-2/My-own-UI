	config = config or {}

	local self = setmetatable({}, Library)
	self.Theme = table.clone(DEFAULT_THEME)
	if config.Theme then
		for k, v in pairs(config.Theme) do
			self.Theme[k] = v
		end
	end

	self.Title = config.Title or "KilometresUI"
	self.Subtitle = config.Subtitle or "mobile-first UI library"
	self._hidden = false
	self._activeTab = nil
	self.Tabs = {}

	local gui = create("ScreenGui", {
		Name = "KilometresUI",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
