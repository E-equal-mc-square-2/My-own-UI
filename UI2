	})
	ApplyCorner(square, 12)
	ApplyStroke(square, theme.Stroke, 0.55, 1)

	local hue = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Position = UDim2.new(1, -12, 0, 28),
		Size = UDim2.fromOffset(12, 96),
		Parent = card
	})
	ApplyCorner(hue, 12)
	ApplyStroke(hue, theme.Stroke, 0.55, 1)

	local hueGrad = New("UIGradient", {
		Rotation = 90,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
			ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255, 255, 0)),
			ColorSequenceKeypoint.new(0.32, Color3.fromRGB(0, 255, 0)),
			ColorSequenceKeypoint.new(0.48, Color3.fromRGB(0, 255, 255)),
			ColorSequenceKeypoint.new(0.64, Color3.fromRGB(0, 0, 255)),
			ColorSequenceKeypoint.new(0.80, Color3.fromRGB(255, 0, 255)),
			ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0))
		}),
		Parent = hue
	})

	local sat = New("Frame", {
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = square
	})
	ApplyCorner(sat, 12)

	local whiteOverlay = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = sat
	})
	ApplyCorner(whiteOverlay, 12)
	ApplyGradient(whiteOverlay, Color3.fromRGB(255, 255, 255), Color3.fromRGB(255, 255, 255), 0)

	local darkOverlay = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(0, 0, 0),
		BackgroundTransparency = 0.4,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = sat
	})
	ApplyCorner(darkOverlay, 12)
	ApplyGradient(darkOverlay, Color3.fromRGB(255, 255, 255), Color3.fromRGB(0, 0, 0), 90)

	local sv = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = square
	})

	local marker = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(12, 12),
		Parent = square
	})
	ApplyCorner(marker, 999)
	ApplyStroke(marker, theme.Stroke, 0.15, 1)

	local hueMarker = New("Frame", {
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(14, 14),
		Parent = hue
	})
	ApplyCorner(hueMarker, 999)
	ApplyStroke(hueMarker, theme.Stroke, 0.15, 1)

	local h, s, v = Color3.toHSV(color)
	local draggingSV = false
	local draggingHue = false

	local function updatePreview(silent)
		color = Color3.fromHSV(h, s, v)
		preview.BackgroundColor3 = color
		sat.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
		marker.Position = UDim2.new(s, 0, 1 - v, 0)
		hueMarker.Position = UDim2.new(0.5, 0, h, 0)
		self.Window.Library:_setFlag(pickerFlag, color)
		if not silent and callback then
			task.spawn(callback, color)
		end
	end

	local function pickSV(input)
		local px = Clamp((input.Position.X - square.AbsolutePosition.X) / square.AbsoluteSize.X, 0, 1)
		local py = Clamp((input.Position.Y - square.AbsolutePosition.Y) / square.AbsoluteSize.Y, 0, 1)
		s = px
		v = 1 - py
		updatePreview(false)
	end

	local function pickHue(input)
		local py = Clamp((input.Position.Y - hue.AbsolutePosition.Y) / hue.AbsoluteSize.Y, 0, 1)
		h = py
		updatePreview(false)
	end

	square.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSV = true
			pickSV(input)
		end
	end)

	hue.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingHue = true
			pickHue(input)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if draggingSV and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			pickSV(input)
		elseif draggingHue and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			pickHue(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSV = false
			draggingHue = false
		end
	end)

	self.Window.Library:_registerFlag(pickerFlag, function(v, silent)
		if typeof(v) == "Color3" then
			color = v
			h, s, val = Color3.toHSV(v)
			v = val
			updatePreview(silent)
		end
	end)
	self.Window.Library.Flags[pickerFlag] = color
	updatePreview(true)

	local meta = { Frame = card, SearchText = tostring(text or "") }
	self:_registerElement(meta)

	return {
		Set = function(_, c)
			if typeof(c) == "Color3" then
				color = c
				h, s, v = Color3.toHSV(c)
				updatePreview(false)
			end
		end,
		Get = function() return color end
	}
end

