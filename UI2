function SectionClass:CreateSlider(options)
	options = options or {}
	local name = tostring(options.Name or options.Text or "Slider")
	local callback = options.Callback
	local flag = options.Flag or name
	local min = tonumber(options.Min or 0)
	local max = tonumber(options.Max or 100)
	local increment = tonumber(options.Increment or 1)
	local value = tonumber(options.Default or min)
	value = Clamp(value, min, max)

	local theme = self.Window.Library.Theme
	local card = self:_createItemCard(74)

	local topRow = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Parent = card
	})

	local label = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -64, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = name,
		TextColor3 = theme.Text,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = topRow
	})

	local valueLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, 0, 0, 0),
		Size = UDim2.fromOffset(60, 18),
		Font = Enum.Font.GothamMedium,
		Text = tostring(value),
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = topRow
	})

	local track = New("Frame", {
		BackgroundColor3 = theme.Muted,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 36),
		Size = UDim2.new(1, 0, 0, 14),
		Parent = card
	})
	ApplyCorner(track, 999)

	local fill = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		Parent = track
	})
	ApplyCorner(fill, 999)
	ApplyGradient(fill, theme.Accent, theme.Accent2, 0)

	local handle = New("Frame", {
		BackgroundColor3 = theme.Text,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0, 0, 0.5, 0),
		Size = UDim2.fromOffset(20, 20),
		Parent = track
	})
	ApplyCorner(handle, 999)
	ApplyStroke(handle, theme.Accent2, 0.18, 1)

	local dragging = false

	local function snap(v)
		local step = increment > 0 and increment or 1
		return math.floor(((v - min) / step) + 0.5) * step + min
	end

	local function apply(v, silent)
		value = Clamp(snap(tonumber(v) or min), min, max)
		self.Window.Library.Flags[flag] = value
		local alpha = (value - min) / math.max(max - min, 1)
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		handle.Position = UDim2.new(alpha, 0, 0.5, 0)
		valueLabel.Text = tostring(value)
		if not silent and callback then
			task.spawn(callback, value)
		end
	end

	self.Window.Library:_registerFlag(flag, apply)
	self.Window.Library.Flags[flag] = value
	apply(value, true)

	local function fromInput(input)
		local pos = Clamp((input.Position.X - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
		local v = min + ((max - min) * pos)
		self.Window.Library:SetFlag(flag, v)
		if callback then
			task.spawn(callback, self.Window.Library.Flags[flag])
		end
	end

	local function startDrag(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			fromInput(input)
		end
	end

	track.InputBegan:Connect(startDrag)
	handle.InputBegan:Connect(startDrag)

	self.Window._connections:Give(UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			fromInput(input)
		end
	end))

	self.Window._connections:Give(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end))

	self:_bindTheme(function(th)
		card.BackgroundColor3 = th.Background
		label.TextColor3 = th.Text
		valueLabel.TextColor3 = th.SubText
		track.BackgroundColor3 = th.Muted
		fill.BackgroundColor3 = th.Accent
		handle.BackgroundColor3 = th.Text
		local s = card:FindFirstChildOfClass("UIStroke")
		if s then
			s.Color = th.Stroke
		end
	end)

	self:_registerElement({ Frame = card, SearchText = name })
	return {
		Set = function(_, v)
			self.Window.Library:SetFlag(flag, v)
			if callback then
				task.spawn(callback, self.Window.Library.Flags[flag])
			end
		end,
		Get = function()
			return value
		end
	}
end

