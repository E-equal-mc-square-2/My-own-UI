				Size = UDim2.new(1, 0, 0, 48),
				Parent = page,
			})
			corner(holder, self._library.Theme.Radius - 4)
			stroke(holder, self._library.Theme.Stroke, 0.4)
			padding(holder, 12)

			local header = create("TextButton", {
				BackgroundTransparency = 1,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(1, 0, 0, 22),
				Parent = holder,
			})

			local titleLbl = create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Dropdown",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Size = UDim2.new(1, -24, 0, 18),
				Parent = holder,
			})

			local selected = create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(current or "Select"),
				TextColor3 = self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = 12,
				Size = UDim2.new(1, -24, 0, 18),
				Parent = holder,
			})

			local listHolder = create("Frame", {
				BackgroundTransparency = 1,
				Visible = false,
				AutomaticSize = Enum.AutomaticSize.Y,
				Size = UDim2.new(1, 0, 0, 0),
				Parent = holder,
			})
			create("UIListLayout", {
				Padding = UDim.new(0, 6),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = listHolder,
			})

			for _, item in ipairs(items) do
				local opt = makeButton(listHolder, tostring(item), self._library.Theme)
				opt.Size = UDim2.new(1, 0, 0, 32)
				opt.MouseButton1Click:Connect(function()
					current = item
					selected.Text = tostring(current)
					open = false
					listHolder.Visible = false
					if info.Callback then
						info.Callback(current)
					end
				end)
			end

			header.MouseButton1Click:Connect(function()
				open = not open
				listHolder.Visible = open
			end)

			return {
				Set = function(_, v)
					current = v
					selected.Text = tostring(current)
				end,
				Get = function() return current end,
			}
		end

		function tab:CreateBox(info)
			info = info or {}
			local box = create("TextBox", {
				BackgroundColor3 = self._library.Theme.Panel,
				PlaceholderText = info.Placeholder or "Type here",
				Text = info.Default or "",
				TextColor3 = self._library.Theme.Text,
				PlaceholderColor3 = self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = 14,
				ClearTextOnFocus = false,
				Size = UDim2.new(1, 0, 0, 40),
				Parent = page,
			})
			corner(box, self._library.Theme.Radius - 4)
			stroke(box, self._library.Theme.Stroke, 0.4)
			padding(box, 10)
			box.FocusLost:Connect(function()
				if info.Callback then
					info.Callback(box.Text)
				end
			end)
			return box
		end

		table.insert(self._library.Tabs, tab)
		if not self._library._activeTab then
			activateTab(tab)
		end
		return tab
	end

	self.Window = window
	setVisible(true)

	return window
end

function Library:CreateWindow(config)
	return Library.new(config)
end

return Library
