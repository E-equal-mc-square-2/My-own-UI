--//=======================================================================================
--// UTILITY ENGINE
--//=======================================================================================

local Utility = {}

function Utility:Create(className, properties, children)
    local inst = Instance.new(className)
    for i, v in pairs(properties or {}) do
        if i ~= "Parent" then inst[i] = v end
    end
    if children then
        for _, child in pairs(children) do
            child.Parent = inst
        end
    end
    if properties and properties.Parent then
        inst.Parent = properties.Parent
    end
    table.insert(NeonPrime.Instances, inst)
    return inst
end

function Utility:AddCorner(parent, radius)
    return self:Create("UICorner", {
        CornerRadius = UDim.new(0, radius or NeonPrime.Theme.Sizes.Radius),
        Parent = parent
    })
end

function Utility:AddStroke(parent, color, thickness, transparency)
    return self:Create("UIStroke", {
        Color = color or NeonPrime.Theme.StrokeLight,
        Thickness = thickness or 1,
        Transparency = transparency or 0,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = parent
    })
end

function Utility:AddPadding(parent, all)
    local p = all or NeonPrime.Theme.Sizes.Padding
    return self:Create("UIPadding", {
        PaddingLeft = UDim.new(0, p),
        PaddingRight = UDim.new(0, p),
        PaddingTop = UDim.new(0, p),
        PaddingBottom = UDim.new(0, p),
        Parent = parent
    })
end

function Utility:AddGradient(parent, color1, color2, rotation)
    return self:Create("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, color1),
            ColorSequenceKeypoint.new(1, color2)
        },
        Rotation = rotation or 0,
        Parent = parent
    })
end

function Utility:Tween(instance, properties, duration, style, direction)
    local info = TweenInfo.new(
        duration or 0.3,
        style or Enum.EasingStyle.Quint,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

function Utility:Connection(signal, callback)
    local connection = signal:Connect(callback)
    table.insert(NeonPrime.Connections, connection)
    return connection
end

function Utility:GetTextBounds(text, font, size, width)
    local params = Instance.new("GetTextBoundsParams")
    params.Text = text
    params.Font = font
    params.Size = size
    params.Width = width or math.huge
    return TextService:GetTextBoundsAsync(params)
end

function Utility:CreateShadow(parent, blur, intensity)
    local shadow = self:Create("ImageLabel", {
        Name = "DropShadow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://5554236805",
        ImageColor3 = NeonPrime.Theme.Shadow,
        ImageTransparency = intensity or 0.4,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(23, 23, 277, 277),
        Size = UDim2.new(1, blur * 2, 1, blur * 2),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = parent.ZIndex - 1,
        Parent = parent
    })
    return shadow
end

--//=======================================================================================
--// ANIMATION ENGINE & RIPPLE
--//=======================================================================================

local AnimationEngine = {}

function AnimationEngine:CreateRipple(parent, x, y)
    local absolutePos = parent.AbsolutePosition
    local absoluteSize = parent.AbsoluteSize
    
    local relativeX = x - absolutePos.X
    local relativeY = y - absolutePos.Y
    
    local rippleContainer = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = parent,
        ZIndex = parent.ZIndex + 5
    })
    
    Utility:AddCorner(rippleContainer, NeonPrime.Theme.Sizes.Radius)
    
    local maxRadius = math.sqrt(absoluteSize.X^2 + absoluteSize.Y^2)
    
    local ripple = Utility:Create("Frame", {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0, relativeX, 0, relativeY),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BackgroundTransparency = 0.6,
        ZIndex = parent.ZIndex + 6,
        Parent = rippleContainer
    })
    
    Utility:AddCorner(ripple, 999)
    
    local anim = Utility:Tween(ripple, {
        Size = UDim2.new(0, maxRadius * 2, 0, maxRadius * 2),
        BackgroundTransparency = 1
    }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    anim.Completed:Connect(function()
        rippleContainer:Destroy()
    end)
end

function AnimationEngine:HoverEffect(element, defaultColor, hoverColor)
    Utility:Connection(element.MouseEnter, function()
        Utility:Tween(element, {BackgroundColor3 = hoverColor}, 0.2)
    end)
    Utility:Connection(element.MouseLeave, function()
        Utility:Tween(element, {BackgroundColor3 = defaultColor}, 0.2)
    end)
end

function AnimationEngine:Glow(element, color, size, duration)
    local glow = Utility:Create("ImageLabel", {
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857084",
        ImageColor3 = color,
        Size = UDim2.new(1, size, 1, size),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = element.ZIndex - 1,
        ImageTransparency = 1,
        Parent = element
    })
    Utility:Tween(glow, {ImageTransparency = 0.5}, duration / 2).Completed:Connect(function()
        Utility:Tween(glow, {ImageTransparency = 1}, duration / 2).Completed:Connect(function()
            glow:Destroy()
        end)
    end)
end

--//=======================================================================================
--// INPUT & DRAG & GESTURE SYSTEM (MOBILE OPTIMIZED)
--//=======================================================================================

local InputSystem = {
    Connections = {}
}

function InputSystem:MakeDraggable(frame, dragHandle)
    local dragging, dragInput, dragStart, startPos
    local handle = dragHandle or frame

    Utility:Connection(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    Utility:Connection(handle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    Utility:Connection(UserInputService.InputChanged, function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Utility:Tween(frame, {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }, 0.08, Enum.EasingStyle.Linear)
        end
    end)
end

function InputSystem:BindGesture(frame, gestureType, callback)
    local startPos = nil
    local threshold = 50
    
    Utility:Connection(frame.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            startPos = input.Position
        end
    end)
    
    Utility:Connection(frame.InputEnded, function(input)
        if not startPos then return end
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local delta = input.Position - startPos
            if gestureType == "SwipeDown" and delta.Y > threshold and math.abs(delta.X) < threshold then
                callback()
            elseif gestureType == "SwipeUp" and delta.Y < -threshold and math.abs(delta.X) < threshold then
                callback()
            end
            startPos = nil
        end
    end)
end

