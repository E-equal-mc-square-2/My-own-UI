--//=======================================================================================
--// CONFIG SYSTEM
--//=======================================================================================

local ConfigSystem = {
    FolderName = "NeonPrimeConfigs",
    FileExtension = ".json",
    AutoSave = true
}

function ConfigSystem:Init()
    if makefolder and isfolder and not isfolder(self.FolderName) then
        makefolder(self.FolderName)
    end
end

function ConfigSystem:Save(name)
    if not writefile then return false end
    local data = {}
    for key, flag in pairs(NeonPrime.Flags) do
        data[key] = flag
    end
    local success, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if success then
        writefile(self.FolderName .. "/" .. name .. self.FileExtension, encoded)
        NotificationSystem:Notify("Config Saved", "Successfully saved config: " .. name, 3, "success")
        return true
    end
    return false
end

function ConfigSystem:Load(name)
    if not readfile or not isfile then return false end
    local path = self.FolderName .. "/" .. name .. self.FileExtension
    if isfile(path) then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(path))
        if success then
            for key, value in pairs(decoded) do
                if NeonPrime.Flags[key] ~= nil then
                    NeonPrime.Flags[key] = value
                    -- Note: Updating UI elements happens via events in elements
                end
            end
            NotificationSystem:Notify("Config Loaded", "Successfully loaded config: " .. name, 3, "success")
            return true
        end
    end
    return false
end

