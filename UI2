local function DefaultWindowSize()
	local vp = GetViewport()
	if IsTouch() then
		return UDim2.fromOffset(math.clamp(vp.X * 0.94, 300, 760), math.clamp(vp.Y * 0.82, 330, 760))
	end
	return UDim2.fromOffset(math.clamp(vp.X * 0.52, 400, 920), math.clamp(vp.Y * 0.66, 360, 780))
end

function WindowClass:_bindTheme(fn)
	self._themeHooks = self._themeHooks or {}
	table.insert(self._themeHooks, fn)
	fn(self.Library.Theme)
end

function WindowClass:_syncResponsiveSize()
	if self.Destroyed then
		return
	end

	local target = self.Maximized and self:_getMaximizedSize() or self._normalSize
	if not target then
		target = DefaultWindowSize()
		self._normalSize = target
	end

	self.Main.Size = target
	self.Shadow.Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)
end

function WindowClass:_getMaximizedSize()
	local vp = GetViewport()
	return UDim2.fromOffset(math.clamp(vp.X * 0.96, 320, 1100), math.clamp(vp.Y * 0.92, 320, 840))
end

function WindowClass:_selectTab(tab)
	if self.Destroyed then
		return
	end
	self.ActiveTab = tab
	for _, t in ipairs(self.Tabs) do
		local active = (t == tab)
		if t.Page then
			t.Page.Visible = active
			if active then
				t.Page.CanvasPosition = Vector2.new(0, 0)
			end
		end
		if t.Button then
			Tween(t.Button, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundColor3 = active and self.Library.Theme.Accent or self.Library.Theme.Card2
			})
		end
		if t.ActiveBar then
			Tween(t.ActiveBar, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundTransparency = active and 0 or 1
			})
		end
		if t.ButtonStroke then
			Tween(t.ButtonStroke, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Transparency = active and 0.18 or 0.52
			})
		end
	end
end

function WindowClass:ApplyTheme(theme)
	theme = theme or self.Library.Theme

	if self.Main then
		self.Main.BackgroundColor3 = theme.Background
	end
	if self.Shadow then
		self.Shadow.BackgroundColor3 = theme.Shadow
	end
	if self.Header then
		self.Header.BackgroundColor3 = theme.Card
	end
	if self.Body then
		self.Body.BackgroundColor3 = theme.Background
	end
	if self.TabBar then
		self.TabBar.BackgroundColor3 = theme.Card2
	end
	if self.TitleLabel then
		self.TitleLabel.TextColor3 = theme.Text
	end
	if self.SubtitleLabel then
		self.SubtitleLabel.TextColor3 = theme.SubText
	end
	if self.TabBarStroke then
		self.TabBarStroke.Color = theme.Stroke
	end
	if self.MainStroke then
		self.MainStroke.Color = theme.Stroke
	end
	if self.HeaderStroke then
		self.HeaderStroke.Color = theme.Stroke
	end
	if self.ReopenButton then
		self.ReopenButton.BackgroundColor3 = theme.Card
		local stroke = self.ReopenButton:FindFirstChildOfClass("UIStroke")
		if stroke then
			stroke.Color = theme.Accent
		end
	end
	if self._themeHooks then
		for _, fn in ipairs(self._themeHooks) do
			pcall(fn, theme)
		end
	end
	for _, tab in ipairs(self.Tabs) do
		if tab and tab.ApplyTheme then
			tab:ApplyTheme(theme)
		end
	end
end

function WindowClass:_setBlur(enabled)
	self.Library._blurGoal = enabled and 12 or 0
end

function WindowClass:Show(noTween)
	if self.Destroyed then
		return
	end
	self.Visible = true
	if self.Main then
		self.Main.Visible = true
	end
	if self.Shadow then
		self.Shadow.Visible = true
	end
	if self.ReopenButton then
		self.ReopenButton.Visible = false
	end
	self:_setBlur(true)

	if self.Main and not noTween then
		self.Main.BackgroundTransparency = 1
		Tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0
		})
	end

	if self.Shadow and not noTween then
		self.Shadow.BackgroundTransparency = 1
		Tween(self.Shadow, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.58
		})
	end
end

function WindowClass:Hide(noTween)
	if self.Destroyed then
		return
	end
	self.Visible = false
	self:_setBlur(false)

	if not noTween and self.Main then
		Tween(self.Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			BackgroundTransparency = 1
		})
	end
	if self.ReopenButton then
		self.ReopenButton.Visible = true
	end

	task.delay(noTween and 0 or 0.2, function()
		if self.Main and not self.Visible then
			self.Main.Visible = false
		end
		if self.Shadow and not self.Visible then
			self.Shadow.Visible = false
		end
	end)
end

function WindowClass:Toggle()
	if self.Visible then
		self:Hide()
	else
		self:Show()
	end
end

function WindowClass:Minimize()
	if self.Destroyed or self.Minimized then
		return
	end
	self.Minimized = true
	self._restoreSize = self.Main.Size
	self.Body.Visible = false
	self.TabBar.Visible = false

	local target = UDim2.fromOffset(self.Main.AbsoluteSize.X, 58)
	Tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = target
	})
	Tween(self.Shadow, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)
	})
end

function WindowClass:Maximize(state)
	if self.Destroyed then
		return
	end
	self.Maximized = (state == nil) and (not self.Maximized) or state and true or false
	self.Minimized = false

	self.Body.Visible = true
	self.TabBar.Visible = true

	local target = self.Maximized and self:_getMaximizedSize() or self._normalSize or DefaultWindowSize()
	self._normalSize = self._normalSize or target
	self.Main.Size = target
	self.Shadow.Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)

	Tween(self.Main, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Size = target })
	Tween(self.Shadow, TweenInfo.new(0.24, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)
	})
end

function WindowClass:Restore()
	if self.Destroyed then
		return
	end
	self.Minimized = false
	self.Maximized = false
	self.Body.Visible = true
	self.TabBar.Visible = true
	local target = self._normalSize or DefaultWindowSize()
	Tween(self.Main, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Size = target })
	Tween(self.Shadow, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)
	})
end

function WindowClass:Destroy()
	if self.Destroyed then
		return
	end
	self.Destroyed = true
	self.Library:_removeReopenButton(self)
	self._connections:Cleanup()
	for _, tab in ipairs(self.Tabs) do
		if tab and tab.Destroy then
			pcall(function()
				tab:Destroy()
			end)
		end
	end
	DestroyIfExists(self.Root)
end

function WindowClass:SetSearch(query)
	self.SearchQuery = tostring(query or "")
	for _, tab in ipairs(self.Tabs) do
		for _, section in ipairs(tab.Sections) do
			if section and section.ApplySearch then
				section:ApplySearch(self.SearchQuery)
			end
		end
	end
end

function WindowClass:SetTitle(title)
	self.Title = tostring(title or self.Title)
	if self.TitleLabel then
		self.TitleLabel.Text = self.Title
	end
end

function WindowClass:SetSubtitle(text)
	self.Subtitle = tostring(text or self.Subtitle)
	if self.SubtitleLabel then
		self.SubtitleLabel.Text = self.Subtitle
	end
end

function WindowClass:Notify(...)
	return self.Library:Notify(...)
end

function WindowClass:_build(options)
	local theme = self.Library.Theme
	local gui = self.Library._rootGui

	local screen = New("Frame", {
		Name = "Window_" .. tostring(self.Id),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = gui
	})
	self.Root = screen

	local shadow = New("Frame", {
		Name = "Shadow",
		BackgroundColor3 = theme.Shadow,
		BackgroundTransparency = 0.58,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = options.Size or DefaultWindowSize(),
		Parent = screen
	})
	ApplyCorner(shadow, 22)
	self.Shadow = shadow

	local main = New("Frame", {
		Name = "Main",
		BackgroundColor3 = theme.Background,
		BackgroundTransparency = 0,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = options.Size or DefaultWindowSize(),
		ClipsDescendants = true,
		Parent = screen
	})
	ApplyCorner(main, 22)
	self.Main = main

	self.MainStroke = ApplyStroke(main, theme.Stroke, 0.35, 1)
	ApplyGradient(main, theme.Background, theme.Card, 90)

	local scale = New("UIScale", {
		Scale = 1,
		Parent = main
	})
	self.Scale = scale

	local vp = GetViewport()
	local baseScale = Clamp(math.min(vp.X / 900, vp.Y / 780), IsTouch() and 0.92 or 0.84, 1.1)
	scale.Scale = baseScale

	local header = New("Frame", {
		Name = "Header",
		BackgroundColor3 = theme.Card,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 0),
		Size = UDim2.new(1, 0, 0, 58),
		Parent = main
	})
	ApplyGradient(header, theme.Card2, theme.Card, 0)
	self.Header = header
	self.HeaderStroke = ApplyStroke(header, theme.Stroke, 0.42, 1)

	local titleHolder = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(16, 8),
		Size = UDim2.new(1, -190, 1, -16),
		Parent = header
	})

	local titleLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 18),
		Font = Enum.Font.GothamBold,
		Text = options.Title or "NeonVX",
		TextColor3 = theme.Text,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = titleHolder
	})
	self.TitleLabel = titleLabel

	local subtitleLabel = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 22),
		Size = UDim2.new(1, 0, 0, 16),
		Font = Enum.Font.GothamMedium,
		Text = options.Subtitle or "Mobile-first UI",
		TextColor3 = theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = titleHolder
	})
	self.SubtitleLabel = subtitleLabel

	local controls = New("Frame", {
		Name = "Controls",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -10, 0.5, 0),
		Size = UDim2.fromOffset(156, 44),
		Parent = header
	})
	controls.ClipsDescendants = false
	AddListLayout(controls, 8).FillDirection = Enum.FillDirection.Horizontal
	controls.HorizontalAlignment = Enum.HorizontalAlignment.Right

	local function makeControl(text, accent)
		local b = New("TextButton", {
			BackgroundColor3 = theme.Card2,
			BackgroundTransparency = 0.04,
			BorderSizePixel = 0,
			Size = UDim2.fromOffset(44, 44),
			Text = text,
			Font = Enum.Font.GothamBold,
			TextSize = 18,
			TextColor3 = accent and theme.Accent or theme.Text,
			AutoButtonColor = false,
			Parent = controls
		})
		ApplyCorner(b, 14)
		ApplyStroke(b, theme.Stroke, 0.5, 1)
		return b
	end

	local minBtn = makeControl("–", false)
	local maxBtn = makeControl("▢", false)
	local closeBtn = makeControl("×", true)

	local body = New("Frame", {
		Name = "Body",
		BackgroundColor3 = theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 58),
		Size = UDim2.new(1, 0, 1, -58),
		ClipsDescendants = true,
		Parent = main
	})
	self.Body = body

	local tabBar = New("Frame", {
		Name = "TabBar",
		BackgroundColor3 = theme.Card2,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 0, 0, 56),
		Parent = body
	})
	ApplyGradient(tabBar, theme.Card2, theme.Background, 0)
	self.TabBar = tabBar
	self.TabBarStroke = ApplyStroke(tabBar, theme.Stroke, 0.5, 1)

	local tabScroller = New("ScrollingFrame", {
		Name = "TabScroller",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(10, 0),
		Size = UDim2.new(1, -20, 1, 0),
		ScrollingDirection = Enum.ScrollingDirection.X,
		ScrollBarThickness = 0,
		AutomaticCanvasSize = Enum.AutomaticSize.X,
		CanvasSize = UDim2.fromOffset(0, 0),
		Parent = tabBar
	})
	self.TabScroller = tabScroller
	AddPadding(tabScroller, 2, 2, 7, 7)
	local tabLayout = AddListLayout(tabScroller, 8, Enum.SortOrder.LayoutOrder)
	tabLayout.FillDirection = Enum.FillDirection.Horizontal
	tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left

	local pagesHolder = New("Frame", {
		Name = "PagesHolder",
		BackgroundColor3 = theme.Background,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(0, 56),
		Size = UDim2.new(1, 0, 1, -56),
		Parent = body
	})
	self.PagesHolder = pagesHolder
	AddPadding(pagesHolder, 10, 10, 10, 10)

	local pageArea = New("Frame", {
		Name = "PageArea",
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.fromScale(1, 1),
		Parent = pagesHolder
	})
	self.PageArea = pageArea

	local titleConnect = function()
		self.TitleLabel.TextColor3 = self.Library.Theme.Text
		self.SubtitleLabel.TextColor3 = self.Library.Theme.SubText
	end
	self:_bindTheme(function(th)
		main.BackgroundColor3 = th.Background
		shadow.BackgroundColor3 = th.Shadow
		header.BackgroundColor3 = th.Card
		body.BackgroundColor3 = th.Background
		tabBar.BackgroundColor3 = th.Card2
		self.TabBarStroke.Color = th.Stroke
		self.MainStroke.Color = th.Stroke
		self.HeaderStroke.Color = th.Stroke
		titleConnect()
		for _, btn in ipairs({ minBtn, maxBtn, closeBtn }) do
			btn.BackgroundColor3 = th.Card2
			local stroke = btn:FindFirstChildOfClass("UIStroke")
			if stroke then
				stroke.Color = th.Stroke
			end
		end
		closeBtn.TextColor3 = th.Danger
		if self.ReopenButton then
			self.ReopenButton.BackgroundColor3 = th.Card
			local stroke = self.ReopenButton:FindFirstChildOfClass("UIStroke")
			if stroke then
				stroke.Color = th.Accent
			end
		end
	end)

	minBtn.MouseButton1Click:Connect(function()
		self:Minimize()
	end)
	maxBtn.MouseButton1Click:Connect(function()
		self:Maximize(not self.Maximized)
	end)
	closeBtn.MouseButton1Click:Connect(function()
		self:Hide()
	end)

	local function controlRipple(btn)
		btn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
				Rippler(btn, self.Library.Theme, input.Position)
			end
		end)
	end
	controlRipple(minBtn)
	controlRipple(maxBtn)
	controlRipple(closeBtn)

	self._connections:Give(header.InputBegan:Connect(function(input)
		if self.Minimized or self.Destroyed then
			return
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			self._dragging = true
			self._dragStart = input.Position
			self._dragOrigin = self.Main.Position
		end
	end))

	self._connections:Give(UserInputService.InputChanged:Connect(function(input)
		if self._dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - self._dragStart
			self.Main.Position = UDim2.new(
				self._dragOrigin.X.Scale,
				self._dragOrigin.X.Offset + delta.X,
				self._dragOrigin.Y.Scale,
				self._dragOrigin.Y.Offset + delta.Y
			)
			self.Shadow.Position = self.Main.Position
		end
	end))

	self._connections:Give(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if self._dragging and self._gestureStart and input.Position then
				local delta = input.Position - self._gestureStart
				if math.abs(delta.Y) > 70 and math.abs(delta.Y) > math.abs(delta.X) then
					if delta.Y > 0 then
						self:Minimize()
					else
						self:Maximize(true)
					end
				end
			end
			self._dragging = false
			self._gestureStart = nil
		end
	end))

	self._connections:Give(header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch then
			self._gestureStart = input.Position
		end
	end))

	self._connections:Give(Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
		if self.Destroyed then
			return
		end
		local scale = Clamp(math.min(GetViewport().X / 900, GetViewport().Y / 780), IsTouch() and 0.92 or 0.84, 1.1)
		if self.Scale then
			self.Scale.Scale = scale
		end
		if not self.Maximized and not self.Minimized and self.Visible then
			self._normalSize = self._normalSize or (options.Size or DefaultWindowSize())
			self.Main.Size = self._normalSize
			self.Shadow.Size = UDim2.new(0, self._normalSize.X.Offset + 16, 0, self._normalSize.Y.Offset + 18)
		elseif self.Maximized then
			local target = self:_getMaximizedSize()
			self.Main.Size = target
			self.Shadow.Size = UDim2.new(0, target.X.Offset + 16, 0, target.Y.Offset + 18)
		end
	end))

	self._connections:Give(tabScroller.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(tabScroller, self.Library.Theme, input.Position)
		end
	end))

	self.ReopenButton = self.Library:_createReopenButton(self)
	self.Library:_setBlur(true)

	self._normalSize = options.Size or DefaultWindowSize()
	self.Main.Size = self._normalSize
	self.Shadow.Size = UDim2.new(0, self._normalSize.X.Offset + 16, 0, self._normalSize.Y.Offset + 18)
	self.Main.Position = UDim2.fromScale(0.5, 0.5)
	self.Shadow.Position = self.Main.Position

	if options.Visible == false then
		self:Hide(true)
	else
		self:Show(true)
	end
end

function WindowClass:CreateTab(options)
	options = options or {}
	local tab = setmetatable({}, TabClass)
	tab.Window = self
	tab.Name = tostring(options.Name or "Tab")
	tab.Icon = options.Icon or "◉"
	tab.Sections = {}
	tab._themeHooks = {}
	tab.Destroyed = false

	local theme = self.Library.Theme

	local btn = New("TextButton", {
		BackgroundColor3 = theme.Card2,
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(124, 42),
		AutoButtonColor = false,
		Text = "",
		Parent = self.TabScroller
	})
	ApplyCorner(btn, 14)
	tab.Button = btn
	tab.ButtonStroke = ApplyStroke(btn, theme.Stroke, 0.52, 1)

	local iconStr, isImage = ResolveIconIcon(tab.Icon)
	local iconHolder = New("Frame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(10, 0),
		Size = UDim2.fromOffset(22, 42),
		Parent = btn
	})

	if iconStr then
		if isImage then
			local img = New("ImageLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.fromOffset(18, 18),
				Position = UDim2.fromOffset(2, 12),
				Image = iconStr,
				ImageColor3 = theme.Accent,
				Parent = iconHolder
			})
			tab.IconObject = img
		else
			local txt = New("TextLabel", {
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.fromOffset(22, 42),
				Font = Enum.Font.GothamBold,
				Text = tostring(iconStr),
				TextColor3 = theme.Accent,
				TextSize = 15,
				Parent = iconHolder
			})
			tab.IconObject = txt
		end
	end

	local name = New("TextLabel", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.fromOffset(34, 0),
		Size = UDim2.new(1, -40, 1, 0),
		Font = Enum.Font.GothamSemibold,
		Text = tab.Name,
		TextColor3 = theme.Text,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = btn
	})
	tab.NameLabel = name

	local activeBar = New("Frame", {
		BackgroundColor3 = theme.Accent,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 12, 1, -4),
		Size = UDim2.new(1, -24, 0, 2),
		BackgroundTransparency = 1,
		Parent = btn
	})
	ApplyCorner(activeBar, 999)
	ApplyGradient(activeBar, theme.Accent, theme.Accent2, 0)
	tab.ActiveBar = activeBar

	local page = New("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Visible = false,
		Size = UDim2.fromScale(1, 1),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.fromOffset(0, 0),
		ScrollBarThickness = IsTouch() and 3 or 4,
		ScrollBarImageColor3 = theme.Accent,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		Parent = self.PageArea
	})
	AddPadding(page, 0, 4, 0, 8)
	local pageLayout = AddListLayout(page, 12)
	pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tab.Page = page

	page.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(page, self.Library.Theme, input.Position)
		end
	end)

	btn.MouseButton1Click:Connect(function()
		self:_selectTab(tab)
	end)

	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
			Rippler(btn, self.Library.Theme, input.Position)
		end
	end)

	tab:_bindTheme(function(th)
		btn.BackgroundColor3 = (self.ActiveTab == tab) and th.Accent or th.Card2
		tab.ButtonStroke.Color = th.Stroke
		name.TextColor3 = th.Text
		if tab.IconObject then
			tab.IconObject.TextColor3 = th.Accent
			if tab.IconObject:IsA("ImageLabel") then
				tab.IconObject.ImageColor3 = th.Accent
			end
		end
		tab.ActiveBar.BackgroundColor3 = th.Accent
		tab.Page.ScrollBarImageColor3 = th.Accent
	end)

	table.insert(self.Tabs, tab)

	if not self.ActiveTab then
		self.ActiveTab = tab
	end
	self:_selectTab(self.ActiveTab)

	return tab
end

function WindowClass:DestroyTab(tab)
	for i, t in ipairs(self.Tabs) do
		if t == tab then
			table.remove(self.Tabs, i)
			tab:Destroy()
			break
		end
	end
	if self.ActiveTab == tab then
		self.ActiveTab = self.Tabs[1]
		if self.ActiveTab then
			self:_selectTab(self.ActiveTab)
		end
	end
end

