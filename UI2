                local function SetValue(val)
                    Input.Text = val
                    Utility.Flags[flag] = {Value = val, Set = SetValue}
                    pcall(callback, val)
                end
                
                Utility.Flags[flag] = {Value = default, Set = SetValue}
                
                Input.Focused:Connect(function()
                    Utility:Tween(stroke, {Color = Theme.Accent}, 0.3)
                end)
                
                Input.FocusLost:Connect(function()
                    Utility:Tween(stroke, {Color = Theme.Stroke}, 0.3)
                    SetValue(Input.Text)
                end)
            end

            -- KEYBIND
            function Section:CreateKeybind(options)
                local name = options.Name or "Keybind"
                local default = options.Default or Enum.KeyCode.Unknown
                local flag = options.Flag or name:gsub("%s+", "")
                local callback = options.Callback or function() end
                
                local CurrentKey = default
                local IsBinding = false
                
                local KeybindFrame = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 40),
                    Parent = SectionFrame
                })
                
                local Title = Utility:Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -100, 1, 0),
                    Font = Theme.Font,
                    Text = name,
                    TextColor3 = Theme.Text,
                    TextSize = Theme.TextSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = KeybindFrame
                })
                
                local BindBG = Utility:Create("Frame", {
                    BackgroundColor3 = Theme.Tertiary,
                    Position = UDim2.new(1, -90, 0.5, -13),
                    Size = UDim2.new(0, 90, 0, 26),
                    Parent = KeybindFrame
                })
                Utility:AddCorner(BindBG, UDim.new(0, 4))
                local stroke = Utility:AddStroke(BindBG, Theme.Stroke)
                
                local BindText = Utility:Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Theme.BoldFont,
                    Text = CurrentKey == Enum.KeyCode.Unknown and "None" or CurrentKey.Name,
                    TextColor3 = Theme.Accent,
                    TextSize = Theme.TextSize - 1,
                    Parent = BindBG
                })
                
                local BindButton = Utility:Create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = BindBG
                })
                
                local function SetValue(key)
                    CurrentKey = key
                    BindText.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
                    Utility.Flags[flag] = {Value = key.Name, Set = function(v) SetValue(Enum.KeyCode[v] or Enum.KeyCode.Unknown) end}
                end
                
                Utility.Flags[flag] = {Value = CurrentKey.Name, Set = function(v) SetValue(Enum.KeyCode[v] or Enum.KeyCode.Unknown) end}
                
                BindButton.MouseButton1Click:Connect(function()
                    IsBinding = true
                    BindText.Text = "..."
                    Utility:Tween(stroke, {Color = Theme.Accent}, 0.2)
                end)
                
                Utility:Connect(UserInputService.InputBegan, function(input)
                    if IsBinding and input.UserInputType == Enum.UserInputType.Keyboard then
                        if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
                            SetValue(Enum.KeyCode.Unknown)
                        else
                            SetValue(input.KeyCode)
                        end
                        IsBinding = false
                        Utility:Tween(stroke, {Color = Theme.Stroke}, 0.2)
                    elseif not IsBinding and input.KeyCode == CurrentKey and CurrentKey ~= Enum.KeyCode.Unknown then
                        -- Do not trigger if typing in a textbox
                        if UserInputService:GetFocusedTextBox() then return end
                        pcall(callback, CurrentKey)
                    end
                end)
            end

            -- COLOR PICKER
            function Section:CreateColorPicker(options)
                local name = options.Name or "Color Picker"
                local default = options.Default or Color3.fromRGB(255, 255, 255)
                local flag = options.Flag or name:gsub("%s+", "")
                local callback = options.Callback or function() end
                
                local CurrentColor = default
                local Expanded = false
                local Hue, Sat, Val = CurrentColor:ToHSV()
                
                local ColorFrame = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 40),
                    Parent = SectionFrame,
                    ClipsDescendants = true
                })
                
                local Title = Utility:Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -60, 0, 40),
                    Font = Theme.Font,
                    Text = name,
                    TextColor3 = Theme.Text,
                    TextSize = Theme.TextSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = ColorFrame
                })
                
                local DisplayBG = Utility:Create("Frame", {
                    BackgroundColor3 = CurrentColor,
                    Position = UDim2.new(1, -50, 0, 8),
                    Size = UDim2.new(0, 50, 0, 24),
                    Parent = ColorFrame
                })
                Utility:AddCorner(DisplayBG, UDim.new(0, 4))
                local DisplayStroke = Utility:AddStroke(DisplayBG, Theme.Stroke)
                
                local ExpandBtn = Utility:Create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = DisplayBG
                })
                
                -- Expandable Picker Area
                local PickerArea = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 0, 0, 40),
                    Size = UDim2.new(1, 0, 0, 150),
                    Parent = ColorFrame
                })
                
                -- Saturation/Value Map
                local SVMap = Utility:Create("ImageButton", {
                    BackgroundColor3 = Color3.fromHSV(Hue, 1, 1),
                    Position = UDim2.new(0, 0, 0, 10),
                    Size = UDim2.new(1, -30, 0, 130),
                    AutoButtonColor = false,
                    Parent = PickerArea
                })
                Utility:AddCorner(SVMap, UDim.new(0, 4))
                
                local UIGradientSV1 = Utility:Create("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                        ColorSequenceKeypoint.new(1, Color3.new(1,1,1))
                    },
                    Transparency = NumberSequence.new{
                        NumberSequenceKeypoint.new(0, 0),
                        NumberSequenceKeypoint.new(1, 1)
                    },
                    Parent = SVMap
                })
                
                local BlackOverlay = Utility:Create("ImageLabel", {
                    BackgroundColor3 = Color3.new(1,1,1),
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Image = "rbxassetid://3483656916", -- Black gradient image
                    Parent = SVMap
                })
                Utility:AddCorner(BlackOverlay, UDim.new(0, 4))
                
                local SVThumb = Utility:Create("Frame", {
                    BackgroundColor3 = Color3.new(1,1,1),
                    Size = UDim2.new(0, 10, 0, 10),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(Sat, 0, 1 - Val, 0),
                    Parent = SVMap
                })
                Utility:AddCorner(SVThumb, UDim.new(1, 0))
                Utility:AddStroke(SVThumb, Color3.new(0,0,0))
                
                -- Hue Slider
                local HueSlider = Utility:Create("ImageButton", {
                    BackgroundColor3 = Color3.new(1,1,1),
                    Position = UDim2.new(1, -20, 0, 10),
                    Size = UDim2.new(0, 20, 0, 130),
                    AutoButtonColor = false,
                    Parent = PickerArea
                })
                Utility:AddCorner(HueSlider, UDim.new(0, 4))
                
                Utility:Create("UIGradient", {
                    Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                        ColorSequenceKeypoint.new(0.16, Color3.fromRGB(255, 255, 0)),
                        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                        ColorSequenceKeypoint.new(0.66, Color3.fromRGB(0, 0, 255)),
                        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                    },
                    Rotation = 90,
                    Parent = HueSlider
                })
                
                local HueThumb = Utility:Create("Frame", {
                    BackgroundColor3 = Color3.new(1,1,1),
                    Size = UDim2.new(1, 4, 0, 6),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(0.5, 0, Hue, 0),
                    Parent = HueSlider
                })
                Utility:AddCorner(HueThumb, UDim.new(1, 0))
                Utility:AddStroke(HueThumb, Color3.new(0,0,0))
                
                local function UpdateColor()
                    CurrentColor = Color3.fromHSV(Hue, Sat, Val)
                    DisplayBG.BackgroundColor3 = CurrentColor
                    SVMap.BackgroundColor3 = Color3.fromHSV(Hue, 1, 1)
                    Utility.Flags[flag] = {Value = {CurrentColor.R, CurrentColor.G, CurrentColor.B}, Set = function(v) 
                        Hue, Sat, Val = Color3.new(v[1], v[2], v[3]):ToHSV()
                        UpdateColor()
                        SVThumb.Position = UDim2.new(Sat, 0, 1 - Val, 0)
                        HueThumb.Position = UDim2.new(0.5, 0, Hue, 0)
                    end}
                    pcall(callback, CurrentColor)
                end
                UpdateColor()
                
                ExpandBtn.MouseButton1Click:Connect(function()
                    Expanded = not Expanded
                    Utility:Tween(ColorFrame, {Size = UDim2.new(1, 0, 0, Expanded and 200 or 40)}, 0.3, Enum.EasingStyle.Quart)
                    Utility:Tween(DisplayStroke, {Color = Expanded and Theme.Accent or Theme.Stroke}, 0.3)
                end)
                
                local function TrackInput(frame, thumb, type)
                    local dragging = false
                    
                    local function update(input)
                        local pos = input.Position
                        local relX = math.clamp((pos.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1)
                        local relY = math.clamp((pos.Y - frame.AbsolutePosition.Y) / frame.AbsoluteSize.Y, 0, 1)
                        
                        if type == "SV" then
                            Sat = relX
                            Val = 1 - relY
                            Utility:Tween(thumb, {Position = UDim2.new(relX, 0, relY, 0)}, 0.1)
                        elseif type == "Hue" then
                            Hue = relY
                            Utility:Tween(thumb, {Position = UDim2.new(0.5, 0, relY, 0)}, 0.1)
                        end
                        UpdateColor()
                    end
                    
                    frame.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            dragging = true
                            update(input)
                        end
                    end)
                    
                    frame.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            dragging = false
                        end
                    end)
                    
                    Utility:Connect(UserInputService.InputChanged, function(input)
                        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                            update(input)
                        end
                    end)
                end
                
                TrackInput(SVMap, SVThumb, "SV")
                TrackInput(HueSlider, HueThumb, "Hue")
            end

            -- LABEL / PARAGRAPH
            function Section:CreateLabel(text)
                local LabelFrame = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 25),
                    Parent = SectionFrame
                })
                
                local Lbl = Utility:Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Theme.Font,
                    Text = text,
                    TextColor3 = Theme.SubText,
                    TextSize = Theme.TextSize,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    Parent = LabelFrame
                })
                
                -- Auto sizing for paragraphs
                Lbl:GetPropertyChangedSignal("TextBounds"):Connect(function()
                    LabelFrame.Size = UDim2.new(1, 0, 0, Lbl.TextBounds.Y + 10)
                end)
                
                return {
                    Set = function(self, newText)
                        Lbl.Text = newText
                    end
                }
            end

            -- SEPARATOR
            function Section:CreateSeparator()
                local SepFrame = Utility:Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 15),
                    Parent = SectionFrame
                })
                
                Utility:Create("Frame", {
                    BackgroundColor3 = Theme.Stroke,
                    Size = UDim2.new(1, -20, 0, 1),
                    Position = UDim2.new(0, 10, 0.5, 0),
                    BorderSizePixel = 0,
                    Parent = SepFrame
                })
            end

            return Section
        end

        -- SEARCH FILTERING (Tab Level)
        function Tab:CreateSearchBox()
            local SearchFrame = Utility:Create("Frame", {
                BackgroundColor3 = Theme.Secondary,
                Size = UDim2.new(1, 0, 0, 40),
                Parent = Page,
                LayoutOrder = -999 -- Always at top
            })
            Utility:AddCorner(SearchFrame)
            local stroke = Utility:AddStroke(SearchFrame, Theme.Stroke)
            
            local SearchIcon = Utility:Create("ImageLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0.5, -9),
                Size = UDim2.new(0, 18, 0, 18),
                Image = "rbxassetid://10736932148",
                ImageColor3 = Theme.SubText,
                Parent = SearchFrame
            })
            
            local SearchInput = Utility:Create("TextBox", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 35, 0, 0),
                Size = UDim2.new(1, -45, 1, 0),
                Font = Theme.Font,
                Text = "",
                PlaceholderText = "Search...",
                PlaceholderColor3 = Theme.SubText,
                TextColor3 = Theme.Text,
                TextSize = Theme.TextSize,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = SearchFrame
            })
            
            SearchInput.Focused:Connect(function()
                Utility:Tween(stroke, {Color = Theme.Accent}, 0.3)
                Utility:Tween(SearchIcon, {ImageColor3 = Theme.Accent}, 0.3)
            end)
            
            SearchInput.FocusLost:Connect(function()
                Utility:Tween(stroke, {Color = Theme.Stroke}, 0.3)
                Utility:Tween(SearchIcon, {ImageColor3 = Theme.SubText}, 0.3)
            end)
            
            -- Real-time filtering logic
            SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
                local query = string.lower(SearchInput.Text)
                
                for _, sectionFrame in ipairs(Page:GetChildren()) do
                    if sectionFrame:IsA("Frame") and sectionFrame.Name:match("^Section_") then
                        local sectionHasMatch = false
                        
                        for _, elementFrame in ipairs(sectionFrame:GetChildren()) do
                            if elementFrame:IsA("Frame") and elementFrame.Name ~= "UIListLayout" and elementFrame.Name ~= "UIPadding" then
                                -- Try to find a TextLabel that represents the title
                                local matched = false
                                for _, desc in ipairs(elementFrame:GetDescendants()) do
                                    if desc:IsA("TextLabel") and desc.Text ~= "" then
                                        if string.find(string.lower(desc.Text), query) then
                                            matched = true
                                            sectionHasMatch = true
                                            break
                                        end
                                    end
                                end
                                
                                -- Do not hide standard structural lines, just main element frames
                                if elementFrame.Size.Y.Offset > 1 then
                                    elementFrame.Visible = matched or query == ""
                                end
                            end
                        end
                        
                        -- Hide entirely empty sections if searching
                        if query ~= "" then
                            sectionFrame.Visible = sectionHasMatch
                        else
                            sectionFrame.Visible = true
                        end
                    end
                end
            end)
        end

        return Tab
    end

    return Window
end

--//======================================================
--// THEME UPDATER ENGINE
--//======================================================
function Library:ChangeTheme(newThemeTable)
    for key, color in pairs(newThemeTable) do
        if Theme[key] then
            Theme[key] = color
        end
    end
    
    local gui = UI_PARENT:FindFirstChild("NeonVortex_Main")
    if not gui then return end
    
    -- Recursive function to find and tween colors dynamically based on current usage
    local function UpdateInstances(parent)
        for _, inst in ipairs(parent:GetChildren()) do
            -- Best effort heuristic match for dynamic theme switching without caching thousands of instances
            if inst:IsA("Frame") or inst:IsA("ScrollingFrame") then
                if inst.BackgroundColor3 == Theme.Background then
                    Utility:Tween(inst, {BackgroundColor3 = Theme.Background}, 0.5)
                elseif inst.BackgroundColor3 == Theme.Secondary then
                    Utility:Tween(inst, {BackgroundColor3 = Theme.Secondary}, 0.5)
                elseif inst.BackgroundColor3 == Theme.Tertiary then
                    Utility:Tween(inst, {BackgroundColor3 = Theme.Tertiary}, 0.5)
                elseif inst.BackgroundColor3 == Theme.Accent then
                    Utility:Tween(inst, {BackgroundColor3 = Theme.Accent}, 0.5)
                end
            elseif inst:IsA("TextLabel") or inst:IsA("TextBox") then
                if inst.TextColor3 == Theme.Accent then
                    Utility:Tween(inst, {TextColor3 = Theme.Accent}, 0.5)
                end
            elseif inst:IsA("ImageLabel") or inst:IsA("ImageButton") then
                if inst.ImageColor3 == Theme.Accent then
                    Utility:Tween(inst, {ImageColor3 = Theme.Accent}, 0.5)
                end
            elseif inst:IsA("UIStroke") then
                if inst.Color == Theme.Accent then
                    Utility:Tween(inst, {Color = Theme.Accent}, 0.5)
                end
            end
            
            UpdateInstances(inst)
        end
    end
    
    UpdateInstances(gui)
end

--//======================================================
--// INITIALIZATION & RETURN
--//======================================================
function Library:Init()
    NotificationSystem:Notify("Neon Vortex", "Framework initialized successfully. Press RightShift to toggle.", 5)
end

-- Export APIs to Library root
Library.Notify = function(self, title, text, duration)
    NotificationSystem:Notify(title, text, duration)
end

Library.SetWatermark = function(self, text)
    if not WatermarkSystem.Frame then
        WatermarkSystem:Create(text)
    else
        WatermarkSystem.Text.Text = text
    end
end

Library.SaveConfig = function(self, name) ConfigSystem:Save(name) end
Library.LoadConfig = function(self, name) ConfigSystem:Load(name) end

return Library

