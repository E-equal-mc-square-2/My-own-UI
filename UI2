function Utility:RippleEffect(instance, x, y)
    local ripple = self:Create("Frame", {
        BackgroundColor3 = CurrentTheme.Primary,
        BackgroundTransparency = 0.5,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0, x, 0, y),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = instance.ZIndex + 10,
        Parent = instance
    })
    
    self:AddCorner(ripple, UDim.new(1, 0))
    
    self:Tween(ripple, {
        Size = UDim2.new(0, 100, 0, 100),
        BackgroundTransparency = 1
    }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, function()
        ripple:Destroy()
    end)
end

function Utility:MakeDraggable(frame, handle)
    handle = handle or frame
    
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    local function update(input)
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
        
        Utility:Tween(frame, {Position = targetPos}, DRAG_SMOOTHNESS, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    end
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

function Utility:GetTextSize(text, font, fontSize)
    local textSize = TextService:GetTextSize(
        text,
        fontSize,
        font,
        Vector2.new(math.huge, math.huge)
    )
    return textSize
end

function Utility:IsOnMobile()
