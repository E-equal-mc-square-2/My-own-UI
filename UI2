		current = v
		self.Window.Library.Flags[flag] = current
		refreshText(current)
		if not silent and callback then
			task.spawn(callback, current)
		end
	end

	local function rebuild()
		for _, child in ipairs(list:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
