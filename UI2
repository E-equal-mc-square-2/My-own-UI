		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = sidebar,
	})
	self.SideList = sideList

	local pages = create("Frame", {
		Name = "Pages",
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 158, 0, 0),
		Size = UDim2.new(1, -158, 1, 0),
		Parent = body,
	})
	self.Pages = pages

	local pagePadding = create("UIPadding", {
		PaddingTop = UDim.new(0, 10),
		PaddingBottom = UDim.new(0, 10),
		PaddingLeft = UDim.new(0, 10),
		PaddingRight = UDim.new(0, 10),
		Parent = pages,
	})
	self.PagePadding = pagePadding

	local pageStack = create("UIStackLayout", {
		Padding = UDim.new(0, 10),
		SortOrder = Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Top,
		Parent = pages,
	})
	self.PageStack = pageStack

	local function setVisible(visible: boolean)
		self._hidden = not visible
		if visible then
			shadow.Visible = true
			main.Visible = true
			floating.Visible = false
			shadow.BackgroundTransparency = 1
			main.BackgroundTransparency = 1
			tween(shadow, 0.18, {BackgroundTransparency = 0.55})
			tween(main, 0.22, {BackgroundTransparency = 0})
			main.Size = UDim2.new(0, 540, 0, 360)
			tween(main, 0.22, {Size = UDim2.new(0, 560, 0, 380)})
		else
			floating.Visible = true
			shadow.Visible = true
			tween(main, 0.16, {BackgroundTransparency = 1, Size = UDim2.new(0, 560, 0, 364)})
			tween(shadow, 0.16, {BackgroundTransparency = 1})
			task.delay(0.17, function()
				if self._hidden then
					main.Visible = false
					shadow.Visible = false
				end
			end)
		end
	end

	local function moveTabIndicator(activeButton: TextButton)
		local indicator = sidebar:FindFirstChild("Indicator")
		if not indicator then
			indicator = create("Frame", {
				Name = "Indicator",
				BackgroundColor3 = self.Theme.Accent,
				BorderSizePixel = 0,
				Size = UDim2.new(0, 4, 0, 24),
				Position = UDim2.new(0, 6, 0, 0),
				ZIndex = 2,
				Parent = sidebar,
			})
			corner(indicator, 999)
		end
		tween(indicator, 0.18, {Position = UDim2.new(0, 6, 0, activeButton.AbsolutePosition.Y - sidebar.AbsolutePosition.Y + 13)})
	end

	local function activateTab(tab)
		for _, other in ipairs(self.Tabs) do
			other.Page.Visible = false
			if other.Button then
				other.Button.BackgroundColor3 = self.Theme.Panel2
			end
		end
		tab.Page.Visible = true
		tab.Button.BackgroundColor3 = self.Theme.Accent
		self._activeTab = tab
		moveTabIndicator(tab.Button)
	end

	hideBtn.MouseButton1Click:Connect(function()
		setVisible(false)
	end)

	floating.MouseButton1Click:Connect(function()
		setVisible(true)
	end)

	local window = {}
	window._library = self

	function window:Show()
		setVisible(true)
	end

	function window:Hide()
		setVisible(false)
	end

	function window:Toggle()
		setVisible(self._library._hidden)
	end

	function window:SetTitle(text: string)
		title.Text = text
		self._library.Title = text
	end

	function window:SetSubtitle(text: string)
		subtitle.Text = text
		self._library.Subtitle = text
	end

	function window:Notify(info)
		info = info or {}
		local holder = create("Frame", {
			BackgroundColor3 = self._library.Theme.Panel,
			Size = UDim2.new(0, 270, 0, 64),
			Position = UDim2.new(1, -290, 1, -86),
			ZIndex = 60,
			Parent = root,
		})
		corner(holder, self._library.Theme.Radius - 2)
		stroke(holder, self._library.Theme.Stroke, 0.35)

		local accent = create("Frame", {
			BackgroundColor3 = info.Type == "error" and self._library.Theme.Danger or self._library.Theme.Accent,
			BorderSizePixel = 0,
			Size = UDim2.new(0, 6, 1, 0),
			Parent = holder,
		})
		corner(accent, 999)

		local txt = create("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 8),
			Size = UDim2.new(1, -28, 1, -16),
			TextXAlignment = Enum.TextXAlignment.Left,
			TextYAlignment = Enum.TextYAlignment.Top,
			TextWrapped = true,
			Text = info.Text or "Notification",
			TextColor3 = self._library.Theme.Text,
			Font = self._library.Theme.Font,
			TextSize = 14,
			Parent = holder,
		})

		tween(holder, 0.18, {Position = UDim2.new(1, -290, 1, -96)})
		task.delay(info.Duration or 2.5, function()
			if holder.Parent then
				tween(holder, 0.18, {Position = UDim2.new(1, -290, 1, -56), BackgroundTransparency = 1})
				task.delay(0.2, function()
					if holder.Parent then
						holder:Destroy()
					end
				end)
			end
		end)
	end

	function window:CreateTab(tabName: string)
		local tab = {
			Name = tabName,
			Elements = {},
		}

		local button = makeButton(sidebar, tabName, self._library.Theme)
		button.LayoutOrder = #self._library.Tabs + 1
		button.Size = UDim2.new(1, 0, 0, 36)
		button.ZIndex = 3

		local page = create("ScrollingFrame", {
			Name = tabName .. "Page",
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			Size = UDim2.new(1, 0, 1, 0),
			Visible = false,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = self._library.Theme.Accent,
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticSize.Y,
			Parent = pages,
		})
		padding(page, 2)
		local list = create("UIListLayout", {
			Padding = UDim.new(0, 10),
			SortOrder = Enum.SortOrder.LayoutOrder,
			Parent = page,
		})
		page.LayoutOrder = #self._library.Tabs + 1

		tab.Button = button
		tab.Page = page

		button.MouseButton1Click:Connect(function()
			activateTab(tab)
		end)

		function tab:CreateSection(sectionName: string)
			local section = create("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				Parent = page,
			})
			corner(section, self._library.Theme.Radius - 2)
			stroke(section, self._library.Theme.Stroke, 0.38)
			padding(section, 12)

			local titleLabel = create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = sectionName,
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.FontBold,
				TextSize = 15,
				Parent = section,
			})

			local container = create("Frame", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				Parent = section,
			})
			create("UIListLayout", {
				Padding = UDim.new(0, 8),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = container,
			})
			return container
		end

		function tab:CreateLabel(info)
			info = info or {}
			local lbl = create("TextLabel", {
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, info.Height or 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Label",
				TextColor3 = info.Color or self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = info.Size or 13,
				TextWrapped = true,
				Parent = page,
			})
			return lbl
		end

		function tab:CreateDivider()
			local div = create("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				BackgroundTransparency = 0.45,
				BorderSizePixel = 0,
				Size = UDim2.new(1, 0, 0, 1),
				Parent = page,
			})
			return div
		end

		function tab:CreateButton(info)
			info = info or {}
			local btn = makeButton(page, info.Text or "Button", self._library.Theme)
			btn.MouseEnter:Connect(function()
				tween(btn, 0.12, {BackgroundColor3 = self._library.Theme.Accent})
			end)
			btn.MouseLeave:Connect(function()
				tween(btn, 0.12, {BackgroundColor3 = self._library.Theme.Panel2})
			end)
			btn.MouseButton1Click:Connect(function()
				if info.Callback then
					info.Callback()
				end
			end)
			table.insert(tab.Elements, btn)
			return btn
		end

		function tab:CreateToggle(info)
			info = info or {}
			local state = info.Default == true

			local holder = create("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 46),
				Parent = page,
			})
			corner(holder, self._library.Theme.Radius - 4)
			stroke(holder, self._library.Theme.Stroke, 0.4)

			local label = create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Toggle",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 0),
				Size = UDim2.new(1, -80, 1, 0),
				Parent = holder,
			})

			local switch = create("TextButton", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Text = "",
				AutoButtonColor = false,
				Size = UDim2.new(0, 50, 0, 28),
				Position = UDim2.new(1, -62, 0.5, -14),
				Parent = holder,
			})
			corner(switch, 999)

			local knob = create("Frame", {
				BackgroundColor3 = Color3.fromRGB(255,255,255),
				Size = UDim2.new(0, 22, 0, 22),
				Position = UDim2.new(0, 3, 0.5, -11),
				Parent = switch,
			})
			corner(knob, 999)

			local function render()
				tween(switch, 0.15, {BackgroundColor3 = state and self._library.Theme.Accent or self._library.Theme.Stroke})
				tween(knob, 0.15, {Position = state and UDim2.new(1, -25, 0.5, -11) or UDim2.new(0, 3, 0.5, -11)})
			end
		render()

			switch.MouseButton1Click:Connect(function()
				state = not state
				render()
				if info.Callback then
					info.Callback(state)
				end
			end)

			return {
				Set = function(_, v)
					state = v and true or false
					render()
				end,
				Get = function()
					return state
				end,
			}
		end

		function tab:CreateSlider(info)
			info = info or {}
			local min = info.Min or 0
			local max = info.Max or 100
			local value = info.Default or min
			local dragging = false

			local holder = create("Frame", {
				BackgroundColor3 = self._library.Theme.Panel,
				Size = UDim2.new(1, 0, 0, 62),
				Parent = page,
			})
			corner(holder, self._library.Theme.Radius - 4)
			stroke(holder, self._library.Theme.Stroke, 0.4)

			local label = create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Text = info.Text or "Slider",
				TextColor3 = self._library.Theme.Text,
				Font = self._library.Theme.Font,
				TextSize = 14,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				Parent = holder,
			})

			local valueLabel = create("TextLabel", {
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Right,
				Text = tostring(value),
				TextColor3 = self._library.Theme.SubText,
				Font = self._library.Theme.Font,
				TextSize = 12,
				Position = UDim2.new(0, 12, 0, 6),
				Size = UDim2.new(1, -24, 0, 16),
				Parent = holder,
			})

			local bar = create("Frame", {
				BackgroundColor3 = self._library.Theme.Stroke,
				Position = UDim2.new(0, 12, 0, 38),
				Size = UDim2.new(1, -24, 0, 10),
				Parent = holder,
			})
			corner(bar, 999)

			local fill = create("Frame", {
				BackgroundColor3 = self._library.Theme.Accent,
				Size = UDim2.new(0, 0, 1, 0),
				Parent = bar,
			})
			corner(fill, 999)

			local function setValue(v)
				value = math.clamp(math.floor(v + 0.5), min, max)
				local alpha = (value - min) / math.max(max - min, 1)
				fill.Size = UDim2.new(alpha, 0, 1, 0)
				valueLabel.Text = tostring(value)
				if info.Callback then
					info.Callback(value)
				end
			end
			setValue(value)

			local function update(input)
				local alpha = math.clamp((input.Position.X - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
				setValue(min + ((max - min) * alpha))
			end

			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					update(input)
				end
			end)
			bar.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					update(input)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			return {
				Set = function(_, v) setValue(v) end,
				Get = function() return value end,
			}
		end

