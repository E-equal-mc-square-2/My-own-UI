                    Parent = sliderFrame
                })
                
                local sliderTrack = Utility:Create("Frame", {
                    Name = "Track",
                    BackgroundColor3 = CurrentTheme.Background,
                    Size = UDim2.new(1, -30, 0, 8),
                    Position = UDim2.new(0, 15, 1, -25),
                    ZIndex = 7,
                    Parent = sliderFrame
                })
                
                Utility:AddCorner(sliderTrack, UDim.new(1, 0))
                
                local sliderFill = Utility:Create("Frame", {
                    Name = "Fill",
                    BackgroundColor3 = CurrentTheme.Primary,
                    Size = UDim2.new(0, 0, 1, 0),
                    ZIndex = 8,
                    Parent = sliderTrack
                })
                
                Utility:AddCorner(sliderFill, UDim.new(1, 0))
                Utility:AddGradient(sliderFill, CurrentTheme.Primary, CurrentTheme.PrimaryLight, 90)
                
                local sliderKnob = Utility:Create("Frame", {
                    Name = "Knob",
                    BackgroundColor3 = CurrentTheme.Text,
                    Size = UDim2.new(0, 18, 0, 18),
                    Position = UDim2.new(0, 0, 0.5, -9),
                    ZIndex = 9,
                    Parent = sliderFill
                })
                
                Utility:AddCorner(sliderKnob, UDim.new(1, 0))
                Utility:AddStroke(sliderKnob, CurrentTheme.Primary, 2)
                
                local function updateSlider(value, skipCallback)
                    value = math.clamp(value, min, max)
                    value = math.floor(value / increment + 0.5) * increment
                    
                    sliderValue = value
                    sliderValueLabel.Text = tostring(value)
                    
                    local percent = (value - min) / (max - min)
                    Utility:Tween(sliderFill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.15)
                    
                    if flag then
                        ConfigSystem:SetFlag(flag, value)
                    end
                    
                    if not skipCallback then
                        pcall(callback, value)
                    end
                end
                
                local dragging = false
                
                sliderTrack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        
                        local function update()
                            local mousePos = UserInputService:GetMouseLocation().X
                            local trackPos = sliderTrack.AbsolutePosition.X
                            local trackSize = sliderTrack.AbsoluteSize.X
                            
                            local percent = math.clamp((mousePos - trackPos) / trackSize, 0, 1)
                            local value = min + (max - min) * percent
                            
                            updateSlider(value)
                        end
                        
                        update()
                        
                        local connection
                        connection = UserInputService.InputChanged:Connect(function(input2)
                            if dragging and (input2.UserInputType == Enum.UserInputType.MouseMovement or input2.UserInputType == Enum.UserInputType.Touch) then
                                update()
                            end
                        end)
                        
                        local endConnection
                        endConnection = UserInputService.InputEnded:Connect(function(input2)
                            if input2.UserInputType == Enum.UserInputType.MouseButton1 or input2.UserInputType == Enum.UserInputType.Touch then
                                dragging = false
                                connection:Disconnect()
                                endConnection:Disconnect()
                            end
                        end)
                    end
                end)
                
                updateSlider(sliderValue, true)
                
                local Slider = {}
                function Slider:Set(value)
                    updateSlider(value, false)
                end
                
                return Slider
            end
            
