            function Section:CreateSlider(Settings)
                Settings = Settings or {}

                local Min = Settings.Min or 0
                local Max = Settings.Max or 100
                local Default = Settings.Default or Min
                local Value = Default

                if Settings.Flag then
                    Library.Flags[Settings.Flag] = Value
                end

                local Sliding = false

                local SliderFrame = Utility:Create("Frame", {
                    Parent = Holder,
                    Size = UDim2.new(1,0,0,68),
                    BackgroundColor3 = Library.Theme.Tertiary,
                    BorderSizePixel = 0
                })

                Utility:Corner(SliderFrame,14)
